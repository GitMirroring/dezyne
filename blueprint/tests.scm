(define xfail-lts
  (or (and=> (getenv "XFAIL_LTS")
             (compose (cute filter (negate string-null?) <>)
                      (cute string-split <> #\space)))
   '("test/all/compliance_single_to_multiple")))

(define xfail-parse
  (or (and=> (getenv "XFAIL_PARSE")
             (compose (cute filter (negate string-null?) <>)
                      (cute string-split <> #\space)))
      '("test/all/comment_traceability")))

(define xfail-verify
  (or (and=> (getenv "XFAIL_VERIFY")
             (compose (cute filter (negate string-null?) <>)
                      (cute string-split <> #\space)))
      '("test/all/blocking_defer"
        "test/all/compliance_livelock"
        "test/all/compliance_livelock_escape"
        "test/all/compliance_livelock_refusal"
        "test/all/external_blocking_livelock")))

(define xfail-simulate
  (or (and=> (getenv "XFAIL_SIMULATE")
             (compose (cute filter (negate string-null?) <>)
                      (cute string-split <> #\space)))
      '("test/all/blocking_shared_reply"
        "test/all/compliance_livelock")))

(define xfail-tests
  (or (and=> (getenv "XFAIL_TESTS")
             (compose (cute filter (negate string-null?) <>)
                      (cute string-split <> #\space)))
      (append
       xfail-lts
       xfail-parse
       xfail-verify
       xfail-simulate)))

(define hello-tests
  (append
   smoke-tests
   semantic-tests
   feature-tests))

(define full-tests
  (or (and=> (getenv "TESTS")
             (compose (cute filter (negate string-null?) <>)
                      (cute string-split <> #\space)))
      (append
       smoke-tests
       semantic-tests
       semantic-error-tests
       feature-tests
       doc-semantics-tests
       parser-tests
       regression-tests
       unstable-tests
       usage-tests)))

