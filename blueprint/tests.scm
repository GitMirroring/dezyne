(define unit-tests
  (or (and=> (getenv "UNIT_TESTS")
             (compose (cute filter (negate string-null?) <>)
                      (cute string-split <> #\space)))
      (and=> (getenv "TESTS")
             (compose (cute filter (cute string-prefix? "test/dzn" <>) <>)
                      (cute filter (negate string-null?) <>)
                      (cute string-split <> #\space)))
      '("test/dzn/ast.scm"
        "test/dzn/language.scm"
        "test/dzn/lts.scm"
        "test/dzn/makreel.scm"
        "test/dzn/normalize.scm"
        "test/dzn/parse.scm")))

