# hello

make && { set -o pipefail; rm -f my.aut; { ./pre-inst-env gdzn code -l makreel -o - test/all/hello/hello.dzn; } | tee /dev/stderr | mcrl22lps -b | lps2lts /dev/stdin my.aut; cat my.aut | ltsconvert --tau=tau -edpweak-bisim my.aut my.aut; cat my.aut 1>&2; } && ltsgraph my.aut

