w'qin: iworld'events;
w'qin': iworld'events;
w'qout: iworld'events;
w'qout': iworld'events;
w'queue_full;

hello_blocked_external'end;
hello_blocked_external'end';
declarative_illegal;
illegal;
queue_full;
queue_empty;
queue_empty';
range_error;
recurse;
return;

proc
Illegal' = illegal . Illegal';
Declarative_Illegal' = declarative_illegal . Declarative_Illegal';

%%%%%%%%%%%%%%%%% INTERFACE %%%%%%%%%%%%%%%%%

ihello'interface = ihello' (false);

ihello' (triggered': Bool) = non_optional_ihello' ();

non_optional_ihello' (triggered': Bool) = ihello'0 ();


% {
%   [(!(triggered') && true)] on hello: {
%     triggered' = true;
%     reply(void);
%   }
%   [(triggered' && true)] on hello: {
%     declaritive-illegal;
%     reply(void);
%   }
%   [(!((triggered' && true)) && (!((!(triggered') && true)) && true))] on hello: declaritive-illegal;
%   [(triggered' && true)] on cancel: {
%     triggered' = false;
%     reply(void);
%   }
%   [(!(triggered') && true)] on cancel: {
%     declaritive-illegal;
%     reply(void);
%   }
%   [(!((!(triggered') && true)) && (!((triggered' && true)) && true))] on cancel: declaritive-illegal;
%   [(triggered' && true)] on inevitable: {
%     triggered' = false;
%     world();
%     <end of process>
%   }
% }
ihello'0(triggered': Bool) = ihello'1 ()
  + ihello'6 ()
  + ihello'11 ()
  + ihello'14 ()
  + ihello'19 ()
  + ihello'24 ()
  + ihello'27 ();


% [(!(triggered') && true)] on hello: {
%   triggered' = true;
%   reply(void);
% }
ihello'1(triggered': Bool) = ((!(triggered') && true)) -> ihello'2 ();


% on hello: {
%   triggered' = true;
%   reply(void);
% }
ihello'2(triggered': Bool) = ihello'in (ihello'action (ihello'in'hello)) . ihello'3 ();


% {
%   triggered' = true;
%   reply(void);
% }
ihello'3(triggered': Bool) = ihello'4 ();


% triggered' = true;
ihello'4(triggered': Bool) = ihello'5(triggered' = true
);


% reply(void);
ihello'5(triggered': Bool) = ihello'reply (ihello'void) . ihello' ();


% [(triggered' && true)] on hello: {
%   declaritive-illegal;
%   reply(void);
% }
ihello'6(triggered': Bool) = ((triggered' && true)) -> ihello'7 ();


% on hello: {
%   declaritive-illegal;
%   reply(void);
% }
ihello'7(triggered': Bool) = ihello'in (ihello'action (ihello'in'hello)) . ihello'8 ();


% {
%   declaritive-illegal;
%   reply(void);
% }
ihello'8(triggered': Bool) = ihello'9 ();


% declaritive-illegal;
ihello'9(triggered': Bool) = Declarative_Illegal' . delta;


% reply(void);
ihello'10(triggered': Bool) = ihello'reply (ihello'void) . ihello' ();


% [(!((triggered' && true)) && (!((!(triggered') && true)) && true))] on hello: declaritive-illegal;
