% }
ihello'16(triggered': Bool) = ihello'17 ();


% triggered' = false;
ihello'17(triggered': Bool) = ihello'18(triggered' = false
);


% reply(void);
ihello'18(triggered': Bool) = ihello'reply (ihello'void) . ihello' ();


% [(!(triggered') && true)] on cancel: {
%   declaritive-illegal;
%   reply(void);
% }
ihello'19(triggered': Bool) = ((!(triggered') && true)) -> ihello'20 ();


% on cancel: {
