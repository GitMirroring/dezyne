%%%%%%%%%%%%%%%%%%% COMPONENT %%%%%%%%%%%%%%%%%%%

hello_blocked_external' (triggered': Bool) = hello_blocked_external'0 ();


% {
%   [(!(triggered') && true)] on h'.hello(): {
%     w'.hello();
%     triggered' = true;
%     reply(void);
%   }
%   [(!((!(triggered') && true)) && true)] on h'.hello(): declaritive-illegal;
%   [(triggered' && true)] on h'.cancel(): blocking {
%     triggered' = false;
%     w'.cancel();
%   }
%
%   [(!((triggered' && true)) && true)] on h'.cancel(): declaritive-illegal;
%   [(triggered' && true)] on w'.world(): {
%     triggered' = false;
%     h'.world();
%     <end of process>
%   }
%   [(!(triggered') && true)] on w'.world(): {
%     <end of process>
%   }
%   [(!((!(triggered') && true)) && (!((triggered' && true)) && true))] on w'.world(): declaritive-illegal;
%   [true] on w'.canceled(): {
%     h'.reply();
%     <end of process>
%   }
%   [(!(true) && true)] on w'.canceled(): declaritive-illegal;
% }
hello_blocked_external'0(triggered': Bool) = hello_blocked_external'1 ()
  + hello_blocked_external'7 ()
  + hello_blocked_external'10 ()
  + hello_blocked_external'16 ()
  + hello_blocked_external'19 ()
  + hello_blocked_external'25 ()
  + hello_blocked_external'29 ()
  + hello_blocked_external'32 ()
  + hello_blocked_external'37 ();


