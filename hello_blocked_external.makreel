component_behaviour = hello_blocked_external'(false);






%%%%%%%%%%%%%% PORT PROCESSES %%%%%%%%%%%%%%%

h'_port_rename = rename ({
  ihello'in -> h'in
  , ihello'out -> h'out
  , ihello'reply -> h'reply
  , ihello'internal -> h'internal
  , ihello'end -> h'end
  }, ihello'interface);

h'_port = hide ({recurse,return}, h'_port_rename);

w'_port_rename = rename ({
  iworld'in -> w'in
  , iworld'out -> w'out
  , iworld'reply -> w'reply
  , iworld'internal -> w'internal
  , iworld'end -> w'end
  }, iworld'interface);

w'_port = hide ({recurse,return}, w'_port_rename);


%%%%%%%%%%%%%%%%%%%% Q %%%%%%%%%%%%%%%%%%%%%%

component_queue (l: List (requires_events)) =
  (#l < QueueLength) -> (sum e: iworld'events. w'qin (e) . component_queue (l = l <| w'events (e)))
  + (l != [] && w'is (head (l))) -> w'qout (w' (head (l))) . ((#l == 1) -> queue_empty . component_queue (l = tail (l)) <> component_queue (l = tail (l)))
  + (#l == QueueLength) -> (sum e: iworld'events. w'qin (e) . queue_full . Illegal')
;

w'_portexternal_queue (l : List (requires_events)) =
  (#l < QueueLength) -> (sum e: iworld'events. w'qin (e) . w'_portexternal_queue (l = l <| w'events (e)))
  + (l != [] && w'is (head (l))) -> w'internal(iworld'inevitable) . w'qout (w' (head (l))) . w'end . w'_portexternal_queue(l = tail(l))
  + (#l == QueueLength) -> (sum e: iworld'events. w'qin (e) . w'queue_full . Illegal')
;

w'_portinternal_hide = hide({
  w'internal
  , w'end}, w'_port );

w'_portexternal_parallel = w'_portexternal_queue([]) || w'_portinternal_hide;

w'_portexternal_comm = comm({
  w'out | w'qin -> w'qin'
  }, w'_portexternal_parallel);

w'_portexternal_allow = allow({peek,
  w'in
  , w'qin'
  , w'qout
  , w'reply
  , w'internal
  , w'end
  , w'queue_full
  , declarative_illegal
  , illegal
  }, w'_portexternal_comm);

w'_portexternal_rename = rename({
  w'qin' -> w'qin
  , w'qout -> w'out
  }, w'_portexternal_allow);

w'_portexternal = hide({
  w'qin}, w'_portexternal_rename);


req_and_queue_parallel = component_queue([])
  || w'_portexternal;

req_and_queue_comm = comm({
  w'out | w'qin -> w'qin'
  }, req_and_queue_parallel);

req_and_queue_allow = allow({peek,
  w'in
  , w'qin'
  , w'qout
  , w'reply
  , w'internal
  , w'end
  , w'queue_full
  , declarative_illegal
  , illegal
  , queue_empty
  , queue_full
  }, req_and_queue_comm);
req_and_queue_rename = rename({
  w'qin' -> w'qin
  , w'qout -> w'out
  , declarative_illegal -> illegal
  }, req_and_queue_allow);

%req_and_queue = hide({
%  #x:queue-hide-requires
%  }, req_and_queue_rename);

req_and_queue = req_and_queue_rename;



%%%%%%%%%%%%%%%%%%%%% COMPONENT REORDER %%%%%%%%%%%%%%%%%%%%%%%%%%%

component_reorder
  = sum a: ihello'actions. h'in (ihello'action (a))
  . (sum r: ihello'replies. h'reply (r) . h'reply'out (r) . component_reorder
+ h'blocking . sum r: ihello'replies. h'reply (r) . h'reply'out (r) . component_reorder)
  ;

component_reorder_parallel = component_behaviour || component_reorder;

component_reorder_comm = comm({
  h'reply | h'reply -> h'reply'
, h'in | h'in -> h'in'
, h'blocking | h'blocking -> h'blocking'
  }, component_reorder_parallel);

component_reorder_allow = allow({peek,
  declarative_illegal
  , illegal
  , queue_empty
  , range_error
  , recurse
  , return

  , h'in'
  , h'blocking'
  , h'out
  , h'reply'
  , h'reply'out

  , w'in
  , w'out
  , w'reply
  , hello_blocked_external'end
  }, component_reorder_comm);

component_reorder_rename = rename({
  h'in' -> h'in
  , h'blocking' -> h'blocking
  , h'reply'out -> h'reply
  }, component_reorder_allow);

component_reorder_hide = hide({
  h'reply'
  }, component_reorder_rename);

%%%%%%%%%%%%%%%%%%%%%%%%% SEMANTICS %%%%%%%%%%%%%%%%%%%%%%%%%%%

semantics(h'_blocked : Bool)
  = (!h'_blocked) -> sum e : ihello'actions. h'in (ihello'action(e)) . semantics_empty()
  + sum e : iworld'modeling. w'internal (e) . semantics_empty()
  %+ w'end . semantics(h'_blocked)
  ;

semantics_empty(h'_blocked : Bool)
  = sum r : ihello'replies. h'reply (r) . semantics(h'_blocked=false)
  + h'blocking . semantics(h'_blocked=true)
  + sum e : iworld'events . w'qin (e) . w'end . semantics_flush()
  ;

semantics_flush(h'_blocked : Bool)
  = sum a : iworld'actions. w'out (iworld'action(a)) . hello_blocked_external'end . semantics_flush()
  + queue_empty . (semantics() + semantics_empty())
  ;

component_semantics = component_reorder_hide || semantics(h'_blocked=false);

component_semantics_comm = comm({
  h'in | h'in -> h'in'
  , h'blocking | h'blocking -> h'blocking'
  , h'reply | h'reply -> h'reply'


  , w'out | w'out -> w'out'
  , hello_blocked_external'end | hello_blocked_external'end -> hello_blocked_external'end'
  }, component_semantics);

component_semantics_allow = allow({peek,
  declarative_illegal
  , illegal
  , queue_empty
  , range_error
  , recurse
  , return
  , hello_blocked_external'end'

  , h'in'
  , h'blocking'
  , h'out
  , h'reply'

  , w'in
  , w'out'
  , w'reply
  , w'internal
  , w'end
  , w'qin

  }, component_semantics_comm);

component_semantics_rename = rename({
  hello_blocked_external'end' -> hello_blocked_external'end

  , h'in' -> h'in
  , h'blocking' -> h'blocking
  , h'reply' -> h'reply

  , w'out' -> w'out
  }, component_semantics_allow);

component_semantics_hide = hide({
  hello_blocked_external'end
  }, component_semantics_rename);

%%%%%%%%%%%%%%%%%%%%% COMPONENT ASSEMBLY %%%%%%%%%%%%%%%%%%%%%%

component_parallel = component_semantics_hide || req_and_queue;

component_comm = comm({
  queue_empty | queue_empty -> queue_empty'

  , w'in | w'in -> w'in'
  , w'out | w'out -> w'out'
  , w'reply | w'reply -> w'reply'
  , w'internal | w'internal -> w'internal'
  , w'end | w'end -> w'end'
  , w'qin | w'qin -> w'qin'
  }, component_parallel);

component_allow = allow({peek,
  declarative_illegal
  , illegal
  , queue_empty'
  , queue_full
  , range_error
  , recurse
  , return

  , h'in
  , h'blocking
  , h'out
  , h'reply

  , w'in'
  , w'out'
  , w'reply'
  , w'internal'
  , w'end'
  , w'qin'
  , w'queue_full
  , hello_blocked_external'end
  }, component_comm);

% Note that out' is renamed to qin and qin' is renamed to out;
% This is done to preserve the information that events are
% queued which might lead to queue_full.
component_rename = rename({
  queue_empty' -> queue_empty

  , w'in' -> w'in
  %, w'out' -> w'qin
  , w'out' -> w'out
  , w'reply' -> w'reply
  , w'internal' -> w'internal
  , w'end' -> w'end
  %, w'qin' -> w'out
  , w'qin' -> w'qin
  }, component_allow);

component = hide({
  queue_empty
  , range_error
  , recurse
  , return

  , h'blocking


  , w'end
  , w'qin
  }, component_rename);

%%component = component_rename;

%%%%%%%%%%%%%%%%%%%%%%% PROVIDES %%%%%%%%%%%%%%%%%%%%%%%%%%

provides_r2c = sum x: ihello'actions . h'in (ihello'action (x)) . provides_out
  + sum m: ihello'modeling. h'internal (m) . provides_out;

provides_out = sum x: ihello'replies . h'reply (x) . provides_r2c
  + h'end . provides_r2c
  + sum x: ihello'actions . h'out (ihello'action (x)) . provides_out

;

provides_parallel = h'_port|| provides_r2c;

provides_comm = comm ({
  h'in | h'in -> h'in'
  , h'out | h'out -> h'out'
  , h'reply | h'reply -> h'reply'
  , h'internal | h'internal -> h'internal'
  , h'end | h'end -> h'end'
  }, provides_parallel);

provides_allow = allow ({
  h'in'
  , h'out'
  , h'reply'
  , h'internal'
  , h'end'
  , declarative_illegal
  , illegal
  }, provides_comm);

provides_rename = rename ({
  h'in' -> h'in
  , h'out' -> h'out
  , h'reply' -> h'reply
  , h'internal' -> h'internal
  , h'end' -> h'end
  }, provides_allow);

provides = hide ({
  h'internal
  , h'end
  }, provides_rename);

init component;
%init provides;
