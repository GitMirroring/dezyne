# Code:

abs_top_srcdir="`cd "@abs_top_srcdir@" > /dev/null; pwd -P`"
abs_top_builddir="`cd "@abs_top_builddir@" > /dev/null; pwd -P`"

GUILE_LOAD_COMPILED_PATH="$abs_top_builddir${GUILE_LOAD_COMPILED_PATH:+:}$GUILE_LOAD_COMPILED_PATH"
GUILE_LOAD_PATH="$abs_top_builddir:$abs_top_srcdir${GUILE_LOAD_PATH:+:}$GUILE_LOAD_PATH"
LD_LIBRARY_PATH="$abs_top_builddir${LD_LIBRARY_PATH:+:}$LD_LIBRARY_PATH"
export GUILE_LOAD_COMPILED_PATH GUILE_LOAD_PATH LD_LIBRARY_PATH

PATH="$abs_top_builddir/bin:$abs_top_srcdir/test/bin${PATH:+:}$PATH"
export PATH

DZN_PREFIX="$abs_top_srcdir"
export DZN_PREFIX

DZN_UNINSTALLED=1
export DZN_UNINSTALLED

LANG=en_US.UTF-8
export LANG
for E in $(set | grep -oE LC_[^=]+); do unset $E; done

exec "$@"
