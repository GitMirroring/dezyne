#!/bin/sh

abs_top_srcdir="$(cd "@abs_top_srcdir@" > /dev/null; pwd -P)"
abs_top_builddir="$(cd "@abs_top_builddir@" > /dev/null; pwd -P)"

GUIX_PACKAGE_PATH="$abs_top_srcdir/guix${GUIX_PACKAGE_PATH:+:}$GUIX_PACKAGE_PATH"
export GUIX_PACKAGE_PATH

GUILE_LOAD_COMPILED_PATH="$abs_top_builddir/gaiag:$GUIX_PACKAGE_PATH${GUILE_LOAD_COMPILED_PATH:+:}$GUILE_LOAD_COMPILED_PATH"
GUILE_LOAD_PATH="$abs_top_srcdir/gaiag:$GUIX_PACKAGE_PATH${GUILE_LOAD_PATH:+:}$GUILE_LOAD_PATH"
export GUILE_LOAD_COMPILED_PATH GUILE_LOAD_PATH

PATH="$abs_top_builddir/bin:$abs_top_srcdir/dzn/bin:$abs_top_srcdir/test/bin:$abs_top_srcdir/gaiag/scmcrl2:$PATH"
export PATH

LANG=
LC_ALL=

NODE_PATH="$abs_top_builddir/build/node_modules${NODE_PATH:+:}$NODE_PATH"
export NODE_PATH

# For running regression test through client+server, use
# DZN=dzn ./pre-inst-env test test/hello/helloworld
DZN=${DZN-"$abs_top_builddir/bin/gdzn"}
export DZN

PREFIX="$abs_top_srcdir"
export PREFIX

DEZYNE_PREFIX="$abs_top_builddir/build/prefix"
export DEZYNE_PREFIX

DZN_UNINSTALLED=1
export DZN_UNINSTALLED

# For Guix package build: Assume local build from GIT
git_oban=git://localhost
export git_oban

exec "$@"
