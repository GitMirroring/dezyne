(read-set! keywords 'prefix)

(define (main . args)
  (eval '(main (command-line)) (resolve-module '(language asd gaiag))))

(define-module (language asd gaiag)
  :use-module (system base language)
  :use-module (language asd asd)
  :use-module (language asd tokenize)
  :use-module (language asd misc)

  :use-module (language asd c++)
  :use-module (language asd scheme)
  :use-module (language asd pretty)

  :use-module (ice-9 getopt-long))

(define (read-and-parse lang port cenv)
  (let ((exp ((language-reader lang) port cenv)))
    (cond
     ((eof-object? exp) exp)
     ((language-parser lang) => (lambda (parse) (parse exp)))
     (else exp))))

(define (asd-reader port env)
  ((make-parser) (make-tokenizer port) error))

(define (read-asd file-name)
  (asd-reader (open-file file-name "r") (current-module)))

(define (parse-opts args)
  (let* ((option-spec
	  '((help (single-char #\h))
            (language (single-char #\l) (value #t))
	    (version (single-char #\v))))
	 (options (getopt-long (command-line) option-spec
		   :stop-at-first-non-option #t))
	 (help? (option-ref options 'help #f))
	 (files (option-ref options '() '()))
	 (usage? (and (not help?) (null? files)))
	 (version? (option-ref options 'version #f)))
    (or
     (and version?
	  (stdout "0.1\n")
	  (exit 0))
      (and (or help? usage?)
	   ((or (and usage? stderr) stdout) "\
Usage: gaiag [OPTION]... FILE
  -h, --help           display this help
  -l, --language=LANG  generate output for language=LANG [scheme]
  -v, --version        display version

Languages: asd c++ scheme
")
	   (exit (or (and usage? 2) 0)))
     options)))

(define (file->lang file-name language)
  (display ((module-ref (resolve-module `(language asd ,language)) 'asd->) (read-asd file-name))))

(define (main args)
  (let* ((options (parse-opts args))
	 (file-name (car (option-ref options '() '())))
         (language (string->symbol (option-ref options 'language "scheme"))))
    (file->lang file-name language)))
