(read-set! keywords 'prefix)

(define-module (test-handler)
  :use-module (test-suite lib)
  :use-module (test-suite misc)

  :use-module (ice-9 pretty-print)

  :use-module (language asd ast:)
  :use-module (language asd c++)
  :use-module (language asd misc)
  :use-module (language asd reader))

(pass-if "c++-first-dummy-test"
         #t)

(pass-if "c++-alarm-component"
  (let* ((alarm-ast (read-ast 'examples/Alarm.asd))
         (foobar (set! (@@ (language asd c++) *ast*) alarm-ast))
         (module (c++-module alarm-ast))
         (alarm-c++ (with-output-to-string (lambda () ((animate-template 'component.cc.scm) module))))
         (baseline-c++ (gulp-file "examples/AlarmComponent.cpp")))
    (or (diff-noisy-equal? alarm-c++ baseline-c++)
        #t)))

(pass-if "c++-alarm-system"
  (let* ((alarm-ast (read-ast 'examples/AlarmSystem.asd))
         (foobar (set! (@@ (language asd c++) *ast*) alarm-ast))
         (alarm-c++ (with-output-to-string (lambda () ((animate-template 'component.cc.scm) (c++-module alarm-ast)))))
         (baseline-c++ (gulp-file "examples/AlarmSystemComponent.cpp")))
    (or (diff-noisy-equal? alarm-c++ baseline-c++)
        #t)))
