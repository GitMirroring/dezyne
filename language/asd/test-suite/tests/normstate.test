(read-set! keywords 'prefix)

(define-module (test-handler)
  :use-module (test-suite lib)
  :use-module (test-suite misc)

  :use-module (language asd ast:)
  :use-module (language asd reader)
  :use-module (language asd normstate))

(pass-if "normstate-first-dummy-test"
	 #t)

(pass-if "normstate-101" ;; FIXME: normstate eats (guard true (compound))?
  (pretty-noisy-equal?
   (normstate
    (ast:interface (asd->ast 
      #{ 
        interface i { behaviour { on a: [true] { } } } #})))
   '(interface i (types) (events) 
               (behaviour #f (types) (variables) 
                          (compound 
                           (guard true (compound)))))))

(pass-if "normstate-102"
  (pretty-noisy-equal?
   (normstate
    (ast:interface (asd->ast 
      #{ 
        interface i { behaviour { on a: [true] b;
                                     } } #})))
   '(interface i (types) (events) 
               (behaviour #f (types) (variables) 
                          (compound 
                           (guard true 
                                  (on (a) 
                                      (action b))))))))

(pass-if "normstate-aggregate-passive"
  (pretty-noisy-equal?
   (normstate
    (ast:interface (asd->ast 
      #{ 
        interface i { behaviour { on a,b,c: [true] d;
                                     } } #})))
   '(interface i (types) (events) 
               (behaviour #f (types) (variables) 
                          (compound 
                           (guard true 
                                  (on (a b c) 
                                      (action d))))))))

(pass-if "normstate-aggregate-active"
  (pretty-noisy-equal?
   (normstate
    (ast:interface (asd->ast 
      #{ 
        interface i { behaviour { on a: [true] d;
                                     on b: [true] d;
                                     on c: [true] d;
                                     } } #})))
   '(interface i (types) (events) 
               (behaviour #f (types) (variables) 
                          (compound 
                           (guard true 
                                  (compound
                                   (on (a) (action d))
                                   (on (b) (action d))
                                   (on (c) (action d)))))))))
