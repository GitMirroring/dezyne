(read-set! keywords 'prefix)

(define-module (test-handler)
  :use-module (test-suite lib)
  :use-module (test-suite misc)

  :use-module (language asd reader)
  :use-module (language asd mangle))

(pass-if "mangle-first-dummy-test"
	 #t)

(pass-if "mangle-interface"
  (pretty-noisy-equal?
   (mangle '(interface I))
   '(interface if_I)))

(pass-if "mangle-component"
  (pretty-noisy-equal?
   (mangle '(component C))
   '(component co_C)))

(pass-if "mangle-event"
  (pretty-noisy-equal?
   (mangle '(interface I (events (in ((type void)) e) (out ((type void)) a))))
   '(interface if_I (events (in ((type void)) ev_e) (out ((type void)) ev_a)))))

(pass-if "mangle-port"
  (pretty-noisy-equal?
   (mangle '(component C (ports (provides I p) (requires I q))))
   '(component co_C (ports (provides if_I po_p) (requires if_I po_q)))))

(pass-if "mangle-interface-on"
  (pretty-noisy-equal?
   (mangle '(on (e) (action illegal)))
   '(on (ev_e) (action illegal)))) ;; FIXME: type interface trigger '(trigger #f x)?

(pass-if "mangle-trigger"
  (pretty-noisy-equal?
   (mangle '(trigger mangle mangle))
   '(trigger po_mangle ev_mangle)))

(pass-if "mangle-interface-actionn"
  (pretty-noisy-equal?
   (mangle '(action a))
   '(action ev_a))) ;; FIXME: type interface trigger '(trigger #f x)?
