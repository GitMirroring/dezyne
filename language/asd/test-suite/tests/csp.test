         (pretty-noisy-equal?

          ;; from:
          (ast-transform

           c-ast

           '(compound
             (on ((trigger j e))
                 (compound))))

          ;; via:
          '(on ((trigger j e))
               (return)
               (the-end (s b c)))))

(pass-if "c-csp-transform-return"
         (noisy-equal?

          ;; from:
          (csp-transform

           c-ast

           '(on ((trigger j e))
                (return)
                (the-end (s b c))))

          ;; via:
          "j?x:{e} ->
(\\P',V' @ j.return -> P'(V'))(\\V' @ transition_end -> c_B_(V'),((s,b,c)))"))


