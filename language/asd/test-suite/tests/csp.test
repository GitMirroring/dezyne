          ;; via:
          "j?x:{e} ->
semi_((\\P',V' @ j!h -> P'(V')),
(\\P',V' @ j.return -> P'(V')))(\\V' @ transition_end -> c_B_(V'),((s,b,c)))"))

(pass-if "c-csp-transform-required-on"
