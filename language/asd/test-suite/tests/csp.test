(\\P',V' @ P'(V'))(\\V' @ transition_end -> c_B_(V'),((s,b,c)))"))


(define alarm-ast
  ' (component
     Alarm
     (ports (provides Console console)
            (requires Sensor sensor)
            (requires Siren siren))
     (behaviour
      d
      (types (enum States
                   (Disarmed Armed Triggered Disarming)))
      (variables
       (variable
        (type States)
        state
        (value States Disarmed))
       (variable (type bool) sounding false))
      (compound))))

(pass-if "c-ast-transform-alarm-snippet"
         (pretty-noisy-equal?

          ;; from:
          (ast-transform

           alarm-ast

           '(on ((trigger sensor triggered))
                (compound
                 (action (trigger console detected))
                 (action (trigger siren turnon))
                 (assign sounding true)
                 (assign state (value States Triggered)))))

          ;; via:
          '(on ((trigger sensor triggered))
               (semi (semi (action (trigger console detected))
                           (semi (action (trigger siren turnon))
                                 (semi (assign ((state sounding)) () ((state true)))
                                       (assign ((state sounding)) () ((Triggered sounding))))))
                     (return))
               (the-end (state sounding)))))

(pass-if "c-csp-transform-alarm-snippet"
         (diff-noisy-equal?

          ;; from:
          (csp-transform alarm-ast
           (ast-transform

            alarm-ast

            '(on ((trigger sensor triggered))
                 (semi (semi (action (trigger console detected))
                             (semi (action (trigger siren turnon))
                                   (semi (assign ((state sounding)) () ((state true)))
                                         (assign ((state sounding)) () ((Triggered sounding))))))
                       (return))
                 (the-end (state sounding)))))
          ;; via:

"sensor?x:{triggered} ->
semi_(semi_((\\P',V' @ console!detected -> P'(V')),
semi_((\\P',V' @ siren!turnon -> siren.return -> P'(V')),
semi_(assign_(\\((state,sounding)) @ (state,true)),
assign_(\\((state,sounding)) @ (Triggered,sounding))))),
(\\P',V' @ P'(V')))(\\V' @ transition_end -> Alarm_d_(V'),((state,sounding)))"
))





;; reply event

(define i-reply-ast
  '(interface I
     (types (enum Status (Yes No)))
     (events (in ((type Status)) done))
     (behaviour
      #f
      (types)
      (variables)
      (compound
       (on (done)
           (compound
            (guard true
                   (compound (reply (value Status Yes))))
            (guard true (compound (reply (value Status No))))))))))

(define u-reply-ast
  '(interface U
     (types (enum Status (Ok Nok)))
     (events (in ((type Status)) what))
     (behaviour
      #f
      (types)
      (variables)
      (compound
       (on (what)
           (compound
            (guard true (compound (reply (value Status Ok))))
            (guard true
                   (compound (reply (value Status Nok))))))))))

(define c-reply-ast
  '(component C
              (ports (provides I i) (requires U u))
              (behaviour
               #f
               (types)
               (variables
                (variable bool dummy false))
               (compound
                (guard true
                       (compound
                        (on ((trigger i done))
                            (compound
                             (variable
                              (type U (type Status))
                              s
                              (value u what))
                             (if (== s (literal u Status Ok))
                                 (compound (reply (literal I Status Yes)))
                                 (compound (reply (literal I Status No))))))))))))


(define ast-function-call-ast
  '(on (e)
       (compound
        (action toggle))))

(pass-if "ast-transform-ast-transform-function-call"
         (pretty-noisy-equal?

          ;; from:
          (ast-transform-function-call i-ast ast-function-call-ast)

          ;; via:
          '(on (e)
               (compound
                (call toggle)))))


(define csp-function-call-ast
  '(on (e)
       (semi
        (call toggle)
        (return))
       (the-end (s b c))))

(pass-if "ast-transform-function-call"
         (pretty-noisy-equal?

          ;; from:
          (ast-transform

           i-ast

           '(compound
             (on (e)
                 (compound
                  (action toggle)))))

          ;; via:
          csp-function-call-ast))

(pass-if "csp-transform-function-call"
         (diff-noisy-equal?

          ;; from:
          (csp-transform i-ast csp-function-call-ast)

          ;; via:
          "i?x:{e} ->
semi_(toggle,
(\\P',V' @ i.return -> P'(V')))(\\V' @ i_B_(V'),((s,b,c)))"))


(pass-if "csp-transform-function"
         (diff-noisy-equal?

          ;; from:
          (csp-transform i-ast
                         '(function toggle ((type void)) ()))

          ;; via:
          "toggle = \\P',V' @ (\\P',V' @ P'(V'))(P',V')\n"))

(define csp-reply-variable-ast
  '(on ((trigger i done))
       (context
        (((dummy)) s (valued-action (value u what)))
        (if ((dummy)) (s) (expression (== s (literal u Status Ok)))
            (reply (literal I Status Yes))
            (reply (literal I Status No))))
       (the-end (dummy))))

(pass-if "ast-transform-reply-variable"
         (pretty-noisy-equal?

          ;; from:
          (ast-transform

           c-reply-ast

           '(on ((trigger i done))
               (compound
                 (variable (type U (type Status)) s (value u what))
                 (if (== s (literal u Status Ok))
                     (compound (reply (literal I Status Yes)))
                     (compound (reply (literal I Status No)))))))

          ;; via:
          csp-reply-variable-ast))

(pass-if "csp-transform-reply-variable"
         (diff-noisy-equal?

          ;; from:
          (csp-transform

           c-reply-ast

           csp-reply-variable-ast)

          ;; via:
          "i?x:{done} ->
u!what -> u?s -> context_(\\(dummy) @ s,
\\P',((dummy),s) @ ifthenelse_(s == Status_Ok,
(\\P',V' @ i.Status_Yes -> P'(V')),
(\\P',V' @ i.Status_No -> P'(V'))
)(P',((dummy),s)))(\\V' @ transition_end -> C__(V'),((dummy)))")) ;; TESTME


(define return-variable-ast
  '(component
    arguments
    (ports (provides I i))
    (behaviour
     #f
     (types)
     (variables (variable (type bool) b false))
     (functions
      (function
       g
       ((type bool) (parameters ((type bool) c)))
       (compound (return c))))
     (compound
      (on ((trigger i e))
          (compound
           (assign b (! b))
           (variable (type bool) c (call g (arguments b)))
           (if c (compound (action (trigger i f))))))))))

(define csp-return-variable-ast
  '(on ((trigger i e))
       (semi (context (((b)) c (expression true)) (if ((b)) (c) (expression c) (action (trigger i f)) ()))
             (return))
       (the-end (b))))

(pass-if "ast-transform-return-variable"
         (pretty-noisy-equal?

          ;; from:
          (ast-transform

           return-variable-ast


           '(on ((trigger i e)) (compound
                                 (variable (type bool) c true)
                                 (if c (compound (action (trigger i f)))))))

          ;; via:
          csp-return-variable-ast))

(pass-if "csp-transform-return-variable"
         (diff-noisy-equal?

          ;; from:
          (csp-transform

           return-variable-ast

           csp-return-variable-ast
           )

          ;; via:
          "i?x:{e} ->
semi_(context_(\\(b) @ true,\\P',((b),c) @ ifthenelse_(c,
(\\P',V' @ i!f -> P'(V')),
(\\P',V' @ P'(V'))
)(P',((b),c))),
(\\P',V' @ i.return -> P'(V')))(\\V' @ transition_end -> arguments__(V'),((b)))"))
