semi_(assign_active_(sendrecv_(j,h),
\\ (((s,b,c),(stack'))),r' @ ((s,b,c),(stack'))),
(\\ P',V' @ i.return -> P'(V')))(\\ V' @ i_B_(V'),((s,b,c),(stack')))"))
