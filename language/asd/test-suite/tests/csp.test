(pass-if "csp-transform-ifthenelse"
         (diff-noisy-equal?

          ;; via/from:
          (csp-transform i-ast ast-transform-ifthenelse-via)

          ;; to:
          "\\ P',((s,b,c),(stack')) @ ifthenelse_(b,
(\\ P',V' @ P'(V')),
(\\ P',V' @ P'(V'))
)(P',((s,b,c),(stack')))"))

(pass-if "ast-transform-ifthen-illegal"
         (pretty-noisy-equal?

          ;; from:
          (ast-transform

           i-ast

           '(if b
                (action illegal)
                ()))

          ;; via:
          '(if (ctx ((s b c)))
               (expression (and IG b))
               (action illegal)
               ())))

(pass-if "ast-transform-ifthenelse-illegal"
         (pretty-noisy-equal?

          ;; from:
          (ast-transform

           i-ast

           '(if b
                ()
                (action illegal)))

          ;; via:
          '(if (ctx ((s b c)))
               (expression (and (! IG) b))
               ()
               (action illegal))))

(define ast-transform-semi
  '(semi (if (ctx ((s b c)))
             (expression b)
             ()
             ())
         (assign (ctx ((s b c))) (ctx ((s true c))))))

(pass-if "ast-transform-semi"
         (pretty-noisy-equal?

          ;; from:
          (ast-transform

           i-ast

           '(compound
             (if b
                 (compound))
             (assign b true)))

          ;; via:
          ast-transform-semi))

(pass-if "csp-transform-semi"
         (diff-noisy-equal?

          ;; via/from:
          (csp-transform i-ast ast-transform-semi)

          ;; to:
          "semi_(\\ P',((s,b,c),(stack')) @ ifthenelse_(b,
(\\ P',V' @ P'(V')),
(\\ P',V' @ P'(V'))
)(P',((s,b,c),(stack'))),
assign_(\\ ((s,b,c),(stack')) @ ((s,true,c),(stack'))))"))

;; \\)

(define ast-transform-via
  '(on (e)
       (semi
        (semi (if (ctx ((s b c))) (expression (or c b))
                  (semi (action f) (action g))
                  ())
              (semi (if (ctx ((s b c))) (expression b)
                        (semi (if (ctx ((s b c))) (expression c)
                                  (action g)
                                  ())
                              (semi (assign (ctx ((s b c))) (ctx ((s b false))))
                                    (action f)))
                        (if (ctx ((s b c))) (expression c)
                            (semi (assign (ctx ((s b c))) (ctx ((s false c))))
                                  (action h))
                            (semi (assign (ctx ((s b c))) (ctx ((s true c))))
                                  (action g))))
                    (assign (ctx ((s b c))) (ctx ((S_S2 b c))))))
        (eventreturn))
       (the-end (s b c))))

(pass-if "ast-transform"
         (pretty-noisy-equal?

          ;; from:
          (ast-transform

           i-ast

           '(compound
             (on (e)
                 (compound

                  (if (or c b) (compound (action f) (action g)))
                  (if b
                      (compound
                       (if c (compound (action g)))
                       (assign c false)
                       (action f))
                      (compound
                       (if c
                           (compound (assign b false) (action h))
                           (compound (assign b true) (action g)))))
                  (assign s (value S S2))))))

          ;; via:
          ast-transform-via))

(pass-if "csp-transform"
         (diff-noisy-equal?

          ;; from/via:
          (csp-transform i-ast ast-transform-via)

          ;; to:
          "i?x:{e} ->
semi_(semi_(\\ P',((s,b,c),(stack')) @ ifthenelse_((c or b),
                             semi_((\\ P',V' @ i!f -> P'(V')),
                                  (\\ P',V' @ i!g -> P'(V'))),
                             (\\ P',V' @ P'(V'))
                             )(P',((s,b,c),(stack'))),
     semi_(\\ P',((s,b,c),(stack')) @ ifthenelse_(b,
                                  semi_(\\ P',((s,b,c),(stack')) @ ifthenelse_(c,
                                                               (\\ P',V' @ i!g -> P'(V')),
                                                               (\\ P',V' @ P'(V'))
                                                               )(P',((s,b,c),(stack'))),
                                       semi_(assign_(\\ ((s,b,c),(stack')) @ ((s,b,false),(stack'))),
                                            (\\ P',V' @ i!f -> P'(V')))),
                                  \\ P',((s,b,c),(stack')) @ ifthenelse_(c,
                                                          semi_(assign_(\\ ((s,b,c),(stack')) @ ((s,false,c),(stack'))),
                                                               (\\ P',V' @ i!h -> P'(V'))),
                                                          semi_(assign_(\\ ((s,b,c),(stack')) @ ((s,true,c),(stack'))),
                                                               (\\ P',V' @ i!g -> P'(V')))
                                                          )(P',((s,b,c),(stack')))
                                  )(P',((s,b,c),(stack'))),
          assign_(\\ ((s,b,c),(stack')) @ ((S_S2,b,c),(stack'))))),
(\\ P',V' @ i.return -> P'(V')))(\\ V' @ i_B_(V'),((s,b,c),(stack')))"))


(define c-ast `(,(ast:make
               'component 'c
               '(ports (provides i j)
                       (requires i k))
              (ast:make
               '(
                 behaviour
                 B
                 (types (enum S (S1 S2)))
                 (variables
                  (variable S s (value S S1))
                  (variable bool b false)
                  (variable bool c true))
                 (compound))))))

