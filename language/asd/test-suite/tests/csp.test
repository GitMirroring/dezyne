;; OM-PARSER parser test
(define ast-transform-OM-PARSER-assign-action-via
  '(on ((trigger i done))
    (semi (assign-active
            ((ctx ((s b c))) r' (action (trigger j h)))
            (ctx ((s b c))))
          (eventreturn))
    (the-end (s b c))))

(pass-if "ast-transform-OM-PARSER-assign-action"
         (pretty-noisy-equal?

          ;; from:
          (ast-transform c-ast 
                         '(on
                           ((trigger i done))
                           (compound
                            (assign res (action (trigger j h))))))

          ;; via:
          ast-transform-OM-PARSER-assign-action-via))

(pass-if "csp-transform-OM-PARSER-assign-action"
         (diff-noisy-equal?

          ;; via/from:
          (csp-transform i-ast ast-transform-OM-PARSER-assign-action-via)

          ;; to:
