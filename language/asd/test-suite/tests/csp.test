(pass-if "csp-transform-semi"
         (diff-noisy-equal?

          ;; from:
          (csp-transform

           i-ast

           '(semi (if ((s b c)) ()
                     (expression b)
                     ()
                     ())
                 (assign ((s b c)) () ((s true c)))))

          ;; via:
          "semi_(\\P',((s,b,c)) @ ifthenelse_(b,
(\\P',V' @ P'(V')),
(\\P',V' @ P'(V'))
)(P',((s,b,c))),
assign_(\\((s,b,c)) @ (s,true,c)))"))


(pass-if "ast-transform"
         (pretty-noisy-equal?

          ;; from:
          (ast-transform

           i-ast

           '(compound
             (on (e)
                 (compound

                  (if (or c b) (compound (action f) (action g)))
                  (if b
                      (compound
                       (if c (compound (action g)))
                       (assign c false)
                       (action f))
                      (compound
                       (if c
                           (compound (assign b false) (action h))
                           (compound (assign b true) (action g)))))
                  (assign s (value S S2))))))

          ;; via:
          '(on (e)
               (semi
                (semi (if ((s b c)) () (expression (or c b))
                          (semi (action f) (action g))
                          ())
                      (semi (if ((s b c)) () (expression b)
                                (semi (if ((s b c)) () (expression c)
                                          (action g)
                                          ())
                                      (semi (assign ((s b c)) () ((s b false)))
                                            (action f)))
                                (if ((s b c)) () (expression c)
                                    (semi (assign ((s b c)) () ((s false c)))
                                          (action h))
                                    (semi (assign ((s b c)) () ((s true c)))
                                          (action g))))
                            (assign ((s b c)) () ((S2 b c)))))
                            (return))
               (the-end (s b c)))))

(pass-if "csp-transform"
         (diff-noisy-equal?

          ;; from:
          (csp-transform

           i-ast

           '(on (e)
                (semi (semi (if ((s b c)) () (expression (or c b))
                           (semi (action f) (action g))
                           ())
                       (semi (if ((s b c)) () (expression b)
                                 (semi (if ((s b c)) () (expression c)
                                           (action g)
                                           ())
                                       (semi (assign ((s b c)) () ((s b false)))
                                             (action f)))
                                 (if ((s b c)) () (expression c)
                                     (semi (assign ((s b c)) () ((s false c)))
                                           (action h))
                                     (semi (assign ((s b c)) () ((s true c)))
                                           (action g))))
                             (assign ((s b c)) () ((S2 b c)))))
                      (return))
                (the-end (s b c))))

          ;; via:
          "i?x:{e} ->
semi_(semi_(\\P',((s,b,c)) @ ifthenelse_((c or b),
                             semi_((\\P',V' @ i!f -> P'(V')),
                                  (\\P',V' @ i!g -> P'(V'))),
                             (\\P',V' @ P'(V'))
                             )(P',((s,b,c))),
     semi_(\\P',((s,b,c)) @ ifthenelse_(b,
                                  semi_(\\P',((s,b,c)) @ ifthenelse_(c,
                                                               (\\P',V' @ i!g -> P'(V')),
                                                               (\\P',V' @ P'(V'))
                                                               )(P',((s,b,c))),
                                       semi_(assign_(\\((s,b,c)) @ (s,b,false)),
                                            (\\P',V' @ i!f -> P'(V')))),
                                  \\P',((s,b,c)) @ ifthenelse_(c,
                                                          semi_(assign_(\\((s,b,c)) @ (s,false,c)),
                                                               (\\P',V' @ i!h -> P'(V'))),
                                                          semi_(assign_(\\((s,b,c)) @ (s,true,c)),
                                                               (\\P',V' @ i!g -> P'(V')))
                                                          )(P',((s,b,c)))
                                  )(P',((s,b,c))),
          assign_(\\((s,b,c)) @ (S2,b,c)))),
(\\P',V' @ i.return -> P'(V')))(\\V' @ i_B_(V'),((s,b,c)))"))


(define c-ast `(,(ast:make
               'component 'c
               '(ports (provides i j)
                       (requires i k))
              (ast:make
               '(
                 behaviour
                 B
                 (types (enum S (S1 S2)))
                 (variables
                  (variable S s (value S S1))
                  (variable bool b false)
                  (variable bool c true))
                 (compound))))))

