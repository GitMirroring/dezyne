(define ast-transform-ifthenelse-via
  '(if (ctx ((s b c)))
       (expression b)
       ()
       ()))

(pass-if "ast-transform-ifthenelse"
         (pretty-noisy-equal?

          ;; from:
          (ast-transform

           i-ast

           '(if b
                (compound)
                (compound)))

