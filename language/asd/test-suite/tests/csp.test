          ;; via:
          "j?x:{e} ->
semi_((\\ P',V' @ j!h -> P'(V')),
skip_)(\\ V' @ transition_end -> c_B_(V'),((s,b,c),(stack')))"))

(pass-if "c-csp-transform-required-on"
