         (diff-noisy-equal?

          ;; from:
          (csp-transform i-ast csp-transform-function-arguments)

          ;; via:
          "g = \\ P',V',F' @ context_(F',
semi_((\\ P',V' @ i!f -> P'(V')),
returnvalue_(\\ ((s,b,c),((stack',c))) @ c)))(P',V')
"))


(define csp-reply-variable-ast
  '(on ((trigger i done))
    (context-active
      ((ctx ((dummy))) s (valued-action u what))
      (if (ctx ((dummy) s))
        (expression (== s (literal u Status Ok)))
        (reply (literal I Status Yes))
        (reply (literal I Status No))))
    (the-end (dummy))))

(pass-if "ast-transform-reply-variable"
         (pretty-noisy-equal?

          ;; from:
          (ast-transform

           c-reply-ast

           '(on ((trigger i done))
               (compound
                 (variable (type U (type Status)) s (value u what))
                 (if (== s (literal u Status Ok))
                     (compound (reply (literal I Status Yes)))
                     (compound (reply (literal I Status No)))))))

          ;; via:
          csp-reply-variable-ast))

(pass-if "csp-transform-reply-variable"
         (diff-noisy-equal?

          ;; from:
          (csp-transform

           c-reply-ast

           csp-reply-variable-ast)

          ;; via:
          "i?x:{done} ->
context_active_(sendrecv_(u,what),
\\ P',((dummy),((stack',s))) @ ifthenelse_(s == Status_Ok,
(\\ P',V' @ i.Status_Yes -> P'(V')),
(\\ P',V' @ i.Status_No -> P'(V'))
)(P',((dummy),((stack',s)))))(\\ V' @ transition_end -> C__(V'),((dummy),(stack')))"))

;; "

(define return-variable-ast
  '(component
    arguments
    (ports (provides I i))
    (behaviour
     #f
     (types)
     (variables (variable (type bool) b false))
     (functions
      (function
       g
       ((type bool) (parameters ((type bool) c)))
       (compound (return c))))
     (compound
      (on ((trigger i e))
          (compound
           (assign b (! b))
           (variable (type bool) c (call g (arguments b)))
           (if c (compound (action (trigger i f))))))))))

(define csp-return-variable-ast
  '(on ((trigger i e))
    (semi (context
            ((ctx ((b))) c (expression true))
            (if (ctx ((b) c))
              (expression c)
              (action (trigger i f))
              ()))
          (eventreturn))
    (the-end (b))))

(pass-if "ast-transform-return-variable"
         (pretty-noisy-equal?

          ;; from:
          (ast-transform

           return-variable-ast

           '(on ((trigger i e))
                (compound
                 (variable (type bool) c true)
                 (if c 
                     (compound 
                      (action (trigger i f)))))))

          ;; via:
          csp-return-variable-ast))

(pass-if "csp-transform-return-variable"
         (diff-noisy-equal?

          ;; from:
          (csp-transform

           return-variable-ast

           csp-return-variable-ast
           )

          ;; via:
          "i?x:{e} ->
semi_(context_(\\ ((b),(stack')) @ true,
\\ P',((b),((stack',c))) @ ifthenelse_(c,
(\\ P',V' @ i!f -> P'(V')),
(\\ P',V' @ P'(V'))
)(P',((b),((stack',c))))),
(\\ P',V' @ i.return -> P'(V')))(\\ V' @ transition_end -> arguments__(V'),((b),(stack')))"))

(define callvalued-ast
  '(component
    arguments
    (ports (provides I i))
    (behaviour
     #f
     (types)
     (variables (variable (type bool) b false))
     (functions
      (function
       g
       ((type bool) (parameters ((type bool) c)))
       (compound (action (trigger i f)) (return c))))
     (compound
      (guard true
             (on ((trigger i e))
                 (compound
                  (assign b (! b))
                  (variable (type bool) c (call g (arguments b)))
                  (assign b (call g (arguments c)))
                  (if c (compound (action (trigger i f)))))))))))

(define callvalued-on
  '(on ((trigger i e))
       (compound
        (assign b (! b))
        (variable (type bool) c (call g (arguments b)))
        (assign b (call g (arguments c)))
        (if c (compound (action (trigger i f)))))))

(define csp-callvalued-on
  '(on ((trigger i e))
    (semi (semi (assign (ctx ((b))) (ctx (((! b)))))
                (context-active
                  ((ctx ((b))) c (call g (arguments b)))
                  (semi (assign-active
                          ((ctx ((b) c)) r' (call g (arguments c)))
                          (ctx ((r') c)))
                        (if (ctx ((b) c))
                          (expression c)
                          (action (trigger i f))
                          ()))))
          (eventreturn))
    (the-end (b))))

(pass-if "ast-transform-callvalued"
         (pretty-noisy-equal?

          ;; from:
          (ast-transform callvalued-ast callvalued-on)

          ;; via:
          csp-callvalued-on))


(pass-if "csp-transform-callvalued"
         (diff-noisy-equal?

          ;; from:
          (csp-transform callvalued-ast csp-callvalued-on)
          ;; via:
         "i?x:{e} ->
semi_(semi_(assign_(\\ ((b),(stack')) @ ((not b),(stack'))),
context_active_(\\ P',V' @ g (P',V',\\ ((b),(stack')) @ (b)),
semi_(assign_active_(\\ P',V' @ g (P',V',\\ ((b),((stack',c))) @ (c)),
\\ (((b),((stack',c)))),r' @ ((r'),((stack',c)))),
\\ P',((b),((stack',c))) @ ifthenelse_(c,
(\\ P',V' @ i!f -> P'(V')),
(\\ P',V' @ P'(V'))
)(P',((b),((stack',c))))))),
(\\ P',V' @ i.return -> P'(V')))(\\ V' @ transition_end -> arguments__(V'),((b),(stack')))"))


(define doc
"
  on i.e:
    {
      b = ! b;
      bool c = g (b);
      bool d = g (c);

      {
        bool cc = g (c);
        bool dd = g (d);

        if(c)
        {
          f;
        }
      }
   }

")

(define callvalued-on-deep
  '(on ((trigger i e))
       (compound
        (assign b (! b))
        (variable (type bool) c (call g (arguments b)))
        (variable (type bool) d (call g (arguments c)))
        (compound
         (variable (type bool) cc (call g (arguments c)))
         (variable (type bool) dd (call g (arguments d)))
         (if dd (compound (action (trigger i f))))))))

(define csp-callvalued-on-deep
  '(on ((trigger i e))
    (semi (semi (assign (ctx ((b))) (ctx (((! b)))))
                (context-active
                  ((ctx ((b))) c (call g (arguments b)))
                  (context-active
                    ((ctx ((b) c)) d (call g (arguments c)))
                    (context-active
                      ((ctx ((b) c d)) cc (call g (arguments c)))
                      (context-active
                        ((ctx ((b) c d cc)) dd (call g (arguments d)))
                        (if (ctx ((b) c d cc dd))
                          (expression dd)
                          (action (trigger i f))
                          ()))))))
          (eventreturn))
    (the-end (b))))

(pass-if "ast-transform-callvalued-deep"
         (pretty-noisy-equal?

          ;; from:
          (ast-transform callvalued-ast callvalued-on-deep)

          ;; via:
          csp-callvalued-on-deep))

;; OM-PARSER parser test
(define ast-transform-OM-PARSER-variable-action-via
  '(on ((trigger i done))
    (context-active
      ((ctx ((s b c)))
       s
       (expression (action (trigger u what))))
      (eventreturn))
    (the-end (s b c))))

(pass-if "ast-transform-OM-PARSER-variable-action"
         (pretty-noisy-equal?

          ;; from:
          (ast-transform i-ast '(on ((trigger i done))
                                    (compound
                                     (variable
                                      (type U (type Status))
                                      s
                                      (action (trigger u what))))))

          ;; via:
          ast-transform-OM-PARSER-variable-action-via))

(pass-if "csp-transform-OM-PARSER-variable-action"
         (diff-noisy-equal?

          ;; via/from:
          (csp-transform i-ast ast-transform-OM-PARSER-variable-action-via)

          ;; to:
          "i?x:{done} ->
context_active_(sendrecv_(u,what),
(\\ P',V' @ i.return -> P'(V')))(\\ V' @ i_B_(V'),((s,b,c),(stack')))"))

