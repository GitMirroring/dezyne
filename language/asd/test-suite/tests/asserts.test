;; -*-scheme-*-

(read-set! keywords 'prefix)

(define-module (test-handler)
  :use-module (test-suite lib)
  :use-module (test-suite misc)

  :use-module (language asd ast:)
  :use-module (language asd reader)
  :use-module (language asd asserts)
  :use-module (language asd gom)
  :use-module (language asd gom ast)
  :use-module (language asd gom util))

(pass-if "asserts-first-dummy-test"
	 #t)

(pass-if "assert"
  (pretty-noisy-equal?
   (assert-list
    (ast->gom*
     (asd->ast
      #{ interface I {}
                   component C {
                                provides I i ;
                                requires I j ;
                                } #})))
   '((interface I deadlock)
     (interface I livelock)
     (component C deterministic)
     (component C illegal)
     (component C deadlock)
     (component C compliance I)
     (component C livelock))))
