bareSiliconAlarm_(IIG,IG) = let

bareSiliconAlarm__(((state),(stack'))) = transition_begin -> (
((state == States_NotActivated)) & (
alarmSystem?x:{IAlarmSystem_SwitchOn} ->
context_active_(sendrecv_(secretCode,ISecretCode_isCodeCorrect),
\ P',((state),((stack',value))) @ ifthenelse_((value == ISecretCode_Values_CORRECT),
semi_((\ P',V' @ sensors!ISensors_Activate -> sensors.return -> P'(V')),
semi_((\ P',V' @ alarmSystem.IAlarmSystem_Values_OK -> P'(V')),
assign_(\ ((state),((stack',value))) @ ((States_Activated_Idle),((stack',value)))))),
\ P',((state),((stack',value))) @ ifthenelse_((value == ISecretCode_Values_WRONG),
semi_((\ P',V' @ alarmSystem.IAlarmSystem_Values_Failed -> P'(V')),
assign_(\ ((state),((stack',value))) @ ((States_NotActivated),((stack',value))))),
(\ P',V' @ P'(V'))
)(P',((state),((stack',value))))
)(P',((state),((stack',value)))))(\ V' @ transition_end -> bareSiliconAlarm__(V'),((state),(stack')))
 []
  IIG & alarmSystem?x:{IAlarmSystem_SwitchOff} ->
illegal -> STOP
 []
  IG & preAlarmTimer?x:{ISTTimerCB_Timeout} ->
illegal -> STOP
 []
  IG & sensors?x:{ISensors_NI_DetectedMovement} ->
illegal -> STOP)
[]
((state == States_Activated_Idle)) & (
alarmSystem?x:{IAlarmSystem_SwitchOff} ->
semi_(context_active_(sendrecv_(secretCode,ISecretCode_isCodeCorrect),
\ P',((state),((stack',value))) @ ifthenelse_((value == ISecretCode_Values_CORRECT),
semi_((\ P',V' @ sensors!ISensors_Deactivate -> sensors.return -> P'(V')),
semi_((\ P',V' @ alarmSystem!IAlarmSystem_NI_SwitchedOff -> P'(V')),
assign_(\ ((state),((stack',value))) @ ((States_NotActivated),((stack',value)))))),
\ P',((state),((stack',value))) @ ifthenelse_((value == ISecretCode_Values_WRONG),
semi_((\ P',V' @ preAlarmTimer!ISTTimer_CreateTimer -> preAlarmTimer.return -> P'(V')),
semi_((\ P',V' @ alarmSystem!IAlarmSystem_NI_SwitchOffFailed -> P'(V')),
assign_(\ ((state),((stack',value))) @ ((States_CheckingDeactivationCode_WrongCode_Retry),((stack',value)))))),
(\ P',V' @ P'(V'))
)(P',((state),((stack',value))))
)(P',((state),((stack',value))))),
(\ P',V' @ alarmSystem.return -> P'(V')))(\ V' @ transition_end -> bareSiliconAlarm__(V'),((state),(stack')))
 []
  IIG & alarmSystem?x:{IAlarmSystem_SwitchOn} ->
illegal -> STOP
 []
  sensors?x:{ISensors_NI_DetectedMovement} ->
semi_(semi_((\ P',V' @ preAlarmTimer!ISTTimer_CreateTimer -> preAlarmTimer.return -> P'(V')),
semi_((\ P',V' @ alarmSystem!IAlarmSystem_NI_Tripped -> P'(V')),
assign_(\ ((state),(stack')) @ ((States_Activated_Tripped),(stack'))))),
(\ P',V' @ P'(V')))(\ V' @ transition_end -> bareSiliconAlarm__(V'),((state),(stack')))
 []
  IG & preAlarmTimer?x:{ISTTimerCB_Timeout} ->
illegal -> STOP)
[]
((state == States_Activated_AlarmMode)) & (
alarmSystem?x:{IAlarmSystem_SwitchOff} ->
semi_(context_active_(sendrecv_(secretCode,ISecretCode_isCodeCorrect),
\ P',((state),((stack',value))) @ ifthenelse_((value == ISecretCode_Values_CORRECT),
semi_((\ P',V' @ sensors!ISensors_Deactivate -> sensors.return -> P'(V')),
semi_((\ P',V' @ siren!ISiren_TurnOff -> siren.return -> P'(V')),
semi_((\ P',V' @ alarmSystem!IAlarmSystem_NI_SwitchedOff -> P'(V')),
assign_(\ ((state),((stack',value))) @ ((States_NotActivated),((stack',value))))))),
\ P',((state),((stack',value))) @ ifthenelse_((value == ISecretCode_Values_WRONG),
semi_((\ P',V' @ alarmSystem!IAlarmSystem_NI_SwitchOffFailed -> P'(V')),
assign_(\ ((state),((stack',value))) @ ((States_Activated_AlarmMode),((stack',value))))),
(\ P',V' @ P'(V'))
)(P',((state),((stack',value))))
)(P',((state),((stack',value))))),
(\ P',V' @ alarmSystem.return -> P'(V')))(\ V' @ transition_end -> bareSiliconAlarm__(V'),((state),(stack')))
 []
  IIG & alarmSystem?x:{IAlarmSystem_SwitchOn} ->
illegal -> STOP
 []
  sensors?x:{ISensors_NI_DetectedMovement} ->
(\ P',V' @ P'(V'))(\ V' @ transition_end -> bareSiliconAlarm__(V'),((state),(stack')))
 []
  IG & preAlarmTimer?x:{ISTTimerCB_Timeout} ->
illegal -> STOP)
[]
((state == States_Activated_Tripped)) & (
alarmSystem?x:{IAlarmSystem_SwitchOff} ->
semi_(context_active_(sendrecv_(secretCode,ISecretCode_isCodeCorrect),
\ P',((state),((stack',value))) @ ifthenelse_((value == ISecretCode_Values_CORRECT),
semi_((\ P',V' @ sensors!ISensors_Deactivate -> sensors.return -> P'(V')),
semi_((\ P',V' @ preAlarmTimer!ISTTimer_CancelTimer -> preAlarmTimer.return -> P'(V')),
semi_((\ P',V' @ alarmSystem!IAlarmSystem_NI_SwitchedOff -> P'(V')),
assign_(\ ((state),((stack',value))) @ ((States_NotActivated),((stack',value))))))),
\ P',((state),((stack',value))) @ ifthenelse_((value == ISecretCode_Values_WRONG),
semi_((\ P',V' @ preAlarmTimer!ISTTimer_CancelTimer -> preAlarmTimer.return -> P'(V')),
semi_((\ P',V' @ preAlarmTimer!ISTTimer_CreateTimer -> preAlarmTimer.return -> P'(V')),
semi_((\ P',V' @ alarmSystem!IAlarmSystem_NI_SwitchOffFailed -> P'(V')),
assign_(\ ((state),((stack',value))) @ ((States_CheckingDeactivationCode_WrongCode_Retry),((stack',value))))))),
(\ P',V' @ P'(V'))
)(P',((state),((stack',value))))
)(P',((state),((stack',value))))),
(\ P',V' @ alarmSystem.return -> P'(V')))(\ V' @ transition_end -> bareSiliconAlarm__(V'),((state),(stack')))
 []
  IIG & alarmSystem?x:{IAlarmSystem_SwitchOn} ->
illegal -> STOP
 []
  preAlarmTimer?x:{ISTTimerCB_Timeout} ->
semi_(semi_((\ P',V' @ siren!ISiren_TurnOn -> siren.return -> P'(V')),
assign_(\ ((state),(stack')) @ ((States_Activated_AlarmMode),(stack')))),
(\ P',V' @ P'(V')))(\ V' @ transition_end -> bareSiliconAlarm__(V'),((state),(stack')))
 []
  IG & sensors?x:{ISensors_NI_DetectedMovement} ->
illegal -> STOP)
[]
((state == States_CheckingDeactivationCode_WrongCode_Retry)) & (
alarmSystem?x:{IAlarmSystem_SwitchOff} ->
semi_(context_active_(sendrecv_(secretCode,ISecretCode_isCodeCorrect),
\ P',((state),((stack',value))) @ ifthenelse_((value == ISecretCode_Values_CORRECT),
semi_((\ P',V' @ sensors!ISensors_Deactivate -> sensors.return -> P'(V')),
semi_((\ P',V' @ preAlarmTimer!ISTTimer_CancelTimer -> preAlarmTimer.return -> P'(V')),
semi_((\ P',V' @ alarmSystem!IAlarmSystem_NI_SwitchedOff -> P'(V')),
assign_(\ ((state),((stack',value))) @ ((States_NotActivated),((stack',value))))))),
\ P',((state),((stack',value))) @ ifthenelse_((value == ISecretCode_Values_WRONG),
semi_((\ P',V' @ alarmSystem!IAlarmSystem_NI_SwitchOffFailed -> P'(V')),
assign_(\ ((state),((stack',value))) @ ((States_CheckingDeactivationCode_WrongCode_Retry),((stack',value))))),
(\ P',V' @ P'(V'))
)(P',((state),((stack',value))))
)(P',((state),((stack',value))))),
(\ P',V' @ alarmSystem.return -> P'(V')))(\ V' @ transition_end -> bareSiliconAlarm__(V'),((state),(stack')))
 []
  IIG & alarmSystem?x:{IAlarmSystem_SwitchOn} ->
illegal -> STOP
 []
  preAlarmTimer?x:{ISTTimerCB_Timeout} ->
semi_(semi_((\ P',V' @ siren!ISiren_TurnOn -> siren.return -> P'(V')),
assign_(\ ((state),(stack')) @ ((States_Activated_AlarmMode),(stack')))),
(\ P',V' @ P'(V')))(\ V' @ transition_end -> bareSiliconAlarm__(V'),((state),(stack')))
 []
  sensors?x:{ISensors_NI_DetectedMovement} ->
(\ P',V' @ P'(V'))(\ V' @ transition_end -> bareSiliconAlarm__(V'),((state),(stack'))))
)

within bareSiliconAlarm__(((States_NotActivated),(<>)))

channel extensions_over_empty_channels_is_undefined
channel IN,OUT : {preAlarmTimer.ISTTimerCB_Timeout,sensors.ISensors_NI_DetectedMovement,extensions_over_empty_channels_is_undefined}

SINGLETHREADED = true

channel transition_begin, transition_end

channel reorder_in,reorder_out : {alarmSystem.IAlarmSystem_Values_OK,alarmSystem.IAlarmSystem_Values_Failed,alarmSystem.return}

SEMANTICS(in',out',client',modeling') = let
Q'(s') = length(s') < card({|in'|}) & in'?x' -> Q'(s'^<x'>)
       []
       length(s') > 0 & out'!head(s') -> Q'(tail(s'))
       []
       length(s') == card({|in'|}) & in'?x' -> illegal -> STOP

R'(A') = ([] x' : A' @ x' -> R'(A'))
       []
       reorder_in?x' -> reorder_out!x' -> R'(A')

S'    = let

Idle(c') = transition_begin -> ([] x' : union(client',modeling') @ x' -> Busy(c',<>))

Busy(c',r') = c' == 0 & transition_end -> (if r' == <> then Idle(0) else reorder_out!head(r') -> Idle(0))
            []
            c' > 0 & transition_end -> transition_begin -> Busy(c',r')
            []
            c' < card({|in'|}) & ([] x' : {|in'|} @ x' -> Busy(c'+1,r'))
            []
            c' > 0 & ([] x' : {|out'|} @ x' -> Busy(c'-1,r'))
            []
            r' == <> & reorder_in?x' -> Busy(c',<x'>)
            []
            r' != <> & reorder_in?x' -> illegal -> STOP

within Idle(0)

within Q'(<>) [|{|in',out'|}|] if SINGLETHREADED then S' else R'(Union({{|in',out',transition_begin,transition_end|},client',modeling'}))

bareSiliconAlarm__Component(IIG) = let
compress(x) = let
transparent sbisim
transparent diamond
within sbisim(diamond(x))
Exclude = {alarmSystem.IAlarmSystem_Values_OK,alarmSystem.IAlarmSystem_Values_Failed,alarmSystem.return,alarmSystem.IAlarmSystem_NI_Tripped,alarmSystem.IAlarmSystem_NI_SwitchedOff,alarmSystem.IAlarmSystem_NI_SwitchOffFailed,alarmSystem.optional,preAlarmTimer.inevitable,sensors.optional}
ClientCalls = {alarmSystem.IAlarmSystem_SwitchOn,alarmSystem.IAlarmSystem_SwitchOff}
UsedModeling = {preAlarmTimer.inevitable,sensors.optional}
within compress((bareSiliconAlarm_(IIG,true) [[x<-OUT.x|x<-extensions(OUT)]] [[x<-reorder_in.x|x<-extensions(reorder_in)]]
[|diff({|OUT,transition_begin,transition_end,reorder_in,alarmSystem,siren,secretCode,preAlarmTimer,sensors|},Exclude)|]
(((Siren_(true) [[Siren.x<-siren.x|x<-extensions(Siren)]]
 ||| SecretCode_(true) [[SecretCode.x<-secretCode.x|x<-extensions(SecretCode)]]
 ||| STTimer_(true) [[STTimer.x<-preAlarmTimer.x|x<-extensions(STTimer)]]
 ||| Sensors_(true) [[Sensors.x<-sensors.x|x<-extensions(Sensors)]]
) [[x<-IN.x|x<-extensions(IN)]]
[|union({|IN|},UsedModeling)|]
SEMANTICS(IN,OUT,ClientCalls,UsedModeling)))) [[reorder_out.x<-x|x<-extensions(reorder_out)]]\{transition_begin,transition_end})
assert AlarmSystem_(false) :[deadlock free]

assert AlarmSystem_(true)  \ {|AlarmSystem.optional|} :[livelock free]

assert Siren_(false) :[deadlock free]

assert Siren_(true) :[livelock free]

assert SecretCode_(false) :[deadlock free]

assert SecretCode_(true) :[livelock free]

assert STTimer_(false) :[deadlock free]

assert STTimer_(true)  \ {|STTimer.inevitable|} :[livelock free]

assert Sensors_(false) :[deadlock free]

assert Sensors_(true)  \ {|Sensors.optional|} :[livelock free]

assert bareSiliconAlarm_(true,true) :[deterministic]
assert STOP [T= bareSiliconAlarm__Component(false) \ diff(Events,{illegal})
assert bareSiliconAlarm__Component(false) :[deadlock free]
assert AlarmSystem_(true) [[AlarmSystem.x<-alarmSystem.x|x<-extensions(AlarmSystem)]] \ {alarmSystem.optional} [FD= bareSiliconAlarm__Component(true) \ diff(Events,{|illegal,alarmSystem|})
assert bareSiliconAlarm__Component(true) \ diff(Events,{|illegal,alarmSystem|}) :[livelock free]
