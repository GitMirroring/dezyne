SecretCode_(IG) = let

SecretCode__(((dummy),(stack'))) =
(true) & (
SecretCode?x:{ISecretCode_isCodeCorrect} ->
(\ P',V' @ SecretCode.ISecretCode_Values_CORRECT -> P'(V'))(\ V' @ SecretCode__(V'),((dummy),(stack')))
 []
  SecretCode?x:{ISecretCode_isCodeCorrect} ->
(\ P',V' @ SecretCode.ISecretCode_Values_WRONG -> P'(V'))(\ V' @ SecretCode__(V'),((dummy),(stack'))))


within SecretCode__(((false),(<>))) 

STTimer_(IG) = let

STTimer__(((state),(stack'))) =
((state == States_Inactive)) & (
STTimer?x:{ISTTimer_CreateTimer,ISTTimer_CreateTimerEx,ISTTimer_CreateTimerMSec} ->
semi_(assign_(\ ((state),(stack')) @ ((States_Active),(stack'))),
