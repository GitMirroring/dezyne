-- drop_one_local: V => V
drop_one_local_((M', (L', L0'))) = (M', L')

-- send_: (c: channel, e:event) => (P,V)->Proc
send_(c',e') = \P',V' @ c'!e' -> P'(V')
-- skip_: () => (P,V)->Proc
skip_ = \P',V' @ P'(V')
-- sendrecv_: (c: channel, e:event) => (P,V)->Proc
sendrecv_(c',e') = \P',V' @ c'!e'  -> c'?r' -> returnvalue_(\V' @ r')(P',V')
-- callvoid_: (B': (P,V)->Proc) => (P,V)->Proc
callvoid_(B') = \P',V' @ B'(P', V')
-- callvoid_args_: (B': (P,V)->Proc, F': V'->V') => (P,V)->Proc
callvoid_args_(B',F') = \P',V' @ B'(P', V', F')
-- assign_: (F': V -> V) => (P,V) -> Proc
assign_(F') = \ P', V' @ P'(F'(V'))
-- assign_active_: C':(P,V)->Proc, A: (V,val)->V) => (P,V)->Proc
assign_active_(C', A') = \P',V' @ C'(\((M', r'),L') @ P'(A'((M',L'),r')), V')
-- returnvalue_: (F: V->val) => (P,V)->Proc
returnvalue_(F') = \P',(M',L') @ P'(((M',  F'((M', L'))), L'))
-- the_end_: P => V->Proc
the_end_(P') = \V' @ transition_end -> P'(V')

-- semi_: (S1,S2: (P,V)->Proc) => (P,V) -> Proc
semi_(S1',S2') = \ P', V' @ S1'( \ V'' @ S2'(P', V''), V')
-- ifthenelse: (E': val,  S1,S2: (P,V)->Proc) => (P,V) -> Proc
ifthenelse_(E',S1',S2') = \ P', V' @ if E' then S1'(P',V') else S2'(P',V')
-- context_: (F': V->val, S': (P,V)->Proc) => (P,V)->Proc
context_(F', S') = \ P', (M', L') @ S'((\V2' @ P'(drop_one_local_(V2'))), (M', (L', F'((M', L')))))
-- context_active_: (C':(P,V)->Proc, S: (P,V)->Proc) => (P,V)->Proc
context_active_(C', S') = \P',V' @ C'(\((M', r'),L') @ S'(\V2' @ P'(drop_one_local_(V2')), (M', (L',r'))), V')

datatype event_enumeration_alphabet =
IAlarmSystem_NI_SwitchOffFailed | IAlarmSystem_NI_SwitchedOff | IAlarmSystem_NI_Tripped | IAlarmSystem_SwitchOff | IAlarmSystem_SwitchOn | IAlarmSystem_Values_Failed | IAlarmSystem_Values_OK | ISTTimerCB_Timeout | ISTTimer_CancelTimer | ISTTimer_CreateTimer | ISTTimer_CreateTimerEx | ISTTimer_CreateTimerMSec | ISecretCode_Values_CORRECT | ISecretCode_Values_WRONG | ISecretCode_isCodeCorrect | ISensors_Activate | ISensors_Deactivate | ISensors_NI_DetectedMovement | ISiren_TurnOff | ISiren_TurnOn | States_Activated | States_Activated_AlarmMode | States_Activated_Idle | States_Activated_Tripped | States_Active | States_CheckingDeactivationCode_WrongCode_Retry | States_Deactivated | States_Inactive | States_NotActivated | States_SirenOff | States_SirenOn | States_Triggered | inevitable | optional | return

channel illegal

channel alarmSystem: {IAlarmSystem_NI_SwitchOffFailed,IAlarmSystem_NI_SwitchedOff,IAlarmSystem_NI_Tripped,IAlarmSystem_SwitchOff,IAlarmSystem_SwitchOn,optional,IAlarmSystem_Values_OK,IAlarmSystem_Values_Failed,return}
channel siren: {ISiren_TurnOff,ISiren_TurnOn,return}
channel secretCode: {ISecretCode_isCodeCorrect,ISecretCode_Values_CORRECT,ISecretCode_Values_WRONG,return}
channel preAlarmTimer: {ISTTimerCB_Timeout,ISTTimer_CancelTimer,ISTTimer_CreateTimer,ISTTimer_CreateTimerEx,ISTTimer_CreateTimerMSec,inevitable,return}
channel sensors: {ISensors_Activate,ISensors_Deactivate,ISensors_NI_DetectedMovement,optional,return}

channel AlarmSystem: {IAlarmSystem_NI_SwitchOffFailed,IAlarmSystem_NI_SwitchedOff,IAlarmSystem_NI_Tripped,IAlarmSystem_SwitchOff,IAlarmSystem_SwitchOn,optional,IAlarmSystem_Values_OK,IAlarmSystem_Values_Failed,return}
channel Siren: {ISiren_TurnOff,ISiren_TurnOn,return}
channel SecretCode: {ISecretCode_isCodeCorrect,ISecretCode_Values_CORRECT,ISecretCode_Values_WRONG,return}
channel STTimer: {ISTTimerCB_Timeout,ISTTimer_CancelTimer,ISTTimer_CreateTimer,ISTTimer_CreateTimerEx,ISTTimer_CreateTimerMSec,inevitable,return}
channel Sensors: {ISensors_Activate,ISensors_Deactivate,ISensors_NI_DetectedMovement,optional,return}

  AlarmSystem_(IG) = let

AlarmSystem__(((state),(stack'))) =
(((state == States_NotActivated) and true)) & (
AlarmSystem?x:{IAlarmSystem_SwitchOn} ->
semi_((\ P',V' @ AlarmSystem.IAlarmSystem_Values_OK -> P'(V')),
assign_(\ ((state),(stack')) @ ((States_Activated_Idle),(stack'))))(\ V' @ AlarmSystem__(V'),((state),(stack')))
 []
  AlarmSystem?x:{IAlarmSystem_SwitchOn} ->
(\ P',V' @ AlarmSystem.IAlarmSystem_Values_Failed -> P'(V'))(\ V' @ AlarmSystem__(V'),((state),(stack'))))
[]
((state == States_NotActivated)) & (
IG & AlarmSystem?x:{IAlarmSystem_SwitchOff} ->
illegal -> STOP)
[]
(((state == States_Activated_Idle) and true)) & (
AlarmSystem?x:{IAlarmSystem_SwitchOff} ->
semi_(semi_((\ P',V' @ AlarmSystem!IAlarmSystem_NI_SwitchedOff -> P'(V')),
assign_(\ ((state),(stack')) @ ((States_NotActivated),(stack')))),
(\ P',V' @ AlarmSystem.return -> P'(V')))(\ V' @ AlarmSystem__(V'),((state),(stack')))
 []
  AlarmSystem?x:{IAlarmSystem_SwitchOff} ->
semi_(semi_((\ P',V' @ AlarmSystem!IAlarmSystem_NI_SwitchOffFailed -> P'(V')),
assign_(\ ((state),(stack')) @ ((States_Activated_AlarmMode),(stack')))),
(\ P',V' @ AlarmSystem.return -> P'(V')))(\ V' @ AlarmSystem__(V'),((state),(stack'))))
[]
((state == States_Activated_Idle)) & (
AlarmSystem?x:{optional} ->
semi_(semi_((\ P',V' @ AlarmSystem!IAlarmSystem_NI_Tripped -> P'(V')),
assign_(\ ((state),(stack')) @ ((States_Activated_AlarmMode),(stack')))),
(\ P',V' @ P'(V')))(\ V' @ AlarmSystem__(V'),((state),(stack')))
 []
  IG & AlarmSystem?x:{IAlarmSystem_SwitchOn} ->
illegal -> STOP)
[]
(((state == States_Activated_AlarmMode) and true)) & (
AlarmSystem?x:{IAlarmSystem_SwitchOff} ->
semi_(semi_((\ P',V' @ AlarmSystem!IAlarmSystem_NI_SwitchedOff -> P'(V')),
assign_(\ ((state),(stack')) @ ((States_NotActivated),(stack')))),
(\ P',V' @ AlarmSystem.return -> P'(V')))(\ V' @ AlarmSystem__(V'),((state),(stack')))
 []
  AlarmSystem?x:{IAlarmSystem_SwitchOff} ->
semi_((\ P',V' @ AlarmSystem!IAlarmSystem_NI_SwitchOffFailed -> P'(V')),
(\ P',V' @ AlarmSystem.return -> P'(V')))(\ V' @ AlarmSystem__(V'),((state),(stack'))))
[]
((state == States_Activated_AlarmMode)) & (
IG & AlarmSystem?x:{IAlarmSystem_SwitchOn} ->
illegal -> STOP)


within AlarmSystem__(((States_NotActivated),(<>))) [|{AlarmSystem .optional}|] CHAOS({AlarmSystem .optional})

Siren_(IG) = let

