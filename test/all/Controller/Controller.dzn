component Console
{
  provides iconsole console;
  requires isocket socket;
  /**/behaviour {}
}

interface ibrokersocket
{
  out void connect(Websocket ws);
  in void send(Message msg);


  out void close(Websocket ws);
  out void error(Websocket ws, Message msg);
  out void selection_out(Websocket ws, Message msg);
  out void data(Websocket ws, Message msg);
  out void click(Websocket ws, Message msg);
  out void command(Websocket ws, Message msg);
  out void select(Websocket ws, Message msg);

  behaviour
    {
      bool connected = false;

      [!connected] {
        on inevitable: {connected = true; connect;}
        on send: illegal;
      }
      [otherwise] {
        on inevitable: selection_out;
        on inevitable: data;
        on inevitable: command;
        on inevitable: click;
        on inevitable: select;
        on inevitable: error;
        on inevitable: {connected = false; close;}
        on send: {}
      }
    }
}

interface idebugmodel
{
  in void click (Websocket ws, Message msg);
  in void command (Websocket ws, Message msg);
  in void create (Message msg);
  in void empty ();
  in void selection_in (Message msg);
  in void data(Message msg, out Message data);
  in void update (Message msg);
  in void message2data (Message msg, out Message data);

  out void run (Websocket ws, Message msg);
  out void result (Message msg);
  out void reset_out (Message msg);
  out void selection_out (Websocket ws, Message msg);
  behaviour {
    on inevitable: reset_out;
    on inevitable: result;
    on inevitable: run;
    on inevitable: selection_out;
    on data: {}
    on update: {}
    on click: {}
    on command: {}
    on create: {}
    on empty: {}
    on message2data: {}
    on selection_in: {}
  }
}

