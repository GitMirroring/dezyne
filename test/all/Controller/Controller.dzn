component Controller
{
  provides iclient_socket client_socket;
  requires isocket console_socket;
  requires isocket editor_socket;

  requires isocket views_socket;
  requires isocket systemview_socket;
  requires isocket diagramview_socket;
  requires isocket tableview_socket;
  requires isocket eventview_socket;

  requires isocket traceview_socket;
  requires isocket debugger_socket;

  system
    {
      Client client;
      Console console;

      Edit edit;

      Views views;

      System sys;
      Diagram diagram;
      Table table;
      Event event;
      Trace trace;
      Debug debug;
      Control control;

      Sequence_control sequence_control;
      Annotate annotate;

      Server server;
      Proxy proxy;


      client_socket <=> client.socket;

      client.control <=> control.client_control;
      server.control <=> control.server_control;

      client.diagram <=> control.client_diagram;
      client.event <=> control.client_event;
      client.parse <=> control.client_parse;
      client.systems <=> control.client_systems;
      client.table <=> control.client_table;
      client.other <=> control.client_other;

      console_socket <=> console.socket;
      console.console <=> control.console;

      editor_socket <=> edit.socket;
      control.editor <=> edit.control;
      sequence_control.editor <=> edit.sequence;

      views_socket <=> views.socket;

      diagramview_socket <=> diagram.socket;
      diagram.diagram <=> control.diagramview;

      tableview_socket <=> table.socket;
      table.table <=> control.tableview;

      eventview_socket <=> event.socket;
      event.event <=> control.eventview;

      views.views <=> control.views;

      systemview_socket <=> sys.socket;
      sys.sys <=> control.systemview;

      traceview_socket <=> trace.socket;
      trace.trace <=> sequence_control.traceview;

      debugger_socket <=> debug.socket;
      debug.debug <=> sequence_control.debugger;

      control.server_diagram <=> server.diagram;
      control.server_event <=> server.event;
      control.server_parse <=> server.parse;
      control.server_systems <=> server.systems;
      control.server_table <=> server.table;
      control.server_other <=> server.other;

      client.run <=> sequence_control.client_run;
      client.verify <=> sequence_control.client_verify;

      sequence_control.server_run <=> server.run;
      sequence_control.server_verify <=> server.verify;
      sequence_control.annotate <=> annotate.annotate;

      server.socket <=> proxy.socket;
    }
}
