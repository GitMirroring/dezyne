interface isystemmodel
{
  in void click (Websocket ws, Message msg);
  in void select (Websocket ws, Message msg);
  in void data(Message msg, out Message data);
  in void update (Message msg);
  in void message2data (Message msg, out Message data);
  in bool linked_p ();
  out void result (Message msg);

  behaviour {
    on linked_p: reply (false);
    on linked_p: reply (true);
    on inevitable: result;
    on click: {}
    on select: {}
    on data: {}
    on update: {}
    on message2data: {}
  }
}

component Systemmodel
{
  provides isystemmodel model;
  /**/behaviour {}
}

component Systemview
{
  provides isystemview systemview;
  requires isystemmodel model;
  requires ibrokersocket broker;
  behaviour {
    bool connected = false;
    {
      on broker.command (ws, msg): {}
      on systemview.update (msg): {
        model.update(msg);
        Message data;
        model.message2data (msg, data);
        bool linked = model.linked_p ();
        if (connected && linked) broker.send (msg);
      }
      on systemview.model (msg): {}

      [connected] {
        on broker.data(ws, msg):{
          Message data;
          model.data(msg, data);
          broker.send (data);
        }
        on broker.select(ws, msg): model.select (ws, msg);
        on broker.selection_out(ws, msg): systemview.selection_out (ws, msg);
        on broker.click (ws, msg): model.click (ws, msg);
        on broker.error (ws, msg): {}
        on broker.close (ws): connected = false;
        on broker.connect: illegal;

        on model.result (msg): broker.send (msg);
      }
      [!connected] {
        on broker.data
          ,broker.select
          ,broker.selection_out
          ,broker.click
          ,broker.error
          ,broker.close: illegal;
        on broker.connect (ws): connected = true;
        on model.result (msg): {}
      }
    }
  }
}

