component Systembroker
{
  provides ibrokersocket brokersocket;
  requires isocket socket;
  /**/behaviour {}
}

component Debugger
{
  provides idebugger debugger;
  requires idebugmodel model;
  requires ibrokersocket broker;

  behaviour
    {
      bool connected = false;

      {
        on debugger.start(msg): model.create(msg);
        on debugger.update(msg): {
          model.update(msg);
          Message data;
          model.message2data (msg, data);
          if (connected) broker.send (msg);
        }
        on debugger.quit(): model.empty();
        on debugger.selection_in(msg): model.selection_in(msg);
        on broker.click (ws, msg): {}
        on broker.select (ws, msg): {}
        [connected] {
          on broker.data(ws, msg):{
            Message data;
            model.data(msg, data);
            broker.send (data);
          }
          on broker.selection_out(ws, msg): model.selection_in (msg);
          on broker.command(ws, msg): model.command (ws, msg);
          on broker.error (ws, msg): {}
          on broker.close (ws): connected = false;
          on broker.connect: illegal;
          on model.reset_out (msg): debugger.reset_out (msg);
          on model.result (msg): if (connected) broker.send (msg);
          on model.run (ws, msg): debugger.run (ws, msg);
          on model.selection_out (ws, msg): {
            if (connected) broker.send (${selection:msg}$);
            debugger.selection_out(ws, msg);
          }
        }
        [!connected] {
          on broker.data
            ,broker.selection_out
            ,broker.command
            ,broker.error
            ,broker.close: illegal;
          on broker.connect (ws): connected = true;
          on model.reset_out (msg): {}
          on model.result (msg): {}
          on model.run (ws, msg): {}
          on model.selection_out (ws, msg): {}
        }
      }
    }
}

component Debugmodel
{
  provides idebugmodel model;
  /**/behaviour {}
}

component Editor_muxer
{
  provides ieditor control_editor;
  provides ieditor sequence_editor;
  requires ieditor editor;

  behaviour
    {
      on control_editor.selection_in(msg), sequence_editor.selection_in(msg): editor.selection_in(msg);
      on editor.selection_out(ws,msg): sequence_editor.selection_out(ws,msg);
      on editor.view(ws,msg): control_editor.view(ws,msg);
    }
}

