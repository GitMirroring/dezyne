component Traceview
{
  provides itraceview traceview;
  requires idebugmodel model;
  requires ibrokersocket broker;
  behaviour {
    bool connected = false;

    {
      on traceview.start (msg): {
        model.create (msg);
        Message data;
        model.message2data (msg, data);
        if(connected) broker.send (data);
      }
      on traceview.update (msg): {
        model.update (msg);
        Message data;
        model.message2data (msg, data);
        if(connected) broker.send (data);
      }
      on broker.command (ws, msg): {}
      on broker.select (ws, msg): {}

      [connected] {
        on traceview.selection_in (msg): model.selection_in(msg);
        on broker.data(ws, msg):{
          Message data;
          model.data(msg, data);
          broker.send (data);
        }
        on broker.selection_out(ws, msg): model.selection_in (msg);
        on broker.click (ws, msg): model.click (ws, msg);
        on broker.error (ws, msg): {}
        on broker.close (ws): connected = false;
        on broker.connect: illegal;
        on model.reset_out (msg): {
          traceview.reset_out (msg);
          broker.send (msg);
        }
        on model.result (msg): broker.send (msg);
        on model.run (ws, msg): {}
        on model.selection_out (ws, msg): {
          broker.send (${selection:msg}$);
          traceview.selection_out (ws, msg);
        }
      }
      [!connected] {
        on traceview.selection_in (msg): {}
        on broker.data,
          broker.selection_out,
          broker.click,
          broker.error,
          broker.close: illegal;

        on broker.connect (msg): connected = true;
        on model.reset_out (msg): {}
        on model.result (msg): {}
        on model.run (ws, msg): {}
        on model.selection_out (ws, msg): {}
      }
    }
  }
}

component Debug
{
  provides idebugger debug;
  requires isocket socket;
  system {
    Debugger debugger;
    Debugbroker debugbroker;
    Debugmodel debugmodel;

    debug <=> debugger.debugger;
    socket <=> debugbroker.socket;
    debugger.model <=> debugmodel.model;
    debugbroker.brokersocket <=> debugger.broker;
  }
}

