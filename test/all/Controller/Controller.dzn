extern Message $var$;
extern Websocket $var$;
extern Service $var$;
extern Url $var$;

interface iserver
{
  in void start (Websocket ws, Message msg);
  in void cancel (Websocket ws);

  out void progress (Websocket ws, Message msg);
  out void result (Websocket ws, Message msg);
  out void deny (Websocket ws, Message msg);
  out void ping (Websocket ws, Message msg);
  behaviour {
    bool idle = true;
    {
      [idle] {
      on start: idle = false;
      on start: result;
      on cancel: {}
      }
      [!idle] {
        on start: result;
        on cancel: idle = true;
        on inevitable: progress;
        on inevitable: result;
        on inevitable: deny;
        on inevitable: ping;
      }
    }
  }
}

interface iannotate
{
  in void transform(Message msg);

  behaviour
    {
      on transform:{}
    }
}

component Annotate
{
  provides iannotate annotate;
  /**/behaviour {}
}

component Sequence_control
{
  requires itraceview traceview;
  requires idebugger debugger;

  provides iserver client_run;
  requires iserver server_run;

  provides iserver client_verify;
  requires iserver server_verify;

  requires ieditor editor;

  requires iannotate annotate;

  behaviour
    {
      enum state {IDLE,RUN,VERIFY};
      state s = state.IDLE;

      on server_run.ping (ws,msg): {}
      on server_verify.ping (ws,msg): {}

      on debugger.reset_out (msg): {
        // TODO
      }
      on debugger.selection_out (ws,msg): traceview.selection_in (msg);
      on debugger.data (ws,msg): debugger.update (msg);

      on editor.selection_out (ws,msg): traceview.selection_in (msg);
      on editor.view (ws,msg): {}

      on traceview.selection_out(ws,msg): {
        editor.selection_in(msg);
        debugger.selection_in(msg);
        traceview.selection_in(msg);
      }
      on traceview.reset_out (msg): {
        debugger.quit ();
        traceview.start (msg);
      }
      on traceview.data(ws,msg): traceview.update (msg);

      [s.IDLE] {
        on debugger.run (ws,msg): {
          //s = state.RUN;
          //client_run.ping (ws,msg);
          //server_run.start (ws,msg);
          //traceview.reset();
          //debugger.reset();
        }

        on client_run.start (ws,msg): {
          s = state.RUN;
          traceview.start(msg);
          debugger.start(msg);
          server_run.start (ws,msg);
        }
        on client_run.cancel (ws): {}

        on client_verify.start (ws,msg): {
          s = state.VERIFY;
          server_verify.start (ws,msg);
          traceview.start(msg);
          debugger.start(msg);
        }
        on client_verify.cancel (ws): {}

        on server_run.progress(ws,msg),
          server_run.result(ws,msg),
          server_run.deny(ws,msg),
          server_verify.progress(ws,msg),
          server_verify.result(ws,msg),
          server_verify.deny(ws,msg): {}
      }
      [s.RUN] {
        on debugger.run(ws,msg): {
          // client_run.ping (ws,msg);
          // traceview.start(msg);
          // server_run.start(ws,msg);
        }

        on client_verify.start(ws,msg):{
          client_verify.result (ws, ${command:{name:'verify',type:'error',result:'bla',status:1,returncode:1}}$);
        }
        on client_verify.cancel (ws): {}

        on  server_verify.progress(ws,msg),
          server_verify.deny(ws,msg),
          server_verify.result(ws,msg),
          server_run.deny(ws,msg):{}

        on client_run.start (ws,msg): {
          client_run.result (ws, ${command:{name:'run',type:'error',result:'bla',status:1,returncode:1}}$);
        }
        on client_run.cancel (ws): {
          s = state.IDLE;
          server_run.cancel (ws);
        }

        on server_run.progress (ws,msg): {
          annotate.transform(msg);
          client_run.progress (ws,msg);
          traceview.update (msg);
          debugger.update (msg);
        }
        on server_run.result (ws,msg): {
          s = state.IDLE;
          annotate.transform(msg);
          client_run.result (ws,msg);
          traceview.update (msg);
          debugger.update (msg);
        }
      }

      [s.VERIFY] {
        on debugger.run(ws,msg): {
          // client_run.ping (ws,msg);
          // server_run.start(ws,msg);
        }

        on client_run.start(ws,msg): {
          client_run.result (ws, ${command:{name:'run',type:'error',result:'bla',status:1,returncode:1}}$);
        }
        on client_run.cancel (ws): {}

        on server_verify.deny(ws,msg),
          server_run.result(ws,msg),
          server_run.progress(ws,msg),
          server_run.deny(ws,msg): {}

        on client_verify.start (ws,msg): {
          client_verify.result (ws, ${command:{name:'verify',type:'error',result:'bla',status:1,returncode:1}}$);
        }
        on client_verify.cancel (ws): {
          s = state.IDLE;
          server_verify.cancel (ws);
        }


        on server_verify.progress (ws,msg): {
          annotate.transform(msg);
          client_verify.progress (ws,msg);
          traceview.update (msg);
          debugger.update (msg);
        }
        on server_verify.result (ws,msg): {
          s = state.IDLE;
          annotate.transform(msg);
          client_verify.result (ws,msg);
          traceview.update (msg);
          debugger.update (msg);
        }
      }
    }
}

component Control
{
  requires iconsole console;
  requires ieditor editor;
  requires iviews views;
  requires isystemview systemview;
  requires itableview diagramview;
  requires itableview tableview;
  requires itableview eventview;

  provides iserver client_diagram;
  requires iserver server_diagram;

  provides iserver client_event;
  requires iserver server_event;

  provides iserver client_parse;
  requires iserver server_parse;

  provides iserver client_systems;
  requires iserver server_systems;

  provides iserver client_table;
  requires iserver server_table;

  provides iserver client_other;
  requires iserver server_other;

  provides icontrol client_control;
  requires icontrol server_control;

  behaviour {
    on client_control.exit (ws): server_control.exit (ws);
    on console.command (ws,msg): {}

    on client_diagram.start (ws,msg): server_diagram.start (ws,msg);
    on client_diagram.cancel(ws): server_diagram.cancel(ws);

    on server_diagram.ping (ws,msg): {}
    on server_diagram.progress (ws,msg): client_diagram.progress (ws,msg);
    on server_diagram.result (ws,msg): {
      client_diagram.result (ws,msg);
      diagramview.update(msg);
      tableview.update(msg);
    }
    on server_diagram.deny(ws,msg): client_diagram.deny(ws,msg);

    on client_event.start (ws,msg): server_event.start (ws,msg);
    on client_event.cancel(ws): server_event.cancel(ws);

    on server_event.ping (ws,msg): {}
    on server_event.progress (ws,msg): client_event.progress (ws,msg);
    on server_event.result (ws,msg): {
      client_event.result (ws,msg);
      eventview.update(msg);
    }
    on server_event.deny(ws,msg): client_event.deny(ws,msg);

    on client_parse.start (ws,msg): server_parse.start (ws,msg);
    on client_parse.cancel(ws): server_parse.cancel(ws);

    on server_parse.ping (ws,msg): {}
    on server_parse.progress (ws,msg): client_parse.progress (ws,msg);
    on server_parse.result (ws,msg): client_parse.result (ws,msg);
    on server_parse.deny(ws,msg): client_parse.deny(ws,msg);

    on client_systems.start (ws,msg): {systemview.update(msg); server_systems.start(ws,msg);}
    on client_systems.cancel(ws): server_systems.cancel(ws);

    on server_systems.ping (ws,msg): {}
    on server_systems.progress (ws,msg): client_systems.progress (ws,msg);
    on server_systems.result (ws,msg): client_systems.result (ws,msg);
    on server_systems.deny(ws,msg): client_systems.deny(ws,msg);

    on client_table.start (ws,msg): server_table.start (ws,msg);
    on client_table.cancel(ws): server_table.cancel(ws);

    on server_table.ping (ws,msg): {}
    on server_table.progress (ws,msg): client_table.progress (ws,msg);
    on server_table.result (ws,msg): {
      client_table.result (ws,msg);
      tableview.update(msg);
    }
    on server_table.deny(ws,msg): client_table.deny(ws,msg);

    on client_other.start (ws,msg): server_other.start (ws,msg);
    on client_other.cancel(ws): server_other.cancel(ws);

    on server_other.ping (ws,msg): {}
    on server_other.progress (ws,msg):client_other.progress (ws,msg);
    on server_other.result (ws,msg): client_other.result (ws,msg);
    on server_other.deny(ws,msg): client_other.deny(ws,msg);

    on diagramview.select(ws,msg): diagramview.model(msg);
    on diagramview.selection_out(ws,msg): editor.selection_in(msg);
    on diagramview.data(ws,msg): {
      diagramview.update (msg);
      tableview.update (msg);
    }

    on editor.selection_out (ws,msg): {}

    on eventview.select(ws,msg): eventview.model(msg);
    on eventview.selection_out(ws,msg): editor.selection_in(msg);
    on eventview.data(ws,msg): eventview.update (msg);

    on systemview.select(ws,msg): systemview.model(msg);
    on systemview.selection_out(ws,msg): editor.selection_in(msg);
    on systemview.data(ws,msg): {}

    on tableview.select(ws,msg): tableview.model(msg);
    on tableview.selection_out(ws,msg): editor.selection_in(msg);
    on tableview.data(ws,msg): tableview.update (msg);

    on editor.view(ws,msg): views.select(msg);

    on views.data(ws,msg): views.update (msg);
  }
}

interface icontrol
{
  in void exit(Websocket ws);
  behaviour {
    on exit: {}
  }
}

interface iclient_socket
{
  in void connect(Websocket ws, Message msg);
  in void exit(Websocket ws);
  out void error(Websocket ws, Message msg);
  out void close(Websocket ws);

  behaviour
    {
      on exit: {}
      on connect: {}
      on inevitable: close;
      on inevitable: error;
    }
}

interface iserver_socket
{
  in void connect(Service service, Websocket ws, Message msg);
  in void exit(Websocket ws);
  out void error(Websocket ws, Message msg);
  out void close(Websocket ws);
  out void connected(Service service, Websocket ws, Message msg, Url url);

  behaviour
    {
      on exit: {}
      on connect: {}
      on connect: connected;
      on inevitable: close;
      on inevitable: error;
      on inevitable: connected;
    }
}

interface isocket
{
  in void error(Websocket ws, Message msg);
  in void close(Websocket ws);
  out void connect(Websocket ws, Message msg);

  behaviour
    {
      on inevitable: connect;
      on close: {}
      on error: {}
    }
}

interface iconsole
{
  out void command(Websocket ws, Message msg);
  behaviour
    {
      on inevitable: command;
    }
}

interface idebugger
{
  out void selection_out(Websocket ws, Message msg);
  out void data(Websocket ws, Message msg);
  out void reset_out (Message msg);
  out void run(Websocket ws, Message msg);
  in void update(Message msg);
  in void quit();
  in void start(Message msg);
  in void selection_in(Message msg);
  behaviour
    {
      on inevitable: selection_out;
      on inevitable: data;
      on inevitable: reset_out;
      on inevitable: run;
      on update: {}
      on quit: {}
      on start: {}
      on selection_in: {}
    }
}
interface itableview
{
  out void select(Websocket ws, Message msg);
  out void selection_out(Websocket ws, Message msg);
  out void data(Websocket ws, Message msg);

  in void update(Message msg);
  in void model(Message msg);
  in void reset();

  behaviour
    {
      on inevitable: select;
      on inevitable: selection_out;
      on inevitable: data;
      on model: {}
      on reset: {}
      on update: {}
    }
}
interface iviews
{
  out void data(Websocket ws, Message msg);
  in void select(Message msg);
  in void update(Message msg);
  behaviour
    {
      on select: {}
      on update: {}
      on inevitable: data;
    }
}
interface isystemview
{
  out void select(Websocket ws, Message msg);
  out void selection_out(Websocket ws, Message msg);
  out void data(Websocket ws, Message msg);

  in void update(Message msg);
  in void model(Message msg);

  behaviour
    {
      on inevitable: select;
      on inevitable: selection_out;
      on inevitable: data;
      on model: {}
      on update: {}
    }
}
interface itraceview
{
  out void selection_out(Websocket ws, Message msg);
  out void data(Websocket ws, Message msg);
  out void reset_out (Message msg);

  in void start(Message msg);
  in void selection_in(Message msg);
  in void update(Message msg);

  behaviour
    {
      on inevitable: selection_out;
      on inevitable: data;
      on inevitable: reset_out;
      on start: {}
      on selection_in: {}
      on update: {}
    }
}
interface ieditor
{
  in void selection_in(Message msg);
  out void selection_out(Websocket ws, Message msg);
  out void view(Websocket ws, Message msg);
  behaviour
    {
      on selection_in: {}
      on inevitable: selection_out;
      on inevitable: view;
    }
}

