import iworld.dzn;
import foreign.dzn;

interface ihello
{
  in void hello();

  behavior
  {
    on hello: {}
  }
}

component hello
{
  provides ihello h;
  requires iworld w;

  behavior
  {
    on h.hello(): w.world();
  }
}

component hello_foreign_file
{
  provides ihello h;

  system
    {
      hello c;
      stranger f;
      h <=> c.h;
      c.w <=> f.w;
    }
}
