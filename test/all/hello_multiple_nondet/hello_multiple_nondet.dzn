// Commentary:
//
// This model offers a non determinstic choice between modeling events
// sharing an event prefix leading to a deadlock.
// A regression reported by perry.van.wesel@thermofisher.com
//
// Code:

interface ihello
{
  in void hello ();
  out void cruel ();
  out void world ();
  behavior
  {
    bool idle = true;
    [idle] on hello: idle = false;
    [!idle]
    {
      on inevitable: {cruel; idle = true;}
      on optional: {cruel; world; idle = true;}
    }
  }
}

component hello_multiple_nondet
{
  provides ihello h;
  requires ihello w;
  behavior
  {
    on h.hello (): w.hello ();
    on w.cruel (): h.cruel ();
    on w.world (): {}
  }
}
