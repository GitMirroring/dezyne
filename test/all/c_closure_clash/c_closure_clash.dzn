// Code:

extern Integer $int$;

interface IContainer {
	in void FuncA(Integer b);
  out void FuncB(Integer a);

	behaviour {
		on FuncA: {}
    on inevitable: FuncB;
	}
}

interface IContainer2 {
	in void FuncA(Integer a);
  out void FuncB(Integer b);

	behaviour {
    on FuncA: {}
    on inevitable: FuncB;
  }
}

component c_closure_clash {
	provides IContainer iContainer;
	requires IContainer2 iContainer2;

	behaviour {
		on iContainer.FuncA(b): {
      iContainer2.FuncA(b);
		}
		on iContainer2.FuncB(a): {
      iContainer.FuncB(a);
		}
	}
}
