interface IDataVariables
{
  extern integer $int$; // until we have language feature, int mostly works.
  extern boolean $int$;
  extern string $int$;
  extern DataVariableType $int$;

  in void inInt(in integer number);
  in void outBool(out boolean condition);
  in void inoutString(inout string text);

  out void inDataVariable(in DataVariableType dv);

  behaviour
  {
    on inInt: {}
    on outBool: {}
    on inoutString: {}
    on optional: inDataVariable;
  }
}

component DataVariables
{
  provides IDataVariables pp;
  requires IDataVariables rp;

  behaviour
  {
    IDataVariables.integer idv = $42$;
    IDataVariables.boolean bdv; // uninitialized data variable allowed
    IDataVariables.string sdv = $0$; // $"Hotsy Flotsy"$;
    IDataVariables.DataVariableType dvtdv = $0$; // not if you ever decide to generate and run code, it doesn't ;$Anything %goes% between excape chars$;

    void f(inout IDataVariables.string s) {s = /* $"Niks Hotsy Flotsy! Kedeng!!!$*/ $1$; rp.inoutString(s);}

    on pp.inInt(idv): {} // assign inInt input value directly to variable idv
    on pp.outBool(bdv): {bdv = $0$;} // output bdv value
    on pp.inoutString(s): {IDataVariables.string local = s; f(local); s = local;}
    on rp.inDataVariable(idv): {pp.inDataVariable(dvtdv);}
  }
}
