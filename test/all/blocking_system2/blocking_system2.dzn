// Code:

interface ihello
{
  in void hello ();

  behavior
  {
    on hello:{}
  }
}

interface iworld
{
  in void hello ();
  out void world ();

  behavior
  {
    bool pending = false;
    on hello:
    {
      [!pending] pending = true;
      [pending] illegal;
    }
    on inevitable:
    {
      [pending]{pending = false; world;}
    }
  }
}

component Blocked
{
  provides blocking ihello provided;

  requires iworld required;

  behavior
  {
    blocking on provided.hello (): required.hello ();

    on required.world (): provided.return;
  }
}

component blocking_system2
{
  provides blocking ihello port1;
  provides blocking ihello port2;

  requires iworld async1;
  requires iworld async2;

  system
  {
    Blocked blocked1;
    Blocked blocked2;

    blocked1.provided <=> port1;
    blocked2.provided <=> port2;

    blocked1.required <=> async1;
    blocked2.required <=> async2;
  }
}
