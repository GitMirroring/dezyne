// Commentary:
//
// Derived from deadlock_cancel_guarantee: demonstrate how to resolve the
// deadlock situation, in the context of two asynchonous ports.
//
// Code:

interface isynchronous
{
  in void request();
  out void complete();
  behavior
  {
    bool active = false;
    [!active] on request: active = true;
    [active] on inevitable: {active = false; complete;}
  }
}

interface itransaction
{
  in void cancel();
  in void request();
  out void complete();
  behavior
  {
    bool active = false;
    [!active] on request: active = true;
    on cancel: active = false;
    [active] on inevitable: {active = false; complete;}
  }
}

interface iblock
{
  in void block();
  behavior
  {
    on block: {} // this event blocks
  }
}

component cancel_guarantee
{
  provides blocking isynchronous pt;
  requires blocking iblock rb;
  requires itransaction rt;
  requires itransaction rt2;
  behavior
  {
    bool pending = false;
    bool active = false;
    [!active] on pt.request():
      {active = true; rt.request(); rt2.request(); rb.block();}
    [active && pending] on rt.complete(), rt2.complete():
      {pending = false; active = false; pt.complete();}
    [active && !pending] on rt.complete(), rt2.complete(): pending = true;
  }
}
