// Code:

interface ihello
{
  in void hello();

  behavior
  {
    on hello: {}
  }
}

component mux
{
  provides blocking ihello left;
  provides blocking ihello right;

  behavior
  {
    enum Side {None, Left, Right};
    Side side = Side.None;
    [side.None]
    {
      blocking on left.hello(): side = Side.Left;
      blocking on right.hello(): side = Side.Right;
    }
    [side.Left]
    {
      on right.hello(): {side = Side.None; left.reply();}
    }
    [side.Right]
    {
      on left.hello(): {side = Side.None; right.reply();}
    }
  }
}

component compliance_blocking_multiple_provides2
{
  provides blocking ihello left;
  provides blocking ihello right;

  system
  {
    mux m;

    left <=> m.left;
    right <=> m.right;
  }
}