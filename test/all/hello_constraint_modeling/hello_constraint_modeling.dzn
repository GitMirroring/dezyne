// Commentary:
//
// This example "show cases" the application of the provides ports
// behaviors as constraint on the component behavior. The example is a
// proxy.
//
// Code:

interface ihello
{
  in void hello();
  in void bye();

  out void cruel();
  out void world();

  behavior
  {
    bool idle = true;
    bool cruelty = true;

    [idle] on hello: idle = false;
    [!idle]
    {
      on bye: idle = true;
      [cruelty] on optional: {cruelty = false; cruel;}
      on inevitable: {idle = true; world;}
    }
  }
}

component hello_constraint_modeling
{
  provides ihello h;
  requires ihello w;

  behavior
  {
    on h.hello(): w.hello();
    on h.bye(): w.bye();
    on w.cruel(): h.cruel();
    on w.world(): h.world();
  }
}
