// Commentary:
//
// Code:

interface ihello
{
  in void hello();
  out void world();

  behaviour
  {
    on hello: {}
  }
}

component hello
{
  provides ihello hh;
  requires ihello hw;

  behaviour
  {
    on hh.hello(): hw.hello();
    on hw.world(): hh.world();
  }
}

component world
{
  provides ihello ww;
  requires ihello wh;

  behaviour
  {
    on ww.hello(): wh.hello();
    on wh.world(): ww.world();
  }
}

component system_hello_world
{
  provides ihello h;
  requires ihello w;

  system
    {
      hello ch;
      world cw;
      h <=> ch.hh;
      ch.hw <=> cw.ww;
      cw.wh <=> w;
    }
}
