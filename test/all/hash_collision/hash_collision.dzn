// Commentary:
//
// This model leads to a duplicate case label in the interface switch
// statement, due to a hash collision caused by not increasing the pow
// value after initial use in the hash function.
//
// Code:

interface ihello
{
  in void _3 ();
  in void _1 ();

  behavior
  {
    bool idle = true;
    [idle]  on _3: {idle = !idle;}
    [!idle] on _1: {idle = !idle;}
  }
}

component hash_collision
{
  provides ihello h;

  behavior
  {
    on h._3 (): {}
    on h._1 (): {}
  }
}
