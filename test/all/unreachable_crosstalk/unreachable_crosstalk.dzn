import ihello.dzn;

component unreachable_crosstalk
{
  provides ihello h;
  requires ihello w;

  behavior
  {
    [false] on h.hello ():/*****/{} /* Be sure the leave the open brace
                                       at position (33, 33) just like in
                                       ihello.dzn. */
    [true] on h.hello (): w.hello ();
  }
}
