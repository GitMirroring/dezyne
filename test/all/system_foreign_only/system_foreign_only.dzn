// Commentary:
//
// Assert that there is no conflict between a foreign updating its own
// provides state and another Dezyne component port endpoint.
//
// Code:


import foreign_only.dzn;

component proxy
{
  provides foreign_only p;
  requires foreign_only r;
  behavior
  {
    on p.hello (i,d): r.hello (i,d);
    on r.cruel (): p.cruel ();
    on r.world (i,d): p.world (i,d);
    on p.bye (): r.bye ();
  }
}

component system_foreign_only
{
  provides foreign_only port;
  system
  {
    proxy p;
    port <=> p.p;
    foreign f;
    p.r <=> f.port;
  }
}
