interface IAsync {
  in void e();
  in void c();
  out void cb();

  behaviour {
    bool idle = true;
    [idle] {
      on e: idle = false;
      on c: {}
    }
    [!idle] {
      on e: illegal;
      on c: idle = true;
      on inevitable: { cb; idle = true; }
    }
  }
}

interface IAsync2 {
  in void e();
  in void c();
  out void cb1();
  out void cb2();

  behaviour {
    bool idle = true;
    [idle] {
      on e: idle = false;
      on c: {}
    }
    [!idle] {
      on e: illegal;
      on c: idle = true;
      on inevitable: { cb1; cb2; idle = true; }
    }
  }
}

component async_synccb2 {
  provides IAsync p;
  requires IAsync2 r;
  behaviour {
    requires dzn.async i;
    bool idle = true;
    bool b = false;
    [idle] {
      on p.e(): { r.e(); idle = false; }
      on p.c(): i.clr();
    }
    [!idle] {
      on p.e: illegal;
      on p.c(): { r.c(); idle = true; }
      [b] on i.ack(): { p.cb(); idle = true; }
      on r.cb1(): {i.req(); b = true;}
      [b] on r.cb2(): {} // {i.clr(); i.req();}
    }
  }
}

