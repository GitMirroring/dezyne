// Commentary:
//
// Use defer to mimick the previous async interface modulo the ack priority.
//
// Code:

interface ihello
{
  in void hello();
  in void cancel();
  out void world();

  behavior
  {
    bool idle = true;

    [idle] on hello: idle = false;
    on cancel: idle = true;
    [!idle] on inevitable: {idle = true; world;}
  }
}


interface iasync
{
  in void req ();
  in void clr ();
  out void ack ();
  behavior
  {
    bool idle = true;
    [idle] on req: idle = false;
    on clr: idle = true;
    [!idle] on inevitable: {idle = true; ack;}
  }
}

component hello
{
  provides ihello h;
  requires iasync async;
  behavior
  {
    on h.hello (): async.req ();
    on async.ack (): h.world ();
    on h.cancel (): async.clr ();
  }
}

component async_defer
{
  provides iasync async;

  behavior
  {
    bool toggle = true;
    on async.req (): defer async.ack ();
    on async.clr (): toggle = !toggle;
  }
}

component defer_async
{
  provides ihello h;
  system
  {
    hello hello_;
    async_defer async_;
    h <=> hello_.h;
    hello_.async <=> async_.async;
  }
}
