interface parse_type_mismatch
{
  extern x $int$;
  in void hello();

  behaviour
  {
    enum e {f,t};
    enum f {f,w};
    bool b = e.f;
    f c = e.f;
    bool z;
    x y;
    on hello: {c = f.t;}
  }
}
