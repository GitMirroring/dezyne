// Code:

interface ihello
{
  in void hello ();
  behavior
  {
    on hello: {}
  }
}

interface iworld
{
  in void hello ();
  out void world ();

  behavior
  {
    bool idle = true;
    [idle] on hello: idle = false;
    [!idle] on inevitable: {idle = true; world;}
  }
}

component demuxer
{
  provides blocking iworld h;
  requires blocking ihello l;
  requires iworld r;

  behavior
  {
    bool idle = true;
    [idle] on h.hello (): {r.hello (); l.hello (); idle = false; }
    on r.world (): defer { h.world (); idle = true; }
  }
}

component block
{
  provides blocking ihello h;
  requires iworld w;

  behavior
  {
    blocking on h.hello (): w.hello ();
    on w.world (): h.reply ();
  }
}

component proxy
{
  provides iworld h;
  requires iworld w;

  behavior
  {
    bool idle = true;
    [idle] on h.hello (): { w.hello (); idle = false; }
    on w.world (): { h.world (); idle = true; }
  }
}

component collateral_blocking_out
{
  provides blocking iworld h;
  requires iworld l;
  requires iworld r;

  system
  {
    demuxer top;
    block left;
    proxy right;

    h <=> top.h;
    top.l <=> left.h;
    top.r <=> right.h;
    left.w <=> l;
    right.w <=> r;
  }
}
