// Code:

interface Start {
  in bool start();
  behaviour {
    on start: reply(false);
    on start: reply(true);
  }
}

interface Action {
  enum E {E1, E2};
  in E action();
  behaviour {
    on action: reply(E.E1);
  }
}

component Test {
  provides Start start;
  requires Action action;
  behaviour {
    void func() {
      reply(Action.E.E1);
    }
    on start.start(): func();
  }
}
