interface ihello
{
  in void hello ();
  out void cruel ();
  out void world ();
  behavior
  {
    enum S {A,B,C};
    S s = S.A;
    on hello: s = S.B;
    [s.B || s.C] on inevitable: {s = S.A; world;}
    [s.B] on inevitable: {s = S.C; cruel;}
  }
}

component defer_twice_noisy
{
  provides ihello h;
  requires ihello w;

  behavior
  {
    bool idle = true;
    [idle] on h.hello ():
    {
      w.hello();
      idle = false;
      defer h.cruel ();
      defer {idle = true; h.world ();}
    }
    [!idle] on h.hello (): {}
    [idle] on w.world (): {}
    [!idle] on w.world (): {idle = true; h.world ();}
    on w.cruel (): {}
  }
}
