// Code:

import blocking_release.dzn;

component proxy_left
{
  provides blocking ihello left;
  requires blocking ihello hello;

  behavior
  {
    on left.hello (): hello.hello ();
  }
}

component proxy_right
{
  provides blocking ihello right;
  requires blocking ihello hello;

  behavior
  {
    on right.hello (): {hello.hello ();hello.hello ();}
  }
}

component collateral_blocking_release
{
  provides blocking ihello block;
  provides blocking ihello release;
  requires iworld w;

  system
  {
    proxy_left top_left;
    proxy_right top_right;
    blocking_release bottom;

    block <=> top_left.left;
    top_left.hello <=> bottom.block;
    release <=> top_right.right;
    top_right.hello <=> bottom.release;
    w <=> bottom.w;
  }
}
