interface ihello
{
  in void hello ();

  behavior
  {
    bool h = true;
    [h.foo] on hello: {}
    [w.bar] on hello: {}
    [foo.bar] on hello: {}
    on hello: bool b = h.foo;
    on hello: {bool b = false; b = h.foo;}
    on hello: if (h.foo) {}
    on hello: reply (h.foo);
  }
}
