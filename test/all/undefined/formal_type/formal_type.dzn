//extern Extern $$;

interface ihello
{
  in void hello();
  behavior
  {
    on hello: {}
  }
}

interface iworld
{
  in void world(in Extern p);
  behavior
  {
    on world: {}
  }
}

component formal_type
{
  provides ihello h;
  requires iworld w;
  behavior
  {
    on h.hello(): w.world($$);
  }
}
