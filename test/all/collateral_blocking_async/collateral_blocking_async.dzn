// Commentary:
//
// Code:

interface ihello
{
  in void hello();
  in void cruel();
  out void world();

  behavior
  {
    on hello: world;
    on cruel: world;
  }
}

component Top
{
  provides blocking ihello h;
  requires blocking ihello w;

  behavior
  {
    requires dzn.async i;

    blocking on h.hello(): {w.hello(); i.req();}
    blocking on h.cruel(): {i.req(); w.hello();}
    on w.world(): h.world();
    on i.ack(): h.reply();
  }
}

component Bottom
{
  provides blocking ihello h;

  behavior
  {
    requires dzn.async i;

    blocking on h.hello(): i.req();
    blocking on h.cruel(): i.req();
    on i.ack(): {h.world(); h.reply();}
  }
}

component collateral_blocking_async
{
  provides blocking ihello h;
  system
  {
    Top top;
    Bottom bottom;

    h <=> top.h;
    top.w <=> bottom.h;
  }
}
