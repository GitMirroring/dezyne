// Code:

interface ihello
{
  in void hello ();
  in void bye ();
  out void world ();

  behavior
  {
    bool idle = true;
    on hello: {
      if (!idle) world;
      idle = !idle;
    }
    on bye:
      if (!idle) {idle = true; world;}
      else idle = false;
  }
}

component hello_guard_if
{
  provides ihello h;

  behavior
  {
    bool idle = true;
    on h.hello (), h.bye ():
    {
      if (!idle) h.world ();
      idle = !idle;
    }
  }
}
