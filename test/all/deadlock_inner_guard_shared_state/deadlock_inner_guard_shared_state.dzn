interface ihello
{
  in void hello ();
  in bool bye ();

  out void cruel ();

  behavior
  {
    bool idle = true;

    [idle] on hello: idle = false;
    on bye:
    {
      [!idle] {reply (true); idle = true; cruel;}
      [!idle] reply (false);
    }
  }
}

interface icruel
{
  in bool cruel ();

  behavior
  {
    on cruel:
    {
      [true] reply (true);
      [true] reply (false);
    }
  }
}


component deadlock_inner_guard_shared_state
{
  provides ihello h;
  requires icruel c;
  behavior
  {
    on h.hello (): [h.idle] {}
    on h.bye ():
    {
      if (c.cruel ())
      {
        h.cruel ();
        reply (true);
      }
      else
        reply (false);
    }
  }
}
