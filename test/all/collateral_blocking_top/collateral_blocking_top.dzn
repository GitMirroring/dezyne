// Commentary:
//
// Code:

interface ihello
{
  in void hello ();
  behavior
  {
    on hello: {}
  }
}

interface iworld
{
  in void hello ();
  out void world ();
  behavior
  {
    bool idle = true;
    on hello: idle = !idle;
    [!idle] on inevitable: {idle=true;world;}
  }
}

component collateral
{
  provides ihello block;
  provides ihello hello;
  requires ihello w;

  behavior
  {
    on block.hello (): w.hello ();
    on hello.hello (): {}
  }
}

component hello_block
{
  provides ihello block;
  requires iworld w;

  behavior
  {
    bool blocked = false;
    blocking on block.hello (): {w.hello (); blocked = true;}
    [blocked] on w.world (): {blocked = false; block.reply ();}
  }
}

component collateral_blocking_top
{
  provides ihello block;
  provides ihello hello;
  requires iworld w;

  system
  {
    collateral top;
    hello_block bottom;

    block <=> top.block;
    hello <=> top.hello;
    top.w <=> bottom.block;
    w <=> bottom.w;
  }
}
