// Code:

extern xint $int$;

interface i {
  in void e1();
  in void e2(xint foo);

  behaviour {
    bool b = true;

    [!b]
    {
      on e1:
      b = false;
      on e2:
      b = true;
    }
    [b]
    {
      on e1:
      b = false;
      on e2:
      illegal;
    }
  }
}

component normalize_illegal {
  provides i p;

  behaviour {
    bool b = true;

    [!b]
    {
      on p.e1():
      b = false;
      on p.e2(bar):
      b = true;
    }
    [b]
    {
      on p.e1():
      b = false;
      on p.e2():
      illegal;
    }
  }
}

