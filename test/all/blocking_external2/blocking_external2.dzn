// Code:

interface ihello
{
  in void hello ();
  in void cruel ();

  behavior
  {
    on hello: {}
    on cruel: {}
  }
}

interface iworld
{
  in void hello ();
  out void world ();

  behavior
  {
    bool idle = true;
    on hello: idle = !idle;
    [!idle] on inevitable: {world; idle = true;}
  }
}

component blocking_external2
{
  provides blocking ihello h;
  requires external iworld w0;
  requires external iworld w1;

  behavior
  {
    bool idle = true;
    blocking on h.hello (): {w0.hello (); w1.hello (); idle = false;}
    on h.cruel(): {}
    on w0.world (), w1.world (): {if (!idle) idle = true; else h.reply();}
  }
}
