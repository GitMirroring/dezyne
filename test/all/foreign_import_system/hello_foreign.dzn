// Code:

import iworld.dzn;

interface ihello
{
  in bool hello();
  out void goodbye();

  behavior
  {
    bool b = true;
    [b] {
      on hello: reply(b);
      on hello: {b = false; reply(b);}
    }
    [!b] on optional: {b = true; goodbye;}
  }
}

component hello
{
  provides ihello h;
  requires iworld w;

  behavior
  {
    bool b = true;
    on h.hello(): {b = false; w.world(); reply(b);}
    [!b] on w.howdy(): {b = true; h.goodbye();}
  }
}

component Foreign
{
  provides iworld w;
  // behavior {}
}

component hello_foreign
{
  provides ihello h;

  system
    {
      h <=> c.h;
      hello c;
      c.w <=> f.w;
      Foreign f;
    }
}
