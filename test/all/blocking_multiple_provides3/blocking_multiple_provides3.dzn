// Code:


interface ihello
{
  in void hello();

  behavior
  {
    on hello: {}
  }
}

interface iworld
{
  in void hello();
  out void world();

  behavior
  {
    on hello: world;
  }
}

component multiple_provides
{
  provides blocking ihello left;
  provides blocking ihello right;
  requires blocking iworld r;

  behavior
  {
    enum Side {None, Left, Right, LeftRight, RightLeft};
    Side side = Side.None;

    blocking on left.hello(): {
      [side.None] {side = Side.Left; r.hello();}
      [side.Right] {side = Side.RightLeft; r.hello();}
    }
    blocking on right.hello(): {
      [side.None] {r.hello(); side = Side.Right;}
      [side.Left] {r.hello(); side = Side.LeftRight;}
    }

    [side.Left] on r.world(): {side = Side.None; left.reply();}
    [side.LeftRight] on r.world(): {side = Side.Right; left.reply();}

    [side.Right] on r.world(): {side = Side.None; right.reply();}
    [side.RightLeft] on r.world(): {side = Side.Left; right.reply();}
  }
}

component blocking_multiple_provides3
{
  provides blocking ihello left;
  provides blocking ihello right;
  requires iworld r;
  system
  {
    left  <=> mp.left;
    right <=> mp.right;
    multiple_provides mp;
    mp.r <=> r;
  }
}