// Code:

interface ihello
{
  in bool hello ();
  in bool cruel ();

  behavior
  {
    on hello: return false;
    on hello: return true;
    on cruel: return false;
    on cruel: return true;
  }
}

component hello_implicit_temporaries
{
  provides ihello h;
  requires ihello w;

  behavior
  {
    bool foo ()
    {
      if (w.hello ())
        return w.hello ();
      return !w.cruel ();
    }

    on h.hello ():
    if (w.hello ()) return w.hello ();
    else if (foo ()) return !foo () && true;
    else if (w.hello () && true) return w.hello () || true;
    else return false;
    on h.cruel ():
    {
      bool b = true;
      if (w.hello ())
      {
        return w.hello ();
      }
      else
      {
        b = false;
        return false;
      }
      if (true) b = true;
      if (true) if (true) b = true;
    }
  }
}
