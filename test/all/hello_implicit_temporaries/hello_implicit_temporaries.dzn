// Code:

interface ihello
{
  in bool hello ();
  in bool cruel ();

  behavior
  {
    on hello: reply (false);
    on hello: reply (true);
    on cruel: reply (false);
    on cruel: reply (true);
  }
}

component hello_implicit_temporaries
{
  provides ihello h;
  requires ihello w;

  behavior
  {
    bool foo ()
    {
      if (w.hello ())
        return w.hello ();
      return !w.cruel ();
    }

    on h.hello ():
    if (w.hello ()) reply (w.hello ());
    else if (foo ()) reply (!foo () && true);
    else if (w.hello () && true) reply (w.hello () || true);
    else reply (false);
    on h.cruel ():
    {
      bool b = true;
      if (w.hello ())
      {
        reply (w.hello ());
      }
      else
      {
        reply (false);
        b = false;
      }
      if (true) b = true;
      if (true) if (true) b = true;
    }
  }
}
