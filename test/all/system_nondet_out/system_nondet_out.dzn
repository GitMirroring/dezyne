// Commentary:
//
// Code:

interface ihello
{
  in void hello();
  out void cruel();
  out void world();

  behaviour
  {
    on hello: cruel;
    on hello: world;
  }
}

component helloworld
{
  provides ihello h;
  requires ihello w;

  behaviour
  {
    on h.hello(): w.hello();
    on w.cruel(): h.cruel();
    on w.world(): h.world();
  }
}

component system_nondet_out
{
  provides ihello h;
  requires ihello w;
  system
    {
      helloworld c;
      h <=> c.h;
      w <=> c.w;
    }
}
