// Commentary:
//
// Use defer to mimick the previous async interface modulo the ack priority.
//
// Code:

interface ihello
{
  in void hello ();
  out void world ();

  behavior
  {
    on hello: world;
  }
}

component invariant_sync_out
{
  provides ihello h;
  requires ihello w;
  behavior
  {
    bool b = true;
    invariant b;
    on h.hello (): {w.hello(); b = false;}
    on w.world (): {h.world(); b = true;}
  }
}
