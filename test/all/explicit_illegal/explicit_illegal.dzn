extern int $int$;

interface iexplicit_illegal
{
  in void e(int data);
  behaviour {
    bool done = false;
    on e: done = true;
    [done] on e: illegal;
  }
}

component explicit_illegal
{
  provides iexplicit_illegal p;
  behaviour {
    bool done = false;
    [done] on p.e: illegal;
    [!done] on p.e (data): {}
  }
}
