// Commentary:
//
// This model demonstrates a simulate compliance error in blocking
// context leading to a failed provides port state update.
//
// Code:

interface ihello
{
  in bool hello ();
  out void cruel ();

  out void world ();
  behavior
  {
    bool idle = true;
    on optional: cruel;

    [idle] on hello: {world; reply (idle);}
    [idle] on hello: {reply (idle); idle = false;}
    [!idle] on inevitable: {idle = true; world;}
  }
}

interface icruel
{
  in void cruel ();
  behavior
  {
    on cruel: {}
  }
}

interface iworld
{
  in void hello ();
  out void world ();
  behavior
  {
    bool idle = true;
    [idle] on hello: idle = false;
    [!idle] on inevitable: {world; idle = true;}
  }
}

component collateral_blocking_shared_reply
{
  provides blocking ihello h;
  requires blocking icruel c;
  requires iworld w;
  behavior
  {
    on h.hello (): {w.hello (); c.cruel (); reply (h.idle);}
    on w.world (): h.world ();
  }
}
