// Code:

interface ihello
{
  in bool hello ();

  behavior
  {
    on hello: reply (true);
    on hello: reply (false);
  }
}

extern BOOL $bool$;

component cxx_enum_to_string
{
  provides ihello h;
  requires ihello w;

  behavior
  {
    enum r {f,t};
    on h.hello ():
    {
      r v = bool_to_enum ();
      BOOL b = $true; std::clog << dzn::to_string (v) << std::endl$;
      reply (v.t);
    }
    r bool_to_enum ()
    {
      if (w.hello ()) return r.t;
      return r.f;
    }
  }
}
