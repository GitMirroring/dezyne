// Code:

//purpose: An Alarm implementation for a micro-controller



// High-level user requirements:
//
// Initially the alarm is 'unarmed' which is visualized by a green
// status LED.
//
// User presses keys. Each digit key is appended to a pin-code. The
// '*' key erases the pin-code. The '#' key takes the current pin-code
// as input for an arm/disarm toggle.
//
// In the 'unarmed' state an arm attempt with a wrong pin-code has no
// effect. In the 'unarmed' state an arm attempt with a correct
// pin-code is accepted. The 'armed' state is visualized by a yellow
// status LED.
//
// In the 'armed' state an unarm attempt with a wrong pin-code
// triggers the alarm which is visualized by a blinking red status
// LED. A few seconds after that the siren is switched on and the
// status LED will turn red. In the 'armed' state a disarm attempt
// with a correct pin-code is accepted. In the 'armed' state an
// interrupt raised by one of the sensors signifies a break-in. The
// status LED will immediately turn red. A few seconds after that the
// siren is switched on.

component AlarmConsole
{
  provides IAlarmConsole alarmConsole;
  requires IAlarmSystem alarmSystem;
  requires IAlarmStatusUI statusUI;
  requires ICodeBuilder codestore;

  behaviour
  {
    enum States
    {
      Uninitialized,
      Unarmed,
      Armed,
      Disarming,
      Tripped
    };
    States state = States.Uninitialized;

    [state.Uninitialized]
    {
      on alarmConsole.Initialize():
      {
        statusUI.SignalUnarmed();
        state = States.Unarmed;
      }
      on alarmConsole.KeyPressed(key):
      {}
      on alarmSystem.Tripped,
        alarmSystem.SwitchedOff,
        alarmSystem.SwitchOffFailed:
        illegal;
    }

    [state.Unarmed]
    {
      on alarmConsole.Initialize():
      {}
      on alarmConsole.KeyPressed(key):
      {
        ICodeBuilder.Result val = codestore.AddDigit(key);
        if (val == ICodeBuilder.Result.CodeComplete)
        {
          ICodeBuilder.xint pin;
          codestore.GetCode(pin);
          IAlarmSystem.Result val = alarmSystem.SwitchOn(pin);
          if (val == IAlarmSystem.Result.OK)
          {
            statusUI.SignalArmed();
            state = States.Armed;
          }
        }
      }
      on alarmSystem.Tripped,
        alarmSystem.SwitchedOff,
        alarmSystem.SwitchOffFailed:
        illegal;
    }

    [state.Armed]
    {
      on alarmConsole.Initialize():
      {}
      on alarmConsole.KeyPressed(key):
      {
        ICodeBuilder.Result val = codestore.AddDigit(key);
        if (val == ICodeBuilder.Result.CodeComplete)
        {
          ICodeBuilder.xint pin;
          codestore.GetCode(pin);
          alarmSystem.SwitchOff(pin);
          state = States.Disarming;
        }
      }
      on alarmSystem.Tripped():
      {
        statusUI.SignalTripped();
        state = States.Tripped;
      }
      on alarmSystem.SwitchedOff,
        alarmSystem.SwitchOffFailed:
        illegal;
    }

    [state.Disarming]
    {
      on alarmConsole.Initialize():
      {}
      on alarmConsole.KeyPressed(key):
      {}
      on alarmSystem.Tripped():
      {}
      on alarmSystem.SwitchedOff():
      {
        statusUI.SignalUnarmed();
        state = States.Unarmed;
      }
      on alarmSystem.SwitchOffFailed():
      {
        statusUI.SignalTrippedWrongCode();
        state = States.Tripped;
      }
    }

    [state.Tripped]
    {
      on alarmConsole.Initialize():
      {}
      on alarmConsole.KeyPressed(key):
      {
        ICodeBuilder.Result val = codestore.AddDigit(key);
        if (val == ICodeBuilder.Result.CodeComplete)
        {
          ICodeBuilder.xint pin;
          codestore.GetCode(pin);
          alarmSystem.SwitchOff(pin);
          state = States.Disarming;
        }
      }
      on alarmSystem.Tripped,
        alarmSystem.SwitchedOff,
        alarmSystem.SwitchOffFailed:
        illegal;
    }
  }
}

component AlarmStatusUI
{
  provides IAlarmStatusUI alarmStatusUI;
  requires IRgbLed rgbLed;
  requires ITimer blinkTimer;

  behaviour
  {
    enum States {Shining, Blinking};
    States state = States.Shining;
    bool ledOn = false;

    void startBlinking()
    {
      rgbLed.Off();
      blinkTimer.CreateTimer($0.5$);
      ledOn = false;
      state = States.Blinking;
    }

    void blink()
    {
      blinkTimer.CreateTimer($0.5$);
      if (ledOn)
        rgbLed.Off();
      else
        rgbLed.EmitRed();
      ledOn = !ledOn;
    }

    void stopBlinking()
    {
      blinkTimer.CancelTimer();
      state = States.Shining;
    }

    [state.Shining]
    {
      on alarmStatusUI.SignalTripped():
        rgbLed.EmitRed();
      on alarmStatusUI.SignalArmed():
        rgbLed.EmitYellow();
      on alarmStatusUI.SignalUnarmed():
        rgbLed.EmitGreen();
      on alarmStatusUI.SignalTrippedWrongCode():
        startBlinking();
      on blinkTimer.Timeout():
        illegal;
    }
    [state.Blinking]
    {
      on alarmStatusUI.SignalTripped():
      {
        stopBlinking();
        rgbLed.EmitRed();
      }
      on alarmStatusUI.SignalArmed():
      {
        stopBlinking();
        rgbLed.EmitYellow();
      }
      on alarmStatusUI.SignalUnarmed():
      {
        stopBlinking();
        rgbLed.EmitGreen();
      }
      on alarmStatusUI.SignalTrippedWrongCode():
      {}
      on blinkTimer.Timeout():
        blink();
    }
  }
}

// Represent two sensors as if they were one
component SensorMultiplexer
{
  provides ISensor sensors;
  requires ISensor aSensor;
  requires ISensor bSensor;

  behaviour
  {
    enum States {Deactivated, Activated, Triggered};
    States state = States.Deactivated;
    [state.Deactivated]
    {
      on sensors.Activate():
      {
        aSensor.Activate();
        bSensor.Activate();
        state = States.Activated;
      }
      on sensors.Deactivate(),
        aSensor.DetectedMovement(),
        bSensor.DetectedMovement():
        illegal;
    }
    [state.Activated ||
     state.Triggered]
    {
      on sensors.Deactivate():
      {
        aSensor.Deactivate();
        bSensor.Deactivate();
        state = States.Deactivated;
      }
    }
    [state.Activated]
    {
      on aSensor.DetectedMovement(),
        bSensor.DetectedMovement():
      {
        sensors.DetectedMovement();
        state = States.Triggered;
      }
      on sensors.Activate():
        illegal;
    }
    [state.Triggered]
    {
      on aSensor.DetectedMovement(),
        bSensor.DetectedMovement():
      {}
      on sensors.Activate():
        illegal;
    }
  }
}

interface ISiren
{
  in void TurnOn();
  in void TurnOff();

  behaviour
  {
    enum State { Silent, Sounding };
    State state = State.Silent;
    [state == State.Silent]
    {
      on TurnOn:  state = State.Sounding;
      on TurnOff: illegal;
    }
    [state.Sounding]
    {
      on TurnOn:  illegal;
      on TurnOff: state = State.Silent;
    }
  }
}

// Interface to a Secret Code Evaluator
interface ISecretCode
{
  extern SecretCodeType $int$;
  enum AuthorizationResult {CORRECT, WRONG};
  in AuthorizationResult isCodeCorrect(SecretCodeType secretCode);

  behaviour
  {
    on isCodeCorrect: reply(AuthorizationResult.CORRECT);
    on isCodeCorrect: reply(AuthorizationResult.WRONG);
  }
}


// Interface to a one shot timer
// The Timer can be started via CreateTimer, CreateTimerEx, or via CreateTimerMSec
// The Timer is stopped via CancelTimer
// The Timer reports expiration via Timeout
interface ITimer
{
  extern double $double$;
  extern long $long$;
  in void CreateTimer(double t);
  in void CreateTimerEx(long tsec, long tnsec);
  in void CreateTimerMSec(long tmsec);
  in void CancelTimer();
  out void Timeout();

  behaviour
  {
    enum States {Inactive, Active};
    States state = States.Inactive;

    on CancelTimer: state = States.Inactive;

    [state.Inactive]
    {
      on CreateTimer, CreateTimerEx, CreateTimerMSec:
        state = States.Active;
    }
    [state.Active]
    {
      on inevitable:
      {
        Timeout;
        state = States.Inactive;
      }
      on CreateTimer, CreateTimerEx, CreateTimerMSec:
        illegal;
    }
  }
}

// Interface to a Sensor
// The Sensor can be activated via Activate
// The Sensor can be deactivated via Deactivate
// The Sensor indicates that it detected movement via DetectedMovement
interface ISensor
{
  in void Activate();
  in void Deactivate();
  out void DetectedMovement();

  behaviour
  {
    enum States {Deactivated, Activated, Triggered};
    States state = States.Deactivated;
    [state.Deactivated]
    {
      on Activate:
        state = States.Activated;
      on Deactivate:
        illegal;
    }
    [state.Activated]
    {
      on Deactivate:
        state = States.Deactivated;
      on optional:
      {
        DetectedMovement;
        state = States.Triggered;
      }
      on Activate:
        illegal;
    }
    [state.Triggered]
    {
      on Deactivate:
        state = States.Deactivated;
      on Activate:
        illegal;
    }
  }
}

// Interface to an Alarm System
// The Alarm System can be switched on via SwitchOn
// The Alarm System can be switched off via SwitchOff
// The Alarm System indicates that it is Tripped due to a detected movement via Tripped
// The Alarm System indicates that it is switched off via SwitchedOff
// The Alarm System indicates that switch off failed via SwitchedOffFailed
interface IAlarmSystem
{
  extern SecretCodeType $int$;
  enum Result {OK, Failed};
  in Result SwitchOn(SecretCodeType secretCode);
  in void SwitchOff(SecretCodeType secretCode);
  out void Tripped();
  out void SwitchedOff();
  out void SwitchOffFailed(SecretCodeType secretCode);

  behaviour
  {
    enum States
    {
      NotActivated,
      Activated_Idle,
      Activated_AlarmMode
    };
    States state = States.NotActivated;
    [state.NotActivated]
    {
      on SwitchOn:
      {
        reply(Result.OK);
        state = States.Activated_Idle;
      }
      on SwitchOn:
        reply(Result.Failed);
      on SwitchOff:
        illegal;
    }
    [state.Activated_Idle]
    {
      on SwitchOff:
      {
        SwitchedOff;
        state = States.NotActivated;
      }
      on SwitchOff:
      {
        SwitchOffFailed;
        state = States.Activated_AlarmMode;
      }
      on optional:
      {
        Tripped;
        state = States.Activated_AlarmMode;
      }
      on SwitchOn:
        illegal;
    }
    [state.Activated_AlarmMode]
    {
      on SwitchOff:
      {
        SwitchedOff;
        state = States.NotActivated;
      }
      on SwitchOff:
        SwitchOffFailed;
      on SwitchOn:
        illegal;
    }
  }
}

interface IAlarmStatusUI
{
  in void SignalTripped();
  in void SignalArmed();
  in void SignalUnarmed();
  in void SignalTrippedWrongCode();

  behaviour
  {
    on SignalTripped,
      SignalArmed,
      SignalUnarmed,
      SignalTrippedWrongCode:
    {}
  }
}

interface IRgbLed
{
  in void EmitRed();
  in void EmitYellow();
  in void EmitGreen();
  in void Off();

  behaviour
  {
    on EmitRed,
      EmitYellow,
      EmitGreen,
      Off:
    {}
  }
}

// State-less interface: no assumptions about hand-crafted keypad
interface IAlarmConsole
{
  extern char $char$;
  in void KeyPressed(char key);
  in void Initialize();
  behaviour
  {
    on KeyPressed: {}
    on Initialize: {}
  }
}

interface ICodeBuilder
{
  extern char $char$;
  extern xint $int$;
  enum Result
  {
    CharAdded,
    InvalidChar,
    CodeComplete,
    BufferCleared
  };
  in Result AddDigit(char digit);
  in void GetCode(out xint code);

  behaviour
  {
    enum States {Building, Complete};
    States state = States.Building;
    [state.Building]
    {
      on AddDigit: reply(Result.CharAdded);
      on AddDigit: reply(Result.InvalidChar);
      on AddDigit: {reply(Result.CodeComplete); state = States.Complete;}
      on AddDigit: reply(Result.BufferCleared);
      on GetCode: {}
    }
    [state.Complete]
    {
      on AddDigit: illegal;
      on GetCode: state = States.Building;
    }
  }
}

// Burglar alarm business logic
component BurglarAlarm
{
  provides IAlarmSystem alarmSystem;
  requires ISiren siren;
  requires ISecretCode codeValidator;
  requires ITimer preAlarmTimer;
  requires ISensor sensors;

  behaviour
  {
    enum States
    {
      NotActivated,
      Activated_Idle,
      Activated_AlarmMode,
      Activated_Tripped,
      WrongCode_Retry
    };
    States state = States.NotActivated;

    void disarm()
    {
      sensors.Deactivate();
      preAlarmTimer.CancelTimer();
      alarmSystem.SwitchedOff();
    }

    [state.NotActivated]
    {
      on alarmSystem.SwitchOn(pinCode):
      {
        ISecretCode.AuthorizationResult val = codeValidator.isCodeCorrect(pinCode);
        if (val == ISecretCode.AuthorizationResult.CORRECT)
        {
          sensors.Activate();
          reply(IAlarmSystem.Result.OK);
          state = States.Activated_Idle;
        }
        else if (val == ISecretCode.AuthorizationResult.WRONG)
        {
          reply(IAlarmSystem.Result.Failed);
        }
      }
      on alarmSystem.SwitchOff(pinCode),
        preAlarmTimer.Timeout(),
        sensors.DetectedMovement():
        illegal;
    }

    [state.Activated_Idle]
    {
      on alarmSystem.SwitchOff(pinCode):
      {
        ISecretCode.AuthorizationResult val = codeValidator.isCodeCorrect(pinCode);
        if (val == ISecretCode.AuthorizationResult.CORRECT)
        {
          disarm();
          state = States.NotActivated;
        }
        else if (val == ISecretCode.AuthorizationResult.WRONG)
        {
          preAlarmTimer.CreateTimer($10$);
          alarmSystem.SwitchOffFailed(pinCode);
          state = States.WrongCode_Retry;
        }
      }
      on sensors.DetectedMovement():
      {
        preAlarmTimer.CreateTimer($5$);
        alarmSystem.Tripped();
        state = States.Activated_Tripped;
      }
      on alarmSystem.SwitchOn(pinCode),
        preAlarmTimer.Timeout():
        illegal;
    }

    [state.Activated_AlarmMode]
    {
      on alarmSystem.SwitchOff(pinCode):
      {
        ISecretCode.AuthorizationResult val = codeValidator.isCodeCorrect(pinCode);
        if (val == ISecretCode.AuthorizationResult.CORRECT)
        {
          disarm();
          siren.TurnOff();
          state = States.NotActivated;
        }
        else if (val == ISecretCode.AuthorizationResult.WRONG)
        {
          alarmSystem.SwitchOffFailed(pinCode);
        }
      }
      on sensors.DetectedMovement():
      {}
      on alarmSystem.SwitchOn(pinCode),
        preAlarmTimer.Timeout():
        illegal;
    }

    [state.Activated_Tripped]
    {
      on alarmSystem.SwitchOff(pinCode):
      {
        ISecretCode.AuthorizationResult val = codeValidator.isCodeCorrect(pinCode);
        if (val == ISecretCode.AuthorizationResult.CORRECT)
        {
          disarm();
          state = States.NotActivated;
        }
        else if (val == ISecretCode.AuthorizationResult.WRONG)
        {
          preAlarmTimer.CancelTimer();
          preAlarmTimer.CreateTimer($10$);
          alarmSystem.SwitchOffFailed(pinCode);
          state = States.WrongCode_Retry;
        }
      }
      on preAlarmTimer.Timeout():
      {
        siren.TurnOn();
        state = States.Activated_AlarmMode;
      }
      on alarmSystem.SwitchOn(pinCode),
        sensors.DetectedMovement():
        illegal;
    }

    [state.WrongCode_Retry]
    {
      on alarmSystem.SwitchOff(pinCode):
      {
        ISecretCode.AuthorizationResult val = codeValidator.isCodeCorrect(pinCode);
        if (val == ISecretCode.AuthorizationResult.CORRECT)
        {
          disarm();
          state = States.NotActivated;
        }
        else if (val == ISecretCode.AuthorizationResult.WRONG)
        {
          alarmSystem.SwitchOffFailed(pinCode);
        }
      }
      on preAlarmTimer.Timeout():
      {
        siren.TurnOn();
        state = States.Activated_AlarmMode;
      }
      on sensors.DetectedMovement():
      {}
      on alarmSystem.SwitchOn(pinCode):
        illegal;
    }
  }
}
