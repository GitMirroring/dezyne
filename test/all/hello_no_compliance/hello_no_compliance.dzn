//
// Commentary:
//
// When simulating with the compliance check disabled (i.e., using
// --no-compliance), non-compliant provides port traces should still be
// ignored, and never be zipped, as that could result in `ghost' state
// changes in the provides port without visible provides port
// interaction.  To assert this does not happen, use a simulate
// baseline.
//
// Code:

interface ihello
{
  in void start ();
  in void stop ();

  out void started ();
  out void error ();

  behavior
  {
    enum status { OFF, STARTING, ON, ERROR };
    status state = status.OFF;

    on stop:          state = status.OFF;

    [state.OFF]
      on start:       state = status.STARTING;
    [state.STARTING]
      {
        on inevitable:  { state = status.ON; started; }
        on inevitable:  { state = status.ERROR; error; }
      }
    [state.ON]
        on optional:  { state = status.ERROR; error;}
    [state.ERROR]
        on stop:        state = status.OFF;
  }
}

component hello_no_compliance
{
  provides ihello h;
  requires ihello w;
  requires ihello w1;

  behavior
  {
    enum status { OFF, STARTING, ON, ERROR };
    status state = status.OFF;

    void stop ()          { w.stop (); w1.stop (); }

    on h.stop ():         { state = status.OFF; stop (); }
    on w.error (),
       w1.error ():       { state = status.ERROR; h.error (); stop (); }

    [state.OFF]
        on h.start ():    { state = status.STARTING; w.start (); }
    [state.STARTING]
      {
        on w.started ():    w1.start ();
        on w1.started (): { state = status.ON; h.started (); }
      }
  }
}
