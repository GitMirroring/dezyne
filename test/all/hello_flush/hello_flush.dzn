import i_world.dzn;

interface ihellocruelworld_sunrise
{
  in void hello ();
  out void cruel ();
  out void world ();
  out void sunrise ();

  behavior
  {
    on hello: {cruel; world;}
    on inevitable: sunrise;
  }
}

component hello_flush
{
  provides i_world h;
  requires ihellocruelworld_sunrise w;

  behavior
  {
    on w.sunrise (): w.hello ();
    on w.cruel (): h.world ();
    on w.world (): {}
  }
}
