// Code:

interface ihello
{
  in void hello ();
  out void world ();

  behavior
  {
    bool idle = true;

    [idle]
    {
      on hello: world;
      on hello: idle = false;
    }
    [!idle] on inevitable: {idle = true; world;}
  }
}

interface icruel
{
  in void cruel ();
  behavior
  {
    on cruel: {}
  }
}


component shared_multiple_provides
{
  provides icruel c;
  provides ihello left;
  provides ihello right;
  requires ihello r;

  behavior
  {
    enum Side {LEFT, RIGHT};
    Side side = Side.LEFT;


    on left.hello (): if (right.idle) {side = Side.LEFT; r.hello ();} else left.world ();
    on right.hello (): if (left.idle) {side = Side.RIGHT; r.hello ();} else right.world ();
    on c.cruel (): {}
    [side.LEFT] on r.world (): left.world ();
    [side.RIGHT] on r.world (): right.world ();
  }
}
