// Code:


interface ihello
{
  in void hello ();
  out void world ();
  out void cruel ();

  behaviour
  {
    bool idle = true;
    bool do_world = true;

    on hello: { idle = false; do_world = true; }
    on hello: { idle = false; do_world = false; }
    [!idle] {
      [do_world]  on inevitable: { idle = true; world; }
      [!do_world] on optional: { idle = true; cruel; }
    }
  }
}

interface iworld
{
  in void hello ();
  out void world ();

  behaviour
  {
    bool idle = true;

    on hello: idle = false;
    [!idle] on optional: { idle = true; world; }
  }
}

component nondet_optional
{
  provides ihello h;
  requires iworld w;

  behaviour
  {
    on h.hello (): w.hello ();
    on w.world (): h.cruel ();
  }
}
