interface ihello
{
  in void hello ();
  out void world ();
  out void cruel ();

  behaviour
  {
    bool idle = true;
    bool d0 = false;

    [idle]
    {
      on hello: { idle = false; d0 = false; }
      on hello: { idle = false; d0 = true; }
    }
    [!idle && d0]
    {
      on hello: {}
      on inevitable: { idle = true; world; }
    }
    [!idle && !d0]
    {
      on hello: {}
      on optional: { idle = true; cruel; }
    }
  }
}

interface iworld
{
  in void hello ();
  out void done ();

  behaviour
  {
    bool idle = true;

    [idle]
    {
      on hello: idle = false;
    }
    [!idle]
    {
      on hello: {}
      on optional: { idle = true; done; }
    }
  }
}

component nondet_optional
{
  provides ihello h;
  requires iworld w;

  behaviour
  {
    on h.hello (): w.hello ();
    on w.done (): h.cruel ();
  }
}
