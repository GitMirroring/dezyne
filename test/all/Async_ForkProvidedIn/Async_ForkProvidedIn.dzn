// Code:

// Test if defer enables provides port in event to send out event
// through other provides port. (Not allowed without defer. See
// fork.dzn!fork_provided_in.)
component Async_ForkProvidedIn
{
  provides IA ppa;
  provides IA ppb;

  behaviour
  {
    requires dzn.async reflector_a;
    requires dzn.async reflector_b;

    on ppa.ia(): reflector_b.req();
    on ppb.ia(): reflector_a.req();
    on reflector_a.ack(): ppa.oa();
    on reflector_b.ack(): ppb.oa();

    // Component Async_ForkProvidedIn shall at least perform trace
    // ppa.ia
    // ppa.return
    // ppb.oa
    // ppb.ia
    // ppb.return
    // ppa.oa
  }
}


interface IA
{
  in void ia();
  out void oa();

  behaviour
  {
    on ia: {}
    on optional: oa;
  }
}

