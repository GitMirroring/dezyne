// Test if defer enables requires port out event to send multiple out
// events through a provides port. (Not allowed without defer. See
// fork.dzn!fork_required_out.)
component Async_ForkRequiredOut
{
  provides IA ppa;
  provides IA ppb;
  requires IB rp;

  behaviour
  {
    requires dzn.async() reflector;

    on ppa.ia(): rp.ib();
    on ppb.ia(): rp.ib();
    on rp.ob(): {reflector.req(); ppb.oa();}
    on reflector.ack(): ppa.oa();

    // component Async_ForkRequiredOut shall at least perform trace
    // ppa.ia
    // rp.ib
    // rp.return
    // ppa.return
    // rp.ob
    // ppb.oa
    // ppa.oa

    // component Async_ForkRequiredOut shall at least perform trace
    // ppa.ia
    // rp.ib
    // rp.return
    // ppa.return
    // ppb.ia
    // rp.ib
    // rp.return
    // ppb.return
    // rp.ob
    // ppb.oa
    // ppa.oa
  }
}

interface IA
{
  in void ia();
  out void oa();

  behaviour
  {
    on ia: {}
    on optional: oa;
  }
}

interface IB
{
  in void ib();
  out void ob();

  behaviour
  {
    bool is_active = false;
    on ib: is_active = true;
    [is_active] on inevitable: {ob; is_active = false;}
  }
}
