// Commentary:
//
// Ensure lookup of an unknown scoped enum is not quadratic
//
// Code:

interface ihello
{
  in void hello ();
  out void world ();
  behavior
  {
    on hello: world;
  }
}

component parse_unknown_enum
{
  provides ihello h;
  behavior
  {
    void f ()
    {
      h.world ();
      if (true);
      else if (true) reply (ihello.Unknown.a);
      else if (true) reply (ihello.Unknown.a);
      else if (true) reply (ihello.Unknown.a);
      else if (true) reply (ihello.Unknown.a);
      else if (true) reply (ihello.Unknown.a);
      else if (true) reply (ihello.Unknown.a);
      else if (true) reply (ihello.Unknown.a);
      else if (true) reply (ihello.Unknown.a);
      else if (true) reply (ihello.Unknown.a);
      else if (true) reply (ihello.Unknown.a);
      else if (true) reply (ihello.Unknown.a);
      else if (true) reply (ihello.Unknown.a);
      else if (true) reply (ihello.Unknown.a);
      else if (true) reply (ihello.Unknown.a);
    }
    on h.hello (): f ();
  }
}
