// Commentary:
//
// Code:

enum r {f,t};

interface ihello
{
  in r hello();

  behaviour
  {
    on hello: reply (r.f);
  }
}

component hello_enum
{
  provides ihello h;
  requires iworld w;

  behaviour
  {
    on h.hello():
      {
        r v = w.world();
        reply (v);
      }
  }
}

interface iworld
{
  in r world();

  behaviour
  {
    on world: reply (r.f);
  }
}
