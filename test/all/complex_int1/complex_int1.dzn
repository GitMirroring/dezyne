// Code:

interface ihello
{
  subint int {0..1};
  in int hello ();
  out void dec ();
  out void inc ();

  behavior
  {
    on hello: {inc;dec;reply (0);}
  }
}

component complex_int1
{
  provides ihello h;

  behavior
  {
    subint int {-1..1};

    int dec (int i) {h.dec ();return i-1;}
    int inc (int i) {h.inc ();return i+1;}

    on h.hello ():
    {
      int i = 0;
      bool b = inc (i) == 1 && dec (i) == 1;
      reply (0);
    }
  }
}
