import collateral_blocking_reorder.dzn;

interface iworld2
{
  in void hello ();
  out void world ();

  behavior
  {
    on hello: {}
    on inevitable: world;
  }
}

component proxy
{
  provides blocking iworld2 p;
  requires blocking iworld2 r;

  behavior
  {
    on p.hello (): r.hello ();
    on r.world (): p.world ();
  }
}

component collateral_blocking_reorder_bypass
{
  provides blocking ihello pleft;

  requires iworld rleft;
  requires iworld eleft;

  provides blocking iworld2 pright;
  requires blocking iworld2 rright;

  system
  {
    collateral_blocking_reorder left;
    pleft <=> left.p;
    left.e <=> eleft;
    left.r <=> rleft;

    proxy right;
    pright <=> right.p;
    right.r <=> rright;
  }
}
