import collateral_blocking_reorder.dzn;

component proxy
{
  provides blocking iworld p;
  requires blocking iworld r;

  behavior
  {
    bool idle = true;
    [idle] on p.hello (): {r.hello(); idle = false;}
    on r.world (): {p.world(); idle = true;}
  }
}

component collateral_blocking_reorder_bypass
{
  provides blocking ihello pleft;

  requires blocking iworld rleft;
  requires blocking iworld eleft;

  provides blocking iworld pright;
  requires blocking iworld rright;

  system
  {
    collateral_blocking_reorder left;
    pleft <=> left.p;
    left.e <=> eleft;
    left.r <=> rleft;

    proxy right;
    pright <=> right.p;
    right.r <=> rright;
  }
}
