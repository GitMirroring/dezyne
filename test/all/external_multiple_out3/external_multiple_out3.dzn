interface I
{
  in void e();
  out void a();
  out void b();
  behavior
  {
    bool idle = true;
    [idle] on e: idle = false;
    [!idle] on e: illegal;
    [!idle] on inevitable: {idle = true; a; b;}
  }
}

component external_multiple_out3
{
  provides I p;
  requires external I r;
  behavior
  {
    bool idle = true;
    [idle] on p.e(): {idle = false; r.e();}
    [!idle] on p.e: illegal;
    on r.a(): {}
    on r.b(): {idle = true; p.a(); p.b();}
  }
}
