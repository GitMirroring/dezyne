// Commentary:
//
// Code:

interface ihello
{
  in void hello();
  behavior
  {
    on hello:;
  }
}

component hello
{
  provides ihello p;
  requires ihello r;
}

component wfc_missing_bindings
{
  provides ihello p;
  requires ihello r;
  system
  {
    p <=> h1.p;
    hello h1;
    hello h2;
  }
}