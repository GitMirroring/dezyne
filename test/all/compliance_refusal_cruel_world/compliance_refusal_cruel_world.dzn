import ihello_world.dzn;

interface ihello_cruel_world
{
  in void hello ();
  out void cruel ();
  out void world ();
  behavior
  {
    bool idle = true;
    on hello: idle = false;
    [!idle]
    {
      on inevitable: {idle = true; cruel;}
      on inevitable: {idle = true; world;}
    }
  }
}

component compliance_refusal_cruel_world
{
  provides ihello_cruel_world h;
  requires ihello_world w;
  behavior
  {
    on h.hello (): if (w.idle) w.hello ();
    on w.world (): {}
  }
}
