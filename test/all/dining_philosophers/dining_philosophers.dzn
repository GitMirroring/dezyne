// Commentary:
//
// This is a Dezyne model of E.W. Dijkstra's dining philosophers. The
// starvingphilosophers system will deadlock when the two philosophers
// start eating together and both pickup their left fork before either
// picking up their right fork.
//
// The dining_philosophers system will indefinitely serve the
// philosophers as long as they are both are willing to continue to
// alternate eating and thinking indefinitely, i.e. in C++ (code
// generated with --shell=dining_philosophers):
//
// int
// main ()
// {
//   dzn::locator locator;
//   dzn::runtime runtime;
//   dining_philosophers sut (locator.set (runtime));
//
//   std::thread t0([&]
//   {
//     while(true)
//       {
//         sut.p0.in.eat ();
//         sut.p0.in.think ();
//       }
//   });
//   std::thread t1([&]
//   {
//     while (true)
//      {
//         sut.p1.in.eat();
//         sut.p1.in.think();
//       }
//   });
//   t0.join ();
//   t1.join ();
// }
//
// Code:

import philosopher.dzn;
import fork.dzn;

component Test
{
  provides blocking IMind m;
  requires blocking IMind m0;
  requires blocking IMind m1;

  behavior
  {
    bool idle = true;
    [idle] on m.start (): {idle = false; m0.start (); m1.start ();}
    [!idle] on m.stop (): {idle = true; m0.stop (); m1.stop ();}
  }
}

component dining_philosophers
{
  provides blocking IMind m;

  system
  {
    philosopher P0;
    vork F0;
    philosopher P1;
    vork F1;
    Test T;

    m <=> T.m;
    T.m0 <=> P0.m;
    T.m1 <=> P1.m;

    P0.l <=> F0.l;
    F0.r <=> P1.l;
    P1.r <=> F1.l;
    F1.r <=> P0.r;
  }
}
