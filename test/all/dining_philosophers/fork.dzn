import timer.dzn;

interface IFork
{
  in bool pickup ();
  in void putdown ();

  out void available ();

  behavior
  {
    bool waiting = false;
    bool idle = true;
    [idle]
    {
      on pickup: {waiting = true; reply (false);}
      on pickup: {waiting = false; idle = false; reply (true);}
      [waiting] on inevitable: {waiting = false; available;}
    }
    [!idle]
    {
      on pickup: illegal;
      on putdown: idle = true;
    }
  }
}

component ForkBehavior
{
  provides IFork l;
  provides IFork r;

  requires ITimer t;

  behavior
  {
    bool pending = false;
    enum Who {None, Left, Right};

    Who taken = Who.None;
    Who waiting = Who.None;

    [taken.None]
    {
      on l.pickup (): {taken = Who.Left;  reply (true);}
      on r.pickup (): {taken = Who.Right; reply (true);}
    }
    [taken.Left]
    {
      on l.putdown (): {taken = Who.None; if (waiting.Right && !pending) {pending = true; t.deferred ();}}
      on r.pickup (): {waiting = Who.Right; reply (false);}
    }
    [taken.Right]
    {
      on r.putdown (): {taken = Who.None; if (waiting.Left && !pending) {pending = true; t.deferred ();}}
      on l.pickup (): {waiting = Who.Left;  reply (false);}
    }
    on t.timeout ():
    {
      [waiting.Left] {pending = false; waiting = Who.None; l.available ();}
      [waiting.Right]{pending = false; waiting = Who.None; r.available ();}
    }
  }
}

component vork
{
  provides IFork l;
  provides IFork r;

  system
  {
    ForkBehavior Fork;
    Timer timer;

    l <=> Fork.l;
    r <=> Fork.r;
    Fork.t <=> timer.t;
  }
}
