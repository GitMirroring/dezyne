// Code:

interface ihello
{
  in void hello();

  behaviour
  {
    void g () { f(); }
    void f () {}
    on hello: {}
  }
}

component unused_function
{
  provides ihello h;
  requires iworld w;

  behaviour
  {
    void g() { f(); }
    void f() {w.world();}
    on h.hello(): w.world ();
  }
}

interface iworld
{
  in void world();

  behaviour
  {
    on world: {}
  }
}
