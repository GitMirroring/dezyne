// Commentary:
//
// The queuefull_component0 triggers a queue-full error for the default
// queue-size of 3.
//
// Code:

interface ihello
{
  in void hello ();
  out void world ();
  behaviour
  {
    on hello: {world;world;world;world;}
  }
}

component queuefull_component0
{
  provides ihello h;
  requires ihello w;
  behaviour
  {
    on h.hello (): w.hello ();
    on w.world (): h.world ();
  }
}
