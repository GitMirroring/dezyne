// Code:

interface ihello
{
  in bool hello ();
  out void world ();

  behavior
  {
    on hello: reply (true);
    on optional: world;
  }
}

interface iworld
{
  in void hello ();
  out void world ();

  behavior
  {
    bool idle = true;
    [idle] on hello: idle=false;
    [!idle] on inevitable: {world; idle=true;}
  }
}

component hello_hello_block
{
  provides blocking ihello h;
  requires iworld w;

  behavior
  {
    enum status {A, B, C};

    status s = status.A;
    bool pending = false;

    void h_reply (bool b)
    {
      h.reply (b);
    }

    [s.A] on h.hello (): {h_reply (true);s = status.B;}
    [s.B] on h.hello (): {w.hello (); s = status.C; h.reply (true);}
    [s.C]
    {
      blocking on h.hello (): pending = true;
      [pending] on w.world (): {h.reply (true); s = status.B; pending = false;}
      [!pending] on w.world (): s = status.B;
    }
  }
}
