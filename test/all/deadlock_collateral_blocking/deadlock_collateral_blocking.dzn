// Code:

interface ihello
{
  in void hello ();
  out void world ();
  behavior
  {
    bool idle = true;
    on hello: idle = false;
    [!idle] on optional: {idle = true; world;}
  }
}

interface iworld
{
  in void hello ();
  out void world ();

  behavior
  {
    bool idle = true;
    on hello: idle = false;
    [!idle] on inevitable: {idle = true; world;}
  }
}

component fork
{
  provides blocking ihello p;
  requires blocking ihello r_left;
  requires iworld r_right;

  behavior
  {
    on p.hello (): {r_right.hello (); r_left.hello ();}
    on r_right.world (): p.world ();
    on r_left.world (): {}
  }
}

component block
{
  provides blocking ihello p;
  requires iworld r;

  behavior
  {
    blocking on p.hello (): r.hello ();
    on r.world (): p.reply ();
  }
}

component proxy
{
  provides iworld p;
  requires iworld r;

  behavior
  {
    on p.hello (): r.hello ();
    on r.world (): p.world ();
  }
}

component deadlock_collateral_blocking
{
  provides blocking ihello p;
  requires iworld r_left;
  requires iworld r_right;

  system
  {
    fork top;
    block left;
    proxy right;

    p <=> top.p;
    top.r_left <=> left.p;
    top.r_right <=> right.p;
    left.r <=> r_left;
    right.r <=> r_right;
  }
}
