// Code:

interface ihello
{
  in void hello();
  in void cruel();
  out void world();
  out void bye();
  behavior
  {
    bool idle = true;
    bool busy = false;

    [idle] on hello: {idle = false;}
    [!busy] on cruel: {busy = true;}
    [!idle] on inevitable: {idle=true; world;}
    [busy] on inevitable: {busy=false; bye;}
  }
}

component defer_parallel
{
  provides ihello h;
  behavior
  {
    bool idle = true;
    bool busy = false;
    [idle] on h.hello():
    {
      idle = false;
      defer
      {
        idle = true; h.world();
      }
    }
    [!busy] on h.cruel():
    {
      busy = true;
      defer
      {
        busy = false; h.bye();
      }
    }
  }
}
