// Commentary:
//
// A minimal, valid example for external, i.e., no illegals or
// queue-fulls, with observable other behavior.  When port 'w' is
// external, we see reply values h.true and h.false.  When port 'w' is
// non-external, we never see h.false.
//
// Code:

interface ihello
{
  in void hello ();
  in void cruel ();

  behavior
  {
    on hello: {}
    on cruel: illegal;
  }
}

interface iworld
{
  in void hello ();
  out void world ();
  behavior
  {
    bool idle=true;
    [idle] on hello: idle=false;
    [!idle] on inevitable: {world;idle=true;}
  }
}

component illegal_external
{
  provides ihello h;
  requires external iworld w;

  behavior
  {
    bool idle = true;
    [idle] on h.hello (): {idle=false; w.hello ();}
    [!idle] on h.hello (): {}
    on w.world (): idle=true;
  }
}
