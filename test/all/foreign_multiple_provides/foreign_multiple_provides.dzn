// Code:

import ihello.dzn;

component Foreign
{
  provides ihello h0;
  provides ihello h1;
  // behavior {}
}

component hello
{
  provides ihello h;
  requires ihello w0;
  requires ihello w1;

  behavior
  {
    bool b = true;
    on h.hello (): {b = false; w0.hello (); w1.hello ();}
    on w0.world (): {}
    [!b] on w1.world (): {b = true; h.world ();}
  }
}

component foreign_multiple_provides
{
  provides ihello h;

  system
    {
      h <=> c.h;
      hello c;
      c.w0 <=> f.h0;
      c.w1 <=> f.h1;
      Foreign f;
    }
}
