// Commentary:
//
// This model leads to a defer queue full, since defer does not capture
// shared state, it is not canceled by the bye.  As a result a sequence
// of: hello, bye, hello, hello hits the default queue size limit of 2.
//
// Code:

interface ihello
{
  in void hello ();
  in void bye ();
  out void world ();
  behavior
  {
    bool idle = true;
    [idle] on hello: idle = false;
    on bye: idle = true;
    [!idle] on inevitable: {idle = true; world;}
  }
}

component queuefull_constraint_defer
{
  provides ihello h;
  behavior
  {
    on h.hello (): defer h.world ();
    on h.bye (): {}
  }
}
