// Code:

interface ihello
{
  in void hello ();
  out void always ();
  out void never ();
  behavior
  {
    bool also_true ()
    {
      return true;
    }
    on hello:
      {
        bool b = true;
        if (b && also_true ()) always;
        else never;
      }
  }
}

component unreachable_function
{
  provides ihello h;

  behavior
  {
    bool always = true;

    bool called ()
    {
      return always;
    }

    bool never_called ()
    {
      also_never_called ();
      return true;
    }

    void also_never_called ()
    {
      if (always)
        h.never ();
      else
        h.never ();
    }

    void also_called ()
    {
      if (always)
        h.always ();
      else
        h.never ();
    }

    on h.hello ():
    {
      if ((always || never_called ())
          && (always && called ()))
        also_called ();
      else
        also_never_called ();
    }
  }
}
