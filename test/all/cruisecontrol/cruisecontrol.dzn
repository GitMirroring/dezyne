interface icontrol
{
  in void enable();
  in void disable();

  in void set();
  in void resume();
  in void cancel();

  out void inactive();

  behavior
  {
    enum State {Disabled,Enabled,Active};
    enum Setpoint {Unset,Set};

    State state = State.Disabled;
    Setpoint setpoint = Setpoint.Unset;

    // allow always
    on disable: {state = State.Disabled; setpoint = Setpoint.Unset;}

    [state.Disabled] {
      on enable: state = State.Enabled;
      on cancel, resume, set: {/*ignore when disabled*/}
    }
    [state.Enabled] {
      on enable: {}
      on cancel: {}
      on set: {state = State.Active; setpoint = Setpoint.Set;}
      [setpoint.Set] on resume: state = State.Active;
      [setpoint.Unset] on resume: {/*ignore without a previous setpoint*/}
    }
    [state.Active]
    {
      on optional: {state = State.Enabled; inactive;}
      on cancel: state = State.Enabled;
      on enable, set, resume: {/*ignore when active*/}
    }
  }
}

interface imonitor
{
  in bool enable();
  in void disable();
  out void engage();
  out void disengage();
  behavior
  {
    bool monitor = false;
    bool engaged = false;
    [!monitor] {
      on enable: {monitor = true; reply(engaged);}
      on enable: {monitor = true; engaged = !engaged; reply(engaged);}
    }
    [monitor] {
      on disable: {monitor = false; engaged = false;}
      on inevitable: {
        if(!engaged) engage; else disengage;
        engaged = !engaged;
      }
    }
  }
}

interface ithrottle
{
  in void set();
  in void reset();
  out void unset();

  behavior
  {
    bool active = false;
    on set: active = true;
    on reset: active = false;
    [active] on optional: {active = false; unset;}
  }
}

interface itimer
{
  in void start();
  out void timeout();
  in void cancel();
  behavior
  {
    bool idle = true;
    [idle] on start: idle = false;
    [!idle] on inevitable: timeout;
    on cancel: idle = true;
  }
}

component cruisecontrol
{
  provides icontrol control;
  requires imonitor pedals;
  requires ithrottle throttle;
  requires itimer timer;

  behavior
  {
    [control:state.Disabled] {
      on control.enable():
      {
        bool b = false;
        b = pedals.enable();
      }
      on control.disable(): {}
    }
    [!control:state.Disabled] {
      on control.enable(): {}
      on control.disable(): {
        throttle.reset();
        timer.cancel();
        pedals.disable();
      }
    }
    //a set leads to active throttle control
    [control:state.Enabled && timer:idle] {
      on control.set():
        if(!pedals:engaged) {
          throttle.set();
          timer.start();
        }
      on control.resume():
        if(!pedals:engaged && control:setpoint.Set) {
          throttle.set();
          timer.start();
        }
    }
    [!control:state.Enabled || !timer:idle] {
      on control.set(): {}
      on control.resume(): {}
    }
    on timer.timeout(): throttle.set();
    // when the throttle is active,
    // it must be no longer active and remain that way,
    // after these events
    on control.cancel(): {
      throttle.reset();
      timer.cancel();
    }
    on pedals.engage()
      , throttle.unset(): {
      if(control:state.Active) control.inactive();
      throttle.reset();
      timer.cancel();
    }
    on pedals.disengage(): if(control:state.Active) {
      control.inactive();
      timer.cancel();
    }
  }
}
