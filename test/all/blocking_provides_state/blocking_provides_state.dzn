interface ihello
{
  in void hello ();
  in void bye ();

  behavior
  {
    bool b = true;
    [b] on hello: b = false;
    [!b] on bye: b = true;
  }
}

interface iworld
{
  in void hello ();
  out void world ();
  in void bye ();

  behavior
  {
    enum status {A, B, C};
    status state = status.A;
    [state.A] on hello: state = status.B;
    [state.B] on inevitable: {world; state = status.C;}
    [state.C] on bye: state = status.A;
  }
}

component blocking_provides_state
{
  provides blocking ihello h;
  requires iworld w;

  behavior
  {
    enum status {A, B, C};
    status state = status.A;
    [state.A]
    blocking on h.hello ():
    {
      w.hello ();
      state = status.B;
    }
    [state.B]
    on w.world ():
    {
      h.reply ();
      state = status.C;
    }
    [state.C]
    on h.bye ():
    {
      w.bye ();
      state = status.A;
    }
  }
}
