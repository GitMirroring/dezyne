// Code:

interface itransaction
{
  in void cancel();
  in void request();
  out void complete();
  behavior
  {
    bool active = false;
    [!active] on request: active = true;
    on cancel: active = false;
    [active] on optional: {active = false; complete;}
  }
}

interface iblock
{
  in void block();
  out void notify();
  behavior
  {
    on block: {} // this event blocks
    on block: notify;
  }
}

component blocking_cancel_race
{
  provides blocking itransaction pt;
  requires blocking iblock rb;
  requires itransaction rt;
  behavior
  {
    bool active = false;
    bool race = false;
    [!active] on pt.request(): {active = true; rt.request(); rb.block(); race = true; rt.cancel();}
    on rb.notify():{}
    on pt.cancel(): {active = false; rt.cancel();}
    [active]
    {
      [race] on rt.complete(): race = false;
    }
  }
}
