// Code:

subint int {0..2};

interface ihello
{
  in void hello();

  behaviour
  {
    on hello: {}
  }
}

component hello_bool
{
  provides ihello h;
  requires ihello w;

  behaviour
  {
    bool b = false;
    on h.hello():
      {
        [!b] {b=!b;w.hello ();}
        [b] {b=!b;w.hello ();}
      }
  }
}

component world_int
{
  provides ihello h;
  requires iworld w;
  behaviour
    {
      bool b = false;
      int i = 0;
      on h.hello ():
        {
          [!b] {
            [i == 0] {i=1;w.goodbye ();}
            [i == 1] {i=2;w.cruel ();}
            [i == 2] {b=!b;w.world ();}
          }
          [b] {
            [i == 0] {b=!b;w.doc ();}
            [i == 1] {i=0;w.up ();}
            [i == 2] {i=1;w.whats ();}
          }
        }
    }
}

component step_state
{
  provides ihello ph;
  requires iworld pw;
  system
    {
      hello_bool h;
      world_int wi;
      ph <=> h.h;
      h.w <=> wi.h;
      pw <=> wi.w;
    }
}

interface iworld
{
  in void goodbye();
  in void cruel();
  in void world();

  in void whats();
  in void up();
  in void doc();

  behaviour
  {
    on goodbye: {}
    on cruel: {}
    on world: {}
    on whats: {}
    on up: {}
    on doc: {}
  }
}
