extern int $int$;

interface ihello
{
  in void hello(int i);

  behaviour
  {
    on hello: {}
  }
}

component hello_data
{
  provides ihello h;
  requires iworld w;

  behaviour
  {
    on h.hello(i): {
      int j;
      int k = $0$;
      k = $1$;
      bool b = w.world(i);
    }
  }
}

interface iworld
{
  in bool world(int i);

  behaviour
  {
    on world: reply(true);
  }
}
