import hello_requires2.dzn;
import hello_block_requires.dzn;

component blocking_system
{
  provides blocking ihello h;
  requires blocking ihello_world w0;
  requires blocking i_world w1;

  system
  {
    hello_requires2 top;
    hello_block_requires bottom;

    h <=> top.h;
    top.w0 <=> bottom.h;
    top.w1 <=> w1;
    bottom.w <=> w0;
  }
}
