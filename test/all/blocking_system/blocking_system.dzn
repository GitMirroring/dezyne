// Commentary:
//
// Code:

interface ihello
{
  in void hello ();

  behavior
  {
    on hello: {}
  }
}

interface iworld
{
  out void world ();

  behavior
  {
    on inevitable: world;
  }
}

component A
{
  provides blocking ihello p;
  requires blocking ihello r1;
  requires blocking iworld r2;

  behavior
  {
    on p.hello (): r1.hello ();
    on r2.world (): r1.hello ();
  }
}

interface I3
{
  in void hello ();
  out void world ();

  behavior
  {
    bool pending = false;
    [!pending]
    {
      on hello: pending = true;
    }
    [otherwise]
    {
      on inevitable: {pending = false; world;}
    }
  }
}

component Blocked
{
  provides blocking ihello p;
  requires blocking I3 r;

  behavior
  {
    blocking on p.hello (): {r.hello ();}
    on r.world (): p.return;
  }
}

component blocking_system
{
  provides blocking ihello p;
  requires blocking iworld r2;
  requires blocking I3 r3;

  system
  {
    A a;
    Blocked b;

    p <=> a.p;
    a.r1 <=> b.p;
    a.r2 <=> r2;
    b.r <=> r3;
  }
}
