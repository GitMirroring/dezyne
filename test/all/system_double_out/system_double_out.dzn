// Commentary:
//
// Code:

interface ihello
{
  in void hello ();
  in void bye ();
  out void cruel ();
  out void world ();

  behavior
  {
    on hello: {cruel; world;}
    on bye: {}
  }
}

component hello
{
  provides ihello hh;
  requires ihello ww;

  behavior
  {
    bool idle = true;
    on hh.hello (): {idle = false; ww.hello ();}
    [idle] on hh.bye (): {}
    on ww.cruel (): {hh.cruel (); ww.bye();}
    on ww.world (): {idle = true; hh.world ();}
  }
}

component system_double_out
{
  provides ihello h;
  requires ihello w;

  system
    {
      h <=> top.hh;
      hello top;
      top.ww <=> bottom.hh;
      hello bottom;
      bottom.ww <=> w;
    }
}
