import lego.dzn;

interface ILightSense
{
  in void measure();
  in void cancel();
  out void accept();
  out void reject();
  behaviour {
    bool settling = false;
    on cancel: settling = false;
    [!settling] on measure: settling = !settling;
    [settling] {
      on measure: illegal;
      on inevitable: { accept; settling = !settling; }
      on inevitable: { reject; settling = !settling; }
    }
  }
}

component LightSensor
{
  provides ILightSense ctrl;

  // Foreign component with asynchronous interface to illustrate system
  // abstraction and encapsulation during Expert Workshop  
}

component LightSensor_org
{
  provides ILightSense ctrl;

  system
  {
    timer pollTimer;
    LightSense bhv;
    light hw;

    ctrl <=> bhv.ctrl;
    bhv.timer <=> pollTimer.port;
    bhv.sensor <=> hw.ctrl;
  }
}

component LightSense
{
  provides ILightSense ctrl;
  requires ilight sensor;
  requires itimer timer;
  behaviour {
    bool settling = false;
    [!settling] on ctrl.measure(): {
      timer.create($100$);
      sensor.turnon();
      settling = !settling;
    }
    on ctrl.cancel(): { timer.cancel(); sensor.turnoff(); settling = false; }
    [settling] on timer.timeout(): {
      ilight.status st = sensor.detect();
      sensor.turnoff();
      if (st.accept) ctrl.accept();
      else ctrl.reject();
      settling = !settling;
    }
  } 
}

