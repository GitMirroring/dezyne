import TouchSensor.dzn;
import Motor.dzn;
import lego.dzn;

interface IConvey
{
  in void convey();
  out void conveyed();
  in void stop();

  behaviour
  {
    enum State {Idle, Conveying};
    State s = State.Idle;

    on stop: s = State.Idle;

    [s.Idle] on convey: s = State.Conveying;
    //[s.Idle] on convey: conveyed;
    [s.Conveying]
    {
      on convey: illegal;
      on inevitable: {conveyed; s = State.Idle;}
    }
  }
}

component Conveyor
{
  provides IConvey ctrl;
  // Foreign implementation for workshop
}

component Conveyor_org
{
  provides IConvey ctrl;
  system
  {
    Convey bhv;
    Motor motor;
    TouchSensor sensor;

    ctrl <=> bhv.ctrl;
    bhv.motor <=> motor.ctrl;
    bhv.sensor <=> sensor.ctrl;
  }
}

component Convey
{
  provides IConvey ctrl;
  requires IMove motor;
  requires ITouchSense sensor;

  behaviour
  {
    enum State { Idle, Conveying };
    State s = State.Idle;
    on ctrl.stop():
      {
        motor.stop();
        sensor.disable();
        s = State.Idle;
      }

    on motor.arrived(): {}


    [ s.Idle ]
    {
      on ctrl.convey():
        {
          ITouchSense.TouchState ss = sensor.enable();
          if(ss == ITouchSense.TouchState.Pressed) {
            sensor.disable();
            ctrl.conveyed();
          } else {
            motor.run($(config.get("Power::50"))$, $false$); // (power, invert)
            s = State.Conveying;
          }
        }
    }

    [ s.Conveying ]
    {
      on sensor.pressed(), sensor.released():
        {
          sensor.disable();
          motor.stop();
          ctrl.conveyed();
          s = State.Idle;
        }
    }
  }
}
