import MaterialHandler.dzn;
import Inspector.dzn;
import Conveyor.dzn;
import FeedPort.dzn;
import Feeder.dzn;
import lego.dzn;

component BallSortNetwork
{
  provides IHandle ctrl;

  system
  {
    //Sort handler;
    //Robot robot;
    FeedPort input;
    MaterialHandler handler;
    Inspector inspector;
    Conveyor accept;
    Conveyor reject;
    Feeder track;

    ctrl <=> handler.ctrl;
    //handler.robot <=> robot.ctrl;
    handler.feedPort <=> input.ctrl;
    handler.inspector <=> inspector.ctrl;
    handler.acceptPort <=> accept.ctrl;
    handler.rejectPort <=> reject.ctrl;

    input.feeder <=> track.ctrl;
  }
}
