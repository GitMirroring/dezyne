component HomeConstrainedMove
{
  provides IConstrainedMove ctrl;
  requires IMove motor; // required by motor
  requires ITouchSense homeSensor; // required by sensor

  behaviour
  {
    enum State {lost, idle, moving, calibratingHome};
    State s = State.lost;

    void slowBackward() {motor.run($(config.get("Power::CalibrationSpeed"))$, $true$);}
    void recordHome() {
      homeSensor.disable();
      motor.stop(); // brake
      motor.zero();
    }
    void startAbsoluteMove(IConstrainedMove.position_t target) {
      ITouchSense.TouchState ignore = ITouchSense.TouchState.Released;
      ignore = homeSensor.enable();
      motor.move($(config.get("Power::OperationalSpeed"))$, target);
      s = State.moving;
    }
    void notifyArrived() {
      motor.stop();
      homeSensor.disable();
      s = State.idle;
      ctrl.arrived();
    }

    on ctrl.stop(): {motor.stop(); homeSensor.disable(); s = State.lost;}

    [s.lost]
    {
      on ctrl.calibrate():
        {
          ITouchSense.TouchState hss = homeSensor.enable();
          if (hss == ITouchSense.TouchState.Pressed)
          {
            recordHome();
            s = State.idle;
            ctrl.homed();
          }
          else
          {
            slowBackward();
            s = State.calibratingHome;
          }
        }
    }

    [s.calibratingHome]
    {
      on homeSensor.pressed():
        {
          recordHome();
          s = State.idle;
          ctrl.homed();
        }
    }

    [s.idle]
    {
      //on ctrl.move(pos): startAbsoluteMove(pos);
      on ctrl.move(target):
        {
          ITouchSense.TouchState ignore = ITouchSense.TouchState.Released;
          ignore = homeSensor.enable();
          motor.move($(config.get("Power::OperationalSpeed"))$, target);
          s = State.moving;
        }
    }

    [s.moving]
    {
      on homeSensor.pressed(): {motor.stop(); recordHome(); notifyArrived();} // out of range => recalibrate?
      on homeSensor.released(): {}
      on motor.arrived(): notifyArrived();
    }
  }
}

$#include "MachineConstants.hh"$

interface IConstrainedMove
{
  extern position_t $Integer$;

  in void calibrate();
  out void homed();
  in void stop();

  in void move(position_t target);
  out void arrived();


  behaviour
  {
    enum State {lost, idle, calibrating, moving};
    State s = State.lost;

    void notifyHomed() { s = State.idle; homed; }
    void notifyArrived() { s = State.idle; arrived; }

    on calibrate: [s.lost] s = State.calibrating;
    // on calibrate: [s.lost] notifyHomed();
    on calibrate: [!s.lost] illegal;

    on move: [s.idle] s = State.moving;
    on move: [!s.idle] illegal;
    on stop: s = State.lost;

    [s.moving] on inevitable: { s = State.idle; arrived; } // notifyArrived;
    [s.calibrating] on inevitable: { s = State.idle; homed; } // notifyHomed;
  }
}
interface IFeed
{
  in void calibrate();
  out void calibrated();
  in void stop();

  in void produceBall();
  out void consumeNextBall();
  out void consumeLastBall();

  behaviour
  {
    enum State {Lost, Calibrating, Idle, Preparing, Prepared};
    State s = State.Lost;

    on stop: s = State.Lost;

    [s.Lost]
    {
      on calibrate: {s = State.Calibrating;}
      on calibrate: {calibrated; s = State.Idle;}
      on produceBall: illegal;
    }
    [s.Calibrating]
    {
      on inevitable: {calibrated; s = State.Idle;}
      on calibrate, produceBall: illegal;
    }
    [s.Idle]
    {
      on produceBall: {s = State.Preparing;}
      on produceBall: {consumeNextBall; s = State.Prepared;}
      on produceBall: {consumeLastBall; s = State.Idle;}
      on calibrate: illegal;
    }
    [s.Preparing]
    {
      on inevitable: {consumeNextBall; s = State.Prepared;}
      on inevitable: {consumeLastBall; s = State.Idle;}
      on calibrate, produceBall: illegal;
    }
    [s.Prepared]
    {
      on produceBall: {s = State.Preparing;}
      on produceBall: {consumeNextBall; s = State.Prepared;}
      on produceBall: {consumeLastBall; s = State.Idle;}
      on calibrate: illegal;
    }
  }
}


interface IInspect
{
  in void calibrate();
  out void calibrated();
  in void stop();

  in void inspect(); // inspect ball dropped onto stage
  out void accepted(); // at output take-over waiting to be relieved of accepted ball
  out void rejected(); // at output take-over waiting to be relieved of rejected ball
  in void prepare(); // move to input take-over and prepare to receive next ball
  out void prepared(); // at input take-over ready to receive next ball

  behaviour
  {
    enum State {Lost, Ready, Calibrating, Inspecting, Waiting, Preparing};
    State s = State.Lost;

    on stop: s = State.Lost;

    [s.Lost]
    {
      on calibrate: s = State.Calibrating;
      on calibrate: {calibrated; s = State.Ready;}
      on inspect, prepare: illegal;
    }
    [s.Calibrating]
    {
      on calibrate, inspect, prepare: illegal;
      on inevitable: {calibrated; s = State.Ready;}
    }
    [s.Ready]
    {
      on calibrate, prepare: illegal;
      on inspect: s = State.Inspecting;
    }
    [s.Inspecting]
    {
      on calibrate, prepare, inspect: illegal;
      on inevitable: {accepted; s = State.Waiting;}
      on inevitable: {rejected; s = State.Waiting;}
    }
    [s.Waiting]
    {
      on prepare: s = State.Preparing;
      on prepare: {prepared; s = State.Ready;}
      on calibrate, inspect: illegal;
    }
    [s.Preparing]
    {
      on calibrate, prepare, inspect: illegal;
      on inevitable: {prepared; s = State.Ready;}
    }
  }
}

component Inspector
{
  provides IInspect ctrl;

  system
  {
    Inspect bhv;
    Stage stage;
    LightSensor sensor;

    ctrl <=> bhv.ctrl;
    bhv.sensor <=> sensor.ctrl;
    bhv.stage <=> stage.ctrl;
  }
}

component Inspect
{
  provides IInspect ctrl;
  requires IMove2D stage;
  requires ILightSense sensor;

  behaviour
  {
    enum State {Lost, Ready, Calibrating, Inspecting, Waiting, Preparing};
    enum InspectPosition {Unknown, Receive, Inspect, Accept, Reject};

    State s = State.Lost;
    InspectPosition p = InspectPosition.Unknown;
    IMove2D.MovePosition receiveX = $(config.get("Position::Inspector::ReceiveX"))$;
    IMove2D.MovePosition receiveY = $(config.get("Position::Inspector::ReceiveY"))$;
    IMove2D.MovePosition inspectX = $(config.get("Position::Inspector::InspectX"))$;
    IMove2D.MovePosition inspectY = $(config.get("Position::Inspector::InspectY"))$;
    IMove2D.MovePosition acceptX = $(config.get("Position::Inspector::AcceptX"))$;
    IMove2D.MovePosition acceptY = $(config.get("Position::Inspector::AcceptY"))$;
    IMove2D.MovePosition rejectX = $(config.get("Position::Inspector::RejectX"))$;
    IMove2D.MovePosition rejectY = $(config.get("Position::Inspector::RejectY"))$;

    void stop()
    {
      sensor.cancel();
      stage.stop();
      p = InspectPosition.Unknown;
      s = State.Lost;
    }

    [s.Lost]
    {
      on ctrl.stop(): stop();

      on ctrl.calibrate():
        {
          s = State.Calibrating;
          p = InspectPosition.Unknown;
          stage.calibrate();
        }
    }
    [s.Calibrating]
    {
      on ctrl.stop(): stop();
      on stage.calibrated(): [p.Unknown] {stage.move(receiveX, receiveY); p = InspectPosition.Receive;}
      on stage.arrived(): [p.Receive] {ctrl.calibrated(); s = State.Ready;}
    }
    [s.Ready]
    {
      on ctrl.stop(): stop();
      on ctrl.inspect(): {s = State.Inspecting; stage.move(inspectX, inspectY);}
    }
    [s.Inspecting]
    {
      on ctrl.stop(): stop();
      on stage.arrived(): [p.Receive]
      {
        p = InspectPosition.Inspect;
        sensor.measure();
      }
      on stage.arrived(): [p.Accept] {ctrl.accepted(); s = State.Waiting;}
      on stage.arrived(): [p.Reject] {ctrl.rejected(); s = State.Waiting;}

      on sensor.accept(): { stage.move(acceptX, acceptY); p = InspectPosition.Accept; }
      on sensor.reject(): { stage.move(rejectX, rejectY); p = InspectPosition.Reject; }
    }
    [s.Waiting]
    {
      on ctrl.stop(): stop();
      on ctrl.prepare():
        {
          s = State.Preparing;
          p = InspectPosition.Receive;
          stage.move(receiveX, receiveY);
        }
    }
    [s.Preparing]
    {
      on ctrl.stop(): stop();
      on stage.arrived(): {ctrl.prepared(); s = State.Ready;}
    }
  }
}

$#include "MachineConstants.hh"$

interface imotor
{
  extern boolean    $Boolean$;
  extern position_t $Integer$;
  extern power_t    $Byte$; // [0,100]

  in void move(power_t power, position_t position);  //regulated, absolute position
  in void run(power_t power, boolean invert);        //unregulated
  in void stop();
  in void coast();
  in void zero();
  in void position(out position_t pos);
  enum resultT {yes, no};
  in resultT at(position_t pos);

  behaviour
  {
    on move: {}
    on run: {}
    on stop: {}
    on coast: {}
    on zero: {}
    on position: {}
    on at: reply(resultT.yes);
    on at: reply(resultT.no);
  }
}

component motor
{
	provides imotor ctrl;
}

interface itouch
{
  enum status {pressed, released};
  in status detect();
  behaviour
  {
    on detect: reply(status.pressed);
    on detect: reply(status.released);
  }
}

component touch
{
	provides itouch ctrl;
}

interface ilight
{
  in void turnon();
  in void turnoff();

  enum status {accept, reject};
  in status detect();

  behaviour
  {
    on turnon: {}
    on turnoff: {}
    on detect: reply(status.accept);
    on detect: reply(status.reject);
  }
}

component light
{
	provides ilight ctrl;
}

interface itimer
{
  extern milliseconds_t $Integer$;
  in void create(milliseconds_t ms);
  in void cancel();
  out void timeout();

  behaviour
  {
    enum State {Idle, Pending};
    State state = State.Idle;
    [state.Idle] {
      on create: { state = State.Pending; }
      on cancel: {}
    }
    [state.Pending] {
      on create: illegal;
      on cancel: { state = State.Idle; }
      on inevitable: { timeout; state = State.Idle; }
    }
  }
}

component timer
{
  provides itimer port;
  // use dzn code -m timer lego.dzn to generate stub
  // behaviour {on port.create(ms): {} on port.cancel(): {}}
}


interface ILightSense
{
  in void measure();
  in void cancel();
  out void accept();
  out void reject();
  behaviour {
    bool settling = false;
    on cancel: settling = false;
    [!settling] on measure: settling = !settling;
    [settling] {
      on measure: illegal;
      on inevitable: { accept; settling = !settling; }
      on inevitable: { reject; settling = !settling; }
    }
  }
}

component LightSensor
{
  provides ILightSense ctrl;

  // Foreign component with asynchronous interface to illustrate system
  // abstraction and encapsulation during Expert Workshop
}

component LightSensor_org
{
  provides ILightSense ctrl;

  system
  {
    timer pollTimer;
    LightSense bhv;
    light hw;

    ctrl <=> bhv.ctrl;
    bhv.timer <=> pollTimer.port;
    bhv.sensor <=> hw.ctrl;
  }
}

component LightSense
{
  provides ILightSense ctrl;
  requires ilight sensor;
  requires itimer timer;
  behaviour {
    bool settling = false;
    [!settling] on ctrl.measure(): {
      timer.create($100$);
      sensor.turnon();
      settling = !settling;
    }
    on ctrl.cancel(): { timer.cancel(); sensor.turnoff(); settling = false; }
    [settling] on timer.timeout(): {
      ilight.status st = sensor.detect();
      sensor.turnoff();
      if (st.accept) ctrl.accept();
      else ctrl.reject();
      settling = !settling;
    }
  }
}




interface IHandle
{
  in void calibrate();
  out void calibrated();
  in void stop();

  in void operate(); // start next batch
  out void finished(); // batch finished

  behaviour
  {
    enum State {Lost, Calibrating, Idle, Operating};
    State s = State.Lost;

    on stop: {s = State.Lost;}

    [s.Lost]
    {
      on calibrate: {s = State.Calibrating;}
      //on calibrate: {calibrated; s = State.Idle;}
      on operate: illegal;
      on operate: {}
    }
    [s.Calibrating]
    {
      on calibrate: illegal;
      on calibrate: {}
      on operate: illegal;
      on operate: {}
      on inevitable: {calibrated; s = State.Idle;}
    }
    [s.Idle]
    {
      on calibrate: illegal;
      on calibrate: {}
      on operate: s = State.Operating;
      on operate: finished;
    }
    [s.Operating]
    {
      on calibrate: illegal;
      on calibrate: {}
      on operate: illegal;
      on operate: {}
      on inevitable: {s = State.Idle; finished;}
    }
  }
}

component MaterialHandler
{
  provides IHandle ctrl;
  //requires ITransfer robot;
  requires IFeed feedPort;
  requires IInspect inspector;
  requires IConvey acceptPort;
  requires IConvey rejectPort;

  system
  {
    Sort bhv;
    Robot robot;

    ctrl <=> bhv.ctrl;
    bhv.robot <=> robot.ctrl;
    bhv.inspector <=> inspector;
    bhv.feedPort <=> feedPort;
    bhv.acceptPort <=> acceptPort;
    bhv.rejectPort <=> rejectPort;
  }
}

component Sort
{
  provides IHandle ctrl;
  requires IFeed feedPort;
  requires IInspect inspector;
  requires ITransfer robot;
  requires IConvey acceptPort;
  requires IConvey rejectPort;


  behaviour
  {
    enum State {Lost, Calibrating, Idle, Operating};
    subint usedCount {0..4};
    enum Operation {PreparingInput, TransferringInput, PreparingOutput, TransferringOutput, Finalizing};

    State s = State.Lost;
    usedCount calibrated = 0;
    usedCount requiredCalibrations = 3; // nr of subsystems requiring calibration (robot, inspector, feedPort)
    Operation o = Operation.PreparingInput;

    bool isLastBall = false;
    bool isBallAtInput = false; // FeedPort ready for input transfer
    bool isRobotAtInput = false;
    bool isRobotAtOutput = false;
    bool isInspectorAtInput = false;
    bool isInspectorAtOutput = false;
    bool isBallAccepted = false;
    bool isAcceptEmpty = true;
    bool isRejectEmpty = true;

    void tryCalibrated() {
      calibrated = calibrated + 1;
      if (calibrated == requiredCalibrations)
      {
        s = State.Idle;
        isInspectorAtInput = true;
        isInspectorAtOutput = false;
        ctrl.calibrated();
      }
    }
    void ignoreIllegal() {
      // NoOp instead of illegal =>
      // no assert on illegal control commands received from UI.
      // This functionality could be moved to a separate armour component
    }
    void startBatch() {
      s = State.Operating;
      isLastBall = false;
      prepareInputTransfer();
    }
    void finalizeBatch() {
      s = State.Idle;
      ctrl.finished();
    }
    void prepareInputTransfer() {
      o = Operation.PreparingInput;
      if (!isBallAtInput) {feedPort.produceBall(); isBallAtInput = false;}
      if (!isInspectorAtInput) {inspector.prepare(); isInspectorAtInput = false;}
      if (!isRobotAtInput) {sendRobotToInputPick(); isRobotAtInput = false;}

      tryInputTransfer();
    }
    void sendRobotToInputPick() {
      robot.move($(config.get("Position::Robot::X::InputPick"))$, $(config.get("Position::Robot::Y::InputPick"))$);
      isRobotAtOutput = false;
      isRobotAtInput = false;
    }
    void tryInputTransfer() {
      if (isBallAtInput && isRobotAtInput && isInspectorAtInput) {
        robot.transfer($(config.get("Position::Robot::X::InputDrop"))$, $(config.get("Position::Robot::Y::InputDrop"))$);
        o = Operation.TransferringInput;
      }
    }
    void tryOutputTransfer() {
      if (isRobotAtOutput && isInspectorAtOutput) {
        if (isAcceptEmpty && isBallAccepted) {
          robot.transfer($(config.get("Position::Robot::X::OutputDrop"))$, $(config.get("Position::Robot::Y::AcceptDrop"))$);
          o = Operation.TransferringOutput;
        }
        if (isRejectEmpty && !isBallAccepted) {
          robot.transfer($(config.get("Position::Robot::X::OutputDrop"))$, $(config.get("Position::Robot::Y::RejectDrop"))$);
          o = Operation.TransferringOutput;
        }
      }
    }
    void tryFinished() {
      if (isLastBall && !isBallAtInput && isAcceptEmpty && isRejectEmpty && isRobotAtInput && isInspectorAtInput) {
        s = State.Idle;
        ctrl.finished();
      }
    }
    void manuallyRemoveStrayMaterial() {
      isBallAtInput = false;
      isAcceptEmpty = true;
      isRejectEmpty = true;
    }

    on ctrl.stop():
      {
        robot.stop();
        inspector.stop();
        feedPort.stop();
        acceptPort.stop();
        rejectPort.stop();
        s = State.Lost;

        manuallyRemoveStrayMaterial();
      }

    on ctrl.calibrate(): [s.Lost]
    {
      robot.calibrate();
      inspector.calibrate();
      feedPort.calibrate();

      calibrated = 0;
      s = State.Calibrating;
    }
    on ctrl.calibrate(): [!s.Lost] ignoreIllegal();

    [s.Calibrating]
    {
      on robot.calibrated(),
        inspector.calibrated(),
        feedPort.calibrated(): tryCalibrated();
    }

    on ctrl.operate(): [s.Idle] startBatch();
    on ctrl.operate(): [!s.Idle] ignoreIllegal();

    [s.Operating] // batch processing
    {
      [o.PreparingInput] // synchronization of feedPort, inspector and robot
      {
        on feedPort.consumeNextBall(): {isLastBall = false; isBallAtInput = true; tryInputTransfer();}
        on feedPort.consumeLastBall(): {isLastBall = true; isBallAtInput = true; tryInputTransfer();}
        on inspector.prepared(): {isInspectorAtInput = true; tryInputTransfer();}
        on robot.arrived(): {isRobotAtInput = true; tryInputTransfer();}
        on robot.picked(), robot.placed(): illegal;
        on acceptPort.conveyed(): isAcceptEmpty = true;
        on rejectPort.conveyed(): isRejectEmpty = true;
      }
      [o.TransferringInput]
      {
        on feedPort.consumeNextBall(): {isLastBall = false; isBallAtInput = true;}
        on feedPort.consumeLastBall(): {isLastBall = true; isBallAtInput = true;}
        on inspector.prepared(), inspector.accepted(), inspector.rejected(): illegal;
        on robot.picked(): [!isLastBall] {feedPort.produceBall(); isBallAtInput = false;}
        on robot.picked(): [isLastBall] {isBallAtInput = false;}
        on robot.placed(): {isInspectorAtInput = false; inspector.inspect(); isRobotAtInput = false; robot.move($(config.get("Position::Robot::X::OutputPick"))$, $(config.get("Position::Robot::Y::OutputPick"))$); o = Operation.PreparingOutput;}
        on acceptPort.conveyed(): isAcceptEmpty = true;
        on rejectPort.conveyed(): isRejectEmpty = true;
      }
      [o.PreparingOutput] // synchronization of robot, inspector and (acceptPort or rejectPort)
      {
        on feedPort.consumeNextBall(): {isLastBall = false; isBallAtInput = true;}
        on feedPort.consumeLastBall(): {isLastBall = true; isBallAtInput = true;}
        on inspector.accepted(): {isBallAccepted = true; isInspectorAtOutput = true; tryOutputTransfer();}
        on inspector.rejected(): {isBallAccepted = false; isInspectorAtOutput = true; tryOutputTransfer();}
        on robot.arrived(): {isRobotAtOutput = true; tryOutputTransfer();}
        on acceptPort.conveyed(): {isAcceptEmpty = true; tryOutputTransfer();}
        on rejectPort.conveyed(): {isRejectEmpty = true; tryOutputTransfer();}
      }
      [o.TransferringOutput]
      {
        on feedPort.consumeNextBall(): {isLastBall = false; isBallAtInput = true;}
        on feedPort.consumeLastBall(): {isLastBall = true; isBallAtInput = true;}
        on inspector.prepared(): isInspectorAtInput = true;
        on robot.picked(): {isInspectorAtOutput = false; inspector.prepare();}
        on robot.placed(): [isBallAccepted] {isAcceptEmpty = false; acceptPort.convey(); sendRobotToInputPick(); if (isLastBall && !isBallAtInput) o = Operation.Finalizing; else o = Operation.PreparingInput;}
        on robot.placed(): [!isBallAccepted] {isRejectEmpty = false; rejectPort.convey(); sendRobotToInputPick(); if (isLastBall && !isBallAtInput) o = Operation.Finalizing; else o = Operation.PreparingInput;}
        on acceptPort.conveyed(): isAcceptEmpty = true;
        on rejectPort.conveyed(): isRejectEmpty = true;
      }
      [o.Finalizing]
      {
        on inspector.prepared(): {isInspectorAtInput = true; tryFinished();}
        on robot.arrived(): {isRobotAtInput = true; tryFinished();}
        on acceptPort.conveyed(): {isAcceptEmpty = true; tryFinished();}
        on rejectPort.conveyed(): {isRejectEmpty = true; tryFinished();}
      }
    }
  }
}

interface ITransfer
{
  extern TrPosition $Integer$;

  in void calibrate();
  out void calibrated();
  in void stop();

  in void move(TrPosition x, TrPosition y);
  out void arrived();
  in void transfer(TrPosition x, TrPosition y);
  out void picked();
  out void placed();

  behaviour
  {
    enum State {Lost, Calibrating, Ready, Moving, Transferring};
    State s = State.Lost;
    bool isPicked = false;

    on stop: s = State.Lost;

    [s.Lost]
    {
      on calibrate: s = State.Calibrating;
      on calibrate: {calibrated; s = State.Ready;}
      on move, transfer: illegal;
    }
    [s.Calibrating]
    {
      on inevitable: {calibrated; s = State.Ready;}

      on calibrate, move, transfer: illegal;
    }
    [s.Ready]
    {
      on move: s = State.Moving;
      on move: arrived;

      on transfer: {s = State.Transferring; isPicked = false;}
      on transfer: {s = State.Transferring; picked; isPicked = true;}
      on transfer: {s = State.Ready; picked; placed;}

      on calibrate: illegal;
    }
    [s.Moving]
    {
      on inevitable: {arrived; s = State.Ready;}

      on calibrate, move, transfer: illegal;
    }
    [s.Transferring]
    {
      on inevitable: [!isPicked] {picked; isPicked = true;}
      on inevitable: [isPicked] {placed; s = State.Ready;}

      on calibrate, move, transfer: illegal;
    }
  }
}

component Robot
{
  provides ITransfer ctrl;


  system
  {
    Transfer bhv;
    Hoist hoist;
    Gripper gripper;
    EndConstrainedAxis trolley;
    HomeConstrainedAxis truck;

    ctrl <=> bhv.ctrl;
    bhv.hoist <=> hoist.ctrl;
    bhv.gripper <=> gripper.ctrl;
    bhv.trolley <=> trolley.ctrl;
    bhv.truck <=> truck.ctrl;
  }
}

component Transfer
{
  provides ITransfer ctrl;
  requires IRetain hoist;
  requires IRetain gripper;
  requires IConstrainedMove trolley;
  requires IConstrainedMove truck;

  behaviour
  {
    enum State {Idle, Calibrating, Moving, Transferring};
    subint Count {0..5};
    enum TransferState {Picking, Raising, Moving, Placing, Idle};
    State s = State.Idle;
    TransferState ts = TransferState.Idle;
    Count nCalibrated = 0;
    Count nMoving = 0;
    bool isCalibrated = false;
    bool isXYMoveAllowed = false; // Hoist must be up to move without gripper collisions.
    bool isRetaining = true;

    ITransfer.TrPosition placeX = $0$;
    ITransfer.TrPosition placeY = $0$;

    void tryCalibrated() {
      nCalibrated = nCalibrated + 1;
      if (nCalibrated == 2) {isXYMoveAllowed = true; calibrateXY();}
      if (nCalibrated == 5) {isCalibrated = true; s = State.Idle; isRetaining = false; ctrl.calibrated();}
    }
    void calibrateZ() {
      s = State.Calibrating;
      isXYMoveAllowed = false;
      nCalibrated = 0;
      hoist.calibrate();
      gripper.calibrate();
    }
    void calibrateXY() {
      if (isXYMoveAllowed) {
        s = State.Calibrating;
        gripper.release();
        trolley.calibrate();
        truck.calibrate();
      }
    }
    void startPick(ITransfer.TrPosition tgtX, ITransfer.TrPosition tgtY) {
      placeX = tgtX;
      placeY = tgtY;
      isXYMoveAllowed = false;
      s = State.Transferring;
      ts = TransferState.Picking;
      hoist.release();
    }

    on ctrl.stop():
      {
        hoist.stop();
        gripper.stop();
        trolley.stop();
        truck.stop();
        s = State.Idle;
        isCalibrated = false;
        isRetaining = true;
        isXYMoveAllowed = false;
      }

    [s.Idle]
    {
      [!isCalibrated]
      {
        on ctrl.calibrate(): {isCalibrated = false; isRetaining = true; calibrateZ();}
      }
      [isCalibrated]
      {
        on ctrl.move(x, y): [isXYMoveAllowed] {truck.move(x); trolley.move(y); nMoving = 2; s = State.Moving;}
        on ctrl.transfer(x, y): startPick(x, y);
      }
    }

    [s.Calibrating]
    {
      on hoist.calibrated(), gripper.calibrated(), trolley.homed(), truck.homed(): tryCalibrated();
      on gripper.ready(): tryCalibrated();
    }

    [s.Moving]
    {
      on truck.arrived(), trolley.arrived(): {nMoving = nMoving - 1; if (nMoving == 0) {s = State.Idle; ctrl.arrived();}}
    }

    [s.Transferring]
    {
      [ts.Picking]
      {
        on hoist.ready(): gripper.retain();
        on gripper.ready(): {hoist.retain(); isRetaining = true; ts = TransferState.Raising;}
      }
      [ts.Raising][isRetaining]
      {
        on hoist.ready():
        {
          isXYMoveAllowed = true;
          ctrl.picked();
          truck.move(placeX);
          trolley.move(placeY);
          nMoving = 2;
          ts = TransferState.Moving;
        }

        on gripper.ready(), trolley.arrived(), truck.arrived(): illegal;
      }
      [ts.Moving]
      {
        on truck.arrived(), trolley.arrived():
        {
          nMoving = nMoving - 1;
          if (nMoving == 0) {
            isXYMoveAllowed = false;
            hoist.release();
            ts = TransferState.Placing;
          }
        }
      }
      [ts.Placing]
      {
        on hoist.ready(): gripper.release();
        on gripper.ready():
        {
          isRetaining = false;
          hoist.retain();
          ts = TransferState.Raising;
        }
      }
      [ts.Raising][!isRetaining]
      {
        on hoist.ready(): [!isRetaining]
        {
          isXYMoveAllowed = true;
          s = State.Idle;
          ts = TransferState.Idle;
          ctrl.placed();
        }
      }
    }
  }
}

interface IRetain
{
  in void stop();
  in void calibrate();
  out void calibrated();

  in void retain(); // raise, close
  in void release(); // lower, open
  out void ready();

  behaviour
  {
    enum State {Lost, Calibrating, Ready, Moving};
    State s = State.Lost;
    bool isHolding = false; // true => up/closed, false => down/open

    on stop: {s = State.Lost; isHolding = false;}

    [s.Lost]
    {
      on calibrate: s = State.Calibrating;
      on calibrate: {calibrated; s = State.Ready; isHolding = true;} // hoist is up => safe to move
      on retain, release: illegal;
    }
    [s.Calibrating]
    {
      on inevitable: {calibrated; s = State.Ready; isHolding = true;}  // hoist is up => safe to move

      on calibrate, retain, release: illegal;
    }
    [s.Ready]
    {
      [!isHolding]
      {
        on retain: s = State.Moving;
        on retain: {ready; isHolding = true;}
        on calibrate, release: illegal;
      }
      [isHolding]
      {
        on release: s = State.Moving;
        on release: {ready; isHolding = false;}
        on calibrate, retain: illegal;
      }
    }
    [s.Moving]
    {
      on inevitable:
        {
          ready;
          s = State.Ready;
          isHolding = !isHolding;
        }

      on calibrate, retain, release: illegal;
    }
  }
}

component Hoist
{
  provides IRetain ctrl;

  system
  {
    Lift bhv;
    EndConstrainedAxis winch;

    ctrl <=> bhv.ctrl;
    bhv.winch <=> winch.ctrl;
  }
}

component Lift
{
  provides IRetain ctrl;
  requires IConstrainedMove winch;

  behaviour
  {
    enum State {Lost, Calibrating, Ready, Moving};
    State s = State.Lost;
    bool isHolding = false; // true => up/closed, false => down/open

    on ctrl.stop(): {winch.stop(); s = State.Lost; isHolding = false;}

    [s.Lost]
    {
      on ctrl.calibrate(): {winch.calibrate(); s = State.Calibrating;}
    }
    [s.Calibrating]
    {
      on winch.homed(): {winch.move($(config.get("Position::Robot::Z::Up"))$);} // end sensor pressed position
      on winch.arrived(): {ctrl.calibrated(); s = State.Ready; isHolding = true;}
    }
    [s.Ready]
    {
      [!isHolding]
      {
        on ctrl.retain(): {winch.move($(config.get("Position::Robot::Z::Up"))$); s = State.Moving;}
      }
      [isHolding]
      {
        on ctrl.release(): {winch.move($(config.get("Position::Robot::Z::Down"))$); s = State.Moving;}
      }
    }
    [s.Moving]
    {
      on winch.arrived():
      {
        ctrl.ready();
        s = State.Ready;
        isHolding = !isHolding;
      }
    }
  }
}

component Gripper
{
  provides IRetain ctrl;

  system
  {
    Grip bhv;
    EndConstrainedAxis gripper;

    ctrl <=> bhv.ctrl;
    bhv.gripper <=> gripper.ctrl;
  }
}

component Grip
{
  provides IRetain ctrl;
  requires IConstrainedMove gripper;

  behaviour
  {
    enum State {Lost, Calibrating, Ready, Moving};
    State s = State.Lost;
    bool isHolding = false;

    on ctrl.stop(): {gripper.stop(); s = State.Lost; isHolding = false;}

    [s.Lost]
    {
      on ctrl.calibrate(): {gripper.calibrate(); s = State.Calibrating;}
    }
    [s.Calibrating]
    {
      on gripper.homed(): {gripper.move($(config.get("Position::Robot::Gripper::Closed"))$);}
      on gripper.arrived(): {ctrl.calibrated(); s = State.Ready; isHolding = true;}
    }
    [s.Ready]
    {
      [!isHolding]
      {
        on ctrl.retain(): {s = State.Moving; gripper.move($(config.get("Position::Robot::Gripper::Closed"))$);}
      }
      [isHolding]
      {
        on ctrl.release(): {s = State.Moving; gripper.move($(config.get("Position::Robot::Gripper::Open"))$);}
      }
    }
    [s.Moving]
    {
      on gripper.arrived(): {
        ctrl.ready();
        s = State.Ready;
        isHolding = !isHolding;
      }
    }
  }
}

interface IMove
{
  extern imove_boolean $Boolean$;
  extern imove_position_t $Integer$;
  extern imove_milliseconds_t $Integer$;
  extern imove_power_t $Byte$; // [0,100]

  in void move(imove_power_t power, imove_position_t position);  //regulated, absolute position
  out void arrived();

  in void run(imove_power_t power, imove_boolean invert);        //unregulated
  in void pulse(imove_power_t power, imove_boolean invert, imove_milliseconds_t duration);
  in void stop(); // brake
  in void coast();
  in void zero();
  in void position(out imove_position_t pos);

  behaviour
  {
    bool moving = false;
    [moving]
    {
      on move: illegal;
      on zero: illegal;
      on inevitable: {moving = false; arrived;}
    }
    [!moving]
    {
      on move: { moving = true; }
      on zero: {}
    }
    on run: {}
    on run: [moving] illegal;
    on pulse: {moving = true;}
    on pulse: [moving] illegal;
    on stop: {moving = false;}
    on coast: {moving = false;}
    on position: {}
  }
}

component Motor
{
  provides IMove ctrl;
  //requires imotor hw;

  system
  {
    timer pollTimer;
    Move bhv;
    motor hw;

    ctrl <=> bhv.ctrl;
    bhv.timer <=> pollTimer.port;
    bhv.motor <=> hw.ctrl;
  }
}

component Move
{
  provides IMove ctrl;
  requires itimer timer;
  requires imotor motor;

  behaviour
  {
    bool moving = false;
    bool pulsing = false;

    itimer.milliseconds_t time = $(config.get("Duration::PollInterval"))$;
    imotor.position_t destination;

    [moving][!pulsing]
    {
      on timer.timeout():
        {
          imotor.resultT arrive = motor.at(destination);

          if (arrive == imotor.resultT.yes) {ctrl.arrived(); moving = false;}
          else                               timer.create(time);
        }
    }
    [!moving][!pulsing]
    {
      on ctrl.move(power, position):
        {
          destination = position;
          timer.create(time);
          motor.move(power, destination);
          moving = true;
        }
      on ctrl.pulse(power, invert, duration):
        {
          timer.create(duration);
          motor.run(power, invert);
          pulsing = true;
        }
      on ctrl.zero(): motor.zero();
    }
    [pulsing][!moving]
    {
      on timer.timeout(): {motor.coast(); ctrl.arrived(); pulsing = false;}
    }
    on ctrl.run(power, invert): motor.run(power, invert);
    on ctrl.stop(): {motor.stop(); timer.cancel(); moving = false; pulsing = false;}
    on ctrl.coast(): {motor.coast(); timer.cancel(); moving = false; pulsing = false;}
    on ctrl.position(pos): motor.position(pos);
  }
}


interface IMove2D
{
  extern MovePosition $Integer$;

  in void calibrate();
  out void calibrated();
  in void stop();

  in void move(MovePosition x, MovePosition y);
  out void arrived();

  behaviour
  {
    enum State {Lost, Calibrating, Ready, Moving};
    State s = State.Lost;

    on stop: s = State.Lost;

    on calibrate: [s.Lost] s = State.Calibrating;
    on calibrate: [s.Lost] {calibrated; s = State.Ready;}
    on calibrate: [!s.Lost] illegal;
    on calibrate: [!s.Lost] {}

    on move: [s.Ready] s = State.Moving;
    on move: [!s.Ready] illegal;
    on move: [!s.Ready] {}

    on inevitable: [s.Calibrating] {s = State.Ready; calibrated;}
    on inevitable: [s.Moving] {s = State.Ready; arrived;}
  }
}

component Stage
{
  provides IMove2D ctrl;

  system
  {
    Move2D bhv;
    ConstrainedAxis xAxis;
    ConstrainedAxis yAxis;

    ctrl <=> bhv.ctrl;
    bhv.xAxis <=> xAxis.ctrl;
    bhv.yAxis <=> yAxis.ctrl;
  }
}

component Move2D
{
  provides IMove2D ctrl;
  requires IConstrainedMove xAxis;
  requires IConstrainedMove yAxis;

  behaviour
  {
    subint AxisCount {0..2};
    bool isCalibrating = false;
    AxisCount nCalibrated = 0;
    AxisCount nMoving = 0;

    void tryCalibrated() {
      nCalibrated = nCalibrated + 1;
      if (nCalibrated == 2) {
        ctrl.calibrated();
        isCalibrating = false;
      }
    }

    void tryArrived() {
      nMoving = nMoving - 1;
      if (nMoving == 0) ctrl.arrived();
    }

    on ctrl.stop():
      {
        xAxis.stop();
        yAxis.stop();
        nCalibrated = 0;
        nMoving = 0;
        isCalibrating = false;
      }

    on ctrl.calibrate(): [nCalibrated == 0 && !isCalibrating]
    {
      xAxis.calibrate();
      yAxis.calibrate();
      nCalibrated = 0;
      isCalibrating = true;
    }
    on ctrl.calibrate(): [nCalibrated != 0 || isCalibrating] {}
    on xAxis.homed(), yAxis.homed(): if(nCalibrated < 2) tryCalibrated(); else illegal;
    //on xAxis.homed(), yAxis.homed(): [nCalibrated == 2] illegal; // Change Request!
    // Model verification => illegal value in assignment in case the two lines
    // above are replaced by the following line:
    //on xAxis.homed(), yAxis.homed(): tryCalibrated();
    // The Axis interfaces should be taken into account in range check verification.

    on ctrl.move(x, y): [nMoving == 0 && nCalibrated == 2]
    {
      nMoving = 2;
      xAxis.move(x);
      yAxis.move(y);
    }
    on ctrl.move(x, y): [nMoving != 0 || nCalibrated != 2] {}
    on xAxis.arrived(), yAxis.arrived(): [nMoving > 0] tryArrived();
    on xAxis.arrived(), yAxis.arrived(): [nMoving == 0] illegal;
  }
}


interface ITouchSense
{
  enum TouchState {Pressed, Released};

  in TouchState enable();
  out void pressed();
  out void released();
  in void disable();

  behaviour
  {
    bool disabled = true;
    TouchState ts = TouchState.Released;

    [disabled]
    {
      on enable: {ts = TouchState.Pressed; reply(ts); disabled = false;}
      on enable: {ts = TouchState.Released; reply(ts); disabled = false;}
      on disable: {}
    }
    [!disabled]
    {
      on enable: illegal;
      on disable: disabled = true;
      on inevitable: [ts.Released] {ts = TouchState.Pressed; pressed;}
      on inevitable: [ts.Pressed] {ts = TouchState.Released; released;}
    }
  }
}

component TouchSensor
{
  provides ITouchSense ctrl;

  // Foreign component with asynchronous interface to illustrate system
  // abstraction and encapsulation during Expert Workshop
}

component TouchSensor_org
{
  provides ITouchSense ctrl;

  system
  {
    timer pollTimer;
    TouchSense bhv;
    touch hw;

    ctrl <=> bhv.ctrl;
    bhv.timer <=> pollTimer.port;
    bhv.sensor <=> hw.ctrl;
  }
}

component TouchSense
{
  provides ITouchSense ctrl;
  requires itimer timer;
  requires itouch sensor;

  behaviour
  {
    ITouchSense.TouchState previous = ITouchSense.TouchState.Released;
    itimer.milliseconds_t time = $50$;
    bool disabled = true;

    ITouchSense.TouchState getStatus()
    {
      itouch.status val = sensor.detect();
      if (val == itouch.status.released) return ITouchSense.TouchState.Released;
      else return ITouchSense.TouchState.Pressed;
    }

    on ctrl.disable(): {timer.cancel(); disabled = true;}

    [disabled]
    {
      on ctrl.enable():
        {
          previous = getStatus();
          timer.create(time);
          disabled = false;
          reply(previous);
        }
    }
    [!disabled]
    {
      on timer.timeout():
        {
          ITouchSense.TouchState current = getStatus();
          if (previous == ITouchSense.TouchState.Released &&
              current  == ITouchSense.TouchState.Pressed)
            ctrl.pressed();
          else if (previous == ITouchSense.TouchState.Pressed &&
                   current  == ITouchSense.TouchState.Released)
            ctrl.released();
          previous = current;
          timer.create(time);
        }
    }
  }
}
