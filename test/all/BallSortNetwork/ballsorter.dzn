component EndConstrainedMove
{
  // Sensor marks end of range which is considered position 0
  // MoveToPosition must receive negative position values!
  provides IConstrainedMove ctrl;
  requires IMove motor; // required by motor
  requires ITouchSense endSensor; // required by sensor

  behaviour
  {
    enum State {lost, idle, moving, calibratingEnd};
    State s = State.lost;

    void slowForward() {motor.run($(config.get("Power::CalibrationSpeed"))$, $false$);}
    void recordHome() {
      endSensor.disable();
      motor.stop(); // brake
      motor.zero();
    }
    void startAbsoluteMove(IConstrainedMove.position_t target) {
      ITouchSense.TouchState ignore = endSensor.enable();
      motor.move($(config.get("Power::OperationalSpeed"))$, target);
      s = State.moving;
    }
    void notifyArrived() {
      motor.stop();
      endSensor.disable();
      s = State.idle;
      ctrl.arrived();
    }

    on ctrl.stop(): {motor.stop(); endSensor.disable(); s = State.lost;}

    [s.lost]
    {
      on ctrl.calibrate():
        {
          ITouchSense.TouchState ess = endSensor.enable();
          if (ess == ITouchSense.TouchState.Pressed)
          {
            recordHome();
            s = State.idle;
            ctrl.homed();
          }
          else
          {
            slowForward();
            s = State.calibratingEnd;
          }
        }
    }

    [s.calibratingEnd]
    {
      on endSensor.pressed():
        {
          recordHome();
          s = State.idle;
          ctrl.homed();
        }
    }

    [s.idle]
    {
      //on ctrl.move(pos): startAbsoluteMove(pos);
      on ctrl.move(target):
        {
          ITouchSense.TouchState ignore = ITouchSense.TouchState.Released;
          ignore = endSensor.enable();
          motor.move($(config.get("Power::OperationalSpeed"))$, target);
          s = State.moving;
        }
    }

    [s.moving]
    {
      on endSensor.pressed(): {motor.stop(); notifyArrived();} // out of range => recalibrate?
      on endSensor.released(): {}
      on motor.arrived(): notifyArrived();
    }
  }
}


component Feeder
{
  provides IFeed ctrl;

  system
  {
    Feed bhv;
    EndConstrainedAxis axis;

    ctrl <=> bhv.ctrl;
    bhv.axis <=> axis.ctrl;
  }
}

component Feed
{
  provides IFeed ctrl;
  requires IConstrainedMove axis;

  behaviour
  {
    enum State {Lost, Calibrating, Idle, Preparing, Prepared};
    subint Count {0..4};
    State s = State.Lost;
    bool isRetracting = false;
    bool isFeedRequested = false;
    Count inventory = 0; // number of balls in store

    void feedNext() {
      if (inventory == 4) {axis.move($(config.get("Position::Feeder::DropFirst"))$);}
      if (inventory == 3) {axis.move($(config.get("Position::Feeder::DropSecond"))$);}
      if (inventory == 2) {axis.move($(config.get("Position::Feeder::DropThird"))$);}
      if (inventory == 1) {axis.move($(config.get("Position::Feeder::DropLast"))$);}
      s = State.Preparing;
      inventory = inventory - 1;
    }
    void retract() {
      axis.move($(config.get("Position::Feeder::Retracted"))$);
      isRetracting = true;
    }
    void refill() {
      inventory = 4;
    }

    on ctrl.stop(): {axis.stop(); s = State.Lost; isRetracting = false; isFeedRequested = false;}

    [s.Lost]
    {
      on ctrl.calibrate(): {axis.calibrate(); s = State.Calibrating;}
    }
    [s.Calibrating]
    {
      on axis.homed(): {ctrl.calibrated(); refill(); s = State.Idle;}
    }
    [s.Idle]
    {
      on ctrl.produceBall(): [!isRetracting] feedNext();
      on ctrl.produceBall(): [isRetracting] [!isFeedRequested] isFeedRequested = true;
      on axis.arrived(): [isRetracting]
      {
        refill();
        if (isFeedRequested) feedNext();
        isRetracting = false;
        isFeedRequested = false;
      }
    }
    [s.Preparing]
    {
      on axis.arrived(): [inventory > 0] {ctrl.consumeNextBall(); s = State.Prepared;}
      on axis.arrived(): [inventory == 0] {ctrl.consumeLastBall(); retract(); s = State.Idle;}
    }
    [s.Prepared]
    {
      on ctrl.produceBall(): feedNext();
    }
  }
}


component FeedPort
{
  provides IFeed ctrl;
  requires IFeed feeder;

  system
  {
    FeedConvey bhv;
    Conveyor conveyor;

    ctrl <=> bhv.ctrl;
    bhv.conveyor <=> conveyor.ctrl;
    bhv.feeder <=> feeder;
  }
}

component FeedConvey
{
  provides IFeed ctrl;
  requires IFeed feeder;
  requires IConvey conveyor;

  behaviour
  {
    enum State {Lost, Calibrating, Idle, Preparing, Prepared};
    enum FeedPhase {Idle, Feeding, ConveyingNext, ConveyingLast};
    State s = State.Lost;
    FeedPhase p = FeedPhase.Idle;

    on ctrl.stop(): {feeder.stop(); conveyor.stop(); s = State.Lost; p = FeedPhase.Idle;}

    [s.Lost]
    {
      on ctrl.calibrate(): {feeder.calibrate(); s = State.Calibrating;}
    }
    [s.Calibrating]
    {
      on feeder.calibrated(): {ctrl.calibrated(); s = State.Idle;}
    }
    [s.Idle]
    {
      on ctrl.produceBall(): {feeder.produceBall(); s = State.Preparing; p = FeedPhase.Feeding;}
    }
    [s.Preparing]
    {
      [p.Feeding]
      {
        on feeder.consumeNextBall(): {conveyor.convey(); p = FeedPhase.ConveyingNext;}
        on feeder.consumeLastBall(): {conveyor.convey(); p = FeedPhase.ConveyingLast;}
      }
      [p.ConveyingNext]
      {
        on conveyor.conveyed(): {ctrl.consumeNextBall(); s = State.Prepared; p = FeedPhase.Idle;}
      }
      [p.ConveyingLast]
      {
        on conveyor.conveyed(): {ctrl.consumeLastBall(); s = State.Prepared; p = FeedPhase.Idle;}
      }
    }
    [s.Prepared]
    {
      on ctrl.produceBall(): {feeder.produceBall(); s = State.Preparing; p = FeedPhase.Feeding;}
    }
  }
}


