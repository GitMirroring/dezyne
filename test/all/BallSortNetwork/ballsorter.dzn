component ConstrainedMove
{
  provides IConstrainedMove ctrl;
  requires IMove motor;
  requires ITouchSense homeSensor;
  requires ITouchSense endSensor;

  behaviour
  {
    enum State {lost, idle, moving, calibratingHome, calibratingLength};
    State s = State.lost;

    void slowForward() {motor.run($(config.get("Power::CalibrationSpeed"))$, $false$);}
    void slowBackward() {motor.run($(config.get("Power::CalibrationSpeed"))$, $true$);}
    void recordHome() {
      homeSensor.disable();
      motor.stop(); // brake
      motor.zero();
    }
    void recordLength() {
      endSensor.disable();
      motor.stop(); // brake
    }
    void startAbsoluteMove(IConstrainedMove.position_t target) {
      ITouchSense.TouchState ignore = ITouchSense.TouchState.Released;
      ignore = homeSensor.enable();
      ignore = endSensor.enable();
      motor.move($(config.get("Power::OperationalSpeed"))$, target);
      s = State.moving;
    }
    void notifyArrived() {
      motor.stop();
      homeSensor.disable();
      endSensor.disable();
      s = State.idle;
      ctrl.arrived();
    }

    on ctrl.stop(): {motor.stop(); homeSensor.disable(); endSensor.disable(); s = State.lost;}

    [s.lost]
    {
      on ctrl.calibrate():
        {
          ITouchSense.TouchState hss = homeSensor.enable();
          if (hss == ITouchSense.TouchState.Pressed)
          {
            recordHome();
            ITouchSense.TouchState ess = endSensor.enable();
            if (ess == ITouchSense.TouchState.Pressed) // axis length 0 is not an error
            {
              recordLength();
              s = State.idle;
              ctrl.homed();
            }
            else
            {
              slowForward();
              s = State.calibratingLength;
            }
          }
          else
          {
            slowBackward();
            s = State.calibratingHome;
          }
        }
    }

    [s.calibratingHome]
    {
      on homeSensor.pressed():
        {
          recordHome();
          ITouchSense.TouchState ess = endSensor.enable();
          if (ess == ITouchSense.TouchState.Pressed) // axis length 0
          {
            recordLength();
            s = State.idle;
            ctrl.homed();
          }
          else
          {
            slowForward();
            s = State.calibratingLength;
          }
        }

    }

    [s.calibratingLength]
    {
      on endSensor.pressed(): {recordLength(); ctrl.homed(); s = State.idle;}
    }

    [s.idle]
    {
      //on ctrl.move(pos): startAbsoluteMove(pos);
      on ctrl.move(target):
        {
          ITouchSense.TouchState ignore = ITouchSense.TouchState.Released;
          ignore = homeSensor.enable();
          ignore = endSensor.enable();
          motor.move($(config.get("Power::OperationalSpeed"))$, target);
          s = State.moving;
        }
    }

    [s.moving]
    {
      on homeSensor.pressed(): {motor.stop(); notifyArrived();} // out of range => recalibrate?
      on homeSensor.released(): {}
      on endSensor.pressed(): {motor.stop(); notifyArrived();} // out of range => recalibrate?
      on endSensor.released(): {}
      on motor.arrived(): notifyArrived();
    }
  }
}


interface IConvey
{
  in void convey();
  out void conveyed();
  in void stop();

  behaviour
  {
    enum State {Idle, Conveying};
    State s = State.Idle;

    on stop: s = State.Idle;

    [s.Idle] on convey: s = State.Conveying;
    //[s.Idle] on convey: conveyed;
    [s.Conveying]
    {
      on convey: illegal;
      on inevitable: {conveyed; s = State.Idle;}
    }
  }
}

component Conveyor
{
  provides IConvey ctrl;
  // Foreign implementation for workshop
}

component Conveyor_org
{
  provides IConvey ctrl;
  system
  {
    Convey bhv;
    Motor motor;
    TouchSensor sensor;

    ctrl <=> bhv.ctrl;
    bhv.motor <=> motor.ctrl;
    bhv.sensor <=> sensor.ctrl;
  }
}

component Convey
{
  provides IConvey ctrl;
  requires IMove motor;
  requires ITouchSense sensor;

  behaviour
  {
    enum State { Idle, Conveying };
    State s = State.Idle;
    on ctrl.stop():
      {
        motor.stop();
        sensor.disable();
        s = State.Idle;
      }

    on motor.arrived(): {}


    [ s.Idle ]
    {
      on ctrl.convey():
        {
          ITouchSense.TouchState ss = sensor.enable();
          if(ss == ITouchSense.TouchState.Pressed) {
            sensor.disable();
            ctrl.conveyed();
          } else {
            motor.run($(config.get("Power::50"))$, $false$); // (power, invert)
            s = State.Conveying;
          }
        }
    }

    [ s.Conveying ]
    {
      on sensor.pressed(), sensor.released():
        {
          sensor.disable();
          motor.stop();
          ctrl.conveyed();
          s = State.Idle;
        }
    }
  }
}


