import shared_choice2.dzn;

component system_shared_choice2
{
  provides ihello h;
  requires ihello w;

  system
    {
      shared_choice2 top;
      shared_choice2 bottom;
      h <=> top.h;
      top.w <=> bottom.h;
      bottom.w <=> w;
    }
}
