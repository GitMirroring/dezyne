// Commentary:
//
// Code:

interface ihello
{
  in void hello();
  out void world();
  out void bye();
  behavior
  {
    bool idle = true;
    bool first = true;

    [idle] on hello: {first = true; idle = false;}
    [!idle] on inevitable: {world; if(first) first = false; else idle=true;}
  }
}

component defer_nested
{
  provides ihello h;
  behavior
  {
    bool idle = true;
    [idle] on h.hello():
    {
      idle = false;
      defer
      {
        h.world();
        defer {idle = true; h.world();}
      }
    }
  }
}
