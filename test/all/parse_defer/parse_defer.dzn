// Commentary:
//
// Verify that the defer statement checked for well-formedness.
//
// Code:

import ihello_world.dzn;

extern int $int$;

component parse_defer
{
  provides ihello_world h;

  behavior
  {
    int m;
    on h.hello ():
    {
      bool l = true;
      defer (u,m,l) h.world ();
      defer (true) h.world ();
    }
  }
}
