// Commentary:
//
// Verify that the defer statement checked for well-formedness.
//
// Code:

extern int $int$;

interface ihello
{
  in void hello ();

  behavior
  {
    int foo;
    on hello: {}
  }
}

component parse_defer
{
  provides ihello h;

  behavior
  {
    int m;
    on h.hello ():
    {
      bool l = true;
      defer (u,m,l) bool b = 0;
    }
  }
}
