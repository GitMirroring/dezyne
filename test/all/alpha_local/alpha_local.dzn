// Code:

extern xint $int$;

interface i
{
  in void e();
  out void f();
  out void g(xint a);

  behavior
  {
    on e: g;
  }
}

component alpha_local
{
  provides i p;
  requires i r;

  behavior
  {
    {
      on p.e(): r.e();
      on r.f: illegal;
      on r.g(x): {xint a = $0$; a = $ax$; p.g(x);}
    }
  }
}
