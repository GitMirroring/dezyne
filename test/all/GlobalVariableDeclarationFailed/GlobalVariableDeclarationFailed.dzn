interface GlobalVariableDeclarationFailed
{
  in void ia();
  
  behaviour
  {
    subint Count {0..5};
    Count c = 6;

    on ia: c = 0;
  }
  
  // Simulate GlobalVariableDeclarationFailed =>
  // Global variable declaration failed. Range error for variable c
}


