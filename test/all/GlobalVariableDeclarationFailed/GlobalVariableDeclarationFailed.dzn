interface GlobalVariableDeclarationFailed_FunctionCall
{
  in void ia();
  
  behaviour
  {
    bool init() {return false;}

    bool b = init();
    on ia: b = true;
  }
  
  // Simulate GlobalVariableDeclarationFailed_FunctionCall =>
  // Well-formedness error: Function calls are not allowed here  
  
  // This error is produced by well-formedness check, not by simulator.
}

interface IA
{
  in void ia();
  behaviour
  {
    on ia: {}
  }
}

interface IB
{
  in bool get();
  behaviour
  {
    on get: reply(true);
    on get: reply(false);
  }
}
  

component GlobalVariableDeclarationFailed_ActionExpression
{
  provides IA pp;
  requires IB rp;
  
  behaviour
  {
    bool init() { return false;}
    bool b = rp.get();
    
    on pp.ia(): b = false;
  }
  
  // Simulate GlobalVariableDeclarationFailed_ActionExpression =>
  // Well-formedness error: Actions are not allowed here

  // This error is produced by well-formedness check, not by simulator.
}

