#file "hello_import.dzn"
//import interfaces.dzn;
//import components.dzn;

component hello_import
{
  provides ihello h;
  requires iworld w;

  behaviour
  {
    on h.hello(): w.world();
  }
}
#imported "interfaces.dzn"
//import iworld.dzn;

interface ihello
{
  in void hello();

  behaviour
  {
    on hello: {}
  }
}
#imported "iworld.dzn"
interface iworld
{
  in void world();

  behaviour
  {
    on world: {}
  }
}
#imported "components.dzn"
//import interfaces.dzn;

component comp {
  provides ihello h;

  behaviour
  {
    on h.hello(): {
      f(); // this error will not be detected!
    }
  }
}
