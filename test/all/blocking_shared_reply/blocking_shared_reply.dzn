// Commentary:
//
// This model demonstrates a simulate compliance error in blocking
// context leading to a failed provides port state update.
//
// Code:

interface ihello
{
  in bool hello ();
  out void cruel ();

  out void world ();
  behavior
  {
    bool b = false;
    on optional: cruel;
    on hello: {b=true; world; reply (b); b=false;}
  }
}

interface iworld
{
  in void hello ();
  out void world ();
  behavior
  {
    bool idle = true;
    [idle] on hello: idle = false;
    [!idle] on inevitable: {world; idle = true;}
  }
}

component blocking_shared_reply
{
  provides blocking ihello h;
  requires iworld w;
  behavior
  {
    on h.hello (): blocking w.hello ();
    on w.world (): {h.world (); h.reply (h.b);}
  }
}
