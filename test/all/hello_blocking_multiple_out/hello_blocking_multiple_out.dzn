// Code:

interface ihello
{
  in void hello ();

  behavior
  {
    on hello: {}
  }
}

interface iworld
{
  in void hello ();
  out void world ();

  behavior
  {
    on hello: world;
  }
}

component hello_blocking_multiple_out
{
  provides blocking ihello p;
  requires iworld r0;
  requires iworld r1;

  behavior
  {
    blocking on p.hello (): r0.hello ();
    on r0.world (): r1.hello ();
    on r1.world (): p.reply ();
  }
}
