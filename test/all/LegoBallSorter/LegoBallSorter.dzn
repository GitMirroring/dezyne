import Motor.dzn;
import TouchSensor.dzn;
import LightSensor.dzn;
import BallSorter.dzn;


component LegoBallSorter
{
  provides IHandle ctrl;
  // NxtBrick brick1; // INPUT
  requires imotor brick1_aA; //<=> handler.trolleyMotor; // robot trolley
  requires imotor brick1_aB; //<=> input.motor; // input
  requires imotor brick1_aC; //<=> track.motor; // feeder
  requires itouch brick1_s1; //<=> inspector.stageXEndSensor; // stage x home
  requires itouch brick1_s2; //<=> input.sensor;  // input
  requires itouch brick1_s3; //<=> handler.truckHomeSensor; // robot truck home
  requires itouch brick1_s4; //<=> track.endSensor; // feeder retracted switch

  //  NxtBrick brick2; // OUTPUT
  requires imotor brick2_aA; //<=> reject.motor; // reject
  requires imotor brick2_aB; //<=> accept.motor; // accept
  //requires itouch brick2_s1; //<=> handler.truckEndSensor; // robot truck end
  requires itouch brick2_s2; //<=> inspector.stageXHomeSensor;  // stage x home
  requires itouch brick2_s3; //<=> reject.sensor; // reject
  requires itouch brick2_s4; //<=> accept.sensor; // accept

  //  NxtBrick brick3; // STAGE
  requires imotor brick3_aA; //<=> inspector.stageXMotor; // stage x
  requires imotor brick3_aC; //<=> inspector.stageYMotor; // stage y
  requires ilight brick3_s1; //<=> inspector.sensor; // inspect light sensor
  requires itouch brick3_s2; //<=> inspector.stageYEndSensor; // stage y end
  requires itouch brick3_s3; //<=> inspector.stageYHomeSensor; // stage y home

  //  NxtBrick brick4; // ROBOT
  requires imotor brick4_aA; //<=> handler.hoistMotor; // robot hoist
  requires imotor brick4_aB; //<=> handler.gripperMotor; // robot gripper
  requires imotor brick4_aC; //<=> handler.truckMotor; // truck
  requires itouch brick4_s1;
  requires itouch brick4_s2; //<=> handler.trolleyHomeSensor; // extender home
  requires itouch brick4_s3; //<=> handler.hoistEndSensor; // hoist home

  system
  {
    BallSorter sorter;
    Motor motor1_aA; // <=> handler.trolleyMotor; // robot trolley
    Motor motor1_aB; // <=> input.motor; // input
    Motor motor1_aC; // <=> track.motor; // feeder
    TouchSensor touch1; // <=> inspector.stageXEndSensor; // stage x home
    TouchSensor touch2; // <=> input.sensor;  // input
    TouchSensor touch3; // <=> handler.truckHomeSensor; // robot truck home
    TouchSensor touch4; // <=> track.endSensor; // feeder retracted switch
    // NxtBrick brick2; // OUTPUT
    Motor motor2_aA; // <=> reject.motor; // reject
    Motor motor2_aB; // <=> accept.motor; // accept
    // TouchSensor touch5; //<=> handler.truckEndSensor; // robot truck end
    TouchSensor touch6; // <=> inspector.stageXHomeSensor;  // stage x home
    TouchSensor touch7; // <=> reject.sensor; // reject
    TouchSensor touch8; // <=> accept.sensor; // accept
    // NxtBrick brick3; // STAGE
    Motor motor3_aA; // <=> inspector.stageXMotor; // stage x
    Motor motor3_aC; // <=> inspector.stageYMotor; // stage y
    LightSensor light1;
    TouchSensor touch9; // <=> inspector.stageYEndSensor; // stage y end
    TouchSensor touch10; // <=> inspector.stageYHomeSensor; // stage y home
    // NxtBrick brick4; // ROBOT
    Motor motor4_aA; // <=> handler.hoistMotor; // robot hoist
    Motor motor4_aB; // <=> handler.gripperMotor; // robot gripper
    Motor motor4_aC; // <=> handler.truckMotor; // truck
    TouchSensor touch11;
    TouchSensor touch12; // <=> handler.trolleyHomeSensor; // extender home
    TouchSensor touch13; // <=> handler.hoistEndSensor; // hoist home
    // ///////////////////////////
    ctrl <=> sorter.ctrl;
    motor1_aA.ctrl <=> sorter.move1;
    motor1_aA.hw <=> brick1_aA; // <=> handler.trolleyMotor; // robot trolley
    motor1_aB.ctrl <=> sorter.move2; // <=> input.motor; // input
    motor1_aB.hw <=> brick1_aB; // <=> input.motor; // input
    motor1_aC.ctrl <=> sorter.move3; // <=> track.motor; // feeder
    motor1_aC.hw <=> brick1_aC; // <=> track.motor; // feeder
    touch1.ctrl <=> sorter.touch1; // <=> inspector.stageXEndSensor; // stage x home
    touch1.hw <=> brick1_s1; // <=> inspector.stageXEndSensor; // stage x home
    touch2.ctrl <=> sorter.touch2; // <=> input.sensor;  // input
    touch2.hw <=> brick1_s2; // <=> input.sensor;  // input
    touch3.ctrl <=> sorter.touch3; // <=> handler.truckHomeSensor; // robot truck home
    touch3.hw <=> brick1_s3; // <=> handler.truckHomeSensor; // robot truck home
    touch4.ctrl <=> sorter.touch4; // <=> track.endSensor; // feeder retracted switch
    touch4.hw <=> brick1_s4; // <=> track.endSensor; // feeder retracted switch
    motor2_aA.ctrl <=> sorter.move4; // <=> reject.motor; // reject
    motor2_aA.hw <=> brick2_aA; // <=> reject.motor; // reject
    motor2_aB.ctrl <=> sorter.move5; // <=> accept.motor; // accept
    motor2_aB.hw <=> brick2_aB; // <=> accept.motor; // accept
    // touch5; //<=> handler.truckEndSensor; // robot truck end
    touch6.ctrl <=> sorter.touch6; // <=> inspector.stageXHomeSensor;  // stage x home
    touch6.hw <=> brick2_s2; // <=> inspector.stageXHomeSensor;  // stage x home
    touch7.ctrl <=> sorter.touch7; // <=> reject.sensor; // reject
    touch7.hw <=> brick2_s3; // <=> reject.sensor; // reject
    touch8.ctrl <=> sorter.touch8; // <=> accept.sensor; // accept
    touch8.hw <=> brick2_s4; // <=> accept.sensor; // accept
    // NxtBrick brick3; // STAGE
    motor3_aA.ctrl <=> sorter.move6; // <=> inspector.stageXMotor; // stage x
    motor3_aA.hw <=> brick3_aA; // <=> inspector.stageXMotor; // stage x
    motor3_aC.ctrl <=> sorter.move7; // <=> inspector.stageYMotor; // stage y
    motor3_aC.hw <=> brick3_aC; // <=> inspector.stageYMotor; // stage y
    //TODO  requires ilight brick3_s1; //<=> inspector.sensor; // inspect light sensor
    light1.ctrl <=> sorter.light1;
    light1.hw <=> brick3_s1;
    touch9.ctrl <=> sorter.touch9; // <=> inspector.stageYEndSensor; // stage y end
    touch9.hw <=> brick3_s2; // <=> inspector.stageYEndSensor; // stage y end
    touch10.ctrl <=> sorter.touch10; // <=> inspector.stageYHomeSensor; // stage y home
    touch10.hw <=> brick3_s3; // <=> inspector.stageYHomeSensor; // stage y home
    // NxtBrick brick4; // ROBOT
    motor4_aA.ctrl <=> sorter.move8; // <=> handler.hoistMotor; // robot hoist
    motor4_aA.hw <=> brick4_aA; // <=> handler.hoistMotor; // robot hoist
    motor4_aB.ctrl <=> sorter.move9; // <=> handler.gripperMotor; // robot gripper
    motor4_aB.hw <=> brick4_aB; // <=> handler.gripperMotor; // robot gripper
    motor4_aC.ctrl <=> sorter.move10; // <=> handler.truckMotor; // truck
    motor4_aC.hw <=> brick4_aC; // <=> handler.truckMotor; // truck
    touch11.ctrl <=> sorter.touch11;
    touch11.hw <=> brick4_s1;
    touch12.ctrl <=> sorter.touch12; // <=> handler.trolleyHomeSensor; // extender home
    touch12.hw <=> brick4_s2; // <=> handler.trolleyHomeSensor; // extender home
    touch13.ctrl <=> sorter.touch13; // <=> handler.hoistEndSensor; // hoist home
    touch13.hw <=> brick4_s3; // <=> handler.hoistEndSensor; // hoist home
  }
}
