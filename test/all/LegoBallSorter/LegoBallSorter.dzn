import Motor.dzn;
import TouchSensor.dzn;
import LightSensor.dzn;
import BallSorter.dzn;

component Brick1
{
  provides IMove motorA;
  provides IMove motorB;
  provides IMove motorC;
  provides ITouchSense touch1;
  provides ITouchSense touch2;
  provides ITouchSense touch3;
  provides ITouchSense touch4;

  requires imotor aA; // robot trolley
  requires imotor aB; // input
  requires imotor aC; // feeder

  requires itouch s1; // stage x home
  requires itouch s2; // input
  requires itouch s3; // robot truck home
  requires itouch s4; // feeder retracted switch

  system
  {
    // NxtBrick brick1; // INPUT
    Motor motor_A; // robot trolley
    Motor motor_B; // input
    Motor motor_C; // feeder

    motorA <=> motor_A.ctrl;
    motorB <=> motor_B.ctrl;
    motorC <=> motor_C.ctrl;

    motor_A.hw <=> aA;
    motor_B.hw <=> aB;
    motor_C.hw <=> aC;

    TouchSensor touch_1; // stage x home
    TouchSensor touch_2; // input
    TouchSensor touch_3; // robot truck home
    TouchSensor touch_4; // feeder retracted switch

    touch1 <=> touch_1.ctrl;
    touch2 <=> touch_2.ctrl;
    touch3 <=> touch_3.ctrl;
    touch4 <=> touch_4.ctrl;

    touch_1.hw <=> s1;
    touch_2.hw <=> s2;
    touch_3.hw <=> s3;
    touch_4.hw <=> s4;
  }
}

component Brick2
{
  provides IMove motorA;
  provides IMove motorB;

  provides ITouchSense touch6;
  provides ITouchSense touch7;
  provides ITouchSense touch8;

  requires imotor aA; // reject
  requires imotor aB; // accept

  requires itouch s2; // stage x home
  requires itouch s3; // reject
  requires itouch s4; // accept

  system
  {
    // NxtBrick brick2; // OUTPUT
    Motor motor_A; // reject
    Motor motor_B; // accept

    motorA <=> motor_A.ctrl; // reject
    motorB <=> motor_B.ctrl; // accept

    motor_A.hw <=> aA; // reject
    motor_B.hw <=> aB; // accept

    TouchSensor touch_6; // stage x home
    TouchSensor touch_7; // reject
    TouchSensor touch_8; // accept

    touch6 <=> touch_6.ctrl; // stage x home
    touch7 <=> touch_7.ctrl; // reject
    touch8 <=> touch_8.ctrl; // accept

    touch_6.hw <=> s2; // stage x home
    touch_7.hw <=> s3; // reject
    touch_8.hw <=> s4; // accept
  }
}

component Brick3
{
  provides IMove motorA;
  provides IMove motorC;

  provides ILightSense light1;
  provides ITouchSense touch9;
  provides ITouchSense touch10;

  requires imotor aA; // stage x
  requires imotor aC; // stage y

  requires ilight s1; // light
  requires itouch s2; // stage y end
  requires itouch s3; // stage y home

  system
  {
    // NxtBrick brick3; // STAGE
    Motor motor_A; // stage x
    Motor motor_C; // stage y

    motorA <=> motor_A.ctrl;
    motorC <=> motor_C.ctrl;

    motor_A.hw <=> aA;
    motor_C.hw <=> aC;

    LightSensor light_1;
    TouchSensor touch_9; // stage y end
    TouchSensor touch_10; // stage y home

    light1 <=> light_1.ctrl;
    light_1.hw <=> s1;

    touch9 <=> touch_9.ctrl;
    touch_9.hw <=> s2;

    touch10 <=> touch_10.ctrl;
    touch_10.hw <=> s3;
  }
}

component Brick4
{
  provides IMove motorA;
  provides IMove motorB;
  provides IMove motorC;

  provides ITouchSense touch11;
  provides ITouchSense touch12;
  provides ITouchSense touch13;

  requires imotor aA; // robot hoist
  requires imotor aB; // robot gripper
  requires imotor aC; // robot truck

  requires itouch s1;
  requires itouch s2; // extender home
  requires itouch s3; // hoist home

  system
  {
    // NxtBrick brick4; // ROBOT
    Motor motor_A;
    Motor motor_B;
    Motor motor_C;

    motorA <=> motor_A.ctrl;
    motor_A.hw <=> aA;

    motorB <=> motor_B.ctrl;
    motor_B.hw <=> aB;

    motorC <=> motor_C.ctrl;
    motor_C.hw <=> aC;

    TouchSensor touch_11;
    TouchSensor touch_12;
    TouchSensor touch_13;

    touch11 <=> touch_11.ctrl;
    touch_11.hw <=> s1;

    touch12 <=> touch_12.ctrl;
    touch_12.hw <=> s2;

    touch13 <=> touch_13.ctrl;
    touch_13.hw <=> s3;
  }
}

component LegoBallSorter
{
  provides IHandleRobust ctrl;
  requires imotor brick1_aA;
  requires imotor brick1_aB;
  requires imotor brick1_aC;
  requires itouch brick1_s1;
  requires itouch brick1_s2;
  requires itouch brick1_s3;
  requires itouch brick1_s4;

  requires imotor brick2_aA;
  requires imotor brick2_aB;
  requires itouch brick2_s2;
  requires itouch brick2_s3;
  requires itouch brick2_s4;

  requires imotor brick3_aA;
  requires imotor brick3_aC;
  requires ilight brick3_s1;
  requires itouch brick3_s2;
  requires itouch brick3_s3;

  requires imotor brick4_aA;
  requires imotor brick4_aB;
  requires imotor brick4_aC;
  requires itouch brick4_s1;
  requires itouch brick4_s2;
  requires itouch brick4_s3;

  system
  {
    BallSorter sorter;

    ctrl <=> sorter.ctrl;

    Brick1 brick1;

    sorter.move1 <=> brick1.motorA;
    sorter.move2 <=> brick1.motorB;
    sorter.move3 <=> brick1.motorC;

    sorter.touch1 <=> brick1.touch1;
    sorter.touch2 <=> brick1.touch2;
    sorter.touch3 <=> brick1.touch3;
    sorter.touch4 <=> brick1.touch4;

    brick1.aA <=> brick1_aA;
    brick1.aB <=> brick1_aB;
    brick1.aC <=> brick1_aC;

    brick1.s1 <=> brick1_s1;
    brick1.s2 <=> brick1_s2;
    brick1.s3 <=> brick1_s3;
    brick1.s4 <=> brick1_s4;

    Brick2 brick2;

    sorter.move4 <=> brick2.motorA;
    sorter.move5 <=> brick2.motorB;

    sorter.touch6 <=> brick2.touch6;
    sorter.touch7 <=> brick2.touch7;
    sorter.touch8 <=> brick2.touch8;

    brick2.aA <=> brick2_aA;
    brick2.aB <=> brick2_aB;

    brick2.s2 <=> brick2_s2;
    brick2.s3 <=> brick2_s3;
    brick2.s4 <=> brick2_s4;

    Brick3 brick3;

    sorter.move6 <=> brick3.motorA;
    sorter.move7 <=> brick3.motorC;

    sorter.light1 <=> brick3.light1;
    sorter.touch9 <=> brick3.touch9;
    sorter.touch10 <=> brick3.touch10;

    brick3.aA <=> brick3_aA;
    brick3.aC <=> brick3_aC;

    brick3.s1 <=> brick3_s1;
    brick3.s2 <=> brick3_s2;
    brick3.s3 <=> brick3_s3;

    Brick4 brick4;

    sorter.move8 <=> brick4.motorA;
    sorter.move9 <=> brick4.motorB;
    sorter.move10 <=> brick4.motorC;

    sorter.touch11 <=> brick4.touch11;
    sorter.touch12 <=> brick4.touch12;
    sorter.touch13 <=> brick4.touch13;

    brick4.aA <=> brick4_aA;
    brick4.aB <=> brick4_aB;
    brick4.aC <=> brick4_aC;

    brick4.s1 <=> brick4_s1;
    brick4.s2 <=> brick4_s2;
    brick4.s3 <=> brick4_s3;
  }
}
