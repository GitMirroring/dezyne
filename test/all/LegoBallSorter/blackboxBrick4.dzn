import IMove.dzn;
import ITouchSense.dzn;

component Brick4
{
  provides IMove motorA;
  provides IMove motorB;
  provides IMove motorC;

  provides ITouchSense touch11;
  provides ITouchSense touch12;
  provides ITouchSense touch13;

  requires imotor aA; // robot hoist
  requires imotor aB; // robot gripper
  requires imotor aC; // robot truck

  requires itouch s1;
  requires itouch s2; // extender home
  requires itouch s3; // hoist home
}