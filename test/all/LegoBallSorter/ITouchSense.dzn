// Commentary:
//
// This component starts in either the pressed or the released state,
// then with time it repeatedly toggles its state.
//
// Code:

import lego.dzn;

interface ITouchSense
{
  in itouch.status enable();
  out void pressed();
  out void released();
  in void disable();

  behavior
  {
    itouch.status state = itouch.status.none;

    [state.none]
    {
      on enable: {state = itouch.status.pressed; return state;}
      on enable: {state = itouch.status.released; return state;}
      on disable: {}
    }
    [!state.none]
    {
      on disable: state = itouch.status.none;
      [state.released] on inevitable: {state = itouch.status.pressed; pressed;}
      [state.pressed] on inevitable: {state = itouch.status.released; released;}
    }
  }
}
