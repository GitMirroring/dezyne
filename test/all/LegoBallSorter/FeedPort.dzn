import IFeed.dzn;
import Feeder.dzn;
import Conveyor.dzn;
import lego.dzn;

component FeedPort
{
  provides IFeed ctrl;
  requires IFeed feeder;
  requires IMove motor;
  requires ITouchSense sensor;

  system
  {
    FeedConvey bhv;
    Conveyor conveyor;

    ctrl <=> bhv.ctrl;
    bhv.conveyor <=> conveyor.ctrl;
    bhv.feeder <=> feeder;

    conveyor.motor <=> motor;
    conveyor.sensor <=> sensor;
  }
}

component FeedConvey
{
  provides IFeed ctrl;
  requires IFeed feeder;
  requires IConvey conveyor;

  behaviour
  {
    enum State {Lost, Calibrating, Idle, Preparing, Prepared};
    enum FeedPhase {Idle, Feeding, ConveyingNext, ConveyingLast};
    State s = State.Lost;
    FeedPhase p = FeedPhase.Idle;

    on ctrl.stop(): {feeder.stop(); conveyor.stop(); s = State.Lost; p = FeedPhase.Idle;}

    [s.Lost]
    {
      on ctrl.calibrate(): {feeder.calibrate(); s = State.Calibrating;}
    }
    [s.Calibrating]
    {
      on feeder.calibrated(): {ctrl.calibrated(); s = State.Idle;}
    }
    [s.Idle]
    {
      on ctrl.produceBall(): {feeder.produceBall(); s = State.Preparing; p = FeedPhase.Feeding;}
    }
    [s.Preparing]
    {
      [p.Feeding]
      {
        on feeder.consumeNextBall(): {conveyor.convey(); p = FeedPhase.ConveyingNext;}
        on feeder.consumeLastBall(): {conveyor.convey(); p = FeedPhase.ConveyingLast;}
      }
      [p.ConveyingNext]
      {
        on conveyor.conveyed(): {ctrl.consumeNextBall(); s = State.Prepared; p = FeedPhase.Idle;}
      }
      [p.ConveyingLast]
      {
        on conveyor.conveyed(): {ctrl.consumeLastBall(); s = State.Prepared; p = FeedPhase.Idle;}
      }
    }
    [s.Prepared]
    {
      on ctrl.produceBall(): {feeder.produceBall(); s = State.Preparing; p = FeedPhase.Feeding;}
    }
  }
}
