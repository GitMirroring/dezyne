import IFeed.dzn;
import Feeder.dzn;
import Conveyor.dzn;
import lego.dzn;

component FeedPort
{
  provides IFeed ctrl;
  requires IFeed feeder;
  requires IMove motor;
  requires ITouchSense sensor;

  system
  {
    FeedConvey bhv;
    Conveyor conveyor;

    ctrl <=> bhv.ctrl;
    bhv.conveyor <=> conveyor.ctrl;
    bhv.feeder <=> feeder;

    conveyor.motor <=> motor;
    conveyor.sensor <=> sensor;
  }
}

component FeedConvey
{
  provides IFeed ctrl;
  requires IFeed feeder;
  requires IConvey conveyor;

  behavior
  {
    bool next = true;

    on ctrl.stop(): {feeder.stop(); conveyor.stop();}

    on ctrl.calibrate(): feeder.calibrate();
    on feeder.calibrated(): ctrl.calibrated();

    on ctrl.produceBall(): feeder.produceBall();

    on feeder.consumeNextBall(): {conveyor.convey(); next = true;}
    on feeder.consumeLastBall(): {conveyor.convey(); next = false;}

    [next] on conveyor.conveyed(): ctrl.consumeNextBall();
    [!next] on conveyor.conveyed(): ctrl.consumeLastBall();
  }
}
