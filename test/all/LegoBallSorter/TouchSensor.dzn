// Commentary:
//
// This component starts in either the pressed or the released state,
// then with time it repeatedly toggles its state.
//
// Code:

import lego.dzn;

interface ITouchSense
{
  in itouch.status enable();
  out void pressed();
  out void released();
  in void disable();

  behavior
  {
    itouch.status state = itouch.status.none;

    [state.none]
    {
      on enable: {state = itouch.status.pressed; reply(state);}
      on enable: {state = itouch.status.released; reply(state);}
      on disable: {}
    }
    [!state.none]
    {
      on disable: state = itouch.status.none;
      [state.released] on inevitable: {state = itouch.status.pressed; pressed;}
      [state.pressed] on inevitable: {state = itouch.status.released; released;}
    }
  }
}

component TouchSensor
{
  provides ITouchSense ctrl;
  requires itouch hw;

  system
  {
    timer pollTimer;
    TouchSense bhv;

    ctrl <=> bhv.ctrl;
    bhv.timer <=> pollTimer.port;
    bhv.sensor <=> hw;
  }
}

component TouchSense
{
  provides ITouchSense ctrl;
  requires itimer timer;
  requires itouch sensor;

  behavior
  {
    itouch.status previous = itouch.status.released;
    itimer.milliseconds_t time = $50$;

    on ctrl.disable(): timer.cancel();

    on ctrl.enable(): {
      timer.create(time);
      previous = sensor.detect();
      reply(previous);
    }
    on timer.timeout(): {
      timer.create(time);
      itouch.status current = sensor.detect();
      if (previous.released && current.pressed) ctrl.pressed();
      if (previous.pressed && current.released) ctrl.released();
      previous = current;
    }
  }
}
