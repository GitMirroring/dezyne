import lego.dzn;

interface ITouchSense
{
  enum TouchState {Pressed, Released};

  in TouchState enable();
  out void pressed();
  out void released();
  in void disable();

  behavior
  {
    bool disabled = true;
    TouchState ts = TouchState.Released;

    [disabled]
    {
      on enable: {ts = TouchState.Pressed; reply(ts); disabled = false;}
      on enable: {ts = TouchState.Released; reply(ts); disabled = false;}
      on disable: {}
    }
    [!disabled]
    {
      on disable: disabled = true;
      on inevitable: [ts.Released] {ts = TouchState.Pressed; pressed;}
      on inevitable: [ts.Pressed] {ts = TouchState.Released; released;}
    }
  }
}

component TouchSensor
{
  provides ITouchSense ctrl;
  requires itouch hw;

  system
  {
    timer pollTimer;
    TouchSense bhv;

    ctrl <=> bhv.ctrl;
    bhv.timer <=> pollTimer.port;
    bhv.sensor <=> hw;
  }
}

component TouchSense
{
  provides ITouchSense ctrl;
  requires itimer timer;
  requires itouch sensor;

  behavior
  {
    ITouchSense.TouchState previous = ITouchSense.TouchState.Released;
    itimer.milliseconds_t time = $50$;
    bool disabled = true;

    ITouchSense.TouchState getStatus()
    {
      if (sensor.detect() == itouch.status.released) return ITouchSense.TouchState.Released;
      else return ITouchSense.TouchState.Pressed;
    }

    on ctrl.disable(): {timer.cancel(); disabled = true;}

    [disabled]
    {
      on ctrl.enable():
        {
          previous = getStatus();
          timer.create(time);
          disabled = false;
          reply(previous);
        }
    }
    [!disabled]
    {
      on timer.timeout():
        {
          ITouchSense.TouchState current = getStatus();
          if (previous == ITouchSense.TouchState.Released &&
              current  == ITouchSense.TouchState.Pressed)
            ctrl.pressed();
          else if (previous == ITouchSense.TouchState.Pressed &&
                   current  == ITouchSense.TouchState.Released)
            ctrl.released();
          previous = current;
          timer.create(time);
        }
    }
  }
}
