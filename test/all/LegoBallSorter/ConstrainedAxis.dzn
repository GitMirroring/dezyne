import IConstrainedMove.dzn;

import TouchSensor.dzn;
import Motor.dzn;
import lego.dzn;


component ConstrainedAxis
{
  provides IConstrainedMove ctrl;
  requires IMove motor;
  requires ITouchSense homeSensor;
  requires ITouchSense endSensor;

  behavior
  {
    enum State {None, Home, Length};
    State s = State.None;

    void slowForward() {motor.run($(config.get("Power::CalibrationSpeed"))$, $false$);}
    void slowBackward() {motor.run($(config.get("Power::CalibrationSpeed"))$, $true$);}
    void recordHome() {
      homeSensor.disable();
      motor.stop(); // brake
      motor.zero();
    }
    void recordLength() {
      endSensor.disable();
      motor.stop(); // brake
    }
    void notifyArrived() {
      motor.stop();
      homeSensor.disable();
      endSensor.disable();
      ctrl.arrived();
    }

    on ctrl.stop(): {motor.stop(); homeSensor.disable(); endSensor.disable();}

    on ctrl.calibrate(): {
      if (homeSensor.enable() == itouch.status.pressed) {
        recordHome();
        if (endSensor.enable() == itouch.status.pressed) { // axis length 0 is not an error
          recordLength();
          s = State.None;
          ctrl.homed();
        } else {
          slowForward();
          s = State.Length;
        }
      } else {
        slowBackward();
        s = State.Home;
      }
    }

    [s.Home] {
      on homeSensor.pressed(): {
        recordHome();
        if (endSensor.enable() == itouch.status.pressed) { // axis length 0
          recordLength();
          s = State.None;
          ctrl.homed();
        } else {
          slowForward();
          s = State.Length;
        }
      }
    }
    [!s.Home] {
      on homeSensor.pressed(): {motor.stop(); notifyArrived();} // out of range => recalibrate?
      on homeSensor.released(): {}
    }

    [s.Length] {
      on endSensor.pressed(): {
        recordLength();
        ctrl.homed();
        s = State.None;
      }
    }
    [!s.Length] {
      on endSensor.pressed(): {motor.stop(); notifyArrived();} // out of range => recalibrate?
      on endSensor.released(): {}
    }

    on ctrl.move(target): {
      itouch.status ignore = itouch.status.released;
      ignore = homeSensor.enable();
      ignore = endSensor.enable();
      motor.move($(config.get("Power::OperationalSpeed"))$, target);
    }

    on motor.arrived(): notifyArrived();
  }
}
