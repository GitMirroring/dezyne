import IConstrainedMove.dzn;

import TouchSensor.dzn;
import Motor.dzn;
import lego.dzn;


component ConstrainedAxis
{
  provides IConstrainedMove ctrl;
  requires IMove motor;
  requires ITouchSense homeSensor;
  requires ITouchSense endSensor;

  behavior
  {
    enum State {lost, idle, moving, calibratingHome, calibratingLength};
    State s = State.lost;

    void slowForward() {motor.run($(config.get("Power::CalibrationSpeed"))$, $false$);}
    void slowBackward() {motor.run($(config.get("Power::CalibrationSpeed"))$, $true$);}
    void recordHome() {
      homeSensor.disable();
      motor.stop(); // brake
      motor.zero();
    }
    void recordLength() {
      endSensor.disable();
      motor.stop(); // brake
    }
    void notifyArrived() {
      motor.stop();
      homeSensor.disable();
      endSensor.disable();
      s = State.idle;
      ctrl.arrived();
    }

    on ctrl.stop(): {motor.stop(); homeSensor.disable(); endSensor.disable(); s = State.lost;}

    [s.lost]
    {
      on ctrl.calibrate():
        {
          if (homeSensor.enable() == ITouchSense.TouchState.Pressed)
          {
            recordHome();
            if (endSensor.enable() == ITouchSense.TouchState.Pressed) // axis length 0 is not an error
            {
              recordLength();
              s = State.idle;
              ctrl.homed();
            }
            else
            {
              slowForward();
              s = State.calibratingLength;
            }
          }
          else
          {
            slowBackward();
            s = State.calibratingHome;
          }
        }
    }

    [s.calibratingHome]
    {
      on homeSensor.pressed():
        {
          recordHome();
          if (endSensor.enable() == ITouchSense.TouchState.Pressed) // axis length 0
          {
            recordLength();
            s = State.idle;
            ctrl.homed();
          }
          else
          {
            slowForward();
            s = State.calibratingLength;
          }
        }

    }

    [s.calibratingLength]
    {
      on endSensor.pressed(): {recordLength(); ctrl.homed(); s = State.idle;}
    }

    [s.idle]
    {
      //on ctrl.move(pos): startAbsoluteMove(pos);
      on ctrl.move(target):
        {
          ITouchSense.TouchState ignore = ITouchSense.TouchState.Released;
          ignore = homeSensor.enable();
          ignore = endSensor.enable();
          motor.move($(config.get("Power::OperationalSpeed"))$, target);
          s = State.moving;
        }
    }

    [s.moving]
    {
      on homeSensor.pressed(): {motor.stop(); notifyArrived();} // out of range => recalibrate?
      on homeSensor.released(): {}
      on endSensor.pressed(): {motor.stop(); notifyArrived();} // out of range => recalibrate?
      on endSensor.released(): {}
      on motor.arrived(): notifyArrived();
    }
  }
}
