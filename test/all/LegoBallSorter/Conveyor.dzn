import TouchSensor.dzn;
import Motor.dzn;
import lego.dzn;

interface IConvey
{
  in void convey();
  out void conveyed();
  in void stop();

  behavior
  {
    enum State {Idle, Conveying};
    State s = State.Idle;

    on stop: s = State.Idle;

    [s.Idle] on convey: s = State.Conveying;
    [s.Idle] on convey: conveyed;
    [s.Conveying] on inevitable: {conveyed; s = State.Idle;}
  }
}

component Conveyor
{
  provides IConvey ctrl;
  requires IMove motor;
  requires ITouchSense sensor;

  behavior
  {
    enum State { Idle, Conveying };
    State s = State.Idle;
    on ctrl.stop():
      {
        motor.stop();
        sensor.disable();
        s = State.Idle;
      }

    [ s.Idle ]
    {
      on ctrl.convey():
        {
          if(sensor.enable() == ITouchSense.TouchState.Pressed) {
            sensor.disable();
            ctrl.conveyed();
          } else {
            motor.run($(config.get("Power::50"))$, $false$); // (power, invert)
            s = State.Conveying;
          }
        }
    }

    [ s.Conveying ]
    {
      on sensor.pressed(), sensor.released():
        {
          sensor.disable();
          motor.stop();
          ctrl.conveyed();
          s = State.Idle;
        }
    }
  }
}
