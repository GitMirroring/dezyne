import IFeed.dzn;
import IConstrainedMove.dzn;
import EndConstrainedAxis.dzn;
import lego.dzn;

component Feeder
{
  provides IFeed ctrl;

  requires IMove motor;
  requires ITouchSense endSensor;

  system
  {
    Feed bhv;
    EndConstrainedAxis axis;

    ctrl <=> bhv.ctrl;
    bhv.axis <=> axis.ctrl;
    axis.motor <=> motor;
    axis.endSensor <=> endSensor;
  }
}

component Feed
{
  provides IFeed ctrl;
  requires IConstrainedMove axis;

  behavior
  {
    subint Count {0..4};
    Count inventory = 0; // number of balls in store
    bool isRetracting = false;
    bool isFeedRequested = false;

    void feedNext() {
      if (inventory == 4) {axis.move($(config.get("Position::Feeder::DropFirst"))$);}
      if (inventory == 3) {axis.move($(config.get("Position::Feeder::DropSecond"))$);}
      if (inventory == 2) {axis.move($(config.get("Position::Feeder::DropThird"))$);}
      if (inventory == 1) {axis.move($(config.get("Position::Feeder::DropLast"))$);}
      inventory = inventory - 1;
    }
    void retract() {
      axis.move($(config.get("Position::Feeder::Retracted"))$);
      isRetracting = true;
    }
    void refill() {
      inventory = 4;
    }

    on ctrl.stop(): {axis.stop(); isRetracting = false; isFeedRequested = false;}
    on ctrl.calibrate(): axis.calibrate();
    on axis.homed(): {ctrl.calibrated(); refill();}
    [!isRetracting] on ctrl.produceBall(): feedNext();
    [isRetracting] on ctrl.produceBall(): isFeedRequested = true;
    [isRetracting] on axis.arrived(): {
      refill();
      if (isFeedRequested) feedNext();
      isRetracting = false;
      isFeedRequested = false;
    }
    on axis.arrived(): [!isRetracting][inventory > 0] ctrl.consumeNextBall();
    on axis.arrived(): [!isRetracting][inventory == 0] {ctrl.consumeLastBall(); retract();}
  }
}
