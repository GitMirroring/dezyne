import IFeed.dzn;
import IConstrainedMove.dzn;
import EndConstrainedAxis.dzn;
import lego.dzn;

component Feeder
{
  provides IFeed ctrl;

  requires IMove motor;
  requires ITouchSense endSensor;

  system
  {
    Feed bhv;
    EndConstrainedAxis axis;

    ctrl <=> bhv.ctrl;
    bhv.axis <=> axis.ctrl;
    axis.motor <=> motor;
    axis.endSensor <=> endSensor;
  }
}

component Feed
{
  provides IFeed ctrl;
  requires IConstrainedMove axis;

  behaviour
  {
    enum State {Lost, Calibrating, Idle, Preparing, Prepared};
    subint Count {0..4};
    State s = State.Lost;
    bool isRetracting = false;
    bool isFeedRequested = false;
    Count inventory = 0; // number of balls in store

    void feedNext() {
      if (inventory == 4) {axis.move($(config.get("Position::Feeder::DropFirst"))$);}
      if (inventory == 3) {axis.move($(config.get("Position::Feeder::DropSecond"))$);}
      if (inventory == 2) {axis.move($(config.get("Position::Feeder::DropThird"))$);}
      if (inventory == 1) {axis.move($(config.get("Position::Feeder::DropLast"))$);}
      s = State.Preparing;
      inventory = inventory - 1;
    }
    void retract() {
      axis.move($(config.get("Position::Feeder::Retracted"))$);
      isRetracting = true;
    }
    void refill() {
      inventory = 4;
    }

    on ctrl.stop(): {axis.stop(); s = State.Lost; isRetracting = false; isFeedRequested = false;}

    [s.Lost]
    {
      on ctrl.calibrate(): {axis.calibrate(); s = State.Calibrating;}
    }
    [s.Calibrating]
    {
      on axis.homed(): {ctrl.calibrated(); refill(); s = State.Idle;}
    }
    [s.Idle]
    {
      on ctrl.produceBall(): [!isRetracting] feedNext();
      on ctrl.produceBall(): [isRetracting] [!isFeedRequested] isFeedRequested = true;
      on axis.arrived(): [isRetracting]
      {
        refill();
        if (isFeedRequested) feedNext();
        isRetracting = false;
        isFeedRequested = false;
      }
    }
    [s.Preparing]
    {
      on axis.arrived(): [inventory > 0] {ctrl.consumeNextBall(); s = State.Prepared;}
      on axis.arrived(): [inventory == 0] {ctrl.consumeLastBall(); retract(); s = State.Idle;}
    }
    [s.Prepared]
    {
      on ctrl.produceBall(): feedNext();
    }
  }
}
