import Stage.dzn;
import lego.dzn;

interface IInspect
{
  in void calibrate();
  out void calibrated();
  in void stop();

  in void inspect(); // inspect ball dropped onto stage
  out void accepted(); // at output take-over waiting to be relieved of accepted ball
  out void rejected(); // at output take-over waiting to be relieved of rejected ball
  in void prepare(); // move to input take-over and prepare to receive next ball
  out void prepared(); // at input take-over ready to receive next ball

  behaviour
  {
    enum State {Lost, Ready, Calibrating, Inspecting, Waiting, Preparing};
    State s = State.Lost;

    on stop: s = State.Lost;

    [s.Lost]
    {
      on calibrate: s = State.Calibrating;
      on calibrate: {calibrated; s = State.Ready;}
      on inspect, prepare: illegal;
    }
    [s.Calibrating]
    {
      on calibrate, inspect, prepare: illegal;
      on inevitable: {calibrated; s = State.Ready;}
    }
    [s.Ready]
    {
      on calibrate, prepare: illegal;
      on inspect: s = State.Inspecting;
    }
    [s.Inspecting]
    {
      on calibrate, prepare, inspect: illegal;
      on inevitable: {accepted; s = State.Waiting;}
      on inevitable: {rejected; s = State.Waiting;}
    }
    [s.Waiting]
    {
      on prepare: s = State.Preparing;
      on prepare: {prepared; s = State.Ready;}
      on calibrate, inspect: illegal;
    }
    [s.Preparing]
    {
      on calibrate, prepare, inspect: illegal;
      on inevitable: {prepared; s = State.Ready;}
    }
  }
}

component Inspector
{
  provides IInspect ctrl;
  requires ilight sensor;

  requires imotor stageXMotorHw;
  requires itouch stageXHomeSensorHw;
  requires itouch stageXEndSensorHw;

  requires imotor stageYMotorHw;
  requires itouch stageYHomeSensorHw;
  requires itouch stageYEndSensorHw;

  system
  {
    Inspect bhv;
    Stage stage;
    timer sensorSettletimer;

    ctrl <=> bhv.ctrl;
    bhv.sensor <=> sensor;
    bhv.stage <=> stage.ctrl;

    stage.xMotorHw <=> stageXMotorHw;
    stage.xHomeSensorHw <=> stageXHomeSensorHw;
    stage.xEndSensorHw <=> stageXEndSensorHw;

    stage.yMotorHw <=> stageYMotorHw;
    stage.yHomeSensorHw <=> stageYHomeSensorHw;
    stage.yEndSensorHw <=> stageYEndSensorHw;

    bhv.sensorSettleTimer <=> sensorSettletimer.port;
  }
}

component Inspect
{
  provides IInspect ctrl;
  requires ilight sensor;
  requires IMove2D stage;
  requires itimer sensorSettleTimer;

  behaviour
  {
    enum State {Lost, Ready, Calibrating, Inspecting, Waiting, Preparing};
    enum InspectPosition {Unknown, Receive, Inspect, Accept, Reject};

    State s = State.Lost;
    InspectPosition p = InspectPosition.Unknown;
    IMove2D.MovePosition receiveX = $(config.get("Position::Inspector::ReceiveX"))$;
    IMove2D.MovePosition receiveY = $(config.get("Position::Inspector::ReceiveY"))$;
    IMove2D.MovePosition inspectX = $(config.get("Position::Inspector::InspectX"))$;
    IMove2D.MovePosition inspectY = $(config.get("Position::Inspector::InspectY"))$;
    IMove2D.MovePosition acceptX = $(config.get("Position::Inspector::AcceptX"))$;
    IMove2D.MovePosition acceptY = $(config.get("Position::Inspector::AcceptY"))$;
    IMove2D.MovePosition rejectX = $(config.get("Position::Inspector::RejectX"))$;
    IMove2D.MovePosition rejectY = $(config.get("Position::Inspector::RejectY"))$;

    void stop()
    {
      sensorSettleTimer.cancel();
      stage.stop();
      sensor.turnoff();
      p = InspectPosition.Unknown;
      s = State.Lost;
    }

    on sensorSettleTimer.timeout(): [!s.Inspecting] illegal;

    [s.Lost]
    {
      on ctrl.stop(): stop();

      on ctrl.calibrate():
        {
          s = State.Calibrating;
          p = InspectPosition.Unknown;
          stage.calibrate();
        }

      on ctrl.inspect(), ctrl.prepare(): illegal;
      on stage.arrived(), stage.calibrated(): illegal;
    }
    [s.Calibrating]
    {
      on ctrl.stop(): stop();
      on stage.calibrated(): [p.Unknown] {stage.move(receiveX, receiveY); p = InspectPosition.Receive;}
      on stage.calibrated(): [!p.Unknown] illegal;
      on stage.arrived(): [p.Receive] {ctrl.calibrated(); s = State.Ready;}
      on stage.arrived(): [!p.Receive] illegal;

      on ctrl.calibrate(), ctrl.inspect(), ctrl.prepare(): illegal;
    }
    [!s.Calibrating] on stage.calibrated(): illegal;

    [s.Ready]
    {
      on ctrl.stop(): stop();
      on ctrl.inspect(): {s = State.Inspecting; stage.move(inspectX, inspectY);}

      on ctrl.calibrate(), ctrl.prepare(): illegal;
      on stage.arrived(): illegal;
    }
    [s.Inspecting]
    {
      on ctrl.stop(): stop();
      on stage.arrived(): [p.Receive]
      {
        p = InspectPosition.Inspect;
        sensor.turnon();
        sensorSettleTimer.create($100$);
      }
      on stage.arrived(): [p.Accept] {ctrl.accepted(); s = State.Waiting;}
      on stage.arrived(): [p.Reject] {ctrl.rejected(); s = State.Waiting;}
      on stage.arrived():  [p.Inspect] illegal;

      on sensorSettleTimer.timeout():
        { 
          ilight.status ballStatus = sensor.detect();
          sensor.turnoff();
          if (ballStatus == ilight.status.accept) {
            stage.move(acceptX, acceptY);
            p = InspectPosition.Accept;
          } else {
            stage.move(rejectX, rejectY);
            p = InspectPosition.Reject;
          }
        }

      on ctrl.calibrate(), ctrl.prepare(), ctrl.inspect(): illegal;
    }
    [s.Waiting]
    {
      on ctrl.stop(): stop();
      on ctrl.prepare():
        {
          s = State.Preparing;
          p = InspectPosition.Receive;
          stage.move(receiveX, receiveY);
        }

      on ctrl.calibrate(), ctrl.inspect(): illegal;
      on stage.arrived(): illegal;
    }
    [s.Preparing]
    {
      on ctrl.stop(): stop();
      on stage.arrived(): {ctrl.prepared(); s = State.Ready;}

      on ctrl.calibrate(), ctrl.prepare(), ctrl.inspect(): illegal;
    }
  }
}
