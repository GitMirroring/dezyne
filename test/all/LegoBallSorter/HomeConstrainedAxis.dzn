import IConstrainedMove.dzn;
import TouchSensor.dzn;
import Motor.dzn;
import lego.dzn;

component HomeConstrainedAxis
{
  provides IConstrainedMove ctrl;
  requires IMove motor; // required by motor
  requires ITouchSense homeSensor; // required by sensor

  behavior
  {
    bool home = false;

    void slowBackward() {motor.run($(config.get("Power::CalibrationSpeed"))$, $true$);}
    void recordHome() {
      homeSensor.disable();
      motor.stop(); // brake
      motor.zero();
    }
    void notifyArrived() {
      motor.stop();
      homeSensor.disable();
      ctrl.arrived();
    }

    on ctrl.stop(): {home = false; motor.stop(); homeSensor.disable();}

    on ctrl.calibrate(): {
      if (homeSensor.enable() == itouch.status.pressed) {
        recordHome();
        ctrl.homed();
      } else {
        home = true;
        slowBackward();
      }
    }

    [home] on homeSensor.pressed(): {
      home = false;
      recordHome();
      ctrl.homed();
    }

    on ctrl.move(target): {
      itouch.status ignore = itouch.status.released;
      ignore = homeSensor.enable();
      motor.move($(config.get("Power::OperationalSpeed"))$, target);
    }

    [!home] on homeSensor.pressed(): { // out of range => recalibrate?
      motor.stop(); recordHome(); notifyArrived();
    }
    on homeSensor.released(): {}
    on motor.arrived(): notifyArrived();
  }
}
