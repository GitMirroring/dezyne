import IFeed.dzn;
import ITransfer.dzn;

import Inspector.dzn;
import Conveyor.dzn;

interface IHandleRobust
{
  in void calibrate();
  out void calibrated();
  in void stop();
  in void operate(); // start next batch
  out void finished(); // batch finished
  behavior
  {
    on calibrate:{}
    on calibrate: calibrated;
    on stop: {}
    on operate: {}
    on operate: finished;
    on optional: calibrated;
    on optional: finished;
  }
}

component Armor
{
  provides IHandleRobust ctrl;
  requires IHandle handler;
  behavior
  {
    enum State {Lost, Calibrating, Idle, Operating};
    State s = State.Lost;

    on ctrl.stop(): {s = State.Lost; handler.stop();}

    [s.Lost]
    {
      on ctrl.calibrate(): {s = State.Calibrating; handler.calibrate();}
      on ctrl.operate(): {}
    }
    [s.Calibrating]
    {
      on ctrl.calibrate(): {}
      on ctrl.operate(): {}
      on handler.calibrated(): {s = State.Idle; ctrl.calibrated();}
    }
    [s.Idle]
    {
      on ctrl.calibrate(): {}
      on ctrl.operate(): {s = State.Operating; handler.operate();}
    }
    [s.Operating]
    {
      on ctrl.calibrate(): {}
      on ctrl.operate(): {}
      on handler.finished(): {s = State.Idle; ctrl.finished();}
    }
  }
}

component MaterialHandler
{
  provides IHandleRobust ctrl;
  requires ITransfer robot;
  requires IInspect inspector;
  requires IFeed feedPort;
  requires IConvey acceptPort;
  requires IConvey rejectPort;
  system
  {
    ctrl <=> armor.ctrl;
    Armor armor;
    armor.handler <=> handler.ctrl;
    Handler handler;
    handler.robot <=> robot;
    handler.inspector <=> inspector;
    handler.feedPort <=> feedPort;
    handler.acceptPort <=> acceptPort;
    handler.rejectPort <=> rejectPort;

  }
}

interface IHandle
{
  in void calibrate();
  out void calibrated();
  in void stop();

  in void operate(); // start next batch
  out void finished(); // batch finished

  behavior
  {
    enum State {Lost, Calibrating, Idle, Operating};
    State s = State.Lost;

    on stop: {s = State.Lost;}

    [s.Lost]
    {
      on calibrate: {s = State.Calibrating;}
      on calibrate: {calibrated; s = State.Idle;}
    }
    [s.Calibrating]
    {
      on inevitable: {calibrated; s = State.Idle;}
    }
    [s.Idle]
    {
      on operate: s = State.Operating;
      on operate: finished;
    }
    [s.Operating]
    {
      on inevitable: {s = State.Idle; finished;}
    }
  }
}

component Handler
{
  provides IHandle ctrl;
  requires ITransfer robot;
  requires IInspect inspector;
  requires IFeed feedPort;
  requires IConvey acceptPort;
  requires IConvey rejectPort;


  behavior
  {
    enum State {Lost, Calibrating, Idle, Operating};
    subint usedCount {0..4};
    enum Operation {PreparingInput, TransferringInput, PreparingOutput, TransferringOutput, Finalizing};

    State s = State.Lost;
    usedCount calibrated = 0;
    usedCount requiredCalibrations = 3; // nr of subsystems requiring calibration (robot, inspector, feedPort)
    Operation o = Operation.PreparingInput;

    bool isLastBall = false;
    bool isBallAtInput = false; // FeedPort ready for input transfer
    bool isRobotAtInput = false;
    bool isRobotAtOutput = false;
    bool isInspectorAtInput = false;
    bool isInspectorAtOutput = false;
    bool isBallAccepted = false;
    bool isAcceptEmpty = true;
    bool isRejectEmpty = true;

    void tryCalibrated() {
      calibrated = calibrated + 1;
      if (calibrated == requiredCalibrations)
      {
        s = State.Idle;
        isInspectorAtInput = true;
        isInspectorAtOutput = false;
        ctrl.calibrated();
      }
    }
    void startBatch() {
      s = State.Operating;
      isLastBall = false;
      prepareInputTransfer();
    }
    void prepareInputTransfer() {
      o = Operation.PreparingInput;
      if (!isBallAtInput) {feedPort.produceBall(); isBallAtInput = false;}
      if (!isInspectorAtInput) illegal;
      if (!isRobotAtInput) {sendRobotToInputPick(); isRobotAtInput = false;}

      tryInputTransfer();
    }
    void sendRobotToInputPick() {
      robot.move($(config.get("Position::Robot::X::InputPick"))$, $(config.get("Position::Robot::Y::InputPick"))$);
      isRobotAtOutput = false;
      isRobotAtInput = false;
    }
    void tryInputTransfer() {
      if (isBallAtInput && isRobotAtInput && isInspectorAtInput) {
        robot.transfer($(config.get("Position::Robot::X::InputDrop"))$, $(config.get("Position::Robot::Y::InputDrop"))$);
        o = Operation.TransferringInput;
      }
    }
    void tryOutputTransfer() {
      if (isRobotAtOutput && isInspectorAtOutput) {
        if (isAcceptEmpty && isBallAccepted) {
          robot.transfer($(config.get("Position::Robot::X::OutputDrop"))$, $(config.get("Position::Robot::Y::AcceptDrop"))$);
          o = Operation.TransferringOutput;
        }
        if (isRejectEmpty && !isBallAccepted) {
          robot.transfer($(config.get("Position::Robot::X::OutputDrop"))$, $(config.get("Position::Robot::Y::RejectDrop"))$);
          o = Operation.TransferringOutput;
        }
      }
    }
    void tryFinished() {
      if (isLastBall && !isBallAtInput && isAcceptEmpty && isRejectEmpty && isRobotAtInput && isInspectorAtInput) {
        s = State.Idle;
        ctrl.finished();
      }
    }
    void manuallyRemoveStrayMaterial() {
      isBallAtInput = false;
      isAcceptEmpty = true;
      isRejectEmpty = true;
    }

    on ctrl.stop():
      {
        robot.stop();
        inspector.stop();
        feedPort.stop();
        acceptPort.stop();
        rejectPort.stop();
        s = State.Lost;

        manuallyRemoveStrayMaterial();
      }

    on ctrl.calibrate(): [s.Lost]
    {
      robot.calibrate();
      inspector.calibrate();
      feedPort.calibrate();

      calibrated = 0;
      s = State.Calibrating;
    }

    [s.Calibrating] on robot.calibrated(),
      inspector.calibrated(),
      feedPort.calibrated(): tryCalibrated();

    on ctrl.operate(): [s.Idle] startBatch();

    [s.Operating] // batch processing
    {
      [o.PreparingInput] // synchronization of feedPort, inspector and robot
      {
        on feedPort.consumeNextBall(): {isLastBall = false; isBallAtInput = true; tryInputTransfer();}
        on feedPort.consumeLastBall(): {isLastBall = true; isBallAtInput = true; tryInputTransfer();}
        on inspector.prepared(): {isInspectorAtInput = true; tryInputTransfer();}
        on robot.arrived(): {isRobotAtInput = true; tryInputTransfer();}
        on acceptPort.conveyed(): isAcceptEmpty = true;
        on rejectPort.conveyed(): isRejectEmpty = true;
      }
      [o.TransferringInput]
      {
        on feedPort.consumeNextBall(): {isLastBall = false; isBallAtInput = true;}
        on feedPort.consumeLastBall(): {isLastBall = true; isBallAtInput = true;}
        on robot.picked(): [!isLastBall] {feedPort.produceBall(); isBallAtInput = false;}
        on robot.picked(): [isLastBall] {isBallAtInput = false;}
        on robot.placed(): {isInspectorAtInput = false; inspector.inspect(); isRobotAtInput = false; robot.move($(config.get("Position::Robot::X::OutputPick"))$, $(config.get("Position::Robot::Y::OutputPick"))$); o = Operation.PreparingOutput;}
        on acceptPort.conveyed(): isAcceptEmpty = true;
        on rejectPort.conveyed(): isRejectEmpty = true;
      }
      [o.PreparingOutput] // synchronization of robot, inspector and (acceptPort or rejectPort)
      {
        on feedPort.consumeNextBall(): {isLastBall = false; isBallAtInput = true;}
        on feedPort.consumeLastBall(): {isLastBall = true; isBallAtInput = true;}
        on inspector.accepted(): {isBallAccepted = true; isInspectorAtOutput = true; tryOutputTransfer();}
        on inspector.rejected(): {isBallAccepted = false; isInspectorAtOutput = true; tryOutputTransfer();}
        on robot.arrived(): {isRobotAtOutput = true; tryOutputTransfer();}
        on acceptPort.conveyed(): {isAcceptEmpty = true; tryOutputTransfer();}
        on rejectPort.conveyed(): {isRejectEmpty = true; tryOutputTransfer();}
      }
      [o.TransferringOutput]
      {
        on feedPort.consumeNextBall(): {isLastBall = false; isBallAtInput = true;}
        on feedPort.consumeLastBall(): {isLastBall = true; isBallAtInput = true;}
        on inspector.prepared(): isInspectorAtInput = true;
        on robot.picked(): {isInspectorAtOutput = false; inspector.prepare();}
        on robot.placed(): [isBallAccepted] {isAcceptEmpty = false; acceptPort.convey(); sendRobotToInputPick(); if (isLastBall && !isBallAtInput) o = Operation.Finalizing; else o = Operation.PreparingInput;}
        on robot.placed(): [!isBallAccepted] {isRejectEmpty = false; rejectPort.convey(); sendRobotToInputPick(); if (isLastBall && !isBallAtInput) o = Operation.Finalizing; else o = Operation.PreparingInput;}
        on acceptPort.conveyed(): isAcceptEmpty = true;
        on rejectPort.conveyed(): isRejectEmpty = true;
      }
      [o.Finalizing]
      {
        on inspector.prepared(): {isInspectorAtInput = true; tryFinished();}
        on robot.arrived(): {isRobotAtInput = true; tryFinished();}
        on acceptPort.conveyed(): {isAcceptEmpty = true; tryFinished();}
        on rejectPort.conveyed(): {isRejectEmpty = true; tryFinished();}
      }
    }
  }
}
