import IConstrainedMove.dzn;

import ITouchSense.dzn;
import IMove.dzn;

component EndConstrainedAxis
{
  // Sensor marks end of range which is considered position 0
  // MoveToPosition must receive negative position values!
  provides IConstrainedMove ctrl;
  requires IMove motor; // required by motor
  requires ITouchSense endSensor; // required by sensor

  behavior
  {
    bool home = false;

    void slowForward() {motor.run($(config.get("Power::CalibrationSpeed"))$, $false$);}
    void recordHome() {
      endSensor.disable();
      motor.stop(); // brake
      motor.zero();
    }
    void notifyArrived() {
      motor.stop();
      endSensor.disable();
      ctrl.arrived();
    }

    on ctrl.stop(): {home = false; motor.stop(); endSensor.disable();}

    on ctrl.calibrate(): {
      if (endSensor.enable() == itouch.status.pressed) {
        recordHome();
        home = true;
        defer {home = false; ctrl.homed();}
      } else {
        home = true;
        slowForward();
       }
    }

    [home] on endSensor.pressed(): {home = false; recordHome(); ctrl.homed();}

    on ctrl.move(target): {
      itouch.status ignore = itouch.status.released;
      ignore = endSensor.enable();
      motor.move($(config.get("Power::OperationalSpeed"))$, target);
    }

    [!home] on endSensor.pressed(): {motor.stop(); notifyArrived();} // out of range => recalibrate?
    on endSensor.released(): {}
    on motor.arrived(): notifyArrived();
  }
}
