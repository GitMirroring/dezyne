import ihello.dzn;

component unreachable_predicates
{
  provides ihello h;

  behavior
  {
    bool defered = false;
    bool reachable0 () = true;           // declarative called (from guard)
    bool reachable1 () = true;           // declarative called (from invariant)
    bool reachable2 () = true;           // imperative called
    bool reachable3 () = true;           // imperative and declarative called
    bool reachable4 () = !reachable5 (); // declarative called
    bool reachable5 () = !reachable6 (); // indirect declarative called
    bool reachable6 () = !reachable7 (); // indirect declarative called
    bool reachable7 () = false;          // indirect declarative called
    bool unused0 () = true;              // unused
    bool unused1 () = locally_used ();   // unused
    bool locally_used () = true;         // called by unused expression function

    [reachable0 ()] on h.hello(): {bool b = reachable2 (); b = reachable3 ();}
    [true] invariant reachable1 ();
    [true] invariant reachable3 ();
    [true] invariant reachable4 ();
  }
}
