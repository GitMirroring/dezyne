// Code:

interface ihello
{
  in void hello();
  out void cruel();
  out void world();

  behaviour
  {
    on hello: {cruel; world;}
    on hello: {world; world;}
  }
}

component hello_function_local_nest
{
  provides ihello h;

  behaviour
  {
    bool b = false;

    bool f ()
      {
        bool bf = true;
        {
          bool lb = b;
          g (lb);
        }
        return bf;
      }
    void g (bool bp)
      {
        if(bp)
          h.world();
        else {
          bool boe = bp;
          boe = ha(boe, bp);
          h.cruel();
        }
      }
    bool ha(bool boe, bool bah)
      {
        return boe && bah;
      }
    on h.hello():
      {
        b = f();
        b = f();
      }
  }
}
