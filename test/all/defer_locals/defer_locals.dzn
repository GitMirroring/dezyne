// Commentary:
//
// Code:

extern int $int$;

interface ihello
{
  in void hello ();
  out void world (int i, int j);

  behavior
  {
    bool idle = true;

    [idle] on hello: idle = false;
    [!idle]
      {
      on hello: idle = true;
      on inevitable: {idle=true; world;}
    }
  }
}

component defer_locals
{
  provides ihello h;
  behavior
  {
    bool idle = true;
    [idle] on h.hello ():
    {
      idle = false;
      int i = $123$;
      defer {idle = true; int j = $543$; h.world (i, j);}
    }
    [!idle] on h.hello (): idle = true;
  }
}
