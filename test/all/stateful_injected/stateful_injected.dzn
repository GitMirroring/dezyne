// Code:


interface ihello
{
  in void hello ();
  in bool cruel ();
  behavior
  {
    bool idle = true;
    [idle] on hello: idle = false;
    [!idle]
    {
      on hello: {}
      on cruel: return true;
    }
  }
}

component hello
{
  provides ihello h;
  requires injected ihello w;
  behavior
  {
    on h.hello (): w.hello ();
    on h.cruel (): return w.cruel ();
  }
}

component cruel
{
  provides ihello h;
  behavior
  {
    on h.hello (): {}
    on h.cruel (): return true;
  }
}

component mux
{
  provides ihello h;
  requires ihello left;
  requires ihello right;
  behavior
  {
    on h.hello (): {left.hello (); right.hello ();}
    on h.cruel (): {bool b = left.cruel (); b = right.cruel () || b; return b;}
  }
}

component stateful_injected
{
  provides ihello h;
  system
  {
    mux m;
    hello left;
    hello right;
    cruel c;

    h <=> m.h;
    m.left <=> left.h;
    m.right <=> right.h;
    c.h <=> *;
  }
}