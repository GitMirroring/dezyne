// Code:

interface ihello
{
  subint Int {-1..1};
  subint INT {-1..1};
  in Int hello ();
  in INT bye ();

  behavior
  {
    on hello: return 1;
    on bye: return -1;
  }
}

component interface_int
{
  provides ihello h;
  requires iworld w;

  behavior
  {
    ihello.Int i = -1;
    on h.hello ():
    {
      ihello.Int j = w.world ();
      i = -1;
      return j;
    }
    on h.bye (): return i;
  }
}

interface iworld
{
  in ihello.Int world ();

  behavior
  {
    on world:
    {
      ihello.Int i = 0;
      return i+1;
    }
  }
}
