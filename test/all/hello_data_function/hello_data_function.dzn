// Commentary:
//
// Replying a data expression is mapped to void during verification,
// however the expression side effects must be retained.
//
// Code:

extern int $int$;

interface ihello_data
{
  in int hello ();
  in int bye ();
  behavior
  {
    on hello, bye:;
  }
}

component hello_data_function
{
  provides ihello_data h;
  requires ihello_data w;
  behavior
  {
    bool idle = true;
    int f (int i)
    {
      return i;
    }
    int g (int i)
    {
      idle = true;
      return i;
    }
    [idle] on h.hello ():
    {
      idle = false;
      reply (f (g ($0$)));
    }
    [idle] on h.bye ():
    {
      idle = false;
      reply (g (w.bye ()));
    }
  }
}
