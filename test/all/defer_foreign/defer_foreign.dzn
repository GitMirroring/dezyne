// Commentary:
//
// Assert that a stateful provides interface on a foreign component has
// its state updated correctly to avoid triggering an illegal while
// meeting its interface contract.
//
// Code:

interface ihello
{
  in void hello ();
  out void cruel ();
  out void world ();
  behavior
  {
    bool idle = true;
    [idle] on hello: idle = false;
    [!idle]
    {
      on inevitable: {idle = true; cruel; world;}
      on inevitable: {idle = true; world;}
    }
  }
}

interface iworld
{
  in void hello ();
  out void cruel ();
  out void world ();
  behavior
  {
    on hello: world;
    on hello: {cruel; world;}
  }
}

component dispatch_defer
{
  provides ihello h;
  requires iworld w;
  behavior
  {
    on h.hello (): defer w.hello ();
    on w.cruel (): h.cruel ();
    on w.world (): h.world ();
  }
}

component foreign
{
  provides iworld h;
}

component defer_foreign
{
  provides ihello h;
  system
  {
    dispatch_defer d;
    foreign f;

    h <=> d.h;
    d.w <=> f.h;
  }
}
