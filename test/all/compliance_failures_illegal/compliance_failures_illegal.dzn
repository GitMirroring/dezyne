// Code:


interface ihello
{
  in void hello();
  out void world();

  behavior
  {
    bool once = true;
    [once] on hello: once = false;
    [!once] on hello: illegal;
    on inevitable: world;
  }
}

interface iworld
{
  in void hello();
  out void world();

  behavior
  {
    on hello: {}
    on inevitable: world;
  }
}

component compliance_failures_illegal
{
  provides ihello h;
  requires iworld w;

  behavior
  {
    on h.hello(): w.hello();
    on w.world(): h.world();
  }
}
