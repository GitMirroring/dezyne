interface ihello
{
  in void hello ();
  out void world ();
  out void cruel ();

  behavior
  {
    bool echo_world = true;

    [echo_world] on hello: {echo_world = false; world;}
    [!echo_world] on hello: {echo_world = true; cruel;}
  }
}

component shared_out_sync_provides
{
  provides ihello h;
  requires ihello w;

  behavior {
    bool echo_world = true;
    bool h_echo_world = true;

    void dzn_assert (bool c)
    {
      if (!c) illegal;
    }

    void check ()
    {
      dzn_assert (h_echo_world == h.echo_world);
    }

    [echo_world] on h.hello ():
    {
      echo_world = false;
      w.hello ();
      check ();
    }
    [!echo_world] on h.hello ():
    {
      echo_world = true;
      w.hello ();
      check ();
    }
    on w.world (): {h.world (); check (); h_echo_world = false;}
    on w.cruel (): {h.cruel (); check (); h_echo_world = true;}
    }
}
