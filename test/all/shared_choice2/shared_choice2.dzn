// Code:

interface ihello
{
  in void hello ();
  in void bye ();
  out void world ();
  out void cruel ();

  behavior
  {
    bool idle = true;
    [idle] on hello: cruel;
    [idle] on hello: idle = false;
    [!idle] on bye: idle = true;
    [!idle] on inevitable: {world; idle = true;}
  }
}

component shared_choice2
{
  provides ihello h;
  requires ihello w;

  behavior
  {
    [h.idle] on h.hello (): w.hello ();
    on w.cruel (): h.cruel ();
    [!h.idle] on h.bye (): w.bye ();
    [!h.idle] on w.world (): h.world ();
  }
}
