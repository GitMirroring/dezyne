// Commentary:
//
// Code:

interface ihello
{
  in void hello();
  out void world();

  behavior
  {
    bool b = false;

    [!b] on hello: b = true;
    [b] on hello: illegal;   // refuse second hello
    [b] on inevitable: {b = false; world;}
  }
}

interface iworld
{
  in void hello();
  in bool terminated();

  behavior
  {
    bool b = false;

    [!b] on hello: b = true;
    [b] on hello: illegal;
    on terminated: reply(!b); // avoids deadlock
  }
}

component compliance_failures_choice
{
  provides ihello h;
  requires iworld w;

  behavior
  {
    bool b = true;

    on h.hello(): {if(b) w.hello(); b = false;} // accept second hello
  }
}

// ihello                            : hello, return, world (refuses hello)
// compliance_failures_choice : hello, return, hello (refuses world)
