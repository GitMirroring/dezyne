// Code:

interface ihello
{
  in bool hello ();
  out void one ();
  out void two( );
  out void foo ();

  behavior
  {
    on hello: {one;two;foo;reply (false);}
  }
}

component complex_assign2
{
  provides ihello h;
  behavior
  {
    bool one () {h.one ();return false;}
    bool two () {h.two ();return true;}

    bool foo (bool x) {h.foo ();return !x;}

    on h.hello ():
    {
      bool x = true;
      x = foo (one () || two ());
      reply (x);
    }
  }
}
