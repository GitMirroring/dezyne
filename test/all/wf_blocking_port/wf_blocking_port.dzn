// Commentary:
//
// Code:

interface ihello
{
  in void hello();
  behavior
  {
    on hello:;
  }
}

component block_nok0 {
  provides blocking ihello p0;
  provides ihello p1;

  requires blocking ihello r;
}

component block_nok1 {
  provides blocking ihello p0;
  provides ihello p1;

  requires ihello r;

  behaviour {
    on p0.hello(): blocking r.hello();
    on p1.hello(): blocking r.hello();
  }
}

component block {
  provides blocking ihello p;
  requires blocking ihello r;
}

component nonblock {
  provides ihello p;
  requires ihello r;
}

component block_nok2 {
  provides ihello pp;
  requires blocking ihello rr;

  system {
      block inst0;
      nonblock inst1;
      block inst2;
      block inst3;
      nonblock inst4;

      pp <=> inst0.p;
      inst0.r <=> inst1.p;
      inst1.r <=> inst2.p;
      inst2.r <=> inst3.p;
      inst3.r <=> inst4.p;
      rr <=> inst4.r;
  }
}

component block_ok0 {
  provides ihello p0;
  provides ihello p1;

  requires ihello r;
}

component block_ok1 {
  provides blocking ihello p0;
  provides ihello p1;

  requires ihello r;
}

component block_ok2 {
  provides blocking ihello p0;
  provides blocking ihello p1;

  requires blocking ihello r;
}

component block_ok3 {
  provides blocking ihello p0;
  provides blocking ihello p1;

  requires ihello r;

  behaviour {
    on p0.hello(): blocking r.hello();
  }
}

component wf_blocking_port
{
  provides ihello p;
  requires ihello r;
  behavior {}
}
