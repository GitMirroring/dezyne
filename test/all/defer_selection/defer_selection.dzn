// Code:

extern T $int$;

interface ihello
{
  in void hello(T t);
  out void world(T t);
  behavior
  {
    bool idle = true;

    [idle] on hello: idle = false;
    [!idle] on inevitable: {idle=true; world;}
  }
}

interface icruel
{
  in void cruel();
  behavior
  {
    on cruel: {}
  }
}

component defer_selection
{
  provides ihello h;
  provides icruel c;

  behavior
  {
    bool idle = true;
    bool cruel = true;
    [idle] on h.hello (t): {idle = false; defer(idle) {idle = true; h.world(t);}}
    on c.cruel(): {cruel = !cruel;}
  }
}
