// Commentary:
//
// This model leads to a duplicate case label in the interface switch
// statement, due to a hash collision caused by using the integer
// representation of the node index in the hash function.
//
// The problem occurs during compilation, hence to avoid executing a
// vast amount of traces a trivial trace is used instead.
//
// Code:

interface ihello
{
  in void _2 ();
  in void _1 ();

  behavior
  {
    subint count_t {0..79};
    count_t count = 0;
    [count < 79]  on _2: count = count + 1;
    on _1: {}
  }
}

component hash_collision2
{
  provides ihello h;

  behavior
  {
    on h._2 (): {}
    on h._1 (): {}
  }
}
