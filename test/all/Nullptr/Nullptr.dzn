// Code:


enum Result { Ok };
 
interface IExample
{
       in Result Start();
       in Result ValuedEvent();
       in void VoidEvent();
       in void Stop(); // Stop is always allowed
      
       enum States { Idle, Running };
      
       behaviour
       {
             States s = States.Idle;
            
             [s.Idle]
             {
                    on Start: { reply(Result.Ok); s = States.Running; }
                    on Stop: {}
                    on ValuedEvent, VoidEvent: illegal;
             }
            
             [s.Running]
             {
                    on Stop:  s = States.Idle;
                    on ValuedEvent: reply(Result.Ok);
                    on VoidEvent: {}
                    on Start: illegal;
             }
            
       }
}
 
component Nullptr
{
       provides IExample api;
       requires IExample usedComponent;
      
       behaviour
       {
             IExample.States s = IExample.States.Idle;
            
             [s.Idle]
             {
                    blocking on api.Start():
                    {
                           Result r = usedComponent.Start();
                           s = IExample.States.Running;
                           reply(r);
                    }
                    on api.Stop():
                    {
                           s = IExample.States.Idle;
                    }
             }
            
             [s.Running]
             {
                    on api.Stop():
                    {
                           usedComponent.Stop();
                           s = IExample.States.Idle;
                    }
                    on api.ValuedEvent():
                    {
                           Result r = usedComponent.ValuedEvent();
                           reply(r);
                    }
                    on api.VoidEvent():
                    {
                           usedComponent.VoidEvent();
                    }
             }
       }
}
 
