// Commentary:
//
// This model asserts proper shared state type resolving of State which
// exists both in the component as well as the interface.
//
// Code:

interface icruel
{
  enum State {A,C,W};
  in State cruel ();
  behavior
  {
    on cruel: reply (State.C);
    on cruel: reply (State.W);
  }
}

interface ihello
{
  in void hello ();
  out void cruel ();
  out void world ();

  behavior
  {
    icruel.State s = icruel.State.A;
    [s.A]
    {
      on hello: {s = icruel.State.C; cruel;}
      on hello: {s = icruel.State.W; world;}
    }
    [s.C] on inevitable: {cruel; s = icruel.State.A;}
    [s.W] on inevitable: {world; s = icruel.State.A;}
  }
}

component shared_indirect_type
{
  provides ihello h;
  requires icruel c;

  behavior
  {
    on h.hello ():
    {
      if (c.cruel () == icruel.State.C) h.cruel ();
      else h.world ();

      defer if (h.s.C) h.cruel ();
            else h.world ();
    }
  }
}
