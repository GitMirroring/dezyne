// Commentary:
//
// Code:

interface ihello
{
  in void hello();
  out void world();

  behavior
  {
    on hello: {}
    on inevitable: world;
  }
}

component hellocheckcompbindings
{
  provides ihello p;
  requires ihello r;

  behavior
  {
    on p.hello(): {
      r.hello();
    }
    on r.world(): {
      p.world();
    }
  }
}

component hellochecksystembindings
{
  provides ihello p;
  requires ihello r;

  system
  {
    hellocheckcompbindings comp;

    comp.p <=> p;
    comp.r <=> r;
  }
}
