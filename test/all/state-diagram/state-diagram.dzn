// Code:

enum S {A,B,C};

enum M {E,F,G};

interface icruel
{
  in M mode();

  behavior
  {
    on mode: reply(M.E);
    on mode: reply(M.F);
    on mode: reply(M.G);
  }
}


interface ihello
{
  in bool hello();
  in void bye();

  out void cruel();
  out void world();

  behavior
  {
    S s = S.A;

    [!s.A] on bye: s = S.A;

    [s.A]
    {
      on hello: {s = S.A; reply(false);}
      on hello: {s = S.B; reply(true);}
    }
    [s.B]
    {
      on optional: {s = S.C; cruel;}
    }
    [s.C]
    {
      on optional: {s = S.A; world;}
    }
  }
}

interface iworld
{
  in bool hello();
  in void bye();

  out void world();

  behavior
  {
    bool idle = true;
    [idle]
    {
      on hello: {idle = false; reply(true);}
      on hello: reply(false);
    }
    [!idle]
    {
      on inevitable: {idle = true; world;}
    }
    on bye: idle = true;
  }
}

component state_diagram
{
  provides ihello h;
  requires iworld w1;
  requires iworld w2;
  requires icruel c;

  behavior
  {
    S s = S.A;
    M m = M.E;

    [s.A] on h.hello():
    {
      s = S.B;
      m = c.mode();
      if (w1.hello())
      {
        if(w2.hello())
        {
          reply(true);
        }
        else
        {
          reply(true);
        }
      }
      else if(m.E)
      {
        s = S.A;
        reply(false);
      }
      else reply(true);
    }
    [s.B]
    {
      on w1.world(), w2.world(): {s = S.C; h.cruel();}
    }
    [s.C]
    {
      on w1.world(), w2.world(): {s = S.A; h.world();}
    }
    [!s.A] on h.bye(): {s = S.A; w1.bye(); w2.bye();}
  }
}
