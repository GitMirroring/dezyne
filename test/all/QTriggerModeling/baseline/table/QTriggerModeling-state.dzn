interface ICallEmitMulti {
  enum EmitResult {One, Two};
  in void req();
  in EmitResult reqValued();
  in void ack();
  in void done();
  out void ntfA();
  out void ntfB();

  behaviour {
    subint Counter {0..2};
    bool isWaiting = false;
    Counter pending = 0;

    [!isWaiting]
    {
      on req:
      {
        ntfA;
        ntfB;
        pending = 2;
        isWaiting = true;
      }
      on reqValued:
      {
        ntfA;
        ntfB;
        pending = 2;
        isWaiting = true;
        reply(EmitResult.Two);
      }
      on ack, done:
      illegal;
    }
    [isWaiting]
    {
      on req, reqValued:
      illegal;
      on ack:
      {
        [pending == 0]
        illegal;
        [otherwise]
        pending = pending - 1;
      }
      on done:
      {
        [pending == 0]
        isWaiting = false;
        [otherwise]
        illegal;
      }
    }
  }
}

interface ICallTrigger {
  in void start();
  out void notLiveLock();

  behaviour {

    [true]
    on start:
    {}
  }
}

interface ITauTrigger {
  in void noDeadlock();
  out void start();

  behaviour {

    [true]
    {
      on noDeadlock:
      {}
      on optional:
      start;
    }
  }
}

component QTriggerModeling {
  provides ICallTrigger ict;
  requires ITauTrigger itt;
  requires ICallEmitMulti src;

  behaviour {
    bool behave = true;
    bool useVoid = true;

    [!behave]
    {
      on ict.start(), itt.start():
      src.req();
      on src.ntfA():
      {
        src.ack();
        src.done();
      }
      on src.ntfB():
      src.ack();
    }
    [behave]
    {
      on ict.start(), itt.start():
      {
        [useVoid]
        src.req();
        [otherwise]
        ICallEmitMulti.EmitResult ignored = src.reqValued();
      }
      on src.ntfA():
      {
        [useVoid]
        src.ack();
        [otherwise]
        src.ack();
      }
      on src.ntfB():
      {
        [useVoid]
        {
          src.ack();
          src.done();
          useVoid = false;
        }
        [otherwise]
        {
          src.ack();
          src.done();
          behave = false;
        }
      }
    }
  }
}

