interface ihello
{
  in void hello();
  in void bye();

  out void world();
  out void cruel();

  behaviour
  {
    enum S {A,B,C,D};
    S s = S.A;

    [s.A]
    {
      on hello: s = S.B;
//      on bye: illegal;
    }
    [s.B]
    {
//      on hello: illegal;
      on bye: s = S.D;
      on optional: {s = S.C; world;}
    }
    [s.C]
    {
//      on hello: illegal;
      on bye: s = S.D;
    }
    [s.D]
    {
//      on hello: illegal;
//      on bye: illegal;
      on inevitable: {s = S.A; cruel;}
    }
  }
}

component illegal_external_inevitable
{
  provides ihello h;
  requires external ihello w;

  behaviour
  {
    enum S {A,B,C};
    S s = S.A;

    [s.A] on h.hello(): {s = S.B; w.hello();}
    [s.B]
    {
      on w.world(): h.world();
      on h.bye(): {s = S.C; w.bye();}
    }
    [s.C]
    {
      on w.cruel(): {s = S.A; h.cruel();}
     }
  }
}
