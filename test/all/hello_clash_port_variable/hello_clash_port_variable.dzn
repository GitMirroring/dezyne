subint number {0..1};

interface IPort
{
  in void i();
  out void o();
  behaviour {
    number r = 0;
    on i: {}
    on optional: o;
  }
}

component hello_clash_port_variable
{
  provides IPort p;
  requires IPort r;

  behaviour
  {
    on p.i(): {}
    on r.o(): {}
  }
}
