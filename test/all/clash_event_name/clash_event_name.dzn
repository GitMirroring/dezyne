// Code:

interface ihello
{
  in void hello ();
  in void hello_in ();
  in void void_helper ();
  out void world ();
  out void world_out ();
  behavior
  {
    on hello: world;
    on hello_in: world_out;
    on void_helper: {}
  }
}

interface iworld
{
  in void hello ();
  out void world ();

  behavior
  {
    on hello: world;
  }
}

component clash_event_name
{
  provides ihello h;
  requires ihello w;

  behavior
  {
    on h.hello (): {h.world ();w.hello ();}
    on h.hello_in (): h.world_out ();
    on h.void_helper (): {}
    on w.world (): {}
  }
}
