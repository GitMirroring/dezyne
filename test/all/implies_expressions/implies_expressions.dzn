import ihello.dzn;

component implies_expressions
{
  provides ihello h;

  behavior
  {
    bool f = false;
    bool t = true;
    enum Bool {FALSE, TRUE};

    void Assert(bool c)
    {
        if (!c) illegal;
    }

    on h.hello():
      {
        bool r = false;
        Assert(f => f);
        Assert(f => t);
        Assert(!(t => f));
        Assert(t => t);
        Assert(f&&f => f); // check that 'not' around first argument has ()
        Assert(f => f&&f); // check that && binds strong than =>
        Assert(1<3 && 3<5 => 1<5); // correct order: "<", "&&", "=>"
      }
  }
}
