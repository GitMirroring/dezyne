// Commentary:
//
// This model demonstrates a simulate compliance error, i.e. a report of
// non-compliance where the component performs h.world where the port
// expects cruel.
//
// Code:

interface ihello
{
  in bool hello ();
  out void cruel ();

  out void world ();
  behavior
  {
    on optional: cruel;
    on hello: {world; reply (true);}
  }
}

interface iworld
{
  in void hello ();
  out void world ();
  behavior
  {
    bool idle = true;
    [idle] on hello: idle = false;
    [!idle] on inevitable: {world; idle = true;}
  }
}

component blocking_optional
{
  provides blocking ihello h;
  requires iworld w;
  behavior
  {
    on h.hello (): blocking w.hello ();
    on w.world (): {h.world (); h.reply (true);}
  }
}
