// Code:

interface ihello {
  in void hello ();
  in void cruel ();
  behavior {
    bool open = true;
    on hello: open = !open;
    [open] on cruel: {}
  }
}

component hello_multiple_provides {
  provides ihello p1;
  provides ihello p2;
  behavior {
    bool p1_open = true;
    on p1.hello (): p1_open = !p1_open;
    [p1_open] on p1.cruel (): {}

    bool p2_open = true;
    on p2.hello(): p2_open = !p2_open;
    [p2_open] on p2.cruel (): {}
  }
}
