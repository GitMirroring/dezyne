import ihello_reply_bool.dzn;

component hello_block_reply_bool_requires2
{
  provides blocking ihello_reply_bool h;
  requires blocking ihello_reply_bool w0;
  requires blocking ihello_reply_bool w1;

  behavior
  {
    on h.hello (): {bool b = w0.hello (); b = w1.hello (); reply (b);}
  }
}
