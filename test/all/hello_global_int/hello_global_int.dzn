// Code:

subint BOOL {0..1};

interface ihello
{
  in BOOL hello();

  behaviour
  {
    on hello: reply (1);
  }
}

component hello_global_int
{
  provides ihello h;
  requires iworld w;

  behaviour
  {
    BOOL b = 0;
    on h.hello():
    {
      b = w.world();
      reply (b);
    }
  }
}

interface iworld
{
  in BOOL world();

  behaviour
  {
    on world: {
      BOOL i = 0;
      reply (i+1);
    }
  }
}
