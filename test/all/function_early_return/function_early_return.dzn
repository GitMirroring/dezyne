// Commentary:
//
// If early function return does not work correctly, the component will
// non-compliant behavior.
//
// Code:

interface ihello
{
  in void hello ();
  out void world ();

  behavior
  {
    bool idle = true;
    [idle] on hello: {idle=false; world;}
    [!idle] on hello: idle=true;
  }
}

component function_early_return
{
  provides ihello h;

  behavior
  {
    bool b = false;
    on h.hello (): g ();
    void f ()
    {
      if (b) return;
      if (b) illegal;
      h.world ();
      bool r = true;
    }
    void g ()
    {
      bool x = false;
      f ();
      b = !b;
      x = !x;
    }
  }
}
