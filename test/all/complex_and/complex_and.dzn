interface ihello
{
  in bool hello ();

  behavior
  {
    on hello: reply (true);
  }
}

component complex_and
{
  provides ihello h;
  behavior
  {
    bool a () {return true;}
    bool b () {return true;}
    bool c () {return false;}

    on h.hello(): {
      bool dummyb = b();
      bool dummyc = c();
      if (a () && b () && c ()) illegal;
      else reply (true);
    }
  }
}
