import ihello.dzn;

interface ichoice
{
  in bool hello ();
  behavior
  {
    bool idle = true;
    on hello:
    {
      [true] reply (idle);
      [true] {idle = false; reply (idle);}
    }
  }
}

component choice_invariant
{
  provides ihello h;
  requires ichoice w;
  behavior
  {
    bool idle = true;
    invariant !idle => !w.idle;
    on h.hello (): {idle = false; idle = w.hello ();}
  }
}
