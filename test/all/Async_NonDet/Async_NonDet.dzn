// Code:

interface INonDet
{
  in void ie();
  in void ic();
  out void os();
  out void of();

  behaviour {
    bool b = false;
    
    [!b] on ie: b = true;
    on ic: {}
    
    [b] {
      on ie: illegal;
      on inevitable: {b = false; os;}
      on inevitable: {b = false; of;}
    }
  }   
}

component Async_NonDet
{
  provides INonDet p;

  behaviour {
    requires dzn.async rs;
    requires  dzn.async rf;
    
    bool armed = false;
    bool disrupt = false;
    

    on p.ic(): disrupt = true;

    [!armed] on p.ie(): {armed = true; disrupt = false; rs.req(); rf.clr();}

    [armed]
    {
      on rs.ack(): [!disrupt] rf.req(); // reached when p.ic(); in fresh client call context or when p.ic() not called
      on rs.ack(): [disrupt] {armed = false; p.os();} // reached when {p.ie();...p.ic()} in same client call context
      on rf.ack(): {armed = false; p.of();}
    }

    // component Async_NonDet shall at least perform trace
    // {p.ie
    // p.return}
    // {p.of}
    
    // {p.ie
    // p.return
    // p.ic
    // p.return}
    // {p.os}
    
    // {p.ie
    // p.return}
    // {p.of}
    // {p.ic
    // p.return}

    // component Async_NonDet shall NOT perform trace
    // {p.ie
    // p.return}
    // {p.os}
    
    // component Async_NonDet shall NOT perform trace
    // {p.ie
    // p.return
    // p.ic
    // p.return}
    // {p.of}

  }
}
