// Code:

interface ihello
{
  in void hello ();
  in void cruel ();

  behavior {
    on hello: {}
    on cruel: {}
  }
}

interface iworld
{
  in void hello ();
  out void world ();

  behavior {
    bool idle = true;
    on hello: idle = !idle;
    [!idle] on inevitable: {world; idle = true;}
  }
}

component Top
{
  provides ihello h;
  requires ihello w;

  behavior
  {
    on h.hello (): w.hello ();
    on h.cruel (): w.cruel ();
  }
}

component Blocked
{
  provides ihello h;
  requires iworld w0;
  requires iworld w1;

  behavior
  {
    bool idle = true;
    bool idle_w0 = true;
    bool idle_w1 = true;
    [idle] blocking on h.hello (): {w0.hello (); w1.hello (); idle = false; idle_w0 = false; idle_w1 = false;}
    on h.cruel(): {}
    on w0.world (): { idle_w0 = true; if (idle_w1) { h.reply(); idle =true; } }
    on w1.world (): { idle_w1 = true; if (idle_w0) { h.reply(); idle =true; } }
  }
}

component collateral_blocking_shell
{
  provides ihello h;
  requires iworld w0;
  requires iworld w1;

  system
  {
    Top top;
    Blocked blocked;

    h <=> top.h;
    top.w <=> blocked.h;
    blocked.w0 <=> w0;
    blocked.w1 <=> w1;
  }
}
