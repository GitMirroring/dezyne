interface I1 {
  enum I1 { E1, E2 }; //<<<<<<<<<<<<
  enum I2 { E3, E3 }; //<<<<<<<<<<<<
  in void e();
  behaviour {
    on e: {}
  }
}

component wf_NameClash {
  provides I1 wf_NameClash; //<<<<<<<<<<<<<<<<<<
  behaviour {
    on wf_NameClash.e(): {}
  }
}

component wf_NameClash2 {
  provides I1 p;
  behaviour {
    enum wf_NameClash2 { E1, E2 }; //<<<<<<<<<<<<<<<<<<
    on p.e(): {}
  }
}

component wf_NameClash3 {
  provides I1 p;
  behaviour {
    bool wf_NameClash3 = false; // <<<<<<<<<<<<<<<<<<<<<
    bool b = true;
    on p.e(): {
      bool b = false;
      bool b = false;  // <<<<<<<<<<<<<<<<<<<<<
    }
  }
}
