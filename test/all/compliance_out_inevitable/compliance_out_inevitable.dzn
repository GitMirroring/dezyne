// Commentary:
//
// Code:

interface ihello
{
  in void hello();
  out void world();

  behaviour
  {
    bool b = false;

    [!b] on hello: b = true;
    [b] on hello: {}
    [b] on inevitable: {b = false; world;}
  }
}

interface iworld
{
  in void hello();
  in void goodbye();
  out void world();

  behaviour
  {
    bool b = false;

    [!b] on hello: b = true;
    [b] on hello: illegal;
    on goodbye: {}
    [b] on optional: {b = false; world;}
  }
}

component compliance_out_inevitable
{
  provides ihello h;
  requires iworld w;

  behaviour
  {
    bool b = false;

    [!b] on h.hello(): {b = true; w.hello();}
    [b] on h.hello(): {}
    on w.world(): h.world();
  }
}


// Expect complhellonce fail:
// Spec ihello allows
// <hello, return, world>
// Impl complhellonce_out_inevitable performs:
// <h.hello, w.hello, w.return, h.return, h.hello>
