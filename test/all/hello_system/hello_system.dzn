// Code:

interface ihello
{
  in void hello();
  out void world();

  behaviour
  {
    bool b = true;
    on hello: b=!b;
    [!b] on optional: {b=!b; world;}
  }
}

component hello_enum
{
  provides ihello p1;
  requires ihello r1;

  behaviour
  {
    enum E {W,T,F};
    E e = E.W;
    [e.W] on p1.hello(): {e=E.T; r1.hello();}
    [e.W] on r1.world(): e = E.F;
    [e.T] on r1.world(): {e=E.F; p1.world();}
    [e.T] on p1.hello(): {e=E.W; r1.hello();}
    [e.F] on p1.hello(): {e=E.T; r1.hello();}
  }
}

component hello_bool
{
  provides ihello p2;
  requires ihello_nondet r2;

  behaviour
  {
    bool b = true;
    on p2.hello(): {b = r2.hello();}
    [!b] on r2.world(): {b=!b; p2.world();}
  }
}

interface ihello_nondet
{
  in bool hello();
  out void world();

  behaviour
  {
    bool b = true;
    on hello: {b = true; reply(true);}
    on hello: {b = false; reply(false);}
    [!b] on inevitable: {b=!b; world;}
  }
}

component hello_system
{
  provides ihello p;
  requires ihello_nondet r;

  system
    {
      hello_enum e;
      hello_bool b;
      p <=> e.p1;
      e.r1 <=> b.p2;
      b.r2 <=> r;
    }
}
