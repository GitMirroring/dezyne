set -ex
pwd
dir=$1
base=$(basename $dir)
out=$dir/out
dzn code --language=c++ --output=$out/c++ --touch-empty-files --model=$base $dir

if ! test -f runtime/.libs/libdzn-c++.so; then
    echo "warning: libdzn-c++.so not found, skipping c++ test" 1>&2
    exit 0
fi

run-build $dir c++
run-execute $dir c++ $dir/trace
