// Verification shall report compliance error

interface IPedal
{
  in void press();
  in void release();

  out void pressed();
  out void released();

  behaviour
  {
    enum State {Pressed, Released};
    State pedal = State.Released;
    on press:
    {
      [pedal.Released] {pedal = State.Pressed; pressed;}
      [pedal.Released] {pedal = State.Pressed;}
      [otherwise] illegal;
    }
    on release:
    {
      [pedal.Pressed] {pedal = State.Released; released;}
      [pedal.Pressed] {pedal = State.Released;}
      [otherwise] illegal;
    }
  }
}

component SyncPedal
{
  provides IPedal left;
  provides IPedal right;

  requires IPedal pedal;

  behaviour
  {
    enum CLIENT {LEFT,RIGHT};
    CLIENT client = CLIENT.LEFT;
    bool left_pressed = false;
    bool right_pressed = false;


    [left_pressed] on left.press(): illegal;
    [!left_pressed && !right_pressed]  on left.press(): {client = CLIENT.LEFT; left_pressed = true; pedal.press(); right.pressed();}
    [!left_pressed && right_pressed]  on left.press(): {left_pressed = true; left.pressed();}

    [right_pressed] on right.press(): illegal;
    [!right_pressed && !left_pressed] on right.press(): {client = CLIENT.RIGHT; right_pressed = true; pedal.press();}
    [!right_pressed && left_pressed] on right.press(): {right_pressed = true; right.pressed();}

    [!left_pressed] on left.release(): illegal;
    [left_pressed && !right_pressed] on left.release(): {client = CLIENT.LEFT; left_pressed = false; pedal.release();}
    [left_pressed && right_pressed] on left.release(): {left_pressed = false;}

    [!right_pressed] on right.release(): illegal;
    [right_pressed && !left_pressed] on right.release(): {client = CLIENT.RIGHT; right_pressed = false; pedal.release();}
    [right_pressed && left_pressed] on right.release(): {right_pressed = false;}

    on pedal.pressed():
    {
      [client.LEFT] left.pressed();
      [client.RIGHT] right.pressed();
    }
    on pedal.released():
    {
      [client.LEFT] left.released();
      [client.RIGHT] right.released();
    }
  }
}
