// import IConsole.dzn;
// import ISensor.dzn;
// import ISiren.dzn;

interface ISiren
{
  in void turnon();
  in void turnoff();

  behavior c
  {
    enum States {
        Off,
        On
    };
    States state = States.Off;

    [state.Off] on turnon: state = States.On;
    [state.On] on turnoff: state = States.Off;
  }
}
interface ISensor
{
  in void enable();
  in void disable();

  out void triggered();
  out void disabled();

  behavior b
  {
    enum States {
        Disabled,
        Enabled,
        Disabling,
        Triggered
    };
    States state = States.Disabled;

    [state.Disabled] on enable: state = States.Enabled;
    [state.Enabled]
    {
      on disable: state = States.Disabling;
      on optional: {triggered; state = States.Triggered;}
    }
    [state.Disabling] on inevitable: {disabled; state = States.Disabled;}
    [state.Triggered] on disable: state = States.Disabling;
  }
}

interface IConsole
{
    in void arm();
    in void disarm();

    out void detected();
    out void deactivated();

  behavior a
  {
    enum States {
        Disarmed,
        Armed,
        Triggered,
        Disarming
    };

    States state = States.Disarmed;

    [state.Disarmed] on arm: state = States.Armed;

    [state.Armed]
    {
      on disarm: state = States.Disarming;
      on optional: {detected; state = States.Triggered;}
    }

    [state.Triggered] on disarm: state = States.Disarming;

    [state.Disarming] on inevitable: {deactivated; state = States.Disarmed;}
  }
}

component AlarmSystem
{
  provides IConsole console;
  requires ISiren siren;
  requires ISensor sensor;

  system
    {
      Alarm alarm;
      Siren siren_;

      console <=> alarm.console;
      alarm.siren <=> siren_.p;
      siren_.r <=> siren;
      alarm.sensor <=> sensor;
    }
}

component Alarm
{
  provides IConsole console;
  requires ISensor sensor;
  requires ISiren siren;

  behavior d
  {
    enum States { Disarmed, Armed, Triggered, Disarming };
    States state = States.Disarmed;
    bool sounding = false;

    [state.Disarmed] on console.arm(): {sensor.enable(); state = States.Armed;}
    [state.Armed]
    {
      on console.disarm():
      {
        sensor.disable();
        state = States.Disarming;
      }
      on sensor.triggered():
      {
        console.detected();
        siren.turnon();
        sounding = true;
        state = States.Triggered;
      }
    }
    [state.Disarming]
    {
      on sensor.triggered():
      {
        //illegal;
      }
      on sensor.disabled():
      {
        [sounding]
        {
          console.deactivated();
          siren.turnoff();
          state = States.Disarmed;
          sounding = false;
        }
        [otherwise]
        {
          console.deactivated();
          state = States.Disarmed;
        }
      }
    }
    [state.Triggered]
    {
      on console.disarm():
      {
        sensor.disable();
        siren.turnoff();
        sounding = false;
        state = States.Disarming;
      }
    }
  }
}

component Siren
{
  provides ISiren p;
  requires ISiren r;

  behavior
  {
    on p.turnon(): r.turnon();
    on p.turnoff(): r.turnoff();
  }
}
