// Commentary:
//
// Code:

interface icruel
{
  in void cruel ();
  behavior
  {
    on cruel: {}
  }
}

interface ihello
{
  in void hello ();
  out void world ();
  behavior
  {
    on hello: world;
  }
}

interface iworld
{
  in void cruel ();
  out void world ();
  behavior
  {
    on cruel: {}
    on inevitable: world;
  }
}

component hello
{
  provides icruel h;
  requires iworld w;
  behavior
  {
    on h.cruel (): {}
    on w.world (): w.cruel ();
  }
}

component world
{
  provides iworld h;
  requires iworld w;
  requires ihello r;
  behavior
  {
    bool first = true;
    [first] on h.cruel (): {}
    on w.world (): {r.hello(); r.hello();}
    [first] on r.world (): {first = false; h.world ();}
    [!first] on r.world (): first = true;
  }
}

component system_flush_double
{
  provides icruel h;
  requires iworld w;
  requires ihello r;
  system
  {
    h <=> top.h;
    hello top;
    top.w <=> bottom.h;
    world bottom;
    bottom.w <=> w;
    bottom.r <=> r;
  }
}
