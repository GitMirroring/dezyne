// Commentary:
//
// Replying a data expression is mapped to void during verification,
// however the expression side effects must be retained.
//
// Code:

extern int $int$;

interface ihello_data
{
  in int hello ();
  behavior
  {
    on hello: {}
  }
}

interface idata
{
  in int get ();
  in void set (int i);
  behavior
  {
    bool unset = true;
    [!unset] on get: unset = true;
    [unset] on set: unset = false;
  }
}

component hello_data_assign
{
  provides ihello_data h;
  requires idata d;
  behavior
  {
    int i = $0$;
    on h.hello ():
    {
      d.set (i);
      i = d.get ();
      reply (i);
    }
  }
}
