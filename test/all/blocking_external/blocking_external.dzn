// Code:

interface ihello {
  in void hello();
  in void cancel();
  out void world();
  behavior {
    bool idle = true;

    [idle] on hello: idle = false;
    [!idle]
    {
      on cancel: idle = true;
      on inevitable: {idle = true; world;}
    }
  }
}

interface iworld {
  in void hello();
  in void cancel();
  out void world();
  out void canceled();
  behavior {
    bool idle = true;

    on cancel: {idle = true; canceled;}
    [idle] on hello: idle = false;
    [!idle] on inevitable: {idle = true; world;}
  }
}

component blocking_external {
  provides blocking ihello h;
  requires external iworld w;

  behavior {
    bool idle = true;
    [idle]
    {  on h.hello():    {idle = false; w.hello();}
       on w.world():    {}
       on w.canceled(): h.reply();
    }
    [!idle]
    {
      blocking on h.cancel(): {idle = true; w.cancel();}
      on w.world():           {idle = true; h.world();}
    }
  }
}
