interface Intf {
  in void evt();
  behavior {
    void f() {
      bool b = false;
      if (b) {
        f();
        b = true;
      }
    }

    on evt: {}
  }
}

interface Intf2 {
  in void evt();
  behavior {
    bool f() {
      bool b = g();
      return b;
    }
    bool g() {
      bool b = f();
      return b;
    }

    on evt: {}
  }
}

interface Intf3 {
  in void evt();
  behavior {
    void f() {
      f();
    }
    void g() {
      f();
      g();
    }

    on evt: {}
  }
}

interface Intf4 {
  in void evt();
  behavior {
    void f() {
      g();
    }
    void g() {
      f();
      bool b = false;
    }

    on evt: {}
  }
}

interface Intf5
{
  in bool hello ();
  behavior
  {
    bool f ()
    {
      return true;
    }
    bool g ()
    {
      return f ();
    }

    on hello: reply (g());
  }
}

interface Intf6
{
  in bool hello ();
  behavior
  {
    bool f ()
    {
      return g ();
    }
    bool g ()
    {
      return f ();
    }

    on hello: reply (g());
  }
}

interface Intf7
{
  in bool hello ();
  behavior
  {
    bool e ()
    {
      return f ();
    }
    bool f ()
    {
      return e ();
    }
    void g ()
    {
      reply (f ());
    }

    on hello: g ();
  }
}

interface Intf8
{
  in bool hello ();
  behavior
  {
    void f ()
    {
      f ();
    }

    on hello: f ();
  }
}

interface Intf9
{
  in bool hello ();
  behavior
  {
    void f ()
    {
      f ();
      return;
    }

    on hello: f ();
  }
}

interface Intf10
{
  in void hello ();
  behavior
  {
    void f ()
    {
      if (false) {f (); return;}
      bool b = false;
    }

    on hello: f ();
  }
}

interface Intf11
{
  in bool hello ();
  behavior
  {
    void f ()
    {
      f ();
      return;
      bool b = true;  // to be caught dynamically by verify
    }

    on hello: f ();
  }
}
