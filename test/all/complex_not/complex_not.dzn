interface ihello
{
  in bool hello ();
  in bool hey ();
  in bool hi ();
  in bool goodbye ();
  in bool bye ();
  in bool sayonara ();
  out void one ();
  out void two ();

  behavior
  {
    on hello: {one;two;reply (true);}
    on hey: {one;two;reply (true);}
    on hi: reply (true);
    on goodbye: {one;reply (true);}
    on bye: {one;reply (true);}
    on sayonara: {one;reply (true);}
  }
}

component complex_not
{
  provides ihello h;
  behavior
  {
    bool one () {h.one ();return false;}
    bool two () {h.two ();return false;}

    on h.hello ():
      if (true && !(one () && two ())) reply (true);
      else reply (false);

    on h.hey ():
      if (false || !(one () || two ())) reply (true);
      else reply (false);

    on h.hi ():
    {
      bool b = true;
      if (!(b == false) && true)
        reply (true);
      else
        reply (false);
    }

    on h.goodbye ():
    {
      reply ((!(one () == true) && true));
    }

    on h.bye ():
    {
      bool b = !one ();
      reply (b);
    }

    on h.sayonara ():
    {
      bool b = true;
      b = !one ();
      reply (b);
    }
  }
}
