interface ihello_world
{
  in void hello ();
  out void world ();

  behavior
  {
    bool idle = true;
    [idle] on hello: idle = false;
    [!idle] on inevitable: {idle = true; world;}
  }
}

interface ihello_reply_bool
{
  in bool hello ();

  behavior
  {
    on hello: reply (true);
    on hello: reply (false);
  }
}

component defer_poll
{
  provides ihello_world h;
  requires ihello_reply_bool w;

  behavior
  {
    void poll ()
    {
      if (w.hello ()) defer {h.world ();}
      // The redundant compound used to trigger a recursion problem.
      else defer {poll ();}
    }
    on h.hello (): poll ();
  }
}
