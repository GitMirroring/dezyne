// Code:

interface ihello
{
  in void hello();

  behavior
  {
    on hello: {}
  }
}

interface iworlds
{
  in void hello();
  out void world();

  behavior
  {
    on hello: world;
  }
}

interface iworlda
{
  in void hello();
  out void world();

  behavior
  {
    bool idle = true;
    [idle] on hello: idle = false;
    [!idle]
    {
      on hello: illegal;
      on inevitable: {idle = true; world;}
    }
  }
}

component multiple_provides
{
  provides ihello left;
  provides ihello right;
  requires iworlds r;

  behavior
  {
    enum Side {None, Left, Right};
    Side side = Side.None;

    subint Count {0..2};
    Count count = 0;

    blocking on left.hello(): {count = count + 1; r.hello(); side = Side.Left;}
    blocking on right.hello(): {count = count + 1; r.hello(); side = Side.Right;}

    [side.Left]
    {
      on r.world(): {count = count - 1; if(count == 0) side = Side.None; left.reply();}
    }
    [side.Right]
    {
      on r.world(): {count = count - 1; if(count == 0) side = Side.None; right.reply();}
    }
  }
}

component block
{
  provides iworlds p;
  requires iworlda r;

  behavior
  {
    blocking on p.hello(): r.hello();
    on r.world(): {p.reply(); p.world();}
  }
}

component blocking_multiple_provides
{
  provides ihello left;
  provides ihello right;
  requires iworlda r;

  system
  {
    multiple_provides mp;
    left <=> mp.left;
    right <=> mp.right;

    block b;
    mp.r <=> b.p;
    b.r <=> r;
  }
}
