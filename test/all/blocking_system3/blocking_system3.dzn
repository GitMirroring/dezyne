import hello_block_requires.dzn;

component blocking_system3
{
  provides blocking ihello h0;
  provides blocking ihello h1;
  provides blocking ihello h2;

  requires blocking ihello_world w0;
  requires blocking ihello_world w1;
  requires blocking ihello_world w2;

  system
  {
    hello_block_requires left;
    hello_block_requires middle;
    hello_block_requires right;

    left.h <=> h0;
    middle.h <=> h1;
    right.h <=> h2;

    left.w <=> w0;
    middle.w <=> w1;
    right.w <=> w2;
  }
}
