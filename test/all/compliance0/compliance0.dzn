interface ihello
{
  in void hello ();
  in void cruel ();

  behavior
  {
    on hello: {}
    on cruel: {}
  }
}

component compliance0
{
  provides ihello p;
  behavior
  {
    on p.hello (): {}
    on p.cruel (): illegal;
  }
}
