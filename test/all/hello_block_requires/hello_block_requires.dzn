// Commentary:
//
// Marking the requires ihello_world port as `blocking' enables using
// this model in blocked system tests.  It would also enable collateral
// blocking, but as there is only one requires port, collateral blocking
// cannot actually occur.
//
// Code:

import ihello.dzn;
import ihello_world.dzn;

component hello_block_requires
{
  provides blocking ihello h;
  requires blocking ihello_world w;
  behavior
  {
    blocking on h.hello (): w.hello ();
    on w.world (): h.reply ();
  }
}
