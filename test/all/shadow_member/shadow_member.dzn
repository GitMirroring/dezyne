// Code:

extern int $int$;

interface I
{
  in void e1(in int g);
  in void e2(out int g);
  in void e3(in int g);
  in void e4(in int g, in int gx);

  behaviour
  {
    on e1: {}
    on e2: {}
    on e3: {}
    on e4: {}
  }
}

component shadow_member
{
  provides I p;

  behaviour
  {
    int g = $1$;

    on p.e1(h): g = h;
    on p.e2(h): {int gx = g; h = gx;}
    on p.e3(g): {int gx = g;}
    on p.e4(gx, h): [true]{g = gx;}
    on p.e4(h, gx): [true]{g = gx;}
  }
}
