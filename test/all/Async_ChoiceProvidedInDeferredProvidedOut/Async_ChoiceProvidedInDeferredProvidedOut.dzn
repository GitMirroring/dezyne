// Test external choice between provided port in event and deferred
// provided port out event.
component Async_ChoiceProvidedInDeferredProvidedOut // also covered by test/all/async_simple.dzn
{
  provides IA pp;

  behaviour
  {
    requires dzn.async() reflector;

    on pp.ia(): {reflector.clr(); reflector.req();}
    on reflector.ack(): pp.oa();
  }

  // component Async_ChoiceProvidedInDeferredProvidedOut shall at least perform trace
  // pp.ia
  // pp.return
  // pp.ia
  // pp.return
  // pp.oa
  // pp.ia
  // pp.return
  // pp.oa
}

interface IA
{
  in void ia();
  out void oa();

  behaviour
  {
    on ia: {}
    on optional: oa;
  }
}

