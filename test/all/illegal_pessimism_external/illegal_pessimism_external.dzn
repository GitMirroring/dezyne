interface ihello
{
  in void hello();
  in void bye();
  out void world();

  behavior
  {
    enum S {A,B,C};
    S s = S.A;
    [s.A]
    {
      on hello: s = S.B;
    }
    [s.B]
    {
      on bye: {s = S.C;}
    }
    [s.C]
    {
      on hello, bye: illegal;
      on inevitable: {s = S.A; world;}
    }
  }
}


interface iworld
{
  in void hello();
  in void bye();

  out void cruel();
  out void world();

  behavior
  {
    enum S {A,B,C};
    S s = S.A;
    [s.A]
    {
      on hello: {s = S.B; cruel;}
      on hello: s = S.B;
    }
    [s.B]
    {
      on bye: s = S.C;
    }
    [s.C]
    {
      on hello,bye: illegal;
      on inevitable: {s = S.A; world;}
    }
  }
}

component illegal_pessimism_external
{
  provides ihello h;
  requires external iworld w;

  behavior
  {
    enum S {A,B,C};
    S s = S.A;

    [s.A] on h.hello(): {s = S.B; w.hello();}
    [s.B]
    {
      on w.cruel(): {}
      on h.bye(): {s = S.C; w.bye();}
    }
    [s.C]
    {
      on w.world(): {s = S.A; h.world();}
    }
  }
}
