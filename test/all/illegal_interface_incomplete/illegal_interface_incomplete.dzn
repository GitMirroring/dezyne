// Code:

interface ihello
{
  in void hello();
  in void bye();
  out void world();

  behavior
  {
    bool seen = false;
    on hello: {seen=true;world;}
    [seen] on bye: {seen=false;world;}
  }
}

interface iworld
{
  in void hello();
  in void bye();

  behavior
  {
    bool idle = false;
    on hello: {}
    [idle] on bye: illegal;
  }
}

component illegal_interface_incomplete
{
  provides ihello h;
  requires iworld w;

  behavior
  {
    bool seen = false;
    on h.hello(): {seen=true;w.hello(); h.world();}
    [seen] on h.bye(): {seen=false; w.bye(); h.world();}
  }
}
