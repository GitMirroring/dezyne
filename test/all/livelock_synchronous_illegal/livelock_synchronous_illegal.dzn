// Code:

interface ihello
{
  in void hello();
  in void cruel();
  behaviour
  {
    on hello: {}
    on cruel: {}
  }
}

interface iworld
{
  in void hello();
  out void world();
  behaviour
  {
    on hello: world;
  }
}

interface isilly
{
  enum E1 {A,B,C,D,E,F};
  in E1 hello();

  enum E2 {A,B,C,D,E,F};
  in E2 world();

  in void cruel();

   behaviour
   {
     on hello: reply(E1.A);
     on hello: reply(E1.B);
     on hello: reply(E1.C);
     on hello: reply(E1.D);
     on hello: reply(E1.E);
     on hello: reply(E1.F);

     on world: reply(E2.A);
     on world: reply(E2.B);
     on world: reply(E2.C);
     on world: reply(E2.D);
     on world: reply(E2.E);
     on world: reply(E2.F);
   }
}

component livelock_synchronous_illegal
{
  provides ihello h;
  requires iworld w;
  requires isilly d;

  behaviour
  {
    isilly.E1 m1 = isilly.E1.A;
    isilly.E2 m2 = isilly.E2.A;

    on h.hello(): w.hello();
    on h.cruel(): d.cruel();
    on w.world():
    {
      m1 = d.hello();
      w.hello();
      m2 = d.world();
    }
  }
}
