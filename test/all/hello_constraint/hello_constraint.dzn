// Commentary:
//
// Without implicit interface constraints, an illegal is triggered.
//
// Code:

interface ihello
{
  in void hello ();
  in void bye ();
  out void world ();

  behavior
  {
    bool idle = true;
    [idle] on hello: idle = false;
    [!idle]
    {
      on inevitable: {idle = true; world;}
      on bye: idle = true;
    }
  }
}

component hello_constraint
{
  provides ihello h;
  requires ihello w;
  behavior
  {
    on h.hello (): w.hello ();
    on w.world (): h.world ();
    on h.bye (): w.bye ();
  }
}
