component LivelockInModel
{
  provides I pp;
  
  behaviour
  {
    void fn() {fn();}
    
    on pp.ia(): fn();
  }
  // Simulating component 'LivelockInModel' =>
  //   Livelock in model LivelockInModel
  // if the following trace is performed:
  //   pp.ia
}

interface I
{
  in void ia();
  behaviour
  {
    on ia: {}
  }
}
