// Commentary:
//
// There is a compliance bug on line 58 that is not found by the
// verifier
//
// Code:

interface ihello
{
  in void doit();
  in void cancel();
  out void done();

  behaviour
  {
    bool busy = false;

    [!busy] on doit: busy=true;
    [busy]
    {
      on cancel: busy=false;
      on inevitable: {done; busy=false;}
    }
  }
}

component compliance_livelock_escape
{
  provides ihello p;
  requires ihello r;

  behaviour
  {
    bool busy = false;

    [!busy] on p.doit(): {r.doit(); busy=true;}
    [busy]
    {
      on r.done(): r.doit(); /* BUG: should be r.done(), not found by
                              * verifier */
      on p.cancel(): {r.cancel(); busy=false;}
    }
  }
}
