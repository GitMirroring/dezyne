// Code:

interface ihello
{
  enum Bool {FALSE,TRUE};
  in Bool hello ();

  behavior
  {
    on hello: reply (Bool.FALSE);
    on hello: reply (Bool.TRUE);
  }
}

interface iworld
{
  in void hello ();
  out void cruel ();
  out void world ();

  behavior
  {
    on hello: cruel;
    on hello: world;
  }
}

component sync_out_reply_enum
{
  provides ihello h;
  requires iworld w;

  behavior
  {
    on h.hello (): w.hello ();
    on w.cruel (): h.reply (ihello.Bool.FALSE);
    on w.world (): h.reply (ihello.Bool.TRUE);
  }
}
