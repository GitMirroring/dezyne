interface ihello {
  in void hello();
  out void cruel();
  out void world();

  behaviour {
    on hello: illegal;
    on inevitable: { cruel;world; }
  }
}

component async_flush {
  provides ihello p;
  requires ihello r;

  behaviour {
    requires dzn.async async;

    on r.cruel(): {
      p.cruel();
      async.req();
    }

    on r.world(): {
      p.world();
    }

    on async.ack(): {
    }
  }
}
