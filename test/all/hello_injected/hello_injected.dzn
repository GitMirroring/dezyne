import ihelloworld.dzn;
import helloworld.dzn;

interface ilogger
{
  in void log ();
  behavior
  {
    on log:{}
  }
}

component logger
{
  provides ilogger log;
  behavior
  {
    on log.log (): {}
  }
}

component helloworld_injected
{
  provides ihelloworld h;
  requires ihelloworld w;
  requires injected ilogger l;

  behavior
  {
    on h.hello (): {l.log (); w.hello ();}
    on w.world (): {l.log (); h.world ();}
  }
}

component hello_injected
{
  provides ihelloworld h;
  system
  {
    logger log;
    helloworld_injected top;
    helloworld bottom;

    h <=> top.h;
    top.w <=> bottom.h;
    log.log <=> *;
  }
}
