import IDezyne.dzn;
import IBackend.dzn;
import IUserDB.dzn;
import IAccountDB.dzn;
import ITimer.dzn;


component DezyneApplication
{
/* Component implementing the Dezyne Server services defined in the IDezyne interface.
 * The server is responsible for AAA (Authentication, Authorisation, Accounting)
 * and all modelling related services:
 * - well-formedness checking
 * - generating views (state diagram, state table, system view)
 * - verification
 * - simulation
 * - code generation
 *
 * In this example only authentication, authorisation and checking + verification of
 * models is modelled.
 * Users are allowed to use the services for a certain defined amount of time.
 * When this session is expired, users have to re-authenticate.
 */
  provides IDezyne iDezyne;
  requires IBackend ibackend;
  requires IUserDB userDB;
  requires IAccountDB accountDB;
  requires ITimer timer;                 // timer is used to model session duration

  behaviour
  {
    enum AuthState
    { Unknown, Authenticating, Authorized };

    AuthState state = AuthState.Unknown; // state variable representing the state of the interface
    bool ModelCheckOngoing = false;
    bool VerificationOngoing = false;
    bool SessionExpired = false;
    IAccountDB.result SeatAvailable = IAccountDB.result.NotAvailable;

    [state.Unknown]                      // initial state, user is unknown
    {
      on iDezyne.authenticate():
      {
        userDB.checkUser();                // request the userDB to check the user
        state = AuthState.Authenticating;
      }
      // apart from authentication all other services are not yet accessible:
      on iDezyne.checkModel(), iDezyne.verifyModel(): illegal;
      on userDB.UserCredentialsOK(),
        userDB.UserCredentialsNOK(),
        userDB.UserUnknown(): illegal;
      on ibackend.checkModelRes(),
        ibackend.verifyModelRes(): illegal;
      on timer.timeout(): illegal;
    }

    [state.Authenticating]               // authentication is ongoing
    {
      on userDB.UserCredentialsOK():
      {
        SeatAvailable = accountDB.checkIfSeatAvailable();
        if (SeatAvailable == IAccountDB.result.Available)   // check if license is available
        {
            state = AuthState.Authorized;
            timer.createTimer();                              // start the session timer
            iDezyne.authenticateSuccess();                    // return that authentication was successful
        }
        else
        {
          state = AuthState.Unknown;
            iDezyne.authenticateFailed();                     // license was not available
        }
      }
      on userDB.UserCredentialsNOK(), userDB.UserUnknown():     // credentials not ok
      {
        iDezyne.authenticateFailed();
        state = AuthState.Unknown;
      }
      // all other services or results are not possible:
      on iDezyne.checkModel(), iDezyne.verifyModel(): illegal;
      on iDezyne.authenticate(): illegal;
      on ibackend.checkModelRes(),
        ibackend.verifyModelRes(): illegal;
      on timer.timeout(): illegal;
    }

    [state.Authorized]                   // user is authorized
    {
      on iDezyne.authenticate():
      {
        illegal;
      }
      on timer.timeout():                                 // session timer expires
      {
        [ModelCheckOngoing || VerificationOngoing]  // in case a transaction is ongoing:
        {                                           // component waits for the result
          SessionExpired = true;                  // of the transaction before
          iDezyne.reauthenticateNeeded();           // jumping to the Unknown state
        }
        [otherwise]                                 // in case no transaction is ongoing
        {                                           // component can immediately jump
          state = AuthState.Unknown;              // to the Unknown state.
          iDezyne.reauthenticateNeeded();
        }
      }
      on iDezyne.checkModel():
      {
      [!SessionExpired]                               // check if the session has not expired
      {
          [ModelCheckOngoing]                         // if a model check is already ongoing
          {                                           // another one is not allowed.
            illegal;
          }
          [!ModelCheckOngoing]
          {
            ModelCheckOngoing = true;
                ibackend.checkModel();
                reply(IDezyne.res.Ok);
          }
      }
      [otherwise]                                      // the session expired
      {
        reply(IDezyne.res.Nok);                      // reply that model check could not be done
      }
      }
      on iDezyne.verifyModel():
      {

      [!SessionExpired]
      {
          [VerificationOngoing]
          {
            illegal;
          }
          [!VerificationOngoing]
          {
            VerificationOngoing = true;
                ibackend.verifyModel();
                reply(IDezyne.res.Ok);
          }
      }
      [otherwise]
      {
        reply(IDezyne.res.Nok);
      }
      }
      on ibackend.checkModelRes():
      {
        ModelCheckOngoing = false;
        if (SessionExpired && !VerificationOngoing)    // in case session is expired and
        {                                              // there is no other transaction ongoing
          SessionExpired = false;
          state = AuthState.Unknown;
        }
        iDezyne.checkModelRes();
      }
      on ibackend.verifyModelRes():
      {
        VerificationOngoing = false;
        if (SessionExpired && !ModelCheckOngoing)      // in case session is expired and
        {                                              // there is no other transaction ongoing
          SessionExpired = false;
          state = AuthState.Unknown;
        }
        iDezyne.verifyModelRes();
      }
      on userDB.UserCredentialsOK(),
        userDB.UserCredentialsNOK(),
        userDB.UserUnknown(): illegal;
    }
  }
}
