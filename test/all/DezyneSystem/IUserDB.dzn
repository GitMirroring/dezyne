// Code:

interface IUserDB
{
/* Interface of the Authentication Server responsible for user authentication services: 

 */
  in void checkUser();
  out void UserCredentialsOK();        // In this example possible results of
  out void UserCredentialsNOK();       // authentication have been modelled
  out void UserUnknown();              // by separate events
  behaviour
  {
    enum States
    {Idle, Checking};
    States state = States.Idle;        // state variable representing the state of the interface

    [state.Idle]
    {
      on checkUser: state = States.Checking;
    }
    [state.Checking]
    {
      on checkUser: illegal;           // if authentication is already ongoing, it is not allowed to do another one

      // eventually the server will return a result
      // below the possible result cases are defined
      on inevitable:
      {
        state = States.Idle;
        UserCredentialsOK;             // the user credentials are ok
      }
      on inevitable:
      {
        state = States.Idle;
        UserCredentialsNOK;            // the user credentials are not ok
      }
      on inevitable:
      {
        state = States.Idle;
        UserUnknown;                   // the user is unknown
      }
    }
  }
}
