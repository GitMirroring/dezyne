// Code:

interface ihello
{
  enum r {f,t};
  in r hello();

  behaviour
  {
    on hello: reply (r.f);
  }
}

component hello_enum
{
  provides ihello h;
  requires iworld w;

  behaviour
  {
    ihello.r m = ihello.r.t;
    on h.hello():
      {
        ihello.r e = ihello.r.f;
        e = w.world();
        reply (e);
      }
  }
}

interface iworld
{
  in ihello.r world();

  behaviour
  {
    on world: reply (ihello.r.f);
  }
}
