namespace r {
  namespace r {
    interface ihello {
      enum r {t,f};
      in void hello ();
      behavior {
        on hello: {}
        }
      }
    }
}

namespace r.r.iworld {
  enum r {t,f};
}

interface ihello
{
  enum r {t,f};
  in .r.r.ihello.r hello();

  behavior
  {
    on hello: reply (.r.r.ihello.r.f);
  }
}

component hello_namespace_shadow
{
  provides ihello h;
  requires iworld w;

  behavior
  {
    enum R {f,t};

    on h.hello():
      {
        r.r.ihello.r r1 = w.world();
        r.r.iworld.r t = r.r.iworld.r.f;
        r.r.ihello.r q = r1;
        r.r.ihello.r s = r1;
        reply (r1);
      }
  }
}

interface iworld
{
  in r.r.ihello.r world();

  behavior
  {
    on world: reply (r.r.ihello.r.f);
  }
}
