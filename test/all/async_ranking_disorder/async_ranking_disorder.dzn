interface ihello
{
  in void start();
  in void stop();
  out void tick();

  behaviour
  {
    bool operational = false;

    [!operational]
      {
        on start: operational = true;
        on stop: {}
      }

    [operational]
      {
        on start: illegal;
        on stop: operational = false;
        on optional: tick;
      }
    }
}

component Top
{
  provides ihello p;
  requires iworld w;

  behaviour
  {
    requires dzn.async tick;

    bool operational = false;

    [!operational]
      {
        on p.start():
        {
          tick.req();
          w.hello();
          operational = true;
        }
        on p.stop(): {}
      }

    [operational]
      {
        on p.stop():
        {
          tick.clr();
          operational = false;
        }
        on tick.ack(): p.tick();
      }
    }
}

interface iworld
{
  in void hello();
  out void world();

  behaviour
  {
    bool idle = true;
    [idle] on hello: idle = false;
    [!idle] {
//      on hello: illegal;
      on inevitable: {idle = true; world;}
    }
  }
}

component Bottom
{
  provides iworld p;
  behaviour
  {
    requires dzn.async async;
    on p.hello(): async.req();
    on async.ack(): p.world();
  }
}

component async_ranking_disorder
{
  provides ihello p;
  system
  {
    Top top;
    top.p <=> p;

    Bottom bottom;
    bottom.p <=> top.w;
  }
}
