// Code:

interface ihello
{
  enum Status{OK};
  in Status hello ();

  behavior
  {
    on hello: return Status.OK;
  }
}

interface iworld
{
  in void hello ();
  out void world ();

  behavior
  {
    bool pending = false;
    on hello:
    {
      [!pending] pending = true;
      [pending] illegal;
    }
    on inevitable:
    {
      [pending]{pending = false; world;}
    }
  }
}

component DoubleBlocked
{
  provides blocking ihello provided;

  requires blocking ihello blockedL;
  requires blocking ihello blockedR;

  behavior
  {
    on provided.hello (): {ihello.Status r = blockedL.hello (); r = blockedR.hello (); return r;}
  }
}

component Blocked
{
  provides blocking ihello provided;

  requires blocking iworld required;

  behavior
  {
    blocking on provided.hello (): required.hello ();

    on required.world (): provided.return ihello.Status.OK;
  }
}

component blocking_system4
{
  provides blocking ihello port;

  requires blocking iworld asyncL;
  requires blocking iworld asyncR;

  system
  {
    DoubleBlocked blocked;
    Blocked blockedL;
    Blocked blockedR;

    port <=> blocked.provided;
    blocked.blockedL <=> blockedL.provided;
    blocked.blockedR <=> blockedR.provided;

    blockedL.required <=> asyncL;
    blockedR.required <=> asyncR;
  }
}
