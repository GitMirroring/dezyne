import hello_block_reply_bool_requires2.dzn;
import hello_block_reply_bool_requires.dzn;

component blocking_system4
{
  provides blocking ihello_reply_bool h;

  requires blocking ihello_world w0;
  requires blocking ihello_world w1;

  system
  {
    hello_block_reply_bool_requires2 top;
    hello_block_reply_bool_requires left;
    hello_block_reply_bool_requires right;

    h <=> top.h;
    top.w0 <=> left.h;
    top.w1 <=> right.h;
    left.w <=> w0;
    right.w <=> w1;
  }
}
