// Code:

bool g_f ();

interface ihello
{
  in void hello ();
  in void bye ();
  out void cruel ();
  out void world ();

  behavior
  {
    on hello: {}
    on bye: cruel;
    on bye: world;
  }
}

component hello_foreign_function_bool_state
{
  provides ihello h;
  behavior
  {
    bool b = false;
    on h.hello (): b = g_f ();
    on h.bye (): if (b) h.world (); else h.cruel ();
  }
}
