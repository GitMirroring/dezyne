// Code:

interface ihello
{
  in void hello();
  behavior
  {
    on hello: {}
  }
}

component proxy
{
  provides ihello p;
  requires ihello r;
  behavior
  {
    on p.hello(): r.hello();
  }
}

component mux
{
  provides ihello left;
  provides ihello right;

  behavior
  {
    bool blocked = false;
    blocking on left.hello(): blocked = true;
    [blocked] on right.hello(): {blocked = false; left.reply();}
    [!blocked] on right.hello(): {}
  }
}

component blocking_multiple_provides0
{
  provides ihello left;
  provides ihello right;
  system
  {
    left <=> m.left;
    mux m;
    right <=> p.p;
    proxy p;
    p.r <=> m.right;
  }
}
