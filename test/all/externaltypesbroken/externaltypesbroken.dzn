extern integer $int$;
enum Global { aap, noot };


interface Iexternaltypes {
  enum E { yes, no };
  extern bl $bool$;
  in Global e();
  in void f(integer i);
  in E g(); 
  
  behaviour {
    on e: {reply(Global.aap);}
    on f: {}
    on g: {reply(E.yes);}
  }
}

component externaltypes {
  provides Iexternaltypes i;
  
  behaviour {
    integer n;
    Iexternaltypes.bl b;
    
    on i.e(): {reply(Global.aap);}
    on i.f(np): {}
    on i.g(): {reply(Iexternaltypes.E.yes);}
  }
}

