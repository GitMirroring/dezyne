interface ihello_optional_choice4
{
  in void hello ();
  out void world ();
  out void cruel ();

  behavior
  {
    bool idle=true;
    bool foo=true;

    [idle] on hello:
    {
      [true] {idle=false; cruel;}
      [true] {foo=false; world;}
    }

    [!idle]
    {
      on hello: idle=true;
      on optional: {idle=false; world;}
    }
  }
}
