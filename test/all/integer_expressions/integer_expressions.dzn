// int members, assignment, if, if-else, use all operators (tests subset)
interface I
{
  in void e();
  out void a();
  out void hi();
  out void lo();

  behavior
  {
    subint State {0..3};

    State state = 3;
    State c = 0;

    [true]
      on e:
      {
        if (state == 0 && state != 1)
        {
          if (state != 1)
            state = 3;
          if (!(state == 3) && true)
            a;
          if (true && !(state == 3))
            a;
          a;
        }
        else
        {
          state = state - 1;
          if (c < state)
          {
            c = c + 1;
          }
          //else
          else if (c >= state || c > state)
          {
            if (c >= (state + 3))
              lo;
            if (c <= (state + 1))
              lo;
            else
            {
              if (c > state)
              {
                hi;
              }
            }
          }
        }
      }
  }
}

component integer_expressions
{
  provides I i;

  behavior
  {
    subint State {0..3};

    State state = 3;
    State c = 0;

    [true]
      on i.e():
      {
        if (state != 1 && state == 0)
        {
          if (state != 1)
            state = 3;
          if (!(state == 3) && true)
            i.lo();
          if (true && !(state == 3))
            i.a();
          i.a();
        }
        else
        {
          state = state - 1;
          if (c >= (state + 3))
            i.lo();
          if (c < state)
            c = c + 1;
          else
          {
            if (c <= (state + 1))
              i.lo();
            else if (c >= state || c > state)
            {
              if (c > state)
                i.hi();
            }
          }
        }
      }
  }
}
