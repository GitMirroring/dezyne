// Commentary:
//
// Code:

// camera hardware:
//   lens: focus => ILens
//   shutter => IShutter
//   flash => IFlash
//   sensor acquire image => ISensor
//   memory: store/retrieve image => IMemory

// camera software abstractions:
//   optics: controls the optical path: lens, focus, shutter
//   acquisition: controls the imaging path: sensor, memory
//   driver: relays user control to optics and acquisition


// Hardware components (Memory, CMOS, Lens, Contrast and Shutter)
interface ILens
{
  in void forward();
  in void backward();
  in void stop();

  out void stopped();

  behaviour
  {
    bool moving = false;

    [!moving] {
      on forward: {moving = true;}
      on backward: {moving = true;}
    }
    [moving] {
      on forward: illegal;
      on backward: illegal;
      on inevitable: {moving = false; stopped;}
    }
    on stop: moving = false;
  }
}
component Lens
{
  provides ILens port;
}
interface IContrast
{
  enum EContrast {Sharper, Blurrier};
  in EContrast measure();

  behaviour
  {
    on measure: reply(EContrast.Sharper);
    on measure: reply(EContrast.Blurrier);
  }
}
component Contrast // focus sensor
{
  provides IContrast port;
}
interface IShutter
{
  in void expose();
  behaviour
  {
    on expose: {}
  }
}
component Shutter
{
  provides IShutter port;
}

interface ISensor
{
  in void prepare();
  in void acquire();
  in void cancel();
  out void image();

  behaviour
  {
    enum State {Idle, Ready, Acquire};
    State state = State.Idle;

    on cancel: state = State.Idle;

    [state.Idle]
    {
      on prepare: state = State.Ready;
      on acquire: illegal;
    }
    [state.Ready]
    {
      on prepare: illegal;
      on acquire: state = State.Acquire;
    }
    [state.Acquire]
    {
      on prepare, acquire : illegal;
      on inevitable: {state = State.Idle; image;}
    }
  }
}
component CMOS
{
  provides ISensor port;
}

interface IMemory
{
  in void store();
  behaviour
  {
    on store:{}
  }
}
component Memory
{
  provides IMemory port;
}

interface IControl
{
  in void setup(); // focus
  in void shoot(); // expose
  in void release();

  out void focus_lock();
  out void image();

  behaviour
  {
    enum State {Idle, Setup, Ready, Acquire};
    State state = State.Idle;

    [state.Idle] {
      on setup:{ state = State.Setup; }
      on shoot,
      release: illegal;
    }
    [state.Setup] {
      on setup: illegal;
      on shoot: { state = State.Acquire; }
      on release: { state = State.Idle; }
      on optional: { state = State.Ready; focus_lock; }
    }
    [state.Ready] {
      on setup: illegal;
      on release: { state = State.Idle; }
      on shoot: { state = State.Acquire; }
    }
    [state.Acquire] {
      on setup,
      release,
      shoot: illegal;
      on inevitable: { image; state = State.Idle; }
    }
  }
}

// Incremental green-field development of Camera Driver:
// 0. The hardware components (Memory, CMOS, Lens, Contrast and
//    Shutter) are given.
// 1. Initial UX design => IControl interface
// 2. Start with an initial component design and empty interfaces for
//    the non-hardware components. (No behaviours yet.)
// 3. Discover interfaces by wishfull thinking. How would components
//    collaborate to fullfill functional requirements?
//    a. acquire a focussed image;
// TODO
//    b. acquire a blurry image (serving an impatient user);
//    c. abstain from taking an image.
// 4. Review non-functional aspects of current design.
// 5. Refactor current design while proving compliance with functional
//    requirements.

// Functional requirements:
// a. acquire focussed image
//   control.setup -> projection.focus
//   projection.focussed -> control.focus_lock
//   control.shoot -> acquisition.expose
//   acquisition.exposed -> control.image

component Driver
{
  provides IControl control;
  requires IProjection projection;
  requires IAcquisition acquisition;

  behaviour
  {
    on control.setup(): projection.focus();
    on control.shoot(): acquisition.expose();
    on control.release(): {}

    on projection.focussed(): control.focus_lock();
    on acquisition.exposed(): control.image();
  }
}

interface IProjection
{
  in void focus();
  out void focussed();

  behaviour
  {
    on focus: {}
    on optional: focussed;
  }
}

component Projection
{
  provides IProjection control;

  system
  {
    Project project;

    Lens lens;
    Contrast focusSensor;

    control <=> project.control;
    project.lens <=> lens.port;
    project.focusSensor <=> focusSensor.port;
  }
}

component Project
{
  provides IProjection control;
  requires ILens lens;
  requires IContrast focusSensor;

  behaviour
  {
    enum Direction {Stopped, Forward, Backward};
    Direction d = Direction.Stopped;

    void focus()
    {
      IContrast.EContrast c = IContrast.EContrast.Blurrier;
      if (d.Stopped) {
        d = Direction.Forward;
        lens.forward();
      } else {
        c = focusSensor.measure();
        if (d.Backward) if (c.Blurrier) {d = Direction.Stopped; control.focussed();} else lens.backward();
        if (d.Forward) if (c.Blurrier) {d = Direction.Backward; lens.backward();} else lens.forward();
      }
    }

    on control.focus(): focus();
    on lens.stopped(): focus();
  }
}

interface IAcquisition
{
  in void expose();
  out void exposed();

  behaviour
  {
    on expose: {}
    on optional: exposed;
  }
}

component Acquisition
{
  provides IAcquisition control;

  system
  {
    Acquire acquire;

    CMOS imageSensor;
    Memory sdCard;
    Shutter shutter;

    control <=> acquire.control;
    acquire.imageSensor <=> imageSensor.port;
    acquire.sdCard <=> sdCard.port;
    acquire.shutter <=> shutter.port;
  }
}

component Acquire
{
  provides IAcquisition control;
  requires ISensor imageSensor;
  requires IMemory sdCard;
  requires IShutter shutter;

  behaviour
  {
    on control.expose(): {imageSensor.prepare(); shutter.expose(); imageSensor.acquire();}
    on imageSensor.image(): {sdCard.store(); control.exposed();}
  }
}

component Camera
{
  provides IControl control;

  system
  {
    Driver driver; // high-level coordination
    Projection projection; // projects (focussed) image onto sensor
    Acquisition acquisition; // extract and store image data from sensor

    control <=> driver.control;
    driver.projection <=> projection.control;
    driver.acquisition <=> acquisition.control;
  }
}
