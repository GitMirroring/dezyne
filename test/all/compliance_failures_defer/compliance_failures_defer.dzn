// Code:

interface ihello
{
  in void hello();
  in void cancel();
  out void world();

  behavior
  {
    bool idle = true;

    [idle] on hello: idle = false;
    [!idle] on inevitable: {idle = true; world;}
  }
}

interface icruel
{
  in bool cruel();
  behavior
  {
    on cruel: reply(true);
    on cruel: reply(false);
  }
}

component compliance_failures_defer
{
  provides ihello h;
  requires icruel c;
  behavior
  {
    bool idle = true;
    [idle] on h.hello (): {idle = false; defer {idle = true; if(c.cruel()) h.world();}}
  }
}
