interface ihello
{
  in bool hello();
  in bool cruel();
  out void world();
  behavior
  {
    bool idle = true;
    [idle]
    {
      on hello: {reply(true); world;}
      on cruel: {idle = false; reply(true);}
    }
    [!idle] on inevitable: {idle = true; world;}
  }
}

interface iworld
{
  in void hello();
  out void world();
  behavior
  {
    on hello: world;
  }
}

component deadlock_reply
{
  provides ihello h;
  requires iworld l;
  requires ihello r;
  behavior
  {
    enum S {A,B,C,D};
    S s = S.A;
    [s.A]
    {
      on h.hello(): {s = S.B; l.hello();}
      on h.cruel(): {s = S.B; reply(r.cruel());}
    }
    [s.B]
    {
      on l.world(): {s = S.A; h.reply(true); h.world();}
      on r.world(): {s = S.A; h.world(); h.reply(true);}
    }
  }
}