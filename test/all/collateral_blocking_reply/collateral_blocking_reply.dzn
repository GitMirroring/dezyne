// Code:

interface ihello
{
  in void hello ();
  out void world ();

  behaviour
  {
    bool idle = true;
    [idle] on hello: world;
    [idle] on hello: idle=false;
    [!idle] on inevitable: {idle=true;world;}
  }
}

interface iblock
{
  in bool hello ();

  behaviour
  {
    on hello: reply (true);
  }
}

component collateral_blocking_reply
{
  provides blocking ihello h;
  requires blocking iblock b;
  requires ihello r;

  behaviour
  {
    bool idle = true;
    [idle] on h.hello (): {idle=false; r.hello (); bool x = b.hello ();}
    on r.world (): {idle=true;h.world ();}
  }
}
