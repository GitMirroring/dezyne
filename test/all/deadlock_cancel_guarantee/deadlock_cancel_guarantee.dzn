// Commentary:
//
// Assuming the scenario where pt.request(); pt.cancel(); is executed in
// the same context.
//
// When rb.block() blocks in the deadlock_cancel_guarantee component,
// and the modeling event behind the rt.complete() occurs, rt.complete()
// will block collaterally.  The pt.cancel() must deadlock on port rt,
// since it has not run to completion yet.
//
// Code:

interface itransaction
{
  in void cancel();
  in void request();
  out void complete();
  behavior
  {
    bool active = false;
    [!active] on request: active = true;
    [active] on cancel: active = false;
    [active] on inevitable: {active = false; complete;}
  }
}

interface iblock
{
  in void block();
  behavior
  {
    on block: {} // this event blocks
  }
}

component deadlock_cancel_guarantee
{
  provides itransaction pt;
  requires iblock rb;
  requires itransaction rt;
  behavior
  {
    bool active = false;
    [!active] on pt.request(): {active = true; rt.request(); rb.block();}
    [active] on pt.cancel(): {active = false; rt.cancel();}
    [active] on rt.complete(): {active = false; pt.complete();}
  }
}
