interface DeadlockInModel
{
  in void ia();
  out void oa();
  
  behaviour
  {
    bool b = false;
    on ia: illegal;
    [b] on inevitable: oa;
  }
  // Simulating DeadlockInModel =>
  //   deadlock in model Deadlock
  // if empty trace is performed
}
