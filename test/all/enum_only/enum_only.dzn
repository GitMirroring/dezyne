//
// Code:

import enum.dzn;

interface ihello
{
  in r hello ();

  behavior
  {
    on hello: return r.f;
  }
}

component enum_only
{
  provides ihello h;
  requires iworld w;

  behavior
  {
    r m = r.t;
    on h.hello ():
      {
        r v = r.f;
        v = w.world ();
        return v;
      }
  }
}

interface iworld
{
  in r world ();

  behavior
  {
    on world: return r.f;
  }
}
