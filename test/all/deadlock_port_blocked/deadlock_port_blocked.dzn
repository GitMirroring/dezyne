// Code:

interface ihello
{
  in void hello();
  in void cruel();
  behavior
  {
    on hello: {}
    on cruel: {}
  }
}

interface iworld
{
  out void world();
  behavior
  {
    on inevitable: world;
  }
}

component deadlock_port_blocked
{
  provides blocking ihello h;
  requires iworld w;
  behavior
  {
    bool blocked=false;
    [!blocked]
    {
      on h.hello(): blocking blocked=true;
      on w.world(): {}
    }
    [blocked]
    {
      on w.world(): {h.reply (); blocked=false;}
    }
    on h.cruel(): {}
  }
}
