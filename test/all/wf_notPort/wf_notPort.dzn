interface I {
  in void e();

  behavior {
    on e: {}
  }
}

component wf_notPort_1 {
  provides I p;
  requires I r;

  behavior {
    enum p {E1};

    on p.e():r.e();
  }
}

component wf_notPort {
  provides I p;
  requires I r;

  behavior {
    //bool p = false;
    enum E {E1};
    E p = E.E1;

    on p.e():r.e();
  }
}
