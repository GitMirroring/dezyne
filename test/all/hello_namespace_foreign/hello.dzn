// Commentary:
//
// Code:

namespace library
{
  interface ihello
    {
     in void hello();
     out void goodbye();

     behavior
     {
       on hello: {}
     }
    }

  component foreign
    {
      provides iworld w;
      // behavior {}
    }

  component hello
    {
      provides ihello h;
      requires iworld w;

      behavior
        {
          bool b = true;
          on h.hello(): {b = false; w.world();}
          [!b] on w.howdy(): {b = true; h.goodbye();}
        }
    }

  interface iworld
    {
      in void world();
      out void howdy();

      behavior
        {
          bool b = true;
          on world: b = false;
          [!b] on optional: {b = true; howdy;}
        }
    }
}
