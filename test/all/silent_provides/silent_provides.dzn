// Code:

interface ihello
{
  in void hello();

  behavior
  {
    subint count {0..10};
    count c = 0;
    [c == 10] on hello: c = 0;
    [c != 10] on hello: illegal;
    [c < 10] on inevitable: c = c + 1;
  }
}

component silent_provides
{
  provides ihello h;

  behavior
  {
    on h.hello(): {}
  }
}
