interface iworld
{
  out void world();
  behavior
  {
    on optional: world;
  }
}

component component_provides_without_trigger
{
  provides iworld p;
  behavior {}
}

interface ihello
{
  in void hello();
  behavior
  {
    on hello: {}
  }
}

component component_requires_without_trigger
{
  requires ihello r;
  behavior {}
}
