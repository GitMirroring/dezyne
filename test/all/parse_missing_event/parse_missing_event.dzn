extern int $int$;

interface ihello
{
  in void hello(int i);

  behaviour
  {
    on hello: {}
  }
}

component parse_missing_event
{
  provides ihello h;
  requires iworld w;

  behaviour
  {
    enum Bool {False,True};
    void f (bool b) {}
    int j;
    on h.hallo(i):
    {
      j = i;
    }
  }
}

interface iworld
{
  in void world(int i);

  behaviour
  {
    on world: {}
  }
}
