extern int $int$;

interface itimer
{
  in void create(in int ms);
  in void cancel();
  out void timeout();

  behaviour
  {
    bool idle = true;
    on create: {
      [idle] idle = false;
      [otherwise] illegal;
    }
    on cancel: idle = true;
    on inevitable: [!idle] { idle = true; timeout;}
  }
}

component timer
{
  provides itimer t;
}

interface itest
{
  in bool run();

  behaviour
  {
    on run: reply(false);
    on run: reply(true);
  }
}

component test
{
  provides itest t;
  requires itimer t1;
  requires itimer t2;

  behaviour
  {
    on t.run(): blocking { t1.create($50$); t2.create($10$); }
    on t1.timeout(): { t2.cancel(); t.reply(true); }
    on t2.timeout(): { t1.cancel(); t.reply(true); }
  }
}

component Timer
{
  provides itest t;

  system
  {
    test tst;
    timer tm1;
    timer tm2;

    t <=> tst.t;
    tst.t1 <=> tm1.t;
    tst.t2 <=> tm2.t;
  }
}
