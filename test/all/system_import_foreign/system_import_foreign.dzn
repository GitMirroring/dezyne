// Commentary:
//
// Reproduce runtime.hh include order compilation issue reported by
// joran.jesserun@thermofisher.com
//
// Code:

import hello0.dzn;
import hello1.dzn;

component system_import_foreign
{
  provides ihello h;

  system
    {
      hello c;
      h <=> c.h;
      Hello1 f1;
      c.w <=> f1.w;
    }
}
