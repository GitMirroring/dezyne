// Code:

import ihello.dzn;
import hello1.dzn;

interface ihello0
{
  enum BOOL {TRUE, FALSE};
  in BOOL hello ();

  behavior
  {
    on hello: return BOOL.TRUE;
    on hello: return BOOL.FALSE;
  }
}

component Hello0
{
  provides ihello0 w;
}


component hello
{
  provides ihello h;
  requires injected ihello1 w;

  behavior
  {
    on h.hello():
    {
      ihello1.BOOL r = w.hello();
      if (r.TRUE) return ihello.BOOL.TRUE;
      else return ihello.BOOL.FALSE;
    }
  }
}
