// Code:

extern int $int$;

interface ihello
{
  in void hello(inout int i);

  behavior
  {
    on hello: {}
  }
}

interface iworld
{
  in void hello();
  out void world();

  behavior
  {
    bool busy = false;
    [!busy] on hello: busy = true;
    [busy] on inevitable: { world; busy = false; }
  }
}

component blocking_binding
{
  provides blocking ihello h;
  requires iworld w;

  behavior
  {
    int g = $123$;
    bool busy = false;
    [!busy] on h.hello(n <- g): blocking { n = g; w.hello(); busy = true; }
    [busy] on w.world(): { g = $456$; h.reply(); g = $789$; busy = false; }
  }
}
