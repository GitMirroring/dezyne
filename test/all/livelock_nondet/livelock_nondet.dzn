// This interface immediately enters a live-lock
interface livelock_nondet
{
  enum State {A, B, C};

  in void e();

  behavior
  {
    State s = State.A;

    on e: {}

    [s.A] on optional:
    {
      [true] s = State.C;
      [true] s = State.B;
    }
    [s.B] on optional:
    {
      [true] s = State.C;
      [true] s = State.A;
    }
    [s.C] on optional:
    {
      [true] s = State.B;
      [true] s = State.A;
    }
  }
}
