// Code:

interface ihello
{
  in void hello ();
  out void world ();
  out void cruel ();
  behavior
  {
    bool idle = true;

    [idle] on hello: idle = false;
    [!idle] on inevitable: {idle=true; world;}
    on optional: cruel;
  }
}

interface iworld
{
  in void hello ();
  out void world ();
  behavior
  {
    on hello: {}
    on optional: world;
  }
}

component defer_priority
{
  provides ihello h;
  requires iworld w;

  behavior
  {
    bool idle = true;
    void send_world ()
    {
      idle = true;
      h.world ();
    }
    [idle] on h.hello (): {idle = false; defer send_world ();}
    [idle] on w.world (): h.cruel ();
    [!idle] on w.world (): {send_world (); defer h.cruel ();}
  }
}
