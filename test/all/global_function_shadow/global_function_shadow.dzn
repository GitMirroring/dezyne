// Commentary:
//
// Code:

import ihello.dzn;

bool f0 ()
{
  return true;
}

bool f1 ()
{
  return f2 ();
}

bool f2 ()
{
  return false;
}

component global_function_shadow
{
  provides ihello h;
  behavior
  {
    bool f0 ()
    {
      return false;
    }
    bool f2 ()
    {
      return true;
    }

    on h.hello ():
    {
      if (f0 ()) illegal;
      if (f1 ()) illegal;
    }
  }
}
