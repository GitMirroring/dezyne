// Test defer interaction with blocking
component Async_BlockingDeferBecomesSyncOut
{
  provides ISync pp;
  requires IAsync rp;

  behaviour
  {
    requires dzn.async() reflector;
    
    on pp.ia(): blocking {reflector.req(); rp.ia();}
    on reflector.ack(): pp.oa();
    on rp.oa(): pp.reply();

    // Blocked port deferred out event becomes synchronous out event
    // component Async_BlockingDeferBecomesSyncOut shall at least perform trace
    // pp.ia
    // rp.ia
    // rp.return
    // pp.oa
    // rp.oa
    // pp.return
  }
}


interface ISync
{
  in void ia();
  in void ib();
  out void oa();
  out void ob();

  behaviour
  {
    on ia: oa;
    on ib: ob;
  }
}

interface IAsync
{
  in void ia();
  out void oa();

  behaviour
  {
    bool is_active = false;

    [!is_active] on ia: is_active = true;
    [is_active] on ia: illegal;
    
    [is_active] on inevitable: {oa; is_active = false;}
  }
}

