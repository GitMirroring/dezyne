// Code:

import ihello.dzn;

interface iworld
{
  in void hello ();
  out void world ();

  behavior
  {
    on hello: world;
  }
}

component Foreign
{
  provides ihello h;
  requires ihello w0;
  requires ihello w1;
  // behavior {}
}

component hello
{
  provides ihello h0;
  provides ihello h1;
  requires iworld w0;
  requires iworld w1;

  behavior
  {
    on h0.hello (): w0.hello ();
    on h1.hello (): w1.hello ();
    on w0.world (), w1.world (): {}
  }
}

component foreign_requires
{
  provides ihello h;
  requires iworld w0;
  requires iworld w1;

  system
    {
      hello c;
      c.h0 <=> f.w0;
      c.h1 <=> f.w1;
      h <=> f.h;
      Foreign f;
      c.w0 <=> w0;
      c.w1 <=> w1;
    }
}
