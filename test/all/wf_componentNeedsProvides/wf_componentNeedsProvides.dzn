// Code:

interface Sensor {
  in void activate();
  in void deactivate();
  out void deactivated();
  behaviour { 
    on activate: {}
    on deactivate: {}
  }
}
 
component Alarm1 {
  requires Sensor sensor;
  behaviour { 
    on sensor.deactivated(): {}
  }
}

component SensorComp {
  provides Sensor sensor1;
  provides Sensor sensor2;
  behaviour { 
    on sensor1.activate(): {}
    on sensor2.activate(): {}
    on sensor1.deactivate(): {}
    on sensor2.deactivate(): {}
  }
}


