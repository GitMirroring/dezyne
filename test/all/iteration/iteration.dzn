// Code:

interface ihello
{
  in void hello ();
  out void world ();
  behavior
  {
    on hello: world;
  }
}

interface iiteration
{
  in void step ();
  out void next ();
  out void end ();
  behavior
  {
    subint Count {0..1};
    Count count = 0;
    [count < 1] on step: {count = count + 1; next;}
    on step: {count = 0; end;}
  }
}

component list
{
  provides iiteration i;
}

component hello
{
  provides ihello h;
  requires iiteration i;

  behavior
  {
    on h.hello (): i.step ();
    on i.next (): i.step ();
    on i.end (): h.world ();
  }
}

component iteration
{
  provides ihello h;
  system
  {
    h <=> hello_.h;
    hello hello_;
    hello_.i <=> list_.i;
    list list_;
  }
}
