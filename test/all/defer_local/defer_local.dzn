// Code:

interface ihello
{
  in bool hello ();
  out void world ();
  in void bye ();

  behavior
  {
    bool idle = true;
    [idle]
    {
      on hello: {idle = false; return true;}
      on hello: return false;
      on bye: {}
    }
    [!idle]
    {
      on hello: return false;
      on bye: idle = true;
      on inevitable: {idle = true; world;}
    }
  }
}

interface iworld
{
  in bool hello ();
  behavior
  {
    on hello: return true;
    on hello: return false;
  }
}

component defer_local
{
  provides ihello h;
  requires iworld w;
  behavior
  {
    bool idle = true;
    [idle] on h.hello ():
    {
      if (w.hello ())
      {
        idle = false;
        defer {idle = true; h.world ();}
        return true;
      }
      else return false;
    }
    [!idle] on h.hello (): return false;

    on h.bye (): idle = true;
  }
}
