// Code:

interface ihello
{
  in bool hello();
  out void world();
  in void bye();

  behavior
  {
    bool idle = true;
    [idle] {
      on hello: {idle = false; reply(true);}
      on hello: reply(false);
      on bye: {}
    }
    [!idle] {
      on hello: reply(false);
      on bye: idle = true;
      on inevitable: {idle = true; world;}
    }
  }
}

interface iworld
{
  in bool hello();
  behavior
  {
    on hello: reply(true);
    on hello: reply(false);
  }
}

component defer_local
{
  provides ihello h;
  requires iworld w;
  behavior
  {
    bool idle = true;
    [idle] on h.hello():
    {
      if (w.hello())
      {
        reply(true);
        idle = false;
        defer {idle = true; h.world();}
      }
      else reply(false);
    }
    [!idle] on h.hello(): reply(false);

    on h.bye(): idle = true;
  }
}
