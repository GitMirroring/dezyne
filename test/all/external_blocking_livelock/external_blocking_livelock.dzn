// Code:

interface ihello
{
  in void hello();

  behavior
  {
    on hello: {}
  }
}

interface iworld
{
  in void hello();
  out void world();
  out void cruel();

  behavior
  {
    on hello: world;
    on hello: cruel;
  }
}

component external_blocking_livelock
{
  provides ihello h;
  requires external iworld w;

  behavior
  {
    blocking on h.hello(): w.hello();
    on w.world(): h.reply();
    on w.cruel(): w.hello();
  }
}