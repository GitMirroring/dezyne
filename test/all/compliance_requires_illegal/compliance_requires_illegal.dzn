// Code:

interface ihello
{
  in void hello();
  in void cruel();

  behavior
  {
    on hello: {}
    [false] on cruel: illegal;
  }
}

component compliance_requires_illegal
{
  provides ihello h;
  requires ihello w;

  behavior
  {
    on h.hello(): w.cruel();
  }
}
