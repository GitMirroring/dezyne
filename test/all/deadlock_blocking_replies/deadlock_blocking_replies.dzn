interface ihello
{
  in bool hello();
  in bool bye();

  behavior
  {
    on hello:reply(true);
    on bye:reply(true);
  }
}

component deadlock_blocking_replies
{
  provides ihello h;
  requires iworld w;

  behavior
  {
    enum S {A,B,C};
    S s = S.A;

    [s.A] on h.hello(): {s = S.B; h.reply(true);}
    [s.B] blocking on h.bye(): s = S.C;

    on w.world():
    {
      if(s.C)
      {
        s = S.A;
        h.reply(true);
      }
    }
    on w.cruel(): s = S.A;
  }
}

interface iworld
{
  in void hello();
  out void world();
  out void cruel();

  behavior
  {
    bool idle = true;
    [idle] on hello: idle = false;
    [!idle]
    {
      on optional: {idle = true; cruel;}
      on inevitable: {idle = true; world;}
    }
  }
}
