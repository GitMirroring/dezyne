interface IAsync {
  in void e();
  in void c();
  out void cb();

  behaviour {
    bool idle = true;
    [idle] {
      on e: idle = false;
      on c: {}
    }
    [!idle] {
      on e: illegal;
      on c: idle = true;
      on inevitable: { cb; idle = true; }
    }
  }
}

component async_context2 {
  provides IAsync p;
  behaviour {
    enum State { S0, S1, S2 };
    requires dzn.async i;

    State s = State.S0;

    [s.S0] {
      on p.e(): { i.req(); s = State.S1; }
      on p.c(): i.clr();
    }
    [s.S1] {
      on p.c(): { i.clr(); s = State.S0; }
      on i.ack(): { i.req(); s = State.S2; }
    }
    [s.S2] {
      on p.c(): illegal; // between the loop of ack's it is not possible to receive c
      on i.ack(): i.req();
    }
  }
}


