// Code:

interface ihello
{
  in void hello();
  out void world();

  behaviour
  {
    bool b = false;

    [!b]
    {
      on hello: world;
      on hello: b = true;
    }
    [b]
    {
//      on hello: illegal;
      on inevitable: {b = false; world;}
    }
  }
}

component multiple_provides
{
  provides ihello p_left;
  provides ihello p_right;
  requires ihello r;

  behaviour
  {
    enum Direction {Left, Right};
    Direction dir = Direction.Left;

    bool b_left = false;
    bool b_right = false;

    [!b_left && !b_right]
    {
      on p_left.hello(): {dir = Direction.Left; r.hello(); b_left = true;}
      on p_right.hello():{dir = Direction.Right; r.hello(); b_right = true;}
      on r.world(): illegal;
    }
    [b_left || b_right]
    {
      on p_left.hello():
      {
        [b_left] illegal;
        [!b_left] p_left.world();
      }
      on p_right.hello():
      {
        [b_right] illegal;
        [!b_right] p_right.world();
      }
      on r.world(): if(dir.Left){b_left = false; p_left.world();} else {b_right = false; p_right.world();}
    }
  }
}
