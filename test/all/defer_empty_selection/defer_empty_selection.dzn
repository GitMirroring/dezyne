// Code:

interface ihello
{
  in void hello();
  out void world();
  behavior
  {
    bool idle = true;
    [idle] on hello: idle = false;
    [!idle] on inevitable: {idle = true; world;}
  }
}

component defer_empty_selection
{
  provides ihello l;
  provides ihello r;
  requires ihello w;
  behavior
  {
    bool left = false;
    bool right = false;
    bool pending = false;
    bool toggle = false;

    [!left] on l.hello(): {
      left = true;
      defer_hello();
    }
    [!right] on r.hello(): {
      right = true;
      defer_hello();
    }
    void defer_hello() {
      if(!pending) {pending = true; w.hello();}
      else defer() defer_hello();
    }
    on w.world(): {
      pending = false;
      toggle = !toggle;
      if(toggle)
        if(left) {left = false; l.world();}
        else {right = false; r.world();}
      else
        if(right) {right = false; r.world();}
        else {left = false; l.world();}
    }
  }
}
