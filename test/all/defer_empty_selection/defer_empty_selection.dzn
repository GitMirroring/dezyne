import ihello_world.dzn;

component defer_empty_selection
{
  provides ihello_world l;
  provides ihello_world r;
  requires ihello_world w;
  behavior
  {
    bool left = false;
    bool right = false;
    bool pending = false;
    bool toggle = false;

    [!left] on l.hello ():
    {
      left = true;
      defer_hello ();
    }
    [!right] on r.hello ():
    {
      right = true;
      defer_hello ();
    }
    void defer_hello ()
    {
      if (!pending) {pending = true; w.hello ();}
      else defer () defer_hello ();
    }
    on w.world ():
    {
      pending = false;
      toggle = !toggle;
      if (toggle)
        if (left) {left = false; l.world ();}
        else {right = false; r.world ();}
      else
        if (right) {right = false; r.world ();}
        else {left = false; l.world ();}
    }
  }
}
