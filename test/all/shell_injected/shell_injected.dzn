import externaltypes.dzn;

interface ILogger
{
  in void log(in string m);

  behaviour
  {
    on log: {}
  }
}

component Logger
{
  provides ILogger log;
  // behaviour {}
}

interface IRelaxed
{
  in void e();
  out void f();

  behaviour
  {
    on e: {}
    on optional: f;
  }
}


interface IStrict
{
  in void e();
  out void f();

  behaviour
  {
    bool idle = true;

    [idle] on e: { idle = false; }
    [!idle] on inevitable: { f; idle = false; }
  }
}

component TopArmor
{
  provides IRelaxed r;
  requires IStrict s;

  requires injected ILogger l;

  behaviour
  {
    bool idle = true;
    [idle] {
      on r.e(): { idle = false; s.e(); }
      on s.f(): { l.log($"foo"$); }
    }
    [!idle] {
      on r.e(): { l.log($"foo"$); }
      on s.f(): { idle = true; r.f(); }
    }
  }
}

component BottomArmor
{
  provides IStrict s;
  requires IRelaxed r;

  requires injected ILogger l;

  behaviour
  {
    bool idle = true;
    [idle] {
      on s.e(): { idle = false; r.e(); }
      on r.f(): { l.log($"foo"$); }
    }
    [!idle] {
      on s.e(): { l.log($"foo"$); }
      on r.f(): { idle = true; s.f(); }
    }
  }
}

component C
{
  provides IStrict p;
  requires IStrict r;

  behaviour
  {
    on p.e(): r.e();
    on r.f(): p.f();
  }
}

component shell_injected
{
  provides IRelaxed p;
  requires IRelaxed r;

  system
  {
    Logger logger;
    TopArmor top;
    C c;
    BottomArmor bottom;

    p <=> top.r;
    top.s <=> c.p;
    c.r <=> bottom.s;
    bottom.r <=> r;
    logger.log <=> *;
  }
}
