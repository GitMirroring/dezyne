// Test defer interaction with blocking
component Async_BlockingDeferAsyncOut
{
  provides ISyncAsync pp;
  requires IAsync rp;

  behaviour
  {
    requires dzn.async() reflector;

    on pp.ia(): blocking rp.ia();
    on rp.oa(): {reflector.req(); pp.osync(); pp.reply();}
    on reflector.ack(): pp.oasync();

    // Blocked port deferred out event becomes synchronous out event
    // component Async_BlockingDeferAsyncOut shall perform trace
    // pp.ia
    // rp.ia
    // rp.return
    // rp.oa
    // pp.osync
    // pp.return
    // pp.oasync
  }
}


interface ISyncAsync
{
  in void ia();
  out void osync();
  out void oasync();

  behaviour
  {
    bool is_active = false;

    [!is_active] on ia: {is_active = true; osync;}
    [is_active] on ia: illegal;

    [is_active] on inevitable: {is_active = false; oasync;}
  }
}

interface IAsync
{
  in void ia();
  out void oa();

  behaviour
  {
    bool is_active = false;

    [!is_active] on ia: is_active = true;
    [is_active] on ia: illegal;
    
    [is_active] on inevitable: {oa; is_active = false;}
  }
}

