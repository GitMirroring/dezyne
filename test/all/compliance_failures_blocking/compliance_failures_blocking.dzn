// Code:

interface ihello
{
  in void hello ();

  behavior
  {
    on hello: {}
  }
}

component compliance_failures_blocking
{
  provides blocking ihello left;
  provides blocking ihello right;

  behavior
  {
    blocking on left.hello (): {}
    on right.hello (): blocking { right.reply();}
  }
}
