extern string $std::string$;

interface I {
  in void e();
  behaviour {
    on e: {}
  }
}

component componentInDollars {
  provides I p;
  behaviour {
    // here comes the component:
    string s = $"here is the component"$;
    on p.e(): {}
  }
}
