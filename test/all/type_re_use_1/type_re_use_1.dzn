interface IBase // Marker: Description: undefined identifier; Location: table.sh: gr[aiag]: state table failure

{
	enum Result {Ok, Fail, Error};
	
	in Result ia();
	
	behaviour
	{
		on ia: reply(Result.Ok);
		on ia: reply(Result.Fail);
		on ia: reply(Result.Error);
	}
}

interface IDecorator
{
	in IBase.Result ia();
	
	behaviour
	{
		on ia: reply(IBase.Result.Ok);
		on ia: reply(IBase.Result.Fail);
		on ia: reply(IBase.Result.Error);
	}
}