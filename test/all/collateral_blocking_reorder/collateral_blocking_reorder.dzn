// Code:

interface ihello
{
  in void hello();

  behavior
  {
    on hello:{}
  }
}

interface icruel
{
  in void hello();
  out void world();

  behavior
  {
    bool idle = true;
    [idle] on hello: {world; idle = false;}
    [!idle] on hello: idle = true;
  }
}

interface iworld
{
  in void hello();
  out void world();

  behavior
  {
    bool idle = true;
    [idle] on hello: idle = false;
    [!idle]
    {
      on hello: illegal;
      on inevitable: {idle = true; world;}
    }
  }
}
component proxy_block
{
  provides ihello p;
  requires icruel r;
  requires iworld e;

  behavior
  {
    bool idle = true;
                        //async      sync
    [idle] on p.hello(): {e.hello(); r.hello();}
    [!idle] on p.hello(): {}
    on r.world(): idle = false;
    [!idle] on e.world(): {r.hello(); idle = true;}
  }
}

component proxy_release
{
  provides iworld p;
  requires iworld e;

  behavior
  {
    bool idle = true;
    [idle] on p.hello(): {e.hello(); idle = false;}
    [!idle] on e.world(): {p.world(); idle = true;}
  }
}

component blocked
{
  provides icruel p;
  requires iworld r;

  behavior
  {
    bool idle = true;
    blocking on p.hello(): {r.hello(); idle = !idle;}
    on r.world(): {p.reply(); if (!idle) p.world();}
  }
}

component collateral_blocking_reorder
{
  provides ihello p;
  requires iworld r;
  requires iworld e;

  system
  {
    proxy_block top;
    p <=> top.p;

    proxy_release release;
    top.e <=> release.p;
    release.e <=> e;

    blocked bottom;
    top.r <=> bottom.p;
    bottom.r <=> r;
  }
}
