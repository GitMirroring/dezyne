// Code:

interface ihello
{
  in void hello ();

  behavior
  {
    on hello:{}
  }
}

interface icruel
{
  in void hello ();
  out void world ();

  behavior
  {
    bool idle = true;
    [idle] on hello: {world; idle = false;}
    [!idle] on hello: idle = true;
  }
}

interface iworld
{
  in void hello ();
  out void world ();

  behavior
  {
    bool idle = true;
    [idle] on hello: idle = false;
    [!idle]
    {
      on hello: illegal;
      on inevitable: {idle = true; world;}
    }
  }
}
component proxy_block
{
  provides blocking ihello p;
  requires blocking icruel r;
  requires blocking iworld e;

  behavior
  {
    bool idle = true;
                        //async      sync
    [idle] on p.hello (): {e.hello (); r.hello ();}
    [!idle] on p.hello (): {}

    [!idle] on e.world (): {r.hello (); idle = true;}
    [idle] on e.world (): idle = false;

    [!idle] on r.world (): {r.hello (); idle = true;}
    [idle] on r.world (): idle = false;
  }
}

component proxy_release
{
  provides blocking iworld p;
  requires blocking iworld e;

  behavior
  {
    bool idle = true;
    [idle] on p.hello (): {e.hello (); idle = false;}
    [!idle] on e.world (): {p.world (); idle = true;}
  }
}

component blocked
{
  provides blocking icruel p;
  requires blocking iworld r;

  behavior
  {
    bool idle = true;
    blocking on p.hello (): {r.hello (); idle = !idle;}
    on r.world (): {if (!idle) p.world (); p.return;}
  }
}

component adapter
{
  provides blocking iworld h;
  requires blocking ihello b;
  requires external iworld w;
  behavior
  {
    on h.hello (): {b.hello (); w.hello ();}
    on w.world (): h.world ();
  }
}

component blocker
{
  provides blocking ihello b;
  behavior
  {
    blocking on b.hello (): defer b.return;
  }
}

component external_adapter
{
  provides blocking iworld h;
  requires external iworld w;
  system
  {
    adapter adapt;
    h <=> adapt.h;
    blocker block;
    adapt.b <=> block.b;
    adapt.w <=> w;
  }
}

component collateral_blocking_reorder
{
  provides blocking ihello p;
  requires external iworld r;
  requires external iworld e;

  system
  {
    proxy_block top;
    p <=> top.p;

    proxy_release release;
    top.e <=> release.p;
    external_adapter adapt_release;
    release.e <=> adapt_release.h;
    adapt_release.w <=> e;

    blocked bottom;
    top.r <=> bottom.p;
    external_adapter adapt_bottom;
    bottom.r <=> adapt_bottom.h;
    adapt_bottom.w <=> r;
  }
}
