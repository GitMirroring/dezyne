extern foo $int$;
extern foo $bool$; // 'foo' declared before
extern data $int$;

interface I {
  in void e(data x, foo x); // 'x' declared before
  in void e(); // 'e' declared before

  behaviour {
    on e: {}
  }
}

interface I { // 'I' declared before
  enum E {E1, E2};
  enum E {E3, E4}; // 'E' declared before
  enum F {F1, F2, F1}; // 'F1' declared before
  in void e();

  behaviour {
    enum G {G1, G2};
    enum G {G3, G4}; // 'G' declared before
    void fn1(F f, bool f) {} // 'f' declared before
    void fn2() {}
    void fn2() {} // 'fn2' declared before
    on e: {}
  }
}

component wf_declaredBefore {
  provides I p;
  provides I p; // 'p' declared before
  requires I r;
  requires I r; // 'r' declared before
  provides I s;
  requires I s; // 's' declared before
}
