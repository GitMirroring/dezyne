// Commentary:
//
// Code:

interface ihello
{
  in void hello();

  behavior
  {
    on hello: {}
  }
}

interface iworld
{
  in void hello();
  out void world();

  behavior
  {
    bool idle = true;
    [idle] on hello: idle = false;
    [!idle]
    {
      on hello: illegal;
      on inevitable: {idle = true; world;}
    }
  }
}

component mux
{
  provides ihello left;
  provides ihello right;

  requires ihello hello;

  behavior
  {
    on left.hello(): hello.hello();
    on right.hello(): hello.hello();
  }
}

component block
{
  provides ihello hello;
  requires iworld world;

  behavior
  {
    blocking on hello.hello(): world.hello();
    on world.world(): hello.reply();
  }
}

component collateral_blocking_multiple_provides
{
  provides ihello left;
  provides ihello right;

  requires iworld world;

  system
  {
    mux m;

    left <=> m.left;
    right <=> m.right;

    block b;
    m.hello <=> b.hello;
    b.world <=> world;
  }
}