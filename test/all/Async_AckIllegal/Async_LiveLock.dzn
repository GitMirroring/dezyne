// Code:

interface IA
{
  in void e();
  in void c();
  out void cb();

  behaviour
  {
    bool b = false;

    [!b] on e: b = true;
    [b] on e: illegal;

    on c: {}

    [b] on inevitable: {cb; b = false;}
  }
}

component Async_LiveLock
{
  provides IA pp;

  behaviour
  {
    requires dzn.async() refl;

    bool b = false;
    bool ll = false;

    [!b && !ll] on pp.e(): {b = !b; refl.req();}
    [!b && ll] on pp.e(): b = !b;
    on pp.c(): {b = false; ll = false; refl.clr();} // Postponed indefinitely due to async-driven live-lock
    [!ll] on refl.ack(): {pp.cb(); b = false; refl.req(); ll = !ll;}
    [ll] on refl.ack(): {refl.req();} // LiveLock

    // component Async_LiveLock shall be able to repeat the following trace:
    // pp.e
    // pp.return
    // pp.c
    // pp.return

    // component Async_LiveLock shall report a livelock error for following trace:
    // pp.e
    // pp.return
    // pp.cb
    // Error: livelock
  }
}
