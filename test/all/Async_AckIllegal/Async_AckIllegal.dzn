interface IAsync
{
  in void ia();
  out void oa();
  
  behaviour 
  {
    bool b = false;

    [!b] on ia: b = true;
    [b] on ia: illegal;
    
    [b] on inevitable: {b = false; oa;} 
  }
}

component Async_AckIllegal
{
  provides IAsync pp;
  
  behaviour
  {
    requires dzn.async() kick;
    bool b = false;
    
    [!b] on pp.ia(): {b = true; kick.req();}
    on kick.ack(): illegal;
  }
}
