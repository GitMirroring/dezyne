interface ITauEmitMulti {
  in void ack();
  in void done();
  out void ntfA();
  out void ntfB();

  behaviour {
    bool isWaiting = false;
    bool isEmitting = false;

    [!isWaiting]
    {
      on ack:
      {}
      on inevitable:
      {
        [!isEmitting]
        {
          ntfA;
          isEmitting = true;
        }
        [isEmitting]
        {
          ntfB;
          isWaiting = true;
          isEmitting = false;
        }
      }
      on done:
      illegal;
    }
    [isWaiting]
    {
      on ack:
      {}
      on done:
      isWaiting = false;
    }
  }
}

interface IDummy {
  enum ReplyValue {Ok};
  in ReplyValue dummy();
  out void liveLockPreventer();

  behaviour {

    [true]
    on dummy:
    reply(ReplyValue.Ok);
  }
}

component ConsumeMultiple {
  provides IDummy d;
  requires ITauEmitMulti src;

  behaviour {
    bool behave = true;

    [!behave]
    {
      on d.dummy():
      reply(IDummy.ReplyValue.Ok);
      on src.ntfA():
      src.done();
      on src.ntfB():
      src.ack();
    }
    [behave]
    {
      on d.dummy():
      reply(IDummy.ReplyValue.Ok);
      on src.ntfA():
      src.ack();
      on src.ntfB():
      {
        src.done();
        behave = false;
      }
    }
  }
}

