interface IPedal {
  in void press();
  in void release();
  out void pressed();
  out void released();

  behaviour {
    enum State {Pressed, Released};
    State pedal = State.Released;

    [pedal.Pressed]
    {
      on press:
      illegal;
      on release:
      {
        [true]
        {
          pedal = State.Released;
          released;
        }
        [true]
        pedal = State.Released;
      }
    }
    [pedal.Released]
    {
      on press:
      {
        [true]
        {
          pedal = State.Pressed;
          pressed;
        }
        [true]
        pedal = State.Pressed;
      }
      on release:
      illegal;
    }
  }
}

component SyncPedal {
  provides IPedal left;
  provides IPedal right;
  requires IPedal pedal;

  behaviour {
    enum CLIENT {LEFT, RIGHT};
    CLIENT client = CLIENT.LEFT;
    bool left_pressed = false;
    bool right_pressed = false;

    [client.LEFT]
    {
      on left.press():
      {
        [left_pressed]
        illegal;
        [!left_pressed && !right_pressed]
        {
          client = CLIENT.LEFT;
          left_pressed = true;
          pedal.press();
          right.pressed();
        }
        [!left_pressed && right_pressed]
        {
          left_pressed = true;
          left.pressed();
        }
      }
      on right.press():
      {
        [right_pressed]
        illegal;
        [!right_pressed && !left_pressed]
        {
          client = CLIENT.RIGHT;
          right_pressed = true;
          pedal.press();
        }
        [!right_pressed && left_pressed]
        {
          right_pressed = true;
          right.pressed();
        }
      }
      on left.release():
      {
        [!left_pressed]
        illegal;
        [left_pressed && !right_pressed]
        {
          client = CLIENT.LEFT;
          left_pressed = false;
          pedal.release();
        }
        [left_pressed && right_pressed]
        left_pressed = false;
      }
      on right.release():
      {
        [!right_pressed]
        illegal;
        [right_pressed && !left_pressed]
        {
          client = CLIENT.RIGHT;
          right_pressed = false;
          pedal.release();
        }
        [right_pressed && left_pressed]
        right_pressed = false;
      }
      on pedal.pressed():
      left.pressed();
      on pedal.released():
      left.released();
    }
    [client.RIGHT]
    {
      on left.press():
      {
        [left_pressed]
        illegal;
        [!left_pressed && !right_pressed]
        {
          client = CLIENT.LEFT;
          left_pressed = true;
          pedal.press();
          right.pressed();
        }
        [!left_pressed && right_pressed]
        {
          left_pressed = true;
          left.pressed();
        }
      }
      on right.press():
      {
        [right_pressed]
        illegal;
        [!right_pressed && !left_pressed]
        {
          client = CLIENT.RIGHT;
          right_pressed = true;
          pedal.press();
        }
        [!right_pressed && left_pressed]
        {
          right_pressed = true;
          right.pressed();
        }
      }
      on left.release():
      {
        [!left_pressed]
        illegal;
        [left_pressed && !right_pressed]
        {
          client = CLIENT.LEFT;
          left_pressed = false;
          pedal.release();
        }
        [left_pressed && right_pressed]
        left_pressed = false;
      }
      on right.release():
      {
        [!right_pressed]
        illegal;
        [right_pressed && !left_pressed]
        {
          client = CLIENT.RIGHT;
          right_pressed = false;
          pedal.release();
        }
        [right_pressed && left_pressed]
        right_pressed = false;
      }
      on pedal.pressed():
      right.pressed();
      on pedal.released():
      right.released();
    }
  }
}

