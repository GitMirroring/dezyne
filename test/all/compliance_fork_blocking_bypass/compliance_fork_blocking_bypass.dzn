// Commentary:
//
// Code:

interface ihello
{
  in void hello ();

  behavior {
    on hello: {}
  }
}

interface iworld
{
  in void hello ();
  out void world ();

  behavior {
    bool idle = true;
    on hello: idle = !idle;
    [!idle] on inevitable: {world; idle = true;}
  }
}

interface ibypass {
  in void hello ();
  out void world ();

  behavior {
    on hello: {}
    on inevitable: world;
  }

}

component compliance_fork_blocking_bypass {
  provides blocking ihello block;
  provides blocking ibypass bypassp;

  requires iworld world;
  requires ibypass bypassr;

  behavior {
    on block.hello (): blocking {
      world.hello ();
    }
    on world.world (): block.reply();

    on bypassr.world (): bypassp.world ();
    on bypassp.hello (): bypassr.hello ();
  }
}
