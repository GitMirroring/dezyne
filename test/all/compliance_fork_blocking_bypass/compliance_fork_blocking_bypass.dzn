import ihello.dzn;
import ihello_world.dzn;
import ihello_i_world.dzn;

component compliance_fork_blocking_bypass
{
  provides blocking ihello h;
  provides blocking ihello_i_world h_bypass;

  requires ihello_world w;
  requires ihello_i_world w_bypass;

  behavior
  {
    blocking on h.hello (): w.hello ();
    on w.world (): h.reply ();

    on h_bypass.hello (): w_bypass.hello ();
    on w_bypass.world (): h_bypass.world ();
  }
}
