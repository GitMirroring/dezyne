// Code:

interface ihello
{
  in void hello ();
  out void world ();
  in bool cruel ();
  behavior
  {
    bool idle = true;
    void f () {idle = true; world;}
    [idle] on hello: idle = false;
    [!idle] on inevitable: f ();
    on cruel: reply (idle);
  }
}

component hello_function_shared
{
  provides ihello h;
  behavior
  {
    bool idle = true;
    [idle] on h.hello ():
    {
      idle = false;
      defer
      {
        idle = true;
        h.world ();
      }
    }
    on h.cruel (): reply (h.idle);
  }
}
