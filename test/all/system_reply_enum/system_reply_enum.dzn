// Code:

interface ihello
{
  enum e {aa,bb};
  in e hello();

  behaviour
  {
    on hello: reply (e.aa);
  }
}

component hellobool
{
  provides ihello h;
  requires ihello w;

  behaviour
  {
    ihello.e e = ihello.e.bb;
    on h.hello():
      {
        //ihello.e e = w.hello();
        ihello.e e1 = w.hello();
        reply (e1);
      }
  }
}

component system_reply_enum
{
  provides ihello h;
  requires ihello w;
  system
    {
      hellobool c;
      h <=> c.h;
      c.w <=> w;
    }
}
