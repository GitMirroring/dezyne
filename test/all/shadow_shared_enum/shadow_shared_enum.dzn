// Commentary:
//
// Regression test to reproduce missing w shared variable in makreel.
//
// Code:

interface ihello
{
  enum R {A,B};
  in R hello ();

  behavior
  {
    enum S {A,B};
    S s = S.A;
    [s.A] on hello: {s = S.B; reply(R.A);}
    [s.B] on hello: {s = S.A; reply(R.B);}
  }
}

component shadow_shared_enum
{
  provides ihello h;
  requires ihello w;

  behavior
  {
    on h.hello ():
    {
      if (h.s.A && w.s.A) reply (w.hello());
      else reply (w.hello());
    }
  }
}
