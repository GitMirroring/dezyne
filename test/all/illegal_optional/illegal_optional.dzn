// Code:

interface ihello
{
  in void hello();
  in void world();

  behavior
  {
    bool idle = true;
    [idle] on hello: idle = false;
    [!idle] on world: idle = true;
  }
}

interface iworld
{
  in void hello();
  in void world();

  out void cruel();

  behavior
  {
    bool idle = true;

    [idle] on hello: idle = false;
    [!idle]
    {
      on world: idle = true;
      on optional: cruel;
    }
  }
}

component illegal_optional
{
  provides ihello h;
  requires iworld w;

  behavior
  {
    bool idle = true;

    [idle] on h.hello(): { w.hello(); idle = false; }
    [!idle]
    {
      on h.world(): { w.world(); idle = true; }
      on w.cruel(): w.hello();
    }
  }
}
