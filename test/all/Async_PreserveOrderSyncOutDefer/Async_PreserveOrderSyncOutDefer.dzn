// Test synchronous required out event triggered deferred provided out
// event order.
component Async_PreserveOrderSyncOutDefer
{
  provides IAsyncOrder pp;
  requires ISync rp;

  behaviour
  {
    requires dzn.async() reflector_frst;
    requires dzn.async() reflector_scnd;
    bool alt = false;
    
    on pp.ia(): rp.ia();
    [!alt] on rp.oa(): {alt = true; rp.ib(); reflector_frst.req();}
    on reflector_frst.ack(): pp.oa();
    [alt] on rp.oa(): {alt = false ; reflector_frst.req(); rp.ib();}
    on rp.ob(): reflector_scnd.req();
    on reflector_scnd.ack(): pp.ob();

    // component Async_PreserveOrderSyncOutDefer shall at least perform trace
    // pp.ia
    // rp.ia
    // rp.oa
    // rp.return
    // rp.ib
    // rp.ob
    // rp.return
    // pp.return
    // pp.oa
    // pp.ob

    // component Async_PreserveOrderSyncOutDefer shall extend above trace with at least
    // pp.ia
    // rp.ia
    // rp.oa
    // rp.return
    // rp.ib
    // rp.ob
    // rp.return
    // pp.return
    // pp.oa
    // pp.ob
  }
}

interface ISync
{
  in void ia();
  in void ib();
  out void oa();
  out void ob();

  behaviour
  {
    on ia: oa;
    on ib: ob;
  }
}

interface IAsyncOrder
{
  in void ia();
  out void oa();
  out void ob();

  behaviour
  {
    enum State {Idle, Working, Finalizing};
    State s = State.Idle;

    [s.Idle] on ia: s = State.Working;
    [!s.Idle] on ia: illegal;

    [s.Working] on inevitable: {oa; s = State.Finalizing;}

    [s.Finalizing] on inevitable: {ob; s = State.Idle;}
  }
}
