interface ihello
{
  in bool hello ();
  in bool cruel ();

  behavior
  {
    on hello: reply (false);
    on cruel: reply (false);
  }
}

interface iworld
{
  in void hello ();
  out void world ();

  behavior
  {
    on hello: {}
    on inevitable: world;
  }
}

component blocking_local_state_diagram
{
  provides ihello p;
  requires iworld r;

  behavior
  {
    bool blocked = false;
    [!blocked] blocking on p.hello ():
    {
      bool b = false;
      blocked = true;
    }
    blocking on p.cruel (): blocked = true;
    [!blocked] on r.world ():;
    [blocked] on r.world ():
    {
      bool c = false;
      p.reply (false);
      blocked = false;
    }
  }
}
