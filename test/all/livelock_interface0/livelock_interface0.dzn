// Commentary:
//
// Code:

// This interface immediately enters a live-lock
interface livelock_interface0 {
  in void e();

  behaviour {
    on e: illegal;
    on inevitable: {}
  }
}

// Dummy interface and component since there needs to be present a component
interface DummyI {
  in void e();
  behaviour { on e: {} }
}

component DummyC {
  provides DummyI i;
  requires livelock_interface0 ii;
  behaviour { on i.e(): {} }
}
