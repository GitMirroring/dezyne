// Code:

interface ihello
{
  in void hello();
  out void world();

  behaviour
  {
    bool b = true;
    [b]  on hello: b=!b;
    [!b] on inevitable: {b=!b; world;}
  }
}

component helloworld1
{
  provides ihello p;
  requires ihello r;

  behaviour
  {
    bool b = true;
    [b]  on p.hello(): {b=!b; r.hello();}
    [!b] on r.world(): {b=!b; p.world();}
  }
}

component helloworld2
{
  provides ihello p;
  requires ihello r;

  behaviour
  {
    bool b = true;
    [b]  on p.hello(): {b=!b; r.hello();}
    [!b] on r.world(): {b=!b; p.world();}
  }
}

component label_instance_mismatch
{
  provides ihello p;
  requires ihello r;

  system
    {
      helloworld1 c1;
      helloworld2 c2;
      p <=> c1.p;
      c1.r <=> c2.p;
      c2.r <=> r;
    }
}
