// Code:

interface ihello
{
  in void hello();

  behavior
  {
    on hello: {}
  }
}

component hello_ifelse
{
  provides ihello h;
  requires iworld w;

  behavior
  {
    bool b = false;
    on h.hello(): { if (b) w.world (); else {w.cruel (); w.world ();} b=!b;}
  }
}

interface iworld
{
  in void cruel();
  in void world();

  behavior
  {
    on cruel: {}
    on world: {}
  }
}
