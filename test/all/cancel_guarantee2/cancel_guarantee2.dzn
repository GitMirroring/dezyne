// Commentary:
//
// Derived from deadlock_cancel_guarantee: demonstrate how to resolve the
// deadlock situation, in the context of two asynchonous ports.
//
// Code:

interface ihello
{
  in void hello();
  in void bye();
  out void world();
  behavior
  {
    enum S {A,B,C};
    S s = S.A;
    [s.A] on hello: s = S.B;
    [s.B] on bye: s = S.C;
    [s.C] on inevitable: {s = S.A; world;}
  }
}

interface iblock
{
  in void block();
  behavior
  {
    on block: {}
  }
}

interface iworld
{
  in void hello();
  in void cruel();
  out void world();

  behavior
  {
    bool idle = true;
    [idle] on hello: idle = false;
    on cruel: idle = true;
    [!idle] on inevitable: {idle = true; world;}
  }
}

component cancel_guarantee2
{
  provides blocking ihello h;
  requires blocking iblock b;
  requires iworld w1;
  requires iworld w2;

  behavior
  {
    enum S {A,B,C};
    S s = S.A;
    [s.A] on h.hello(): {s = S.B; b.block(); w1.hello();}
    [s.B] on h.bye(): {s = S.C; w2.hello();}
    [s.B] on w1.world(): {s = S.B; w2.cruel();}

    [s.C] on w1.world(): {}
    [s.C] on w2.world(): {s = S.A; w1.cruel(); h.world();}
  }
}