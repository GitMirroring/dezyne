// Code:

interface ihello
{
  in void hello();
  behavior
  {
    on hello: {}
  }
}

component mux_left
{
  provides blocking ihello left_block;
  provides blocking ihello left_release;

  behavior
  {
    bool blocked = false;
    blocking on left_block.hello(): blocked = true;
    [blocked] on left_release.hello(): {blocked = false; left_block.reply();}
    [!blocked] on left_release.hello(): {}
  }
}

component mux_right
{
  provides blocking ihello right_block;
  provides blocking ihello right_release;

  behavior
  {
    bool blocked = false;
    blocking on right_block.hello(): blocked = true;
    [blocked] on right_release.hello(): {blocked = false; right_block.reply();}
    [!blocked] on right_release.hello(): {}
  }
}

component arbiter
{
  provides blocking ihello h;
  requires blocking ihello left;
  requires blocking ihello right;
  behavior
  {
    on h.hello(): {left.hello(); right.hello();}
  }
}

component compliance_blocking_double_release2
{
  provides blocking ihello block0;
  provides blocking ihello block1;
  provides blocking ihello release;

  system
  {
    release <=> middle.h;
    arbiter middle;
    middle.left <=> left.left_release;
    middle.right <=> right.right_release;

    block0 <=> left.left_block;
    block1 <=> right.right_block;
    mux_left left;
    mux_right right;
  }
}
