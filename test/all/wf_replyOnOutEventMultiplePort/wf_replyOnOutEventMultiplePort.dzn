// Commentary:
//
// Code:

interface Sensor {
  in void activate();
  out void activated();
  behavior {
    on activate: activated;
  }
}

interface Start {
  in bool start();
  behavior {
    on start: reply(false);
    on start: reply(true);
  }
}

component Test {
  provides Start start1;
  provides Start start2;
  requires Sensor sensor;
  behavior {
    on start1.start(): { reply(true); }
    on start2.start(): { reply(false); }
    on sensor.activated(): { reply(); }
  }
}
