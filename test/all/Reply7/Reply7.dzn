interface IReply7
{
  enum E {A};
  in E foo();

  behaviour
  {
    on foo: reply(E.A);
  }
}


component Reply7
{
  provides IReply7 p;
  requires IReply7 r;

  behaviour
  {
    void f()
    {
      IReply7.E v = r.foo();
      reply(v);
    }
    on p.foo(): f();
  }
}
