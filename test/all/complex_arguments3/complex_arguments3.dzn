// Commentary:
//
// Code:
interface ihello
{
  in bool hello ();
  out void one ();
  out void two ();
  out void three ();
  out void foo ();
  in void cruel ();

  behavior
  {
    on hello: {one;foo;reply (true);}
    on cruel: {two;three;}
  }
}

component complex_arguments3
{
  provides ihello h;
  behavior
  {
    bool one () {h.one ();return false;}
    bool two () {h.two ();return false;}
    bool three () {h.three ();return true;}

    bool foo (bool x) {h.foo ();return !x;}

    on h.hello ():
    {
      bool x = false;
      x = foo (one () && two ()) || three ();
      reply (x);
    }
    on h.cruel (): {bool b = two(); b = three ();}
  }
}
