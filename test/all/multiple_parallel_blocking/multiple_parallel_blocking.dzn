// Commentary:
//
// Show collateral_blocked coroutines merge out of order in case of
// two simultaneous blocked components inside a single thread safe shell
//
// Code:

import collateral_blocking_reorder.dzn;

component multiple_parallel_blocking
{
  provides ihello pleft;
  provides ihello pright;

  requires iworld rleft;
  requires iworld eleft;

  requires iworld rright;
  requires iworld eright;

  system
  {
    collateral_blocking_reorder left;
    pleft <=> left.p;
    left.e <=> eleft;
    left.r <=> rleft;

    collateral_blocking_reorder right;
    pright <=> right.p;
    right.e <=> eright;
    right.r <=> rright;
  }
}
