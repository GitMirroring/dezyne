// Code:

import iworld.dzn;

interface ihello
{
  in void hello();
  out void hey();
  out void goodbye();

  behavior
  {
    bool b = true;
    [b] on hello: {b=false; hey;}
    [!b] on hello: {b=true; goodbye;}
  }
}

component Foreign
{
  provides iworld w;
  // behavior {
  //   bool b = true;
  //   [b] on w.world (): {b=false; w.cruel ();}
  //   [!b] on w.world (): {b=true; w.howdy ();}
  // }
}

component hello
{
  provides ihello h;
  requires iworld w;

  behavior
  {
    bool b = true;
    on h.hello(): {b=false; w.world();}
    [!b] on w.cruel(): {b=true; h.hey ();}
    [!b] on w.howdy(): {b=true; h.goodbye();}
  }
}

component hello_foreign_out
{
  provides ihello h;

  system
    {
      h <=> c.h;
      hello c;
      c.w <=> f.w;
      Foreign f;
    }
}
