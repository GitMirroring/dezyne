// Code:

enum Bool {False,True};

interface ihello
{
  in Bool hello ();
  enum Result {OK, NOK};
  in Result cruel ();

  behavior
  {
    on hello: return Bool.False;
    on hello: return Bool.True;
    on cruel: return Result.OK;
    on cruel: return Result.NOK;
  }
}

component hello_implicit_enum
{
  provides ihello h;
  requires ihello w;

  behavior
  {
    Bool foo ()
    {
      return w.hello ();
    }

    on h.hello ():
    if (w.hello () == Bool.True) return w.hello ();
    else if (Bool.False == foo () && true) return foo ();
    else return Bool.False;
    on h.cruel ():
    {
      if (w.cruel () == ihello.Result.OK)
        return w.cruel ();
      else
        return ihello.Result.NOK;
    }
  }
}
