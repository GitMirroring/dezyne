import philosopher.dzn;

component starving_philosophers
{
  provides blocking IMind m0;
  provides blocking IMind m1;

  system
  {
    philosopher P0;
    vork F0;
    philosopher P1;
    vork F1;

    m0 <=> P0.m;
    m1 <=> P1.m;

    // this configuration leads to deadlock
    // see deadlock execution trace
    // see also starvingphilosophers example

    P0.l <=> F0.l;
    F0.r <=> P1.r;
    P1.l <=> F1.l;
    F1.r <=> P0.r;
  }
}
