import philosopher.dzn;

component Test
{
  provides blocking IMind m;
  requires blocking IMind m0;
  requires blocking IMind m1;

  behavior
  {
    bool idle = true;
    [idle] on m.start (): {idle = false; m0.start (); m1.start ();}
    [!idle] on m.stop (): {idle = true; m0.stop (); m1.stop ();}
  }
}

component starving_philosophers
{
  provides blocking IMind m;

  system
  {
    philosopher P0;
    vork F0;
    philosopher P1;
    vork F1;
    Test T;

    m <=> T.m;
    T.m0 <=> P0.m;
    T.m1 <=> P1.m;

    // this configuration leads to deadlock
    // see deadlock execution trace
    // see also starvingphilosophers example

    P0.l <=> F0.l;
    F0.r <=> P1.r;
    P1.l <=> F1.l;
    F1.r <=> P0.r;
  }
}
