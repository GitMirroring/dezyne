interface ihello
{
  in void hello ();
  out void world ();

  behavior {
    on hello: world;
    on hello: {}
  }
}

interface iworld
{
  in void hello ();
  out void world ();

  behavior {
    bool idle = true;

    on hello: idle = false;
    [!idle] on inevitable: {world; idle=true;}
  }
}

component collateral_double_blocked_out
{
  provides blocking ihello left;
  provides blocking ihello middle;
  provides blocking ihello right;
  requires iworld r;

  behavior {
    enum status {IDLE, LEFT, MIDDLE};
    status state = status.IDLE;

    blocking on left.hello ():
    {
      if (state.IDLE)
        r.hello ();
      else
        middle.reply ();
      state=status.LEFT;
    }
    blocking on middle.hello ():
    {
      if (state.IDLE)
        r.hello ();
      else
        left.reply ();
      state=status.MIDDLE;
    }
    on right.hello (): right.world ();
    [state.LEFT]
    on r.world (): {left.world (); left.reply (); state=status.IDLE;}
    [state.MIDDLE]
    on r.world (): {middle.world (); middle.reply (); state=status.IDLE;}
  }
}
