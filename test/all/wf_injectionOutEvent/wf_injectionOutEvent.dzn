// Code:

interface Intf {
  in void e();
  behavior { on e: { } }
}

interface InjIntf {
  in void evt();
  out void notif();
  behavior {
    on evt: {}
    on optional: notif;
  }
}

component Comp {
  provides Intf i;
  requires injected InjIntf ii;
  behavior {
    on i.e(): {}
    on ii.notif(): {}
  }
}
