// Commentary:
//
// Code:

interface ihello
{
  in void hello();

  behavior
  {
    on hello:{}
  }
}

interface iworld
{
  in void hello();
  out void world();

  behavior
  {
    bool idle = true;
    [idle] on hello: idle = false;
    [!idle]
    {
      on hello: illegal;
      on inevitable: {idle = true; world;}
    }
  }
}
component Proxy
{
  provides ihello p;
  requires ihello r;

  behavior
  {
    on p.hello(): r.hello();
  }
}

component Block
{
  provides ihello p;
  requires iworld r;

  behavior
  {
    blocking on p.hello(): r.hello();
    on r.world(): p.reply();
  }
}

component blocking_bottom_system
{
  provides ihello p;
  requires iworld r;

  system
  {
    Proxy proxy;
    p <=> proxy.p;

    Block block;
    proxy.r <=> block.p;
    block.r <=> r;
  }
}
