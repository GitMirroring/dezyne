// Code:

interface ihello
{
  in void hello();

  behavior
  {
    on hello: {}
  }
}

interface iworlds
{
  in void hello();
  out void world();

  behavior
  {
    on hello: world;
  }
}

interface iworlda
{
  in void hello();
  out void world();

  behavior
  {
    bool idle = true;
    [idle] on hello: idle = false;
    [!idle]
    {
      on hello: illegal;
      on inevitable: {idle = true; world;}
    }
  }
}

component multiple_provides
{
  provides blocking ihello left;
  provides blocking ihello right;
  requires blocking iworlds r;

  behavior
  {
    enum Side {None, Left, Right, LeftRight, RightLeft};
    Side side = Side.None;

    blocking on left.hello(): {
      [side.None] {side = Side.Left; r.hello();}
      [side.Right] {side = Side.RightLeft; r.hello();}
    }
    blocking on right.hello(): {
      [side.None] {r.hello(); side = Side.Right;}
      [side.Left] {r.hello(); side = Side.LeftRight;}
    }

    [side.Left] on r.world(): {side = Side.None; left.reply();}
    [side.LeftRight] on r.world(): {side = Side.Right; left.reply();}

    [side.Right] on r.world(): {side = Side.None; right.reply();}
    [side.RightLeft] on r.world(): {side = Side.Left; right.reply();}
  }
}

component block
{
  provides blocking iworlds p;
  requires iworlda r;

  behavior
  {
    blocking on p.hello(): r.hello();
    on r.world(): {p.reply(); p.world();}
  }
}

component collateral_blocking_multiple_provides0
{
  provides blocking ihello left;
  provides blocking ihello right;
  requires iworlda r;

  system
  {
    multiple_provides mp;
    left <=> mp.left;
    right <=> mp.right;

    block b;
    mp.r <=> b.p;
    b.r <=> r;
  }
}
