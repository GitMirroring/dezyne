interface i
{
  in void ia();
  in void ib();
  in void ic();
  in void id();
  out void od();
  in void ie();

  behaviour
  {
    on ia: {}
    on ib: illegal;
    on ic: illegal;
    on id: od;
    on ie: illegal;
  }
}

component compliance_provides_illegal
{
  provides i pp;
  requires i rp;

  behaviour
  {
    on pp.ia(): rp.ib();
    on pp.ib(): rp.ib();
    on pp.ic(): illegal;
    on pp.id(): rp.id();
    on rp.od(): illegal;
    on pp.ie(): rp.id();
  }
}
