// Code:

interface ihello
{
  enum Result {Foo, Bar};
  in Result bye();
  in Result hello();

  behaviour
  {
    on bye: reply(Result.Foo);
    on hello: reply(Result.Bar);
  }
}

interface iworld
{
  in void hello();
  out void world();

  behaviour
  {
    bool idle = true;

    on hello: idle = false;

    [!idle] {
      on inevitable: {idle = true; world;}
    }
  }
}

component hello_skip_block {
  provides ihello p;
  requires iworld r;

  behaviour {
    blocking on p.bye(): p.reply(ihello.Result.Foo);
    blocking on p.hello(): r.hello();
    on r.world(): {p.reply(ihello.Result.Bar);}
  }
}
