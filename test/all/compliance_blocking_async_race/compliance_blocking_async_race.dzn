// Commentary:
//
//  The compliance check must never use the state of a non-compliant
//  port trace, "world" in this case.
//
// Code:

interface ihello
{
  in void hello();
  in void bye();
  out void world();
  behavior
  {
    bool idle = true;
    [idle]
    {
      on hello: idle = false;
    }
    [!idle]
    {
      on hello: {}
      on bye: idle = true;
      on inevitable: {idle = true; world;}
    }
  }
}

interface iworld
{
  in void cruel();
  out void world();
  behavior
  {
    bool idle = false;
    on cruel: idle = false;
    [!idle] on inevitable: {idle = true; world;}
  }
}

component compliance_blocking_async_race
{
  provides blocking ihello h;
  requires iworld r;
  requires blocking iworld w;
  behavior
  {
    requires dzn.async async;

    bool idle = true;
    [idle] on h.hello(): {idle = false; async.req();}
    on async.ack(): {r.cruel(); w.cruel();}
    [!idle]
    {
      on h.hello(): {}
      on h.bye(): {async.clr(); idle = true;}
    }
    on r.world(): {}
    on w.world(): {}
  }
}
