component hello_systems
{
  provides ihello h;
  requires iworld w;

  system
    {
      system_hellocruel shc;
      system_cruelworld scw;
      h <=> shc.h;
      shc.c <=> scw.c;
      scw.w <=> w;
    }
}

interface ihello
{
  in void hello();

  behaviour
  {
    on hello: {}
  }
}

interface icruel
{
  in void cruel();

  behaviour
  {
    on cruel: {}
  }
}

interface iworld
{
  in void world();

  behaviour
  {
    on world: {}
  }
}

component hellocruel
{
  provides ihello h;
  requires icruel c;

  behaviour
  {
    on h.hello(): c.cruel();
  }
}

component cruelworld
{
  provides icruel c;
  requires iworld w;

  behaviour
  {
    on c.cruel(): w.world();
  }
}

component system_hellocruel
{
  provides ihello h;
  requires icruel c;

  system
    {
      hellocruel hc;

      h <=> hc.h;
      c <=> hc.c;
    }
}

component system_cruelworld
{
  provides icruel c;
  requires iworld w;

  system
    {
      cruelworld cw;

      c <=> cw.c;
      w <=> cw.w;
    }
}
