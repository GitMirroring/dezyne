interface I1 {
  enum I1 { E1, E2 }; //<<<<<<<<<<<<
  in void e();
  behaviour {
    on e: {}
  }
}

component NameClash {
  provides I1 NameClash; //<<<<<<<<<<<<<<<<<<
  behaviour {
    on NameClash.e(): {}
  }
}

component NameClash2 {
  provides I1 p;
  behaviour {
    enum NameClash2 { E1, E2 }; //<<<<<<<<<<<<<<<<<<
    on p.e(): {}
  }
}

component NameClash3 {
  provides I1 p;
  behaviour {
    bool NameClash3 = false; // <<<<<<<<<<<<<<<<<<<<<
    on p.e(): {}
  }
}

