// Commentary:
//
// Code:

interface I {
    in void e();

    behavior {
        on e: {}
    }
}

interface II {
    in void e();
    out void cb();

    behavior {
        bool idle = false;

        on e: idle = true;
        [idle] on inevitable: { cb; idle=false;}
    }
}

component fork {
    provides I p;
    requires I r0;
    requires I r1;

    behavior {
        on p.e(): {r1.e();r0.e();}
    }
}


component block {
    provides I p;
    requires II rr;

    behavior {
        on p.e(): blocking rr.e();
        on rr.cb(): p.reply();
    }
}

component resource {
    provides II p0;
    provides II p1;
    requires II rrr0;
    requires II rrr1;

    behavior {
        on p0.e(): rrr0.e();
        on p1.e(): rrr1.e();
        on rrr0.cb(): p0.cb();
        on rrr1.cb(): p1.cb();
    }
}

component blocking_system_diamond {
    provides I p;
    requires II rrrr0;
    requires II rrrr1;

    system {
        fork f;
        block b0;
        block b1;
        resource r;

        p <=> f.p;
        f.r0 <=> b0.p;
        f.r1 <=> b1.p;
        b0.rr <=> r.p0;
        b1.rr <=> r.p1;
        r.rrr0 <=> rrrr0;
        r.rrr1 <=> rrrr1;
    }
}
