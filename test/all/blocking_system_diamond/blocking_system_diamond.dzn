// Commentary:
//
// Code:

interface ihello
{
  in void hello ();

  behavior
  {
    on hello: {}
  }
}

interface iworld
{
  in void hello ();
  out void world ();

  behavior
  {
    on hello: world;
  }
}

component fork_event
{
  provides blocking ihello p;
  requires blocking ihello r_left;
  requires blocking ihello r_right;

  behavior
  {
    on p.hello (): {r_left.hello ();r_right.hello ();}
  }
}

component proxy
{
  provides blocking ihello p;
  requires blocking ihello r;

  behavior
  {
    on p.hello (): r.hello ();
  }
}

component resource
{
  provides blocking ihello p_left;
  provides blocking ihello p_right;
  requires external iworld r_left;
  requires external iworld r_right;

  behavior
  {
    on p_left.hello (): blocking r_left.hello ();
    on p_right.hello (): blocking r_right.hello ();
    on r_left.world (): p_left.reply ();
    on r_right.world (): p_right.reply ();
  }
}

component blocking_system_diamond
{
  provides blocking ihello p;
  requires external iworld r_left;
  requires external iworld r_right;

  system
  {
    fork_event top;
    proxy left;
    proxy right;
    resource bottom;

    p <=> top.p;
    top.r_left <=> left.p;
    top.r_right <=> right.p;
    left.r <=> bottom.p_left;
    right.r <=> bottom.p_right;
    bottom.r_left <=> r_left;
    bottom.r_right <=> r_right;
  }
}
