// Code:

interface ihello
{
  in void hello ();

  behavior
  {
    on hello: {}
  }
}

interface iworld
{
  in void hello ();
  out void world ();

  behavior
  {
    bool idle = false;

    on hello: idle = true;
    [idle] on inevitable: {world; idle=false;}
  }
}

component fork
{
  provides ihello p;
  requires ihello r_left;
  requires ihello r_right;

  behavior
  {
    on p.hello (): {r_left.hello ();r_right.hello ();}
  }
}

component block
{
  provides ihello p;
  requires iworld r;

  behavior
  {
    on p.hello (): blocking r.hello ();
    on r.world (): p.reply ();
  }
}

component resource
{
  provides iworld p_left;
  provides iworld p_right;
  requires iworld r_left;
  requires iworld r_right;

  behavior
  {
    on p_left.hello (): r_left.hello ();
    on p_right.hello (): r_right.hello ();
    on r_left.world (): p_left.world ();
    on r_right.world (): p_right.world ();
  }
}

component blocking_system_diamond
{
  provides ihello p;
  requires iworld r_left;
  requires iworld r_right;

  system
  {
    fork top;
    block left;
    block right;
    resource bottom;

    p <=> top.p;
    top.r_left <=> left.p;
    top.r_right <=> right.p;
    left.r <=> bottom.p_left;
    right.r <=> bottom.p_right;
    bottom.r_left <=> r_left;
    bottom.r_right <=> r_right;
  }
}
