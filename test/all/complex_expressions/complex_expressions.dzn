interface ihello
{
  in bool hello ();
  out void one ();
  out void two ();
  out void three ();
  out void four ();
  out void five ();

  behavior
  {
    subint int {0..4};
    int i=0;
    [i == 0] on hello: {i=i+1; one; one; two; reply (true);}
    [i == 1] on hello: {i=i+1; one; two; one; three; reply (false);}
    [i == 2] on hello: {i=i+1; one; two; one; three; one; one; four; five; reply (true);}
    [i == 3] on hello: {i=0; one; two; one; three; one; one; four; reply (true);}
  }
}

interface iworld
{
  in bool hello ();
  in bool cruel ();
  in bool crash ();

  behavior
  {
    subint int {0..4};
    int i=0;
    [i == 0] on hello: {i=i+1; reply (true);}
    [i == 1] on hello: {i=i+1; reply (false);}
    [i == 2] on hello: {i=i+1; reply (true);}
    [i == 3] on hello: {i=0; reply (true);}
  }
}

component complex_expressions
{
  provides ihello h;
  requires iworld w;

  behavior
  {
    bool first=true;
    bool one () {h.one (); bool b=first; first= false; return b;}

    bool second=true;
    bool two () {h.two (); bool b=second; second=false; return b;}

    bool third=true;
    bool three () {h.three (); bool b=third; third=false; return b;}

    bool fourth=true;
    bool four () {h.four (); bool b=fourth; fourth=false; return b;}

    bool fifth=true;
    bool five () {h.five(); bool b=fifth; fifth=false;return b;}

    bool cruel () { return true; }

    void reset () {first=true; second=true; third=true; fourth=true; fifth=true;}

    on h.hello ():
    {
      bool dummy = cruel (); // make code of cruel reachable.
      if (one () || two ()) reply ((one () || two ()) && w.hello ()); //0
      else if (one () || three ()) reply (w.hello ());                //1
      else if (one () && four () && cruel ()) illegal;                //never
      else if (one () || (four () && five ())) reply (w.hello ());    //2
      else {reset (); reply (w.hello ());}                            //3
    }
  }
}
