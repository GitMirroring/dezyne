interface ihello
{
  in void hello ();
  in void bye ();
  behavior
  {
    bool idle = true;
    [idle] on hello: idle = false;
    [!idle] on bye: idle = true;
  }
}

interface icruel
{
  in void hello ();
  in void bye ();
  out void cruel ();
  behavior
  {
    bool idle = true;
    [idle] on hello: idle = false;
    [!idle] on bye: idle = true;
    on optional: {idle = true; cruel;}
  }
}

component blocking_defer
{
  provides blocking ihello h;
  provides blocking icruel c;
  behavior
  {
    on h.hello (): {}
    blocking on h.bye (): defer {c.cruel (); h.reply ();}
    on c.hello (): {}
    on c.bye (): {}
  }
}
