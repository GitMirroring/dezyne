// Commentary:
//
// Code:

import iworld.dzn;

interface ihello
{
  in void hello();

  behavior
  {
    on hello: {}
  }
}

component Foreign
{
  provides iworld w;
  // behavior {
  //   on w.world (): {}
  // }
}

component hello
{
  provides ihello h;
  requires iworld w;

  behavior
  {
    on h.hello(): w.world();
  }
}

component foreign_handwritten
{
  provides ihello h;

  system
    {
      h <=> c.h;
      hello c;
      c.w <=> f.w;
      Foreign f;
    }
}
