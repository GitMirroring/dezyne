// Code:

interface ihello
{
  in void hello();
  in void cruel();
  in void cancel();
  out void world();

  behavior
  {
    bool idle = true;
    bool ignore = false;

    [idle] on hello: {idle = false; ignore = false;}
    [!idle] on cancel: {idle = true; ignore = true;}
    [idle && ignore] on cruel: {idle = false;}
    [!idle] on cruel: {}
    [!idle && !ignore] on inevitable: {idle = true; ignore = false; world;}
  }
}

component defer_cruel
{
  provides ihello h;

  behavior
  {
    bool idle = true;
    bool ignore = false;

    [idle] on h.hello (): {idle = false; ignore = false; defer {idle = true; h.world();}}
    [!idle] on h.cancel (): {idle = true; ignore = true;}
    [idle && ignore] on h.cruel (): {idle = false; ignore = false;}
    [!idle] on h.cruel (): {}
  }
}
