// Commentary:
//
// Code:

//TAG00 interface
interface ihello
{
  //TAG01 in-event
  in void hello();

  //TAG02 out-event
  out void cruel();

  //TAG03 out-event
  out void world();

  behavior
  {
    bool idle = true;

    [idle]
    {
      //TAG04 interface-on
      on hello: {cruel; world;}

      //TAG05 interface-on
      on hello: idle = false;
    }
    [!idle]
    {
      //TAG06 interface-on
      on inevitable: {
        //TAG07 assignment
        idle = true;

        //TAG08 action
        cruel;

        //TAG09 action
        world;
      }
    }
  }
}

//TAG10 component
component comment_traceability
{
  //TAG11 provides
  provides ihello h;

  //TAG12 requires
  requires ihello w;

  behavior
  {
    //TAG13 state
    bool idle = true;

    //TAG14 component-on
    [idle] on h.hello(): {
      //TAG15 assignment
      idle = false;

      //TAG16 action
      w.hello();
    }

    //TAG17 component-on
    on w.cruel(): {
    }


    //TAG18 component-on
    on w.world(): {
      //TAG19 assignment
      idle = true;

      //TAG20 action
      h.cruel();

      //TAG21 action
      h.world();
    }
  }
}