// Code:

interface ihello
{
  in void hello ();
  behavior
  {
    on hello: {}
  }
}

interface iworld
{
  in void hello ();
  in void cruel ();
  out void world ();
  behavior
  {
    bool idle = true;
    on hello: idle = false;
    on cruel: idle = true;
    [!idle] on inevitable: {idle=true;world;}
  }
}

component collateral_blocking_double_release
{
  provides ihello block0;
  provides ihello block1;
  provides ihello release;
  requires iworld w;

  behaviour
  {
    bool blocked0 = false;
    bool blocked1 = false;

    blocking on block0.hello (): {w.hello (); blocked0 = true;}
    blocking on block1.hello (): {w.hello (); blocked1 = true;}

    on release.hello (), w.world ():
    {
      w.cruel ();
      if (blocked0)
      {
        block0.reply ();
        blocked0 = false;
      }
      if (blocked1)
      {
        block1.reply ();
        blocked1 = false;
      }
    }
  }
}
