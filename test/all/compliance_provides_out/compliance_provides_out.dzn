// Code:

interface i
{
  in void hello();
  out void world();
  out void planet();

  behaviour
  {
    on hello: world;
    on hello: {}
    on optional: world;
  }
}

component compliance_provides_out
{
  provides i p;
  behaviour
  {
    on p.hello(): p.planet();
  }
}
