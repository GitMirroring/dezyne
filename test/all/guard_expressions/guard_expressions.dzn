// enum, bool, int members, test all operators in guard expression, otherwise
interface ihello
{
  enum E {OK, NOK};
  in void hello();

  behaviour
  {
    on hello: {}
  }
}

component guard_expressions
{
  provides ihello h;
  requires iworld w;

  behaviour
  {
    subint range {0..2};
    range i = 0;
    ihello.E e = ihello.E.OK;
    bool b = true;
    on h.hello():
    {
      [i == 0
       && (i + 1) == 1
       && (1 - i) == 1
       && 0 < 1
       && 0 <= 0
       && 0 <= 1
       && 1 > 0
       && 0 >= 0
       && 1 >= 0
       && ((
            false
            || e.NOK
            || e.OK
            && b
            && true == b
            && b == e.OK
            && b == e.OK
            && e == ihello.E.OK
            && ihello.E.OK == ihello.E.OK
            ))]
      {b=!b; w.cruel ();}
      [otherwise] {b=!b; w.world ();}
       //  [i == 0
       // && (i + 1) == 1
       // && (1 - i) == 1
       // && 0 < 1
       // && 0 <= 0
       // && 0 <= 1
       // && 1 > 0
       // && 0 >= 0
       // && 1 >= 0
       // && (false
       //     || !e.OK
       //     || !e.NOK
       //     && !b
       //     && false == b
       //     && b != !e.NOK
       //     && e != ihello.E.NOK
       //     && ihello.E.OK != ihello.E.NOK
       //     )] {b=!b; w.world ();}
        }
  }
}

interface iworld
{
  in void cruel();
  in void world();

  behaviour
  {
    on cruel: {}
    on world: {}
  }
}
