// Code:

extern int $int$;

interface ihello
{
  in int hello ();
  behavior
  {
    on hello: {}
  }
}

interface iworld
{
  in int world ();
  behavior
  {
    on world: {}
  }
}

component hello_data_reply
{
  provides ihello h;
  requires iworld w;
  behavior
  {
    on h.hello (): reply (w.world ());
  }
}