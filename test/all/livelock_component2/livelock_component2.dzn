// Code:

interface Iterate
{
  in void map();

  behaviour
  {
    on map: {}
  }
}

interface List
{
  in bool next();

  behaviour
  {
    on next: reply(false);
    on next: reply(true);
  }
}

component livelock_component2
{
  provides Iterate iter;
  requires List list;

  behaviour
  {
    void next()
    {
      bool r = list.next();
      if(r) next();
    }

    on iter.map(): next();
  }
}
