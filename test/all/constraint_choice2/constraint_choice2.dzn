// Code:

subint int {0..1};

interface ihello
{
  in void inc ();
  in void dec ();

  in bool get0 ();
  in bool get1 ();

  behavior
  {
    int i = 0;
    [i<1] on inc: i=i+1;
    [0<i] on dec: i=i-1;

    on get0: reply (false);
    on get0: reply (true);
    on get1: reply (false);
    on get1: reply (true);
  }
}

interface iworld
{
  in int hello ();

  behavior
  {
    on hello: reply (0);
    on hello: reply (1);
  }
}

interface ibool
{
  in void hello ();
  in void cruel ();

  behavior
  {
    on hello: {}
    on cruel: {}
  }
}

component constraint_choice2
{
  provides ihello h;
  requires iworld w;
  requires ibool b;
  behavior
  {
    int i = 0;
    void f ()
    {
      if (w.hello () == 0)
        b.hello ();
      else
        b.cruel ();
    }
    [i<1] on h.inc (): {i=i+1; f ();}
    [0<i] on h.dec (): {i=i-1; f ();}
    on h.get0 (): reply (i==0);
    on h.get1 (): reply (i==1);
  }
}
