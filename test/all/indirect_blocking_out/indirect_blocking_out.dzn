interface I
{
  in void a();
  out void b();
  behavior
  {
    on a: b;
  }
}

interface I2
{
   in void a();
   out void b();
   behavior
   {
     bool idle = true;
     [idle] on a: idle = false;
     [!idle] on a: illegal;
     [!idle] on inevitable: {idle = true; b;}
   }
}

component indirect_blocking_out
{
  provides blocking I p;
  requires I2 r;
  behavior
  {
    blocking on p.a(): r.a();
    on r.b(): {p.b(); p.reply();}
  }
}
