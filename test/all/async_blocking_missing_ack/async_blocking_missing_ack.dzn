// Commentary:
//
// Async prioritizes ack's over other optional and inevitable out
// events.  Combining this with blocking can cause this async invariant
// to be violated.  Details: in the pump, the loop flushing all the
// pending ack's is interrupted by a previously released blocked event.
// The continuation of this coroutine could enter a single out event
// into the pump queue.  The example below demonstrates this.
//
// Code:

interface ihello
{
  in void hello();

  behavior
  {
    on hello: {}
  }
}

component async_blocking_missing_ack
{
  provides ihello h;
  requires iworld w;

  system
  {
    Top top;
    Bottom bottom;

    h <=> top.h1;
    top.h2 <=> bottom.h;
    bottom.w <=> w;
  }
}


component Top
{
  provides ihello h1;
  requires ihello h2;

  behavior
  {
    requires dzn.async async;

    blocking on h1.hello(): {async.req(); h2.hello();}
    on async.ack(): h1.reply();
  }
}

component Bottom
{
  provides ihello h;
  requires iworld w;

  behavior
  {
    enum S {A,B,C};
    S s = S.A;

    requires dzn.async async;

    blocking [s.A] on h.hello(): {s = S.B; async.req(); w.hello();}
    on async.ack(): {s = S.C;h.reply();}
    [s.C] on w.world(): s = S.A;
  }
}

interface iworld
{
  in void hello();
  out void world();

  behavior
  {
    bool idle = true;
    [idle] on hello: idle = false;
    [!idle] on inevitable: {idle = true; world;}
  }
}
