// Commentary:
//
// Code:

interface ihello
{
  in void hello ();
  behavior
  {
    on hello: {}
  }
}

component defer_after_call
{
  provides ihello h;

  behavior
  {
    bool idle = true;
    on h.hello (): f ();

    void f ()
    {
      idle = !idle;
      g ();  // without this call, no defer-qin overflow
      defer {}
    }
    void g () {}
  }
}
