// Code:

interface ihello
{
  in void hello ();
  out void world ();

  behavior
  {
    bool idle = true;

    [idle] on hello: idle = false;
    [!idle] on inevitable: {world; idle = true;}
  }
}

component shared_async_requires
{
  provides ihello h;
  requires ihello w;

  behavior
  {
    bool idle = true;
    bool w_idle = true;

    void dzn_assert (bool c)
    {
      if (!c) illegal;
    }

    void check ()
    {
      dzn_assert (w_idle == w.idle);
    }

    [idle] on h.hello ():
    {
      idle = false;
      w.hello (); w_idle = false;
      check ();
    }
    [!idle] on w.world ():
    {
      idle = true;
      h.world (); w_idle = true;
      check ();
    }
  }
}
