// Commentary:
//
// Code:

extern int $int$;

enum Enum {OK,NOK};

subint Int {0..1};

interface I
{
  in Int return_int();
  in bool return_bool();
  in Enum return_enum(int i, out int j);
  out void foo(int i);

  behaviour
  {
    on return_int: {foo; reply(0);}
    on return_bool: {foo; reply(true);}
    on return_enum: {foo; reply(Enum.OK);}
    on return_enum: {reply(Enum.NOK);}
  }
}

interface II
{
  in Int return_int();
  in bool return_bool();
  in Enum return_enum(int i, out int j);
  out void foo(int i);

  behaviour
  {
    bool idle = true;
    [idle] {
      on return_int: {idle = false; reply(0);}
      on return_bool: {idle = false; reply(true);}
      on return_enum: {idle = false; reply(Enum.OK);}
      on return_enum: {reply(Enum.NOK);}
    }
    [!idle] {
      on return_int: illegal;
      on return_bool: illegal;
      on return_enum: illegal;
      on inevitable: {idle = true; foo;}
    }
  }
}

component C
{
  provides I p_inner;
  requires II r_inner;

  behaviour
  {
    Int i = 1;
    bool b = false;
    Enum r = Enum.NOK;
    on p_inner.return_int(): blocking {b = false; i = r_inner.return_int();}
    on p_inner.return_bool(): blocking {b = r_inner.return_bool();}
    on p_inner.return_enum(i,j): blocking {b = false; r = r_inner.return_enum(i,j); if(r.NOK) reply(r);}
    [b] on r_inner.foo(i): {p_inner.foo(i); p_inner.reply(b);}
    [!b] [i==1] on r_inner.foo(j): {p_inner.foo(j); p_inner.reply(r);}
    [!b] [i==0] on r_inner.foo(j): {p_inner.foo(j); p_inner.reply(i); i = 1;}
  }
}

component B
{
  provides I p_proxy_inner;
  requires I r_proxy_inner;

  behaviour
  {
    on p_proxy_inner.return_int(): {Int i = r_proxy_inner.return_int(); reply(i);}
    on p_proxy_inner.return_bool(): {bool b = r_proxy_inner.return_bool(); reply(b);}
    on p_proxy_inner.return_enum(i,j): {Enum r = r_proxy_inner.return_enum(i,j); reply(r);}
    on r_proxy_inner.foo(i): p_proxy_inner.foo(i);
  }
}

component shell
{
  provides I p_outer;
  requires II r_outer;

  system
  {
    B b;
    C c;
    p_outer<=>b.p_proxy_inner;
    b.r_proxy_inner<=>c.p_inner;
    c.r_inner<=>r_outer;
  }
}
