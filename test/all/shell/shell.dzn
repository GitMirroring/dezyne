// Code:

extern int $int$;

interface I
{
  in bool return_to_sender(int i, out int j);
  out void foo(int i);

  behaviour
  {
    on return_to_sender: {foo; reply(true);}
  }
}

component C
{
  provides I p_inner;
  requires I r_inner;

  behaviour
  {
    on p_inner.return_to_sender(i,j): {bool b = r_inner.return_to_sender(i,j); reply(b);}
    on r_inner.foo(i): p_inner.foo(i);
  }
}

component shell
{
  provides I p_outer;
  requires I r_outer;

  system
  {
    C c;
    p_outer<=>c.p_inner;
    c.r_inner<=>r_outer;
  }
}
