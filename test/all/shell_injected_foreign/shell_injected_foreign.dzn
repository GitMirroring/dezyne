import externaltypes.dzn;

import ilogger.dzn;

component Logger
{
  provides ILogger log;
  // behavior {}
}

interface IWatchdog
{
  in void set ();
  in void cancel ();
  out void timeout ();

  behavior
  {
    bool idle = true;
    on cancel: idle = true;
    [idle] on set: idle = false;
    [!idle]
    {
      on inevitable: timeout;
    }
  }
}

component Watchdog
{
  provides IWatchdog w;
}

interface IRelaxed
{
  in void e ();
  out void f ();

  behavior
  {
    on e: {}
    on e: f;
  }
}


interface IStrict
{
  in void e ();
  out void f ();

  behavior
  {
    bool idle = true;
    on e: { idle = false; }
    [!idle] on inevitable: { f; idle = true; }
  }
}

component TopArmor
{
  provides blocking IRelaxed r;
  requires IStrict s;

  requires injected ILogger l;

  behavior
  {
    on r.e (): blocking s.e ();
    on s.f (): {r.reply (); r.f ();}
  }
}

component BottomArmor
{
  provides IStrict s;
  requires external IRelaxed r;
  requires IWatchdog w;

  behavior
  {
    bool idle = true;
    bool watchdog = false;
    [idle] on s.e (): {idle = false; r.e (); watchdog = true; w.set ();}
    [!idle] {
      on s.e (): {if (!watchdog) w.set (); watchdog = true;}
      on r.f (): {
        if (watchdog) {idle = true; watchdog = false; w.cancel (); s.f ();}
      }
      on w.timeout (): {watchdog = false; w.cancel (); s.f ();}
    }
  }
}

component C
{
  provides IStrict p;
  requires IStrict r;
  requires injected ILogger l;

  behavior
  {
    on p.e (): {l.log ($"foo"$); r.e ();}
    on r.f (): {l.log ($"bar"$); p.f ();}
  }
}

component shell_injected_foreign
{
  provides blocking IRelaxed p;
  requires external IRelaxed r;

  system
  {
    Logger logger;
    TopArmor top;
    C c;
    BottomArmor bottom;
    Watchdog watchdog;

    p <=> top.r;
    top.s <=> c.p;
    c.r <=> bottom.s;
    bottom.r <=> r;
    logger.log <=> *;
    bottom.w <=> watchdog.w;
  }
}
