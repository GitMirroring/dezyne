interface ihello
{
  in void hello();

  behavior
  {
    on hello: {}
  }
}

component mux
{
  provides blocking ihello left;
  provides blocking ihello middle;
  provides blocking ihello right;

  behavior
  {
    enum Which {None, Left, Middle, Right};
    Which first = Which.None;
    Which second = Which.None;

    [first.None && second.None]
    {
      blocking on left.hello(): first = Which.Left;
      blocking on middle.hello(): first = Which.Middle;
      blocking on right.hello(): first = Which.Right;
    }
    [second.None]
    {
      [first.Middle || first.Right] blocking on left.hello(): second = Which.Left;
      [first.Left || first.Right] blocking on middle.hello(): second = Which.Middle;
      [first.Left || first.Middle] blocking on right.hello(): second = Which.Right;
    }
    [otherwise]
    {
      on left.hello(): {first = Which.None; second = Which.None; middle.reply(); right.reply();}
      on middle.hello(): {first = Which.None; second = Which.None; left.reply(); right.reply();}
      on right.hello(): {first = Which.None; second = Which.None; middle.reply(); left.reply();}
    }
  }
}

component compliance_blocking_multiple_provides3
{
  provides blocking ihello left;
  provides blocking ihello middle;
  provides blocking ihello right;

  system
  {
    mux m;

    left <=> m.left;
    middle <=> m.middle;
    right <=> m.right;
  }
}
