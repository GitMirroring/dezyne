// Commentary:
//
// This model demonstrates missing the semantics_blocking_switch_context to
// cater for modeling events during a collateral blocked action in the context
// of a blocking trigger, i.e. the model below must support both interleavings of
// c.cruel and w.world.
//
// Code:

interface icruel
{
  in void hello ();
  out void cruel ();

  behavior
  {
    on hello: cruel;
  }
}

interface iworld
{
  in void hello ();
  out void world ();

  behavior
  {
    bool idle = true;
    [idle] on hello: idle = false;
    [!idle] on inevitable: {idle = true; world;}
  }
}

component collateral_illegal
{
  provides blocking icruel h;
  requires blocking icruel c;
  requires iworld w;

  behavior
  {
    bool expect_cruel = false;
    blocking on h.hello (): {expect_cruel = true; w.hello (); c.hello ();}
    on w.world (): {if (expect_cruel) illegal; h.reply ();}
    on c.cruel (): {expect_cruel = false; h.cruel ();}
  }
}
