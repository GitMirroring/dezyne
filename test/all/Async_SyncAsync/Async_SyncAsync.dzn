// Test async refine interaction with synchronous provides port out
// event.
component Async_SyncAsync // also covered by async_synccb.dzn
{
  provides ISyncAsync pp;

  behaviour
  {
    requires dzn.async() reflector;

    on pp.ia(): {reflector.req(); pp.osync();}
    on reflector.ack(): pp.oasync();
  }

  // component Async_SyncAsync shall at least perform trace
  // pp.ia
  // pp.osync
  // pp.return
  // pp.oasync
}

interface ISyncAsync
{
  in void ia();
  out void osync();
  out void oasync();

  behaviour
  {
    bool is_active = false;

    [!is_active] on ia: {is_active = true; osync;}
    [is_active] on ia: illegal;

    [is_active] on inevitable: {is_active = false; oasync;}
  }
}

