//
// Code:

interface iworld {
  in void hello();
  out void world();

  behavior {
    on hello: world;
  }
}

component World {
  provides iworld w;

  behavior {
    on w.hello(): w.world();
  }
}

interface ihello {
  in void hello();
  out void world();

  behavior {
    bool idle = true;
    [idle] on hello: idle = false;
    [!idle] on inevitable:  {idle = true; world;}
  }
}

component Hello {
  provides ihello h;
  requires iworld w;

  behavior {
    requires dzn.async async;

    enum State { Idle, Starting, Running };
    State state = State.Idle;

    [state.Idle]
    {
      on h.hello(): {
        async.req();
        state = State.Starting;
      }
    }

    [state.Starting]
    {
      on async.ack(): {
        w.hello();
        state = State.Running;
      }
    }

    [state.Running]
    {
      on w.world(): {h.world(); state = State.Idle;}
    }
  }
}

component async_shell {
  provides ihello h;

  system {
    Hello hello;
    World world;

    hello.h <=> h;
    hello.w <=> world.w;
  }
}
