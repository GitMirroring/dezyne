interface I
{
  in void e();

  behaviour
  {
    on e: {}
  }
}

interface II
{
  in void e();
  out void add();

  behaviour
  {
    on e: {}
  }
}

component range_declaration
{
  provides I p;
  requires II r;

  behaviour {
     subint Sub {0..4};
     on p.e(): { Sub n = 5; r.e(); }
     on r.add(): {}
  }
}
