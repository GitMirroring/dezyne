// Test basic async refine: defer <provides_port.event> in component
// shall emit <provides_port.event> in new tau-trigger call context.
component Async_Basic // equivalent to test/all/async_hello.dzn and also covered by test/all/async_simple.dzn
{
  provides IAsync pp;

  behaviour
  {
    requires dzn.async() reflector;

    on pp.ia(): reflector.req();
    on reflector.ack(): pp.oa();
  }

  // component Async_Basic shall at least perform trace
  // pp.ia
  // pp.return
  // pp.oa
}

interface IAsync
{
  in void ia();
  out void oa();

  behaviour
  {
    bool is_active = false;

    [!is_active] on ia: is_active = true;
    [is_active] on ia: illegal;
    
    [is_active] on inevitable: {oa; is_active = false;}
  }
}
