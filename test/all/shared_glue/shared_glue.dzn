// Commentary:
//
// This model demonstrates a handwritten main using lambdas to trivially
// connect events.
//
// Code:

interface ihello
{
  in void hello ();
  in void bye ();
  out void world ();
  behavior
  {
    bool idle = true;
    [idle] on hello: idle = false;
    on bye: {idle = true; world;}
    [!idle] on inevitable: {idle = true; world;}
  }
}

component hello
{
  provides ihello h;
  requires ihello w;
  behavior
  {
    on h.hello (): w.hello ();
    on h.bye (): w.bye ();
    on w.world (): h.world ();
  }
}

component shared_glue
{
  provides ihello h;
  requires ihello w;
  system
  {
    hello hello_;
    h <=> hello_.h;
    hello_.w <=> w;
  }
}
