// Commentary:
//
// This is an example of a cruise control system.  Usually a cruise
// control system centers around the PID feedback control loop where
// functional requirements like reaching and maintaining the set
// velocity comfortably, i.e. with the proper stability and
// responsiveness.  Here we abstract away from those specific
// requirements and focus on the interactions between the different
// actors in the system represented as the HMI, the pedals and the
// throttle actuator.
//
// Note that the throttle actuator can be viewed as representing the
// actual PID control loop.
//
// Code:

import cruise-control-interfaces.dzn;

component cruise_control
{
  provides ihmi hmi;
  requires ipedals pedals;
  requires ithrottle throttle;
  requires itimer timer;

  behavior
  {
    bool no_unwanted_acceleration_p () = !hmi.state.Active => (!throttle.active && timer.idle);
    bool not_active_when_pedals_engaged_p () = pedals.state.Engaged => !hmi.state.Active;
    bool control_throttle_when_active_p () = hmi.state.Active => (throttle.active && !timer.idle);
    bool monitor_pedals_when_active_p ()  = hmi.state.Active => !pedals.state.Unmonitored;

    invariant no_unwanted_acceleration_p();       // line 99 or 108
    invariant not_active_when_pedals_engaged_p(); // line 105
    invariant control_throttle_when_active_p();   // line 80
    invariant monitor_pedals_when_active_p();     // line 66, 74, 79, 83

    [hmi.state.Disabled] {
      on hmi.enable (): bool ignore = pedals.enable ();
      on hmi.disable (): {/* ignore */}
    }
    [!hmi.state.Disabled] {
      on hmi.enable (): {/* ignore */}
      on hmi.disable (): {
        throttle.reset ();
        timer.cancel ();
        pedals.disable ();
      }
    }
    [hmi.state.Enabled && timer.idle] {
      on hmi.set (): {
        if(pedals.state.Disengaged) {
          throttle.setpoint ();
          timer.start ();
          reply (true);
        } else reply (false);
      }
      on hmi.resume (): {
        [pedals.state.Engaged || !hmi.setpoint.Set] reply (false);
        [otherwise] {
          throttle.setpoint ();
          timer.start ();
          reply (true);
        }
      }
    }
    on hmi.set (), hmi.resume (): [!hmi.state.Enabled || !timer.idle] reply (false);
    on timer.timeout (): throttle.setpoint ();
    on hmi.cancel (): {
      if (hmi.state.Active) {
        throttle.reset ();
        timer.cancel ();
      }
    }
    on pedals.disengage (): {/*ignore*/}
    on pedals.engage (), throttle.unset (): {
      if (hmi.state.Active) {
        hmi.inactive ();
        timer.cancel ();
        if (throttle.active) throttle.reset ();
      }
    }
  }
}
