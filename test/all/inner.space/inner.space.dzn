// Commentary:
//
// Code:

namespace inner {} // the first namespace used defines scheme's module name

namespace inner {
  namespace foo {
    interface I {
      enum Bool {f,t};
      in Bool e();
      out void a();
      behavior {
        on e: {a;reply(Bool.t);}
      }
    }
  }
  component space {
    provides foo.I inner;
    behavior {
      foo.I.Bool inner_state = foo.I.Bool.t;
      on inner.e(): {inner.a();reply (inner_state);}
    }
  }
  component ranger {
    provides .foo.I fooi;
    behavior {
      .foo.I.Bool foo_state = .foo.I.Bool.T;
      on fooi.e(): {fooi.a();reply (foo_state);}
    }
  }
}

namespace foo {
  interface I {
    enum Bool {F,T};
    in Bool e();
    out void a();
    behavior {
      on e: {a;reply (Bool.T);}
    }
  }
}

namespace bar {
  component c {
    provides foo.I i;
    behavior {
      foo.I.Bool state = foo.I.Bool.T;
      on i.e(): {i.a();reply (state);}
    }
  }
}
