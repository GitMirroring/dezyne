// Reported by Joran Jessurun on IRC
//
// Code:

interface A {
  in void a();
  behaviour {
    on a: {}
  }
}

component B {
  provides A api;
  requires A apj;

  behaviour {
    on api.a(): apj.a();
  }
}

component system_mix_bindings {
  provides A api;
  requires A apj;

  system {
    B b1;
    b1.api <=> api;

    B b2;
    b2.api <=> b1.apj;
    b2.apj <=> apj;
  }
}
