// Commentary:
//
// Code:

interface ihello
{
  in void hello();

  behavior
  {
    on hello: {}
  }
}

interface iconfig
{
  in bool test();

  behavior
  {
    on test: reply(true);
    on test: reply(false);
  }
}

component hello
{
  provides ihello h;
  requires injected iconfig c;

  behavior
  {
    on h.hello(): bool b = c.test();
  }
}

component injected_dangling
{
  provides ihello h;

  system
  {
    hello hell;
    h <=> hell.h;
  }
}