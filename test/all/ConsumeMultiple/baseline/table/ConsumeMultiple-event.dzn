interface ITauEmitMulti {
  in void ack();
  in void done();
  out void ntfA();
  out void ntfB();

  behaviour {
    bool isWaiting = false;
    bool isEmitting = false;

    on ack:
    {
      [isWaiting || !isWaiting]
      {}
    }
    on inevitable:
    [!isWaiting]
    {
      [!isEmitting]
      {
        ntfA;
        isEmitting = true;
      }
      [otherwise]
      {
        ntfB;
        isWaiting = true;
        isEmitting = false;
      }
    }
    on done:
    {
      [!isWaiting]
      illegal;
      [isWaiting]
      isWaiting = false;
    }
  }
}

interface IDummy {
  enum ReplyValue {Ok};
  in ReplyValue dummy();
  out void liveLockPreventer();

  behaviour {

    on dummy:
    [true]
    reply(ReplyValue.Ok);
  }
}

component ConsumeMultiple {
  provides IDummy d;
  requires ITauEmitMulti src;

  behaviour {
    bool behave = true;

    on d.dummy():
    {
      [behave || !behave]
      reply(IDummy.ReplyValue.Ok);
    }
    on src.ntfA():
    {
      [!behave]
      src.done();
      [behave]
      src.ack();
    }
    on src.ntfB():
    {
      [!behave]
      src.ack();
      [behave]
      {
        src.done();
        behave = false;
      }
    }
  }
}

