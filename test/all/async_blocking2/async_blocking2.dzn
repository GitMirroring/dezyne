interface ihello
{
  in void hello();
  //in void cruel();
  out void world();

  behaviour
  {
    // bool idle = true;
    // [idle] on hello: idle = false;
    // [!idle] {
    //   on hello: illegal;
    //   on inevitable: {idle = false; world;}
    // }
    on hello: {}
    //on cruel: {}
  }
}

interface iflip
{
  //in bool coin();
  in void coin();

  behaviour
  {
    //on coin: reply(true);
    on coin: {}
  }
}

component async_blocking2
{
  provides ihello h;
  requires iflip f;

  behaviour
  {
    requires dzn.async i;

    blocking on h.hello(): i.req();
    on i.ack(): h.reply();
    // bool idle = true;

    // [idle] on h.hello(): {idle = false; i.req();}
