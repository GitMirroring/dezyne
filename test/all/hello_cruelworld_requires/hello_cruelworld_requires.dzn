import ihello_cruelworld.dzn;

component hello_cruelworld_requires
{
  provides ihello_cruelworld h;
  requires ihello_cruelworld w;
  behavior
  {
    bool idle=true;
    [idle] on h.hello (): {w.hello (); idle=false;}
    [!idle] on w.cruel (): idle=true;
    [idle] on w.world (): {h.cruel (); h.world ();}
  }
}
