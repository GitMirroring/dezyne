// Commentary:
//
// A parameterizable model that performs an order of magnitude slower
// with 2.17 than with 2.16.
//
// Code:

import huge_interface.dzn;

component huge_constraint
{
  provides huge_interface h;

  behavior
  {
    subint int {0..9};
    int state = 0;
    int previous = 0;
    int past = 0;
    int target = 0;
    // int future = 0;

    on h.cruel0 (): return previous;
    on h.cruel1 (): return past;
    on h.cruel2 (): return state;
    on h.cruel3 (): return target;
    // on h.cruel4 (): return state;
    // on h.cruel5 (): return state;
    // on h.cruel6 (): return state;
    // on h.cruel7 (): return state;
    // on h.cruel8 (): return state;
    // on h.cruel9 (): return state;

    //on w.foo0 (): {h.foo0 ();previous=state;}
    on h.bar0 (): {h.foo0 ();previous=state;}
    // on w.foo1 (): {h.foo1 ();past=previous;}
    // on w.foo2 (): {h.foo2 ();target=state;}
    // on w.foo3 (): {h.foo3 ();future=target;}

    [state == 0]
      {
        on h.hello (): {state=1;return 0;}
        on h.bye (): return 0;
      }
    [state > 0 && state < 9]
      {
        [previous == 0]
        {
          on h.hello (): {state=state+1;return 0;}
          on h.bye (): return 0;
        }
        [previous > 0 && previous < 9]
        {
          on h.hello (): {state=state-1;return 0;}
          on h.bye (): {state=state+1;return 0;}
        }
        [previous == 9]
        {
          on h.hello (): return 0;
          on h.bye (): {state=state-1;return 0;}
        }
      }
    [state == 9]
      {
        on h.hello (): return 0;
        on h.bye (): {state=state-1;return 0;}
      }
    }
}
