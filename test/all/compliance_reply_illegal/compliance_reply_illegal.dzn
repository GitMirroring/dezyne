//
// Commentary:
//
// This model reports an illegal instead of a non-compliance, because
// the non-compliant behavior, i.e. the return false, puts the interface
// constraint into the any state, allowing the component to trigger an
// illegal in the requires interface, while the the return false is the
// cause of the problem.
//
// A possible solution to this phenomenon could be to make the reply
// value illegal in the constraint behavior.
//
// Code:

interface ihello
{
  in void hello ();
  in bool world ();
  behavior
  {
    bool x = true;
    bool idle = true;
    [idle] on hello: idle = false;
    [!idle] on world:
    {
      [x] {idle = true; return idle;}
    }
  }
}

interface iworld
{
  in void hello ();
  in bool world ();
  behavior
  {
    bool idle = true;
    bool x = true;
    [idle] on hello: idle = false;
    [!idle] on world:
    {
      [x] {idle = true; return true;}
      [x] return false;
    }
  }
}

component compliance_reply_illegal
{
  provides ihello h;
  requires iworld w;
  behavior
  {
    on h.hello (): w.hello ();
    on h.world (): return w.world ();
  }
}
