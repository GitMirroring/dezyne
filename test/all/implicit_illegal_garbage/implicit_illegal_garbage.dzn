// Commentary:
//
// After a(n illegal) error, garbage on the trail must not shadow the
// illegal and lead to a trail match error.
//
// Code:

interface ihello
{
  in void hello ();
  out void world ();
  behavior
  {
    bool idle = true;
    [idle] on hello: idle = false;
    [!idle] on inevitable: {idle = true; world;}
  }
}

component implicit_illegal_garbage
{
  provides ihello h;
  requires ihello w;

  behavior
  {
    on h.hello (): w.hello ();
  }
}
