// Commentary:
//
// Code:
interface ihello
{
  subint int {0..1};
  in int hello ();
  in int hey ();
  in int hi ();
  in int goodbye ();
  in int bye ();
  out void add ();
  out void dec ();
  out void inc ();
  out void foo ();
  out void bar ();

  behavior
  {
    on hello: {inc;add;inc;dec;add;inc;inc;reply (0);}
    on hey: {inc;dec;reply (0);}
    on hi: {inc;dec;dec;inc;bar;foo;reply (0);}
    on goodbye: {inc;inc;dec;dec;reply (0);}
    on bye: reply (0);
  }
}

interface iworld
{
  subint int {0..1};
  in int hello ();

  behavior
  {
    on hello: reply (0);
  }
}

component complex_int
{
  provides ihello h;
  requires iworld w;
  behavior
  {
    subint int {-1..1};

    int add (int a, int b) {h.add ();return a+b;}
    int dec (int i) {h.dec ();return i-1;}
    int inc (int i) {h.inc ();return i+1;}
    void foo (bool b) {h.foo ();}
    bool bar (bool a, bool b) {h.bar();return a || b;}

    on h.hello ():
    {
      int i = 0;
      int j = 0;
      i = add (inc (i), -1);
      i = add (inc (i), dec (j));
      i = inc (i) - inc (i);
      reply (i);
    }
    on h.hey ():
    {
      int i = 0;
      bool b = inc (i) == 1 && dec (i) == 1;
      reply (0);
    }
    on h.hi ():
    {
      int i = 0;
      foo (bar (inc (i) == 1 && dec (i) == 1,
                dec (i) == 1 || inc (i) == 1));
      reply (0);
    }
    on h.goodbye ():
    {
      int i = 0;
      i = inc (i) + inc (i) + dec (i) + dec (i);
      reply (i);
    }
    on h.bye (): if (w.hello () == 0)
      reply (0);
  }
}
