// Commentary:
//
// Code:

interface ihello
{
  in void hello ();

  behavior
  {
    on hello: {}
  }
}

interface iworld
{
  in void hello ();
  out void world ();

  behavior
  {
    on hello: world;
  }
}

component proxy
{
  provides blocking ihello h;
  requires blocking ihello b;

  behavior
  {
    on h.hello (): b.hello ();
  }
}

component left_blocking_proxy
{
  provides blocking ihello h;
  requires external iworld w;
  requires blocking ihello b;

  behavior
  {
    on h.hello (): blocking {w.hello ();}
    on w.world (): {b.hello (); h.return;}
  }
}

component right_blocking_proxy
{
  provides blocking ihello h;
  requires external iworld w;

  behavior
  {
    on h.hello (): blocking {w.hello ();}
    on w.world (): h.return;
  }
}

component mux
{
  provides blocking ihello left;
  provides blocking ihello right;

  requires blocking ihello hello;
  behavior
  {
    on left.hello (): hello.hello ();
    on right.hello (): hello.hello ();
  }
}

// two components can block simulateously in this system
// the remaining components become collaterally blocked

// the order of releasing async.pong events determines which stacks
// are allowed to continue to run first

component double_collateral_blocking_shell
{
  provides blocking ihello left;
  provides blocking ihello right;

  requires external iworld leftw;
  requires external iworld rightw;

  system
  {
    proxy lp;
    left <=> lp.h;

    left_blocking_proxy lbp;
    lp.b <=> lbp.h;
    lbp.w <=> leftw;

    mux m;
    lbp.b <=> m.left;

    proxy rp;
    right <=> rp.h;
    rp.b <=> m.right;

    right_blocking_proxy rbp;
    m.hello <=> rbp.h;
    rbp.w <=> rightw;
  }
}
