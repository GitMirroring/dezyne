// Commentary:
//
// Code:

interface ihello
{
  in void hello();

  behavior
  {
    on hello: {}
  }
}

interface iasync
{
  in void ping();
  out void pong();

  behavior
  {
    bool idle = true;
    [idle] on ping: idle = false;
    [!idle]
    {
      on ping: illegal;
      on inevitable: {idle = true; pong;}
    }
  }
}

component proxy
{
  provides blocking ihello h;
  requires blocking ihello w;

  behavior
  {
    on h.hello(): w.hello();
  }
}

component left_blocking_proxy
{
  provides blocking ihello h;
  requires blocking iasync async;
  requires blocking ihello w;

  behavior
  {
    on h.hello(): blocking {async.ping();}
    on async.pong(): {w.hello(); h.reply();}
  }
}

component right_blocking_proxy
{
  provides blocking ihello h;
  requires blocking iasync async;

  behavior
  {
    on h.hello(): blocking {async.ping();}
    on async.pong(): h.reply();
  }
}

component mux
{
  provides blocking ihello left;
  provides blocking ihello right;

  requires blocking ihello hello;
  behavior
  {
    on left.hello(): hello.hello();
    on right.hello(): hello.hello();
  }
}

// two components can block simulateously in this system
// the remaining components become collaterally blocked

// the order of releasing async.pong events determines which stacks
// are allowed to continue to run first

component double_collateral_blocking_shell
{
  provides blocking ihello left;
  provides blocking ihello right;

  requires blocking iasync la;
  requires blocking iasync ra;

  system
  {
    proxy lp;
    left <=> lp.h;

    left_blocking_proxy lbp;
    lp.w <=> lbp.h;
    lbp.async <=> la;

    mux m;
    lbp.w <=> m.left;

    proxy rp;
    right <=> rp.h;
    rp.w <=> m.right;

    right_blocking_proxy rbp;
    m.hello <=> rbp.h;
    rbp.async <=> ra;
  }
}
