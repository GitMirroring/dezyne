// Commentary:
//
// Code:

interface ihello
{
  in bool hello ();
  in bool cruel ();

  behavior {
    on hello: reply(true);
    on hello: reply(false);
    on cruel: reply(true);
    on cruel: reply(false);
  }
}

interface iworld
{
  in void hello ();
  out void world ();

  in void cruel ();
  out void bye ();

  behavior {
    on hello: world;
    on cruel: bye;
  }
}

extern Exception $int$;

component Blocked
{
  provides blocking ihello h;
  requires blocking iworld w;

  behavior
  {
    bool waiting = false;

    blocking on h.hello (): {
      w.hello ();
      waiting = true;
    }

    [!waiting] on h.cruel(): h.reply(false); // So any cruel() call should return false

    on w.world (): {
      waiting = false;
      h.reply(true);
    }
  }
}

component Bottom
{
  provides blocking iworld p;
  requires blocking iworld r;

  behavior
  {
    on p.hello(): blocking r.hello();
    on r.world(): {p.world(); p.reply ();}
    on p.cruel(): p.bye();
  }
}

component Adapter
{
  provides blocking iworld h;
  requires external iworld w;
  behavior
  {
    blocking on h.hello (): w.hello ();
    on w.world (): {h.world (); h.reply ();}

    blocking on h.cruel (): w.cruel ();
    on w.bye (): {h.bye (); h.reply ();}
  }
}

component collateral_blocking_shell2
{
  provides blocking ihello h;
  requires external iworld w;

  system
  {
    Blocked blocked;
    Bottom bottom;
    Adapter adapter;

    h <=> blocked.h;
    blocked.w <=> bottom.p;
    bottom.r <=> adapter.h;
    adapter.w <=> w;
  }
}
