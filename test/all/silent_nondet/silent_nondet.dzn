// Commentary:
//
// Code:

interface ihello
{
  in void hello();
  out void world();

  behaviour
  {
    bool b = false;
    on hello: {b = !b;}
    on hello: {}
    [b] on inevitable: {b = false; world;}
  }
}

component hello
{
  provides ihello hi;
  requires ihello wi;

  behaviour
  {
    on hi.hello(): wi.hello();
    on wi.world(): hi.world();
  }
}

component silent_nondet
{
  provides ihello h;
  requires ihello w;

  system
    {
      hello c1;
      hello c2;
      h <=> c1.hi;
      c1.wi <=> c2.hi;
      w <=> c2.wi;
    }
}
