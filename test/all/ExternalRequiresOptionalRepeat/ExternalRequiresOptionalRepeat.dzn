component ExternalRequiresOptionalRepeat
{
  provides IToggle pp;
  requires external IAsync rp;
  
  behaviour
  {
    bool b = false;
    on pp.toggle(): [!b] {rp.enable(); b = !b;}
    on pp.toggle(): [b] {rp.disable(); b = !b;}
    on rp.oa(): {}
  }

  // KNOWN issue: Interpreter offers external requires port out event
  // 'rp.oa' only once.  (Interpreter should get a mechanism to limit
  // external queue size in order to fix this.) Problem only occurs
  // for models where verification would fail on external queue full.

  // Simulating component ExternalRequiresOptionalRepeat shall NOT report
  //   Invalid event trace
  // for trace
  //   pp.toggle
  //   rp.enable
  //   rp.return
  //   pp.return
  //   rp.oa
  //   rp.oa
}

interface IToggle
{
  in void toggle();
  behaviour { on toggle: {}}
}

interface IAsync
{
  in void enable();
  in void disable();
  out void oa();
  
  behaviour
  {
    bool b = false;
    on enable: b = true;
    on disable: b = false;
    [b] on optional: oa;
  }
}

