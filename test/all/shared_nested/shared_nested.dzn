// Commentary:
//
// This model is a minimal example that reproduces the bug, reported
// by joran.jesserun@thermofisher.com, that the state of ports on a
// nested system without explicit boundary interaction is not updated
// when the interface is guarded by said state.  Removing the guard
// side steps the bug, see comments below
//
// Code:

interface ihello
{
  in void hello ();
  in void bye ();
  behavior
  {
    bool idle = true;
    [idle] on hello: idle = false;
    [!idle] on bye: idle = true;
  }
}

interface ihellobye
{
  in void hello ();
  in void bye ();
  out void world ();

  behavior
  {
    enum State {Idle, Busy};
    State state = State.Idle;

    // fails to update w.state in (sut o) and h.state in (sut i i)
    [state.Idle] on hello: {state = State.Busy; world;}

    // succesfully updates w.state in (sut o) and h.state in (sut i i)
    // on hello: {state = State.Busy; world;}
    on bye: state = State.Idle;
  }
}

component hellobye
{
  provides ihellobye h;
    behavior
    {
      on h.hello (): h.world();
      on h.bye(): {}
    }
}

component inner
{
  provides ihellobye h;

  system
  {
    hellobye i;
    i.h <=> h;
  }
}

component hello
{
  provides ihello h;
  requires ihellobye w;
  behavior
  {
    on h.hello (): w.hello ();
    on w.world (): {}
    on h.bye (): w.bye ();
  }
}

component shared_nested
{
  provides ihello h;
  system
  {
    hello o;
    o.h <=> h;

    inner i;
    i.h <=> o.w;
  }
}
