// Code:

subint int {0..3};

interface ihello
{
  in int hello ();
  out void world ();

  behavior
  {
    on hello: {world;reply (0);}
    on hello: {world;reply (1);}
    on hello: {world;reply (2);}
  }
}

component inevitable_multiple_requires
{
  provides ihello h;

  requires iworld wl;
  requires iworld wr;

  behavior
  {
    int x = 0;
    on h.hello (): {x=wl.hello ();h.world ();reply (x);}
    [x==0] on wl.world (): x=wl.hello();
    [x==1] on wl.world (): illegal;
    on wr.world (): {}
  }
}

interface iworld
{
  in int hello ();
  out void world ();

  behavior
  {
    int i = 0;
    [i==0] on hello: {i=i+1;reply (i);}
    [i==1] on hello: {i=0;reply (i);}
    [i==0] on inevitable: {i=i+1;world;}
  }
}
