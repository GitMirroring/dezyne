// Test if deferred provides out event has precedence over requires
// port asynchronous out event.
component Async_DeferredProvidesOutPostponesRequiresOut
{
  provides ISyncAsync pp;
  requires ISync rps;
  requires IAsync rpa;

  behaviour
  {
    requires dzn.async() reflector;
    
    on pp.ia(): {rps.ia(); rpa.ia();}
    on rps.oa(): {reflector.req(); pp.osync();} // requirement: reflector.ack() before rpa.oa
    on reflector.ack(): pp.oasync();
    on rpa.oa(): reflector.clr(); // requirement: shall have no effect

    // component Async_DeferredProvidesOutPostponesRequiresOut shall at least perform trace
    // pp.ia
    // rps.ia
    // rps.oa
    // rps.return
    // rpa.ia
    // rpa.return
    // pp.osync
    // pp.return
    // pp.oasync
    // rpa.oa

    // component Async_DeferredProvidesOutPostponesRequiresOut shall NOT perform trace
    // pp.ia
    // rps.ia
    // rps.oa
    // rps.return
    // rpa.ia
    // rpa.return
    // pp.osync
    // pp.return
    // rpa.oa
    // Error: reflector.ack must be handled before rpa.oa can occur.
  }
}


interface ISync
{
  in void ia();
  in void ib();
  out void oa();
  out void ob();

  behaviour
  {
    on ia: oa;
    on ib: ob;
  }
}

interface IAsync
{
  in void ia();
  out void oa();

  behaviour
  {
    bool is_active = false;

    [!is_active] on ia: is_active = true;
    [is_active] on ia: illegal;
    
    [is_active] on inevitable: {oa; is_active = false;}
  }
}

interface ISyncAsync
{
  in void ia();
  out void osync();
  out void oasync();

  behaviour
  {
    bool is_active = false;

    [!is_active] on ia: {is_active = true; osync;}
    [is_active] on ia: illegal;

    [is_active] on inevitable: {is_active = false; oasync;}
  }
}

