import ihello.dzn;

component guard_predicates
{
  provides ihello h;

  behavior
  {
    bool true_p () = true;
    bool false_p () = !true_p ();
    [true_p ()] on h.hello (): {}
    on h.hello (): [false_p ()] illegal;
    [false && true_p ()] on h.hello (): illegal;
    [false_p () && true] on h.hello (): illegal;
  }
}
