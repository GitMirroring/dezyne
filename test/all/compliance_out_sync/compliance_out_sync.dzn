// Code:

interface I
{
  in void ia();
  out void oa();

  behaviour
  {
    on ia: oa;
  }
}

component compliance_out_sync
{
  provides I pp;
  requires I rp;

  behaviour
  {
    on pp.ia(): rp.ia();
    on rp.oa(): {}
  }
}

// Expect compliance fail
// Spec I allows
// <ia, oa>
// Impl compliance_out_sync
// <pp.ia, rp.ia, rp.oa, rp.return, pp.return>
