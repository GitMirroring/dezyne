// Code:

interface I
{
  in void hello();

  out void cruel();
  out void world();

  behaviour
  {
    bool idle = true;

    [idle] on hello: {idle = !idle; cruel;}
    [!idle] {
      on hello: illegal;
      on inevitable: {idle = !idle; world;}
    }
  }
}

interface J
{
  in void hello();

  out void world();

  behaviour
  {
    on hello: world;
  }
}

component async_sync_prio
{
  provides I i;
  requires J j;

  behaviour
  {
    requires dzn.async k;

    bool idle = true;

    [idle] on i.hello(): {idle = !idle; j.hello(); k.req();}
    on j.world(): {i.cruel();}
    on k.ack(): {idle = !idle; i.world();}
  }
}
