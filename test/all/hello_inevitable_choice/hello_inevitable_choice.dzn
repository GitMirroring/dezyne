import ihello_cruel_world.dzn;
import ihello_world.dzn;

component hello_inevitable_choice
{
  provides ihello_cruel_world h;
  requires ihello_world w;
  behavior
  {
    on h.hello (): w.hello ();
    on w.world (): h.world ();
  }
}
