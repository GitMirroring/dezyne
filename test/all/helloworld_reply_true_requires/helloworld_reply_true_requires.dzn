import ihelloworld_reply_true.dzn;

component helloworld_reply_true_requires
{
  provides ihelloworld_reply_true h;
  requires ihelloworld_reply_true w;

  behavior
  {
    on h.hello (): {bool b = w.hello (); reply (b);}
    on w.world (): h.world ();
  }
}
