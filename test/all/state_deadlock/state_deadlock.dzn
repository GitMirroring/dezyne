// Commentary:
//
// Code:

interface ihello
{
  in void hello();
  out void world();

  behaviour
  {
    bool b = true;
    [b]  on hello: b=!b;
    [!b] on inevitable: {b=!b; world;}
  }
}

component helloworld1
{
  provides ihello pc1;
  requires ihello rc1;

  behaviour
  {
    bool b = false;
    [b]  on pc1.hello(): {b=!b; rc1.hello();}
    [!b] on rc1.world(): {b=!b; pc1.world();}
  }
}

component helloworld2
{
  provides ihello pc2;
  requires ihello rc2;

  behaviour
  {
    bool b = true;
    [b]  on pc2.hello(): {b=!b; rc2.hello();}
    [!b] on rc2.world(): {b=!b; pc2.world();}
  }
}

component state_deadlock
{
  provides ihello p;
  requires ihello r;

  system
    {
      helloworld1 c1;
      helloworld2 c2;
      p <=> c1.pc1;
      c1.rc1 <=> c2.pc2;
      c2.rc2 <=> r;
    }
}
