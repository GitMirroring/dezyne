// Code:

extern int $int$;

interface ihello
{
  in void hello (int i);
  in void hi (int i);
  in void cruel (int i);
  out void world (int i);
  behavior
  {
    bool idle = true;

    [idle] on hello: idle = false;
    [!idle] on inevitable: {world; idle=true;}
    on cruel: {}
    on hi: {}
  }
}

component defer_data
{
  provides ihello h;

  behavior
  {
    bool idle = true;
    int m = $0$;

    [idle] on h.hello (i):
    {
      idle = false;
      m = i;
      defer {idle = true; h.world (m);}
    }
    on h.cruel (i): m = i;
    on h.hi (i): m = i;
  }
}
