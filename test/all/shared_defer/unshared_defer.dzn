interface ihello
{
  in bool hello();
  out void world();
  in void bye();

  behavior
  {
    bool idle = true;
    [idle] {
      on hello: {idle = false; reply(true);}
      on hello: reply(false);
      on bye: {}
    }
    [!idle] {
      on hello: reply(false);
      on bye: idle = true;
      on inevitable: {idle = true; world;}
    }
  }
}

component unshared_defer
{
  provides ihello h;
  requires inondet n;
  behavior
  {
    bool idle = true;
    [idle] on h.hello(): {
      if(n.test()) {
        idle = false;
        reply(true);
        defer {idle = false; h.world();}
      } else reply(false);
    }
    [!idle] on h.hello(): reply(false);

    on h.bye(): idle = true;
  }
}

interface inondet
{
  in bool test();
  behavior
  {
    on test: reply(true);
    on test: reply(false);
  }
}
