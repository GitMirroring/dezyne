import ihello.dzn;
import ihello_reply_bool.dzn;

component parse_predicate
{
  provides ihello h;
  requires ihello_reply_bool w;

  behavior
  {
    enum E {A};
    bool true_p () = true;
    bool func () { return true; }

    // Not allowed; should be reported
    E non_bool () = E.A;
    bool has_args (bool b) = b;
    bool recursive () = true_p () && recursive ();
    bool expression_not_predicate_func () =  true_p () && func ();
    bool expression_not_predicate_action () =  true_p () && w.hello ();

    on h.hello (): [false || func ()] {}
    on h.hello (): [false || w.hello ()] {}

    invariant true && func ();
    invariant true && w.hello ();

    // Allowed; should not be reported
    bool b = false;
    bool ok1 () = b;
    bool ok2 () = true;
    bool ok3 () = ok2 () && ok1 ();

    [ok1 ()] on h.hello (): {}
    [ok2 ()] on h.hello (): {}
    [ok3 ()] on h.hello (): {}
  }
}
