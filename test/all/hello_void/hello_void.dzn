// Commentary:
//
// Different void replies
//
// Code:

interface ihello
{
  in void hello1 ();
  in void hello2 ();
  in void hello3 ();
  in void hello4 ();
  in void hello5 ();
  behaviour
  {
    on hello1,hello2,hello3,hello4,hello5: {}
  }
}

component hello_void
{
  provides blocking ihello h;
  requires ihello w;
  behavior
  {
    on h.hello1 (): {}
    on h.hello2 (): return;
    on h.hello3 (): {w.hello3 (); return;}
    on h.hello4 (): return w.hello4 ();
    blocking on h.hello5 (): return w.hello5 ();
  }
}
