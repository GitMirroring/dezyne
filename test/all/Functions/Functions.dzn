// Commentary:
//
// Code:

//purpose: Show usage of functions

interface I
{
  in void e();

  behaviour
  {
    on e: { }
  }
}

component Functions
{
  provides I i;

  behaviour
  {
    // type definition for a finite integer subset
    subint counter_t {0..2};
    
    // a one argument function doing nothing
    void g(counter_t counter)
    {
    }
    
    // a function calling another function
    void f(counter_t counter)
    {
      if(counter < 2)
        g(counter + 1);
    }

    on i.e():
    {
      // a function call
      f(0);
    }
  }
}
