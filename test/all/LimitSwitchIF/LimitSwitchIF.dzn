interface LimitSwitchIF
{
	enum Position { Opened, Closed, Unknown };
	in void doorOpening();
	in void doorClosing();
	in void doorStopped();
	out void doorOpened();
	out void doorClosed();
	out void proximityWarning();
	in Position queryPosition();
	in void initialise();
	
	behaviour
	{
		enum State { NotReady, Ready };
		enum DoorState { Opening, Closing, Idle };
		Position state = Position.Unknown;
		DoorState door = DoorState.Idle;
		State ready = State.NotReady;
		
		[ready.NotReady]
		{
			on initialise: ready = State.Ready;
			on doorOpening, doorClosing, doorStopped, queryPosition: illegal;
		}
		[ready.Ready]
		{
			[door.Idle]
			{
				on doorOpening:
				{
					door = DoorState.Opening;
				}
				on doorClosing:
				{
					door = DoorState.Closing;
				}
				on doorStopped: illegal;
			}

			[door.Opening]
			{				
				on inevitable: { doorOpened; state = Position.Opened; door = DoorState.Idle; }
				on inevitable: { state = Position.Unknown; }					
				on doorClosing, doorOpening: illegal;
				on doorStopped: door = DoorState.Idle;
			}
						
			[door.Closing]
			{
				on inevitable: { doorClosed; state = Position.Closed; door = DoorState.Idle; }
				on inevitable: { state = Position.Unknown; }					
				on optional: { proximityWarning; }
				on doorOpening, doorClosing: illegal;
				on doorStopped: door = DoorState.Idle;
			}
			on queryPosition: reply ( state );		
			on initialise: illegal;
		}
	}
}
