// Code:

interface ihello
{
  in void hello ();
  out void cruel ();
  out void world ();

  behavior
  {
    bool idle = true;

    // The ordering of these is essential to trigger <non-compliance>
    [idle] on hello: {cruel; idle = false;}
    [idle] on hello: world;

    [!idle] on inevitable: {world; idle = true;}
   }
}

interface iworld
{
  in void hello ();
  out void world ();

  behavior
  {
    subint status {0..3};
    status i = 0;

    [i==0] on hello: i=1;
    [i==1] on inevitable: {world; i=2;}
    [i==2] on inevitable: {world; i=3;}
    [i==3] on hello: i=0;
  }
}

component blocking_choice
{
  provides blocking ihello h;
  requires iworld w;

  behavior
  {
    subint status {0..2};
    status i = 0;

    [i==0] blocking on h.hello (): {w.hello (); i=1;}
    [i==1] on w.world (): {h.cruel (); h.reply (); i=2;}
    [i==2] on w.world (): {w.hello (); h.world (); i=0;}
  }
}
