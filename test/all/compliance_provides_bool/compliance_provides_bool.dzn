interface ibool
{
  in bool hello();
  out void a();
  out void b();

  behaviour
  {
    on hello: {a; reply (true);}
    on hello: {b; reply (true);}
    on hello: reply (true);
  }
}

component compliance_provides_bool
{
  provides ibool p;
  behaviour
  {
    on p.hello(): reply (false);
  }
}
