// Commentary:
//
// Taken from examples.dzn: helloworld9
// blocking by one level of indirection reordered (non-compliant)
//
// Code:

interface isynchronous
{
  in void hello();
  out void world();
  out void cruel();
  behavior
  {
    on hello: world;
    on optional: cruel;
  }
}

interface iasynchronous
{
  in void hello();
  out void world();
  behavior
  {
    bool idle = true;
    [idle] on hello: idle = false;
    [!idle] on inevitable: {idle = true; world;}
  }
}

component match_blocking_race
{
  provides blocking iasynchronous h;
  requires iasynchronous w;
  requires blocking isynchronous b;
  behavior
  {
    bool idle = true;
    [idle] on h.hello(): {idle = false; w.hello(); b.hello();}
    on b.world(): {}
    on b.cruel(): {}
    on w.world(): {idle = true; h.world();}
  }
}
