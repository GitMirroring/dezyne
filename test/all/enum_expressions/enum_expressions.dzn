// Code:

interface ihello
{
  enum e {one, two, three, four};
  in void hello();

  behavior
  {
    on hello: {}
  }
}

component enum_expressions
{
  provides ihello h;
  requires iworld w;

  behavior
  {
    ihello.e e = ihello.e.one;
    on h.hello():
    {
      [e == ihello.e.one]
        {
          e = ihello.e.two;
          w.hello();
        }
      [e != ihello.e.one && e != ihello.e.three && e != ihello.e.four]
        {
          if (e != ihello.e.one && e != ihello.e.three && e != ihello.e.four)
            w.world();
          else
            illegal;
          e = ihello.e.three;
        }
      [e.three]
        {
          assert_three ();
          e = ihello.e.four;
          w.goodbye();
        }
      [otherwise]
        {
          e = ihello.e.one;
          w.cruel();
        }
    }
    void assert_three() {
      if(!e.three) illegal;
    }
  }
}

interface iworld
{
  in void cruel();
  in void goodbye();
  in void hello();
  in void world();

  behavior
  {
    on cruel: {}
    on goodbye: {}
    on hello: {}
    on world: {}
  }
}
