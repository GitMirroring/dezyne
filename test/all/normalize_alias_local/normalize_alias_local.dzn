extern xint $int$;

interface Log
{
  in void print(xint x);

  behaviour
  {
    on print: {}
  }
}

interface i
{
  in void e(xint foo);
  out void a(xint foo);
  behaviour {
    on e: a;
  }
}

component normalize_alias_local
{
  provides i p;
  requires Log r;
  behaviour {
    bool b = false;
    xint foox;
    [!b] on p.e (foo): p.a(foo);
    [b] on p.e (bar): {
      r.print(bar);
      xint foo = bar;
      r.print(foo);
      p.a (foo);
      xint baz = bar;
      r.print(baz);
      foox = baz;
    }
  }
}
