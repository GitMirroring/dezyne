// Code:

interface ihello
{
  in void hello ();
  in void bye ();
  out void world ();
  out void cruel ();

  behavior
  {
    bool idle = true;
    [idle] on hello: cruel;
    [idle] on hello: idle = false;
    [!idle] on bye: idle = true;
    [!idle] on optional: {world; idle = true;}
  }
}

component hello
{
  provides ihello th;
  requires ihello tw;

  behavior
  {
    [th:idle] on th.hello (): tw.hello ();
    [!th:idle] on th.bye (): tw.bye ();
    [!th:idle] on tw.world (): th.world ();
  }
}

component world
{
  provides ihello bh;
  requires ihello bw;

  behavior
  {
    [bh:idle] on bh.hello (): bw.hello ();
    [!bh:idle] on bh.bye (): bw.bye ();
    [!bh:idle] on bw.world (): bh.world ();
  }
}

component system_shared
{
  provides ihello h;
  requires ihello w;

  system
    {
      hello top;
      world bottom;
      h <=> top.th;
      top.tw <=> bottom.bh;
      bottom.bw <=> w;
    }
}
