interface ihello
{
  in bool hello ();
  in void world ();

  behavior
  {
    bool idle = true;

    [idle]
    {
      on hello:
        {
          [true] {reply (true); idle = false;}
          [true] reply (false);
        }
      on world: {}
    }

    [!idle] on world: idle = true;
  }
}

interface iworld
{
  in bool hello ();
  in bool world ();

  behavior
  {
    on hello, world:
    {
      [true] reply (true);
      [true] reply (false);
    }
  }
}

component hello_choice3
{
  provides ihello h;
  requires iworld w;

  behavior
  {
    bool idle = true;

    [idle]
    {
      on h.hello ():
        {
          bool b = true;
          if (b) b = w.hello();
          if (b) b = w.world();
          if (b) idle = false;
          reply (b);
        }
      on h.world (): {}
    }
      [!idle] on h.world (): idle = true;
  }
}
