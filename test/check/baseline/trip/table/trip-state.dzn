interface I {
  enum Status {Yes, No};
  extern xint $int$;
  in Status e();
  out void a();
  out void hi();
  out void lo();

  behaviour {
    bool b = false;

    void h() {
      if (b) return false;
      return false;
    }

    bool g(bool ga, bool gb) {
      a;
      return ga || gb;
    }

    [!b]
    on e:
    {
      b = !b;
      bool c = g(b, b);
      b = g(c, c);
      h();
      if (c) a;
      reply(Status.Yes);
    }
    [b]
    on e:
    {
      b = !b;
      bool c = g(b, b);
      b = g(c, c);
      h();
      if (c) a;
      reply(Status.Yes);
    }
  }
}

interface ilogger {
  in void log();

  behaviour {

    [true]
    on log:
    {}
  }
}

interface U {
  enum Status {Ok, Nok};
  in Status what();

  behaviour {
    Status s = Status.Ok;
    bool dummy = false;

    [s.Ok]
    on what:
    {
      [true]
      reply(Status.Ok);
      [true]
      reply(Status.Nok);
    }
    [s.Nok]
    on what:
    reply(Status.Nok);
  }
}

component logger {
  provides ilogger log;

  behaviour {

    [true]
    on log.log():
    {}
  }
}

component trap {
  provides I i;
  requires U u;
  requires injected ilogger l;

  behaviour {
    subint State {0..3};
    State state = 3;
    State c = 0;
    bool b = false;

    bool g(bool ga, bool gb) {
      i.a();
      return ga || gb;
    }

    [state.0]
    on i.e():
    {
      b = !b;
      bool c = g(b, b);
      b = g(c, c);
      if (c) i.a();
      else i.a();
      U.Status s = U.Status.Ok;
      s = U.Status.Nok;
      s = u.what();
      b = s == U.Status.Ok;
      if (s == U.Status.Ok) reply(I.Status.Yes);
      if (!s.Ok) reply(I.Status.No);
    }
    [state.1]
    on i.e():
    {
      [b]
      {
        b = !b;
        bool c = g(b, b);
        b = g(c, c);
        if (c) i.a();
        else i.a();
        U.Status s = U.Status.Ok;
        s = U.Status.Nok;
        s = u.what();
        b = s == U.Status.Ok;
        if (s == U.Status.Ok) reply(I.Status.Yes);
        if (!s.Ok) reply(I.Status.No);
      }
      [otherwise]
      {
        state = state - 1;
        if (c < state) c = c + 1;
        else if (c <= state + 1) i.lo();
        else if (c > state) i.hi();
      }
    }
    [state.2]
    on i.e():
    {
      [b]
      {
        b = !b;
        bool c = g(b, b);
        b = g(c, c);
        if (c) i.a();
        else i.a();
        U.Status s = U.Status.Ok;
        s = U.Status.Nok;
        s = u.what();
        b = s == U.Status.Ok;
        if (s == U.Status.Ok) reply(I.Status.Yes);
        if (!s.Ok) reply(I.Status.No);
      }
      [otherwise]
      {
        state = state - 1;
        if (c < state) c = c + 1;
        else if (c <= state + 1) i.lo();
        else if (c > state) i.hi();
      }
    }
    [state.3]
    on i.e():
    {
      [b]
      {
        b = !b;
        bool c = g(b, b);
        b = g(c, c);
        if (c) i.a();
        else i.a();
        U.Status s = U.Status.Ok;
        s = U.Status.Nok;
        s = u.what();
        b = s == U.Status.Ok;
        if (s == U.Status.Ok) reply(I.Status.Yes);
        if (!s.Ok) reply(I.Status.No);
      }
      [otherwise]
      {
        state = state - 1;
        if (c < state) c = c + 1;
        else if (c <= state + 1) i.lo();
        else if (c > state) i.hi();
      }
    }
  }
}

component trip {
  provides I i;
  requires U u;

  system {
    logger l;
    trap t;

    i <=> t.i;
    t.u <=> u;
    l.log <=> *;
  }
}

