interface I {
  enum Status {Yes, No};
  extern xint $int$;
  in Status e();
  in void b(out xint formal);
  in void r(xint formal);
  out void a();
  out void hi();
  out void lo();

  behaviour {
    bool mb = false;

    void h() {
      if (mb) return;
      return;
    }

    bool g(bool ga, bool gb) {
      a;
      return ga || gb;
    }

    on b:
    {
      [mb || !mb]
      a;
    }
    on r:
    {
      [mb || !mb]
      {}
    }
    on e:
    {
      [mb || !mb]
      {
        mb = !mb;
        bool c = g(mb, mb);
        mb = g(c, c);
        h();
        if (c) a;
        reply(Status.Yes);
      }
    }
  }
}

interface ilogger {
  in void log();

  behaviour {

    on log:
    [true]
    {}
  }
}

interface U {
  enum Status {Ok, Nok};
  in Status what();

  behaviour {
    Status s = Status.Ok;
    bool dummy = false;

    on what:
    {
      [s.Ok]
      {
        [true]
        reply(Status.Ok);
        [true]
        reply(Status.Nok);
      }
      [s.Nok]
      reply(Status.Nok);
    }
  }
}

component logger {
  provides ilogger log;

  behaviour {

    on log.log():
    [true]
    {}
  }
}

component trap {
  provides I i;
  requires U u;
  requires injected ilogger l;

  behaviour {
    subint State {0..3};
    State state = 3;
    State c = 0;
    I.xint global_i;
    bool b = false;

    bool g(bool ga, bool gb) {
      i.a();
      return ga || gb;
    }

    on i.e():
    {
      [state.0]
      {
        b = !b;
        bool c = g(b, b);
        b = g(c, c);
        if (c) i.a();
        else i.a();
        U.Status s = U.Status.Ok;
        s = U.Status.Nok;
        s = u.what();
        b = s == U.Status.Ok;
        if (s == U.Status.Ok) reply(I.Status.Yes);
        if (!s.Ok) reply(I.Status.No);
      }
      [state.3 || state.2 || state.1]
      {
        [b]
        {
          b = !b;
          bool c = g(b, b);
          b = g(c, c);
          if (c) i.a();
          else i.a();
          U.Status s = U.Status.Ok;
          s = U.Status.Nok;
          s = u.what();
          b = s == U.Status.Ok;
          if (s == U.Status.Ok) reply(I.Status.Yes);
          if (!s.Ok) reply(I.Status.No);
        }
        [otherwise]
        {
          state = state - 1;
          if (c < state) c = c + 1;
          else if (c <= state + 1) i.lo();
          else if (c > state) i.hi();
          reply(I.Status.Yes);
        }
      }
    }
  }
}

component trip {
  provides I i;
  requires U u;

  system {
    logger l;
    trap t;

    i <=> t.i;
    t.u <=> u;
    l.log <=> *;
  }
}

