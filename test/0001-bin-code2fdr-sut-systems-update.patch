From 36f96644356d058444cb725a3e33cbfe3c48c8c0 Mon Sep 17 00:00:00 2001
From: Jan Nieuwenhuizen <janneke@gnu.org>
Date: Mon, 30 Nov 2015 21:13:36 +0100
Subject: [PATCH] bin: code2fdr: sut/systems update.

---
 test/bin/code2fdr | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/test/bin/code2fdr b/test/bin/code2fdr
index 41b3e25..da58040 100755
--- a/test/bin/code2fdr
+++ b/test/bin/code2fdr
@@ -1,8 +1,8 @@
 #! /bin/bash
 
-grep -Eo '<(external|internal)>[.][^ ]+|^(\w|[<>])+[.](\w|[<>])+$|^illegal$'\
+grep -Eo '(<external>|<internal>|sut)[.][^. ]+[.][^ ]+|^(\w|[<>])+[.](\w|[<>])+$|^illegal$'\
   | sed -r\
     -e s', -> ,,'\
-    -e s',^<(external|internal)>[.],,'\
+    -e s',^(<external>|<internal>|sut)[.],,'\
   | sed -r\
     -e s',^((\w|[<>])+)[.]((\w|[<>])+)$,\1.\3,'
-- 
2.5.0

