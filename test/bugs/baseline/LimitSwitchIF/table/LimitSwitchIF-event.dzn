interface LimitSwitchIF
{
  enum Position { Opened, Closed, Unknown };
  in void doorOpening();
  in void doorClosing();
  in void doorStopped();
  out void doorOpened();
  out void doorClosed();
  out void proximityWarning();
  in Position queryPosition();
  in void initialise();

  behaviour 
  {
    enum State { NotReady, Ready };
    enum DoorState { Opening, Closing, Idle };
    Position state = Position.Unknown;
    DoorState door = DoorState.Idle;
    State ready = State.NotReady;
    on initialise:
    {
      [state.Unknown || state.Closed || state.Opened]
      [ready.NotReady]
      ready = State.Ready;
      [state.Unknown || state.Closed || state.Opened]
      [ready.Ready]
      illegal;
    }
    on doorOpening:
    {
      [state.Unknown || state.Closed || state.Opened]
      [ready.NotReady]
      illegal;
      [state.Unknown || state.Closed || state.Opened]
      [ready.Ready]
      [door.Idle]
      door = DoorState.Opening;
      [state.Unknown || state.Closed || state.Opened]
      [ready.Ready]
      [door.Opening]
      illegal;
      [state.Unknown || state.Closed || state.Opened]
      [ready.Ready]
      [door.Closing]
      illegal;
    }
    on doorClosing:
    {
      [state.Unknown || state.Closed || state.Opened]
      [ready.NotReady]
      illegal;
      [state.Unknown || state.Closed || state.Opened]
      [ready.Ready]
      [door.Idle]
      door = DoorState.Closing;
      [state.Unknown || state.Closed || state.Opened]
      [ready.Ready]
      [door.Opening]
      illegal;
      [state.Unknown || state.Closed || state.Opened]
      [ready.Ready]
      [door.Closing]
      illegal;
    }
    on doorStopped:
    {
      [state.Unknown || state.Closed || state.Opened]
      [ready.NotReady]
      illegal;
      [state.Unknown || state.Closed || state.Opened]
      [ready.Ready]
      [door.Idle]
      illegal;
      [state.Unknown || state.Closed || state.Opened]
      [ready.Ready]
      [door.Opening]
      door = DoorState.Idle;
      [state.Unknown || state.Closed || state.Opened]
      [ready.Ready]
      [door.Closing]
      door = DoorState.Idle;
    }
    on queryPosition:
    {
      [state.Unknown || state.Closed || state.Opened]
      [ready.NotReady]
      illegal;
      [state.Unknown || state.Closed || state.Opened]
      [ready.Ready]
      reply(state);
    }
    on inevitable:
    {
      [state.Unknown || state.Closed || state.Opened]
      [ready.Ready]
      [door.Opening]
      {
        doorOpened;
        state = Position.Opened;
        door = DoorState.Idle;
      }
      [state.Unknown || state.Closed || state.Opened]
      [ready.Ready]
      [door.Opening]
      state = Position.Unknown;
      [state.Unknown || state.Closed || state.Opened]
      [ready.Ready]
      [door.Closing]
      {
        doorClosed;
        state = Position.Closed;
        door = DoorState.Idle;
      }
      [state.Unknown || state.Closed || state.Opened]
      [ready.Ready]
      [door.Closing]
      state = Position.Unknown;
    }
    on optional:
    {
      [state.Unknown || state.Closed || state.Opened]
      [ready.Ready]
      [door.Closing]
      proximityWarning;
    }
  }
}

