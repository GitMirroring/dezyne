interface LimitSwitchIF
{
  enum Position { Opened, Closed, Unknown };
  in void doorOpening();
  in void doorClosing();
  in void doorStopped();
  out void doorOpened();
  out void doorClosed();
  out void proximityWarning();
  in Position queryPosition();
  in void initialise();

  behaviour 
  {
    enum State { NotReady, Ready };
    enum DoorState { Opening, Closing, Idle };
    Position state = Position.Unknown;
    DoorState door = DoorState.Idle;
    State ready = State.NotReady;
    [state.Opened]
    {
      on initialise:
      {
        [ready.NotReady]
        ready = State.Ready;
        [ready.Ready]
        illegal;
      }
      on doorOpening:
      {
        [ready.NotReady]
        illegal;
        [ready.Ready && door.Idle]
        door = DoorState.Opening;
        [ready.Ready && door.Opening]
        illegal;
        [ready.Ready && door.Closing]
        illegal;
      }
      on doorClosing:
      {
        [ready.NotReady]
        illegal;
        [ready.Ready && door.Idle]
        door = DoorState.Closing;
        [ready.Ready && door.Opening]
        illegal;
        [ready.Ready && door.Closing]
        illegal;
      }
      on doorStopped:
      {
        [ready.NotReady]
        illegal;
        [ready.Ready && door.Idle]
        illegal;
        [ready.Ready && door.Opening]
        door = DoorState.Idle;
        [ready.Ready && door.Closing]
        door = DoorState.Idle;
      }
      on queryPosition:
      {
        [ready.NotReady]
        illegal;
        [ready.Ready]
        reply(state);
      }
      on inevitable:
      {
        [ready.Ready && door.Opening]
        {
          doorOpened;
          state = Position.Opened;
          door = DoorState.Idle;
        }
        [ready.Ready && door.Opening]
        state = Position.Unknown;
        [ready.Ready && door.Closing]
        {
          doorClosed;
          state = Position.Closed;
          door = DoorState.Idle;
        }
        [ready.Ready && door.Closing]
        state = Position.Unknown;
      }
      on optional:
      [ready.Ready && door.Closing]
      proximityWarning;
    }
    [state.Closed]
    {
      on initialise:
      {
        [ready.NotReady]
        ready = State.Ready;
        [ready.Ready]
        illegal;
      }
      on doorOpening:
      {
        [ready.NotReady]
        illegal;
        [ready.Ready && door.Idle]
        door = DoorState.Opening;
        [ready.Ready && door.Opening]
        illegal;
        [ready.Ready && door.Closing]
        illegal;
      }
      on doorClosing:
      {
        [ready.NotReady]
        illegal;
        [ready.Ready && door.Idle]
        door = DoorState.Closing;
        [ready.Ready && door.Opening]
        illegal;
        [ready.Ready && door.Closing]
        illegal;
      }
      on doorStopped:
      {
        [ready.NotReady]
        illegal;
        [ready.Ready && door.Idle]
        illegal;
        [ready.Ready && door.Opening]
        door = DoorState.Idle;
        [ready.Ready && door.Closing]
        door = DoorState.Idle;
      }
      on queryPosition:
      {
        [ready.NotReady]
        illegal;
        [ready.Ready]
        reply(state);
      }
      on inevitable:
      {
        [ready.Ready && door.Opening]
        {
          doorOpened;
          state = Position.Opened;
          door = DoorState.Idle;
        }
        [ready.Ready && door.Opening]
        state = Position.Unknown;
        [ready.Ready && door.Closing]
        {
          doorClosed;
          state = Position.Closed;
          door = DoorState.Idle;
        }
        [ready.Ready && door.Closing]
        state = Position.Unknown;
      }
      on optional:
      [ready.Ready && door.Closing]
      proximityWarning;
    }
    [state.Unknown]
    {
      on initialise:
      {
        [ready.NotReady]
        ready = State.Ready;
        [ready.Ready]
        illegal;
      }
      on doorOpening:
      {
        [ready.NotReady]
        illegal;
        [ready.Ready && door.Idle]
        door = DoorState.Opening;
        [ready.Ready && door.Opening]
        illegal;
        [ready.Ready && door.Closing]
        illegal;
      }
      on doorClosing:
      {
        [ready.NotReady]
        illegal;
        [ready.Ready && door.Idle]
        door = DoorState.Closing;
        [ready.Ready && door.Opening]
        illegal;
        [ready.Ready && door.Closing]
        illegal;
      }
      on doorStopped:
      {
        [ready.NotReady]
        illegal;
        [ready.Ready && door.Idle]
        illegal;
        [ready.Ready && door.Opening]
        door = DoorState.Idle;
        [ready.Ready && door.Closing]
        door = DoorState.Idle;
      }
      on queryPosition:
      {
        [ready.NotReady]
        illegal;
        [ready.Ready]
        reply(state);
      }
      on inevitable:
      {
        [ready.Ready && door.Opening]
        {
          doorOpened;
          state = Position.Opened;
          door = DoorState.Idle;
        }
        [ready.Ready && door.Opening]
        state = Position.Unknown;
        [ready.Ready && door.Closing]
        {
          doorClosed;
          state = Position.Closed;
          door = DoorState.Idle;
        }
        [ready.Ready && door.Closing]
        state = Position.Unknown;
      }
      on optional:
      [ready.Ready && door.Closing]
      proximityWarning;
    }
  }
}

