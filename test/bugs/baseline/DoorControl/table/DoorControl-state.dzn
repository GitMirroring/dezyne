interface LimitSwitchIF
{
  enum Position { Opened, Closed, Unknown };
  in void motorActive();
  in void motorStopped();
  out void doorOpened();
  out void doorClosed();
  out void proximityWarning();
  in Position queryPosition();
  in void initialise();

  behaviour 
  {
    enum State { NOT_READY, READY };
    enum MotorState { Active, Stopped };
    Position state = Position.Unknown;
    MotorState motor = MotorState.Stopped;
    State ready = State.NOT_READY;
    [state.Opened]
    {
      on initialise:
      {
        [ready.NOT_READY]
        ready = State.READY;
        [ready.READY]
        illegal;
      }
      on motorActive:
      {
        [ready.NOT_READY]
        illegal;
        [ready.READY]
        motor = MotorState.Active;
      }
      on motorStopped:
      {
        [ready.NOT_READY]
        illegal;
        [ready.READY]
        motor = MotorState.Stopped;
      }
      on queryPosition:
      {
        [ready.NOT_READY]
        illegal;
        [ready.READY]
        reply(state);
      }
      on optional:
      {
        [ready.READY && motor.Active]
        state = Position.Unknown;
        [ready.READY && motor.Active]
        proximityWarning;
      }
    }
    [state.Closed]
    {
      on initialise:
      {
        [ready.NOT_READY]
        ready = State.READY;
        [ready.READY]
        illegal;
      }
      on motorActive:
      {
        [ready.NOT_READY]
        illegal;
        [ready.READY]
        motor = MotorState.Active;
      }
      on motorStopped:
      {
        [ready.NOT_READY]
        illegal;
        [ready.READY]
        motor = MotorState.Stopped;
      }
      on queryPosition:
      {
        [ready.NOT_READY]
        illegal;
        [ready.READY]
        reply(state);
      }
      on optional:
      {
        [ready.READY && motor.Active]
        state = Position.Unknown;
        [ready.READY && motor.Active]
        proximityWarning;
      }
    }
    [state.Unknown]
    {
      on initialise:
      {
        [ready.NOT_READY]
        ready = State.READY;
        [ready.READY]
        illegal;
      }
      on motorActive:
      {
        [ready.NOT_READY]
        illegal;
        [ready.READY]
        motor = MotorState.Active;
      }
      on motorStopped:
      {
        [ready.NOT_READY]
        illegal;
        [ready.READY]
        motor = MotorState.Stopped;
      }
      on queryPosition:
      {
        [ready.NOT_READY]
        illegal;
        [ready.READY]
        reply(state);
      }
      on optional:
      {
        [ready.READY && motor.Active]
        {
          doorOpened;
          state = Position.Opened;
        }
        [ready.READY && motor.Active]
        {
          doorClosed;
          state = Position.Closed;
        }
        [ready.READY && motor.Active]
        proximityWarning;
      }
    }
  }
}
interface MotorControlIF
{
  in void initialise();
  in void start();
  in void stop();
  in void setOpen();
  in void setClose();
  out void driveFault();
  out void powerWarning();

  behaviour 
  {
    enum State { NotReady, Ready };
    enum OnOff { MotorOn, MotorOff };
    enum Direction { DoorOpen, DoorClose };
    OnOff motor = OnOff.MotorOff;
    Direction dir = Direction.DoorOpen;
    State state = State.NotReady;
    [motor.MotorOn]
    {
      on start, setOpen, setClose:
      {
        [state.Ready]
        illegal;
        [state.NotReady]
        illegal;
      }
      on stop:
      {
        [state.Ready]
        motor = OnOff.MotorOff;
        [state.NotReady]
        illegal;
      }
      on optional:
      {
        [state.Ready]
        {
          driveFault;
          motor = OnOff.MotorOff;
        }
        [state.Ready]
        powerWarning;
      }
      on initialise:
      {
        [state.Ready]
        illegal;
        [state.NotReady]
        {
          state = State.Ready;
          motor = OnOff.MotorOff;
        }
      }
    }
    [motor.MotorOff]
    {
      on start:
      {
        [state.Ready]
        motor = OnOff.MotorOn;
        [state.NotReady]
        illegal;
      }
      on setOpen:
      {
        [state.Ready]
        dir = Direction.DoorOpen;
        [state.NotReady]
        illegal;
      }
      on setClose:
      {
        [state.Ready]
        dir = Direction.DoorClose;
        [state.NotReady]
        illegal;
      }
      on stop:
      {
        [state.Ready]
        illegal;
        [state.NotReady]
        illegal;
      }
      on initialise:
      {
        [state.Ready]
        illegal;
        [state.NotReady]
        {
          state = State.Ready;
          motor = OnOff.MotorOff;
        }
      }
    }
  }
}
interface SwitchPressIF
{
  out void switchPressed();

  behaviour 
  {
    [true]
    on inevitable:
    switchPressed;
  }
}
interface DoorControlIF
{
  in void initialise();
  in void reset();
  out void warning();
  out void error();

  behaviour 
  {
    enum State { NotReady, Ready, Error };
    State state = State.NotReady;
    [state.NotReady]
    {
      on initialise:
      state = State.Ready;
      on reset:
      illegal;
    }
    [state.Ready]
    {
      on initialise, reset:
      illegal;
      on inevitable:
      {
        [true]
        warning;
        [true]
        {
          error;
          state = State.Error;
        }
      }
    }
    [state.Error]
    {
      on initialise:
      illegal;
      on reset:
      state = State.Ready;
    }
  }
}
component DoorControl
{
  provides DoorControlIF doorControl;
  requires SwitchPressIF switchPress;
  requires MotorControlIF motorControl;
  requires LimitSwitchIF limitSw;

  behaviour 
  {
    enum State { NotReady, Ready, Opening, Closing, Error };
    State state = State.NotReady;
    LimitSwitchIF.Position position = LimitSwitchIF.Position.Unknown;
    [state.NotReady]
    {
      on doorControl.initialise():
      {
        limitSw.initialise();
        motorControl.initialise();
        state = State.Ready;
      }
      on doorControl.reset(), limitSw.doorClosed(), limitSw.doorOpened(), limitSw.proximityWarning():
      illegal;
      on switchPress.switchPressed():
      {
      }
      on motorControl.powerWarning():
      doorControl.warning();
      on motorControl.driveFault():
      {
        limitSw.motorStopped();
        doorControl.error();
        state = State.Error;
      }
    }
    [state.Ready]
    {
      on doorControl.initialise(), doorControl.reset(), limitSw.doorClosed(), limitSw.doorOpened(), limitSw.proximityWarning():
      illegal;
      on switchPress.switchPressed():
      {
        position = limitSw.queryPosition();
        if (position == LimitSwitchIF.Position.Opened)
        {
          motorControl.setClose();
          motorControl.start();
          limitSw.motorActive();
          state = State.Closing;
        }
        else
        if (position == LimitSwitchIF.Position.Closed || position == LimitSwitchIF.Position.Unknown)
        {
          motorControl.setOpen();
          motorControl.start();
          limitSw.motorActive();
          state = State.Opening;
        }
      }
      on motorControl.powerWarning():
      doorControl.warning();
      on motorControl.driveFault():
      {
        limitSw.motorStopped();
        doorControl.error();
        state = State.Error;
      }
    }
    [state.Opening]
    {
      on doorControl.initialise(), doorControl.reset():
      illegal;
      on switchPress.switchPressed():
      {
        motorControl.stop();
        motorControl.setClose();
        motorControl.start();
        state = State.Closing;
      }
      on limitSw.doorClosed(), limitSw.proximityWarning():
      {
      }
      on limitSw.doorOpened():
      {
        motorControl.stop();
        limitSw.motorStopped();
        state = State.Ready;
      }
      on motorControl.powerWarning():
      doorControl.warning();
      on motorControl.driveFault():
      {
        limitSw.motorStopped();
        doorControl.error();
        state = State.Error;
      }
    }
    [state.Closing]
    {
      on doorControl.initialise(), doorControl.reset():
      illegal;
      on switchPress.switchPressed(), limitSw.proximityWarning():
      {
        motorControl.stop();
        motorControl.setOpen();
        motorControl.start();
        state = State.Opening;
      }
      on limitSw.doorClosed():
      {
        motorControl.stop();
        limitSw.motorStopped();
        state = State.Ready;
      }
      on limitSw.doorOpened():
      {
      }
      on motorControl.powerWarning():
      doorControl.warning();
      on motorControl.driveFault():
      {
        limitSw.motorStopped();
        doorControl.error();
        state = State.Error;
      }
    }
    [state.Error]
    {
      on doorControl.initialise():
      illegal;
      on doorControl.reset():
      state = State.Ready;
      on switchPress.switchPressed(), limitSw.doorClosed(), limitSw.doorOpened(), limitSw.proximityWarning():
      {
      }
      on motorControl.powerWarning():
      doorControl.warning();
      on motorControl.driveFault():
      {
        limitSw.motorStopped();
        doorControl.error();
        state = State.Error;
      }
    }
  }
}

