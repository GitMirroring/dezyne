// Commentary:
//
// Code:

// For the following behaviour, the symbolic computation does not reduce I.State.NOK != I.State.NOK to false,
// while it correctly reduces I.State.OK != I.State.NOK to true.
// This is observable in the table views, e.g. event table::
//
// e
// [s.NOK]  {} s.NOK 
// [s.NOK] [I.State.NOK != I.State.NOK] illegal;  
// [s.OK]  illegal; 
//


interface I {
  in void e();
  behaviour {
    enum State { NOK, OK};
    State s = State.NOK;
    State t = State.NOK;
    [s.NOK] {
      on e: {}
    }
    [s.OK && t != State.NOK] {
      on e: illegal;
    }
  }
}
