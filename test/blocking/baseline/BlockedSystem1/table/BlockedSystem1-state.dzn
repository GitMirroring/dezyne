// Code:

interface I1 {
  in void e();

  behaviour {

    [true]
    on e:
    {}
  }
}

interface I2 {
  out void f();

  behaviour {

    [true]
    on inevitable:
    f;
  }
}

interface I3 {
  in void e();
  out void f();

  behaviour {
    bool pending = false;

    [!pending]
    on e:
    pending = true;
    [pending]
    {
      on e:
      illegal;
      on inevitable:
      {
        pending = false;
        f;
      }
    }
  }
}

component A {
  provides I1 p;
  requires I1 r1;
  requires I2 r2;

  behaviour {

    [true]
    on p.e(), r2.f():
    r1.e();
  }
}

component B {
  provides I1 p;
  requires I3 r;

  behaviour {

    [true]
    {
      on p.e():
      blocking r.e();
      on r.f():
      p.reply();
    }
  }
}

component BlockedSystem1 {
  provides I1 p;
  requires I2 r2;
  requires I3 r3;

  system {
    A a;
    B b;

    p <=> a.p;
    a.r1 <=> b.p;
    a.r2 <=> r2;
    b.r <=> r3;
  }
}

