// Code:

interface ISynchronousOut {
  enum Val {One, Two};
  in void void_event();
  in Val valued_event();
  out void out_event();

  behaviour {

    on void_event:
    [true]
    out_event;
    on valued_event:
    {
      [true]
      {
        out_event;
        reply(Val.One);
      }
      [true]
      {
        out_event;
        reply(Val.Two);
      }
    }
  }
}

component SynchronousOut {
  provides ISynchronousOut pp;
  requires ISynchronousOut rp;

  behaviour {

    on pp.void_event():
    [true]
    rp.void_event();
    on pp.valued_event():
    [true]
    {
      ISynchronousOut.Val v = rp.valued_event();
      reply(v);
    }
    on rp.out_event():
    [true]
    pp.out_event();
  }
}

