interface RGuardthreetopon {
  in void e();
  out void a();

  behaviour {

    on e:
    [true]
    illegal;
  }
}

interface IGuardthreetopon {
  in void e();
  in void t();
  in void s();
  out void a();

  behaviour {
    bool b = false;

    on e:
    {
      [b || !b]
      a;
    }
    on t:
    {
      [b || !b]
      a;
    }
    on s:
    {
      [b || !b]
      a;
    }
  }
}

component Guardthreetopon {
  provides IGuardthreetopon i;
  requires RGuardthreetopon r;

  behaviour {
    bool b = false;

    on i.e():
    {
      [!b]
      {
        bool c = true;
        if (c) i.a();
      }
      [b]
      i.a();
    }
    on r.a():
    {
      [b || !b]
      {}
    }
    on i.t():
    {
      [b || !b]
      i.a();
    }
    on i.s():
    {
      [b || !b]
      i.a();
    }
  }
}

