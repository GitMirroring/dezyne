// Code:

interface iq {
  in void e();
  out void a();
  in void f();
  out void b();

  behaviour {

    on e:
    [true]
    a;
    on f:
    [true]
    {
      a;
      b;
    }
  }
}

interface ir {
  in void e();
  out void a();
  in void f();
  out void b();

  behaviour {
    bool s = false;

    on e:
    {
      [s || !s]
      {
        s = !s;
        a;
      }
    }
    on f:
    {
      [s || !s]
      {
        s = !s;
        b;
      }
    }
  }
}

component q {
  provides iq p;
  requires ir r;

  behaviour {

    on p.e():
    [true]
    r.e();
    on r.a():
    [true]
    p.a();
    on p.f():
    [true]
    {
      r.e();
      r.f();
    }
    on r.b():
    [true]
    p.b();
  }
}

