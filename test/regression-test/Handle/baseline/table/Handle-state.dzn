interface IHandle {
  in void calibrate();
  out void calibrated();
  in void stop();
  in void operate();
  out void finished();

  behaviour {
    enum State {Lost, Calibrating, Idle, Operating};
    State s = State.Lost;

    [s.Lost]
    {
      on stop:
      s = State.Lost;
      on calibrate:
      {
        [true]
        s = State.Calibrating;
        [true]
        {
          calibrated;
          s = State.Idle;
        }
      }
      on operate:
      {
        [true]
        illegal;
        [true]
        {}
      }
    }
    [s.Calibrating]
    {
      on stop:
      s = State.Lost;
      on calibrate, operate:
      {
        [true]
        illegal;
        [true]
        {}
      }
      on inevitable:
      {
        calibrated;
        s = State.Idle;
      }
    }
    [s.Idle]
    {
      on stop:
      s = State.Lost;
      on calibrate:
      {
        [true]
        illegal;
        [true]
        {}
      }
      on operate:
      {
        [true]
        s = State.Operating;
        [true]
        finished;
      }
    }
    [s.Operating]
    {
      on stop:
      s = State.Lost;
      on calibrate, operate:
      {
        [true]
        illegal;
        [true]
        {}
      }
      on inevitable:
      {
        s = State.Idle;
        finished;
      }
    }
  }
}

interface ITransfer {
  extern TrPosition $int$;
  in void calibrate();
  out void calibrated();
  in void stop();
  in void move(TrPosition x, TrPosition y);
  out void arrived();
  in void transfer(TrPosition x, TrPosition y);
  out void picked();
  out void placed();

  behaviour {
    enum State {Lost, Calibrating, Ready, Moving, Transferring};
    State s = State.Lost;
    bool isPicked = false;

    [s.Lost]
    {
      on stop:
      s = State.Lost;
      on calibrate:
      {
        [true]
        s = State.Calibrating;
        [true]
        {
          calibrated;
          s = State.Ready;
        }
      }
      on move, transfer:
      illegal;
    }
    [s.Calibrating]
    {
      on stop:
      s = State.Lost;
      on calibrate, move, transfer:
      illegal;
      on inevitable:
      {
        calibrated;
        s = State.Ready;
      }
    }
    [s.Ready]
    {
      on stop:
      s = State.Lost;
      on calibrate:
      illegal;
      on move:
      {
        [true]
        s = State.Moving;
        [true]
        arrived;
      }
      on transfer:
      {
        [true]
        {
          s = State.Transferring;
          isPicked = false;
        }
        [true]
        {
          s = State.Transferring;
          picked;
          isPicked = true;
        }
        [true]
        {
          s = State.Ready;
          picked;
          placed;
        }
      }
    }
    [s.Moving]
    {
      on stop:
      s = State.Lost;
      on calibrate, move, transfer:
      illegal;
      on inevitable:
      {
        arrived;
        s = State.Ready;
      }
    }
    [s.Transferring]
    {
      on stop:
      s = State.Lost;
      on calibrate, move, transfer:
      illegal;
      on inevitable:
      {
        [!isPicked]
        {
          picked;
          isPicked = true;
        }
        [isPicked]
        {
          placed;
          s = State.Ready;
        }
      }
    }
  }
}

interface IInspect {
  in void calibrate();
  out void calibrated();
  in void stop();
  in void inspect();
  out void accepted();
  out void rejected();
  in void prepare();
  out void prepared();

  behaviour {
    enum State {Lost, Ready, Calibrating, Inspecting, Waiting, Preparing};
    State s = State.Lost;

    [s.Lost]
    {
      on stop:
      s = State.Lost;
      on calibrate:
      {
        [true]
        s = State.Calibrating;
        [true]
        {
          calibrated;
          s = State.Ready;
        }
      }
      on inspect, prepare:
      illegal;
    }
    [s.Ready]
    {
      on stop:
      s = State.Lost;
      on calibrate, prepare:
      illegal;
      on inspect:
      s = State.Inspecting;
    }
    [s.Calibrating]
    {
      on stop:
      s = State.Lost;
      on calibrate, inspect, prepare:
      illegal;
      on inevitable:
      {
        calibrated;
        s = State.Ready;
      }
    }
    [s.Inspecting]
    {
      on stop:
      s = State.Lost;
      on calibrate, inspect, prepare:
      illegal;
      on inevitable:
      {
        [true]
        {
          accepted;
          s = State.Waiting;
        }
        [true]
        {
          rejected;
          s = State.Waiting;
        }
      }
    }
    [s.Waiting]
    {
      on stop:
      s = State.Lost;
      on calibrate, inspect:
      illegal;
      on prepare:
      {
        [true]
        s = State.Preparing;
        [true]
        {
          prepared;
          s = State.Ready;
        }
      }
    }
    [s.Preparing]
    {
      on stop:
      s = State.Lost;
      on calibrate, inspect, prepare:
      illegal;
      on inevitable:
      {
        prepared;
        s = State.Ready;
      }
    }
  }
}

interface IFeed {
  in void calibrate();
  out void calibrated();
  in void stop();
  in void produceBall();
  out void consumeNextBall();
  out void consumeLastBall();

  behaviour {
    enum State {Lost, Calibrating, Idle, Preparing, Prepared};
    State s = State.Lost;

    [s.Lost]
    {
      on stop:
      s = State.Lost;
      on calibrate:
      {
        [true]
        s = State.Calibrating;
        [true]
        {
          calibrated;
          s = State.Idle;
        }
      }
      on produceBall:
      illegal;
    }
    [s.Calibrating]
    {
      on stop:
      s = State.Lost;
      on calibrate, produceBall:
      illegal;
      on inevitable:
      {
        calibrated;
        s = State.Idle;
      }
    }
    [s.Idle]
    {
      on stop:
      s = State.Lost;
      on calibrate:
      illegal;
      on produceBall:
      {
        [true]
        s = State.Preparing;
        [true]
        {
          consumeNextBall;
          s = State.Prepared;
        }
        [true]
        {
          consumeLastBall;
          s = State.Idle;
        }
      }
    }
    [s.Preparing]
    {
      on stop:
      s = State.Lost;
      on calibrate, produceBall:
      illegal;
      on inevitable:
      {
        [true]
        {
          consumeNextBall;
          s = State.Prepared;
        }
        [true]
        {
          consumeLastBall;
          s = State.Idle;
        }
      }
    }
    [s.Prepared]
    {
      on stop:
      s = State.Lost;
      on calibrate:
      illegal;
      on produceBall:
      {
        [true]
        s = State.Preparing;
        [true]
        {
          consumeNextBall;
          s = State.Prepared;
        }
        [true]
        {
          consumeLastBall;
          s = State.Idle;
        }
      }
    }
  }
}

interface IConvey {
  in void convey();
  out void conveyed();
  in void stop();

  behaviour {
    enum State {Idle, Conveying};
    State s = State.Idle;

    [s.Idle]
    {
      on stop:
      s = State.Idle;
      on convey:
      {
        [true]
        s = State.Conveying;
        [true]
        conveyed;
      }
    }
    [s.Conveying]
    {
      on stop:
      s = State.Idle;
      on convey:
      illegal;
      on inevitable:
      {
        conveyed;
        s = State.Idle;
      }
    }
  }
}

component Handle {
  provides IHandle ctrl;
  requires ITransfer robot;
  requires IInspect inspector;
  requires IFeed feedPort;
  requires IConvey acceptPort;
  requires IConvey rejectPort;

  behaviour {
    enum State {Lost, Calibrating, Idle, Operating};
    subint usedCount {0..4};
    enum Operation {PreparingInput, TransferringInput, PreparingOutput, TransferringOutput, Finalizing};
    State s = State.Lost;
    usedCount calibrated = 0;
    usedCount requiredCalibrations = 3;
    Operation o = Operation.PreparingInput;
    bool isLastBall = false;
    bool isBallAtInput = false;
    bool isRobotAtInput = false;
    bool isRobotAtOutput = false;
    bool isInspectorAtInput = false;
    bool isInspectorAtOutput = false;
    bool isBallAccepted = false;
    bool isAcceptEmpty = true;
    bool isRejectEmpty = true;

    void tryCalibrated() {
      calibrated = calibrated + 1;
      if (calibrated == requiredCalibrations) {
        s = State.Idle;
        isInspectorAtInput = true;
        isInspectorAtOutput = false;
        ctrl.calibrated();
      }
      return;
    }

    void ignoreIllegal() {
      return;
    }

    void startBatch() {
      s = State.Operating;
      isLastBall = false;
      prepareInputTransfer();
      return;
    }

    void finalizeBatch() {
      s = State.Idle;
      ctrl.finished();
      return;
    }

    void prepareInputTransfer() {
      o = Operation.PreparingInput;
      if (!isBallAtInput) {
        feedPort.produceBall();
        isBallAtInput = false;
      }
      if (!isInspectorAtInput) {
        inspector.prepare();
        isInspectorAtInput = false;
      }
      if (!isRobotAtInput) {
        sendRobotToInputPick();
        isRobotAtInput = false;
      }
      tryInputTransfer();
      return;
    }

    void sendRobotToInputPick() {
      robot.move($0$, $0$);
      isRobotAtOutput = false;
      isRobotAtInput = false;
      return;
    }

    void tryInputTransfer() {
      if (isBallAtInput && isRobotAtInput && isInspectorAtInput) {
        robot.transfer($0$, $0$);
        o = Operation.TransferringInput;
      }
      return;
    }

    void tryOutputTransfer() {
      if (isRobotAtOutput && isInspectorAtOutput) {
        if (isAcceptEmpty && isBallAccepted) {
          robot.transfer($0$, $0$);
          o = Operation.TransferringOutput;
        }
        if (isRejectEmpty && !isBallAccepted) {
          robot.transfer($0$, $0$);
          o = Operation.TransferringOutput;
        }
      }
      return;
    }

    void tryFinished() {
      if (isLastBall && !isBallAtInput && isAcceptEmpty && isRejectEmpty && isRobotAtInput && isInspectorAtInput) {
        s = State.Idle;
        ctrl.finished();
      }
      return;
    }

    void manuallyRemoveStrayMaterial() {
      isBallAtInput = false;
      isAcceptEmpty = true;
      isRejectEmpty = true;
      return;
    }

    [s.Lost]
    {
      on ctrl.stop():
      {
        robot.stop();
        inspector.stop();
        feedPort.stop();
        acceptPort.stop();
        rejectPort.stop();
        s = State.Lost;
        manuallyRemoveStrayMaterial();
      }
      on ctrl.calibrate():
      {
        robot.calibrate();
        inspector.calibrate();
        feedPort.calibrate();
        calibrated = 0;
        s = State.Calibrating;
      }
      on robot.calibrated(), inspector.calibrated(), feedPort.calibrated(), feedPort.consumeNextBall(), feedPort.consumeLastBall(), inspector.prepared(), inspector.accepted(), inspector.rejected(), robot.arrived(), robot.picked(), robot.placed(), acceptPort.conveyed(), rejectPort.conveyed():
      illegal;
      on ctrl.operate():
      ignoreIllegal();
    }
    [s.Calibrating]
    {
      on ctrl.stop():
      {
        robot.stop();
        inspector.stop();
        feedPort.stop();
        acceptPort.stop();
        rejectPort.stop();
        s = State.Lost;
        manuallyRemoveStrayMaterial();
      }
      on ctrl.calibrate(), ctrl.operate():
      ignoreIllegal();
      on robot.calibrated(), inspector.calibrated(), feedPort.calibrated():
      tryCalibrated();
      on feedPort.consumeNextBall(), feedPort.consumeLastBall(), inspector.prepared(), inspector.accepted(), inspector.rejected(), robot.arrived(), robot.picked(), robot.placed(), acceptPort.conveyed(), rejectPort.conveyed():
      illegal;
    }
    [s.Idle]
    {
      on ctrl.stop():
      {
        robot.stop();
        inspector.stop();
        feedPort.stop();
        acceptPort.stop();
        rejectPort.stop();
        s = State.Lost;
        manuallyRemoveStrayMaterial();
      }
      on ctrl.calibrate():
      ignoreIllegal();
      on robot.calibrated(), inspector.calibrated(), feedPort.calibrated(), feedPort.consumeNextBall(), feedPort.consumeLastBall(), inspector.prepared(), inspector.accepted(), inspector.rejected(), robot.arrived(), robot.picked(), robot.placed(), acceptPort.conveyed(), rejectPort.conveyed():
      illegal;
      on ctrl.operate():
      startBatch();
    }
    [s.Operating]
    {
      on ctrl.stop():
      {
        robot.stop();
        inspector.stop();
        feedPort.stop();
        acceptPort.stop();
        rejectPort.stop();
        s = State.Lost;
        manuallyRemoveStrayMaterial();
      }
      on ctrl.calibrate(), ctrl.operate():
      ignoreIllegal();
      on robot.calibrated(), inspector.calibrated(), feedPort.calibrated():
      illegal;
      on feedPort.consumeNextBall():
      {
        [o.PreparingInput]
        {
          isLastBall = false;
          isBallAtInput = true;
          tryInputTransfer();
        }
        [o.TransferringInput]
        {
          isLastBall = false;
          isBallAtInput = true;
        }
        [o.PreparingOutput]
        {
          isLastBall = false;
          isBallAtInput = true;
        }
        [o.TransferringOutput]
        {
          isLastBall = false;
          isBallAtInput = true;
        }
        [o.Finalizing]
        illegal;
      }
      on feedPort.consumeLastBall():
      {
        [o.PreparingInput]
        {
          isLastBall = true;
          isBallAtInput = true;
          tryInputTransfer();
        }
        [o.TransferringInput]
        {
          isLastBall = true;
          isBallAtInput = true;
        }
        [o.PreparingOutput]
        {
          isLastBall = true;
          isBallAtInput = true;
        }
        [o.TransferringOutput]
        {
          isLastBall = true;
          isBallAtInput = true;
        }
        [o.Finalizing]
        illegal;
      }
      on inspector.prepared():
      {
        [o.PreparingInput]
        {
          isInspectorAtInput = true;
          tryInputTransfer();
        }
        [o.TransferringInput]
        illegal;
        [o.PreparingOutput]
        illegal;
        [o.TransferringOutput]
        isInspectorAtInput = true;
        [o.Finalizing]
        {
          isInspectorAtInput = true;
          tryFinished();
        }
      }
      on inspector.accepted():
      {
        [o.PreparingInput]
        illegal;
        [o.TransferringInput]
        illegal;
        [o.PreparingOutput]
        {
          isBallAccepted = true;
          isInspectorAtOutput = true;
          tryOutputTransfer();
        }
        [o.TransferringOutput]
        illegal;
        [o.Finalizing]
        illegal;
      }
      on inspector.rejected():
      {
        [o.PreparingInput]
        illegal;
        [o.TransferringInput]
        illegal;
        [o.PreparingOutput]
        {
          isBallAccepted = false;
          isInspectorAtOutput = true;
          tryOutputTransfer();
        }
        [o.TransferringOutput]
        illegal;
        [o.Finalizing]
        illegal;
      }
      on robot.arrived():
      {
        [o.PreparingInput]
        {
          isRobotAtInput = true;
          tryInputTransfer();
        }
        [o.TransferringInput]
        illegal;
        [o.PreparingOutput]
        {
          isRobotAtOutput = true;
          tryOutputTransfer();
        }
        [o.TransferringOutput]
        illegal;
        [o.Finalizing]
        {
          isRobotAtInput = true;
          tryFinished();
        }
      }
      on robot.picked():
      {
        [o.PreparingInput]
        illegal;
        [o.TransferringInput && !isLastBall]
        {
          feedPort.produceBall();
          isBallAtInput = false;
        }
        [o.TransferringInput && isLastBall]
        isBallAtInput = false;
        [o.PreparingOutput]
        illegal;
        [o.TransferringOutput]
        {
          isInspectorAtOutput = false;
          inspector.prepare();
        }
        [o.Finalizing]
        illegal;
      }
      on robot.placed():
      {
        [o.PreparingInput]
        illegal;
        [o.TransferringInput]
        {
          isInspectorAtInput = false;
          inspector.inspect();
          isRobotAtInput = false;
          robot.move($0$, $0$);
          o = Operation.PreparingOutput;
        }
        [o.PreparingOutput]
        illegal;
        [o.TransferringOutput && isBallAccepted]
        {
          isAcceptEmpty = false;
          acceptPort.convey();
          sendRobotToInputPick();
          if (isLastBall && !isBallAtInput) o = Operation.Finalizing;
          else o = Operation.PreparingInput;
        }
        [o.TransferringOutput && !isBallAccepted]
        {
          isRejectEmpty = false;
          rejectPort.convey();
          sendRobotToInputPick();
          if (isLastBall && !isBallAtInput) o = Operation.Finalizing;
          else o = Operation.PreparingInput;
        }
        [o.Finalizing]
        illegal;
      }
      on acceptPort.conveyed():
      {
        [o.PreparingInput]
        isAcceptEmpty = true;
        [o.TransferringInput]
        isAcceptEmpty = true;
        [o.PreparingOutput]
        {
          isAcceptEmpty = true;
          tryOutputTransfer();
        }
        [o.TransferringOutput]
        isAcceptEmpty = true;
        [o.Finalizing]
        {
          isAcceptEmpty = true;
          tryFinished();
        }
      }
      on rejectPort.conveyed():
      {
        [o.PreparingInput]
        isRejectEmpty = true;
        [o.TransferringInput]
        isRejectEmpty = true;
        [o.PreparingOutput]
        {
          isRejectEmpty = true;
          tryOutputTransfer();
        }
        [o.TransferringOutput]
        isRejectEmpty = true;
        [o.Finalizing]
        {
          isRejectEmpty = true;
          tryFinished();
        }
      }
    }
  }
}

