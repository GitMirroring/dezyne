// Code:

interface iq3 {
  in void e();
  out void a();

  behaviour {

    [true]
    on e:
    a;
  }
}

interface ir3 {
  in void e();
  out void a();
  out void b();

  behaviour {
    bool s = false;

    [!s]
    on e:
    {
      s = !s;
      a;
      b;
    }
    [s]
    on e:
    {
      s = !s;
      a;
      b;
    }
  }
}

component q3 {
  provides iq3 p;
  requires ir3 r;

  behaviour {

    [true]
    {
      on p.e():
      {
        p.a();
        r.e();
      }
      on r.a(), r.b():
      {}
    }
  }
}

