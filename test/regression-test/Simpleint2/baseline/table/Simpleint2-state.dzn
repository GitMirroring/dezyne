interface ISimple {
  in void e();
  out void a();

  behaviour {
    bool On = false;

    [!On]
    on e:
    On = !On;
    [On]
    on e:
    {
      a;
      On = !On;
    }
  }
}

component Simpleint2 {
  provides ISimple p;

  behaviour {
    subint S {0..1};
    S s = 0;

    [s.0]
    on p.e():
    s = 1;
    [s.1]
    on p.e():
    {
      p.a();
      s = 0;
    }
  }
}

