interface ITopon {
  in void e();
  in void t();
  out void a();

  behaviour {
    bool b = false;
    bool c = false;

    [!b]
    {
      on t:
      a;
      on e:
      {
        [!c]
        a;
        [!c]
        a;
      }
    }
    [b]
    {
      on t:
      a;
      on e:
      [!c]
      a;
    }
  }
}

component Topon {
  provides ITopon i;

  behaviour {
    bool b = false;
    bool c = false;

    [!b]
    {
      on i.t():
      i.a();
      on i.e():
      {
        [!c]
        i.a();
        [!c]
        i.a();
      }
    }
    [b]
    {
      on i.t():
      i.a();
      on i.e():
      [!c]
      i.a();
    }
  }
}

