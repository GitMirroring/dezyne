interface imultiple_provides {
  in void left();
  out void right();

  behaviour {
    bool b = false;

    on left:
    {
      [!b]
      right;
      [!b]
      b = true;
      [b]
      illegal;
    }
    on inevitable:
    [b]
    {
      b = false;
      right;
    }
  }
}

component multiple_provides {
  provides imultiple_provides p_left;
  provides imultiple_provides p_right;
  requires imultiple_provides r;

  behaviour {
    enum Direction {Left, Right};
    Direction dir = Direction.Left;
    bool b_left = false;
    bool b_right = false;

    on p_left.left():
    {
      [dir.Right || dir.Left]
      [!b_left && !b_right]
      {
        dir = Direction.Left;
        r.left();
        b_left = true;
      }
      [dir.Right || dir.Left]
      [b_left || b_right]
      {
        [b_left]
        illegal;
        [!b_left]
        p_left.right();
      }
    }
    on p_right.left():
    {
      [dir.Right || dir.Left]
      [!b_left && !b_right]
      {
        dir = Direction.Right;
        r.left();
        b_right = true;
      }
      [dir.Right || dir.Left]
      [b_left || b_right]
      {
        [b_right]
        illegal;
        [!b_right]
        p_right.right();
      }
    }
    on r.right():
    {
      [dir.Right || dir.Left]
      [!b_left && !b_right]
      illegal;
      [dir.Left]
      [b_left || b_right]
      {
        b_left = false;
        p_left.right();
      }
      [dir.Right]
      [b_left || b_right]
      {
        b_right = false;
        p_right.right();
      }
    }
  }
}

