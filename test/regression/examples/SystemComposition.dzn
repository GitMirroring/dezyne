    n30.r1 <=> b30.p;
    n30.r2 <=> b18.p;
  }
}

component SystemComposition {
  provides I p;
  requires I r;

  system {
    Split n1;
    Bot n2;
    Sys1 s1;
    Sys2 s2;
    Sys3 s3;
    p <=> n1.p;
    n1.r1 <=> s1.p;
    s1.r <=> s2.p;
    s2.r <=> r;
    n1.r2 <=> s3.p;
    s3.r <=> n2.p;
  }
}
