//purpose: Show non-trivial system composition in two layers

interface I
{
  in void evt();
  behaviour {
    on evt: {}
  }
}
component Bot {
  provides I p;
  behaviour {
    enum State { ALL };
    State s = State.ALL;
    [s.ALL] on p.evt(): { }
  }
}

component Split {
  provides I p;
  requires I r1;
  requires I r2;

  behaviour {
    enum State { ALL };
    State s = State.ALL;
    [s.ALL] on p.evt(): { r1.evt(); r2.evt(); }
  }
}

component Sys1 {
  provides I p;
  requires I r;

  system {
    Split n1;
    Split n2;
    Split n3;
    Bot b1;
    Bot b2;
    Bot b3;

    p <=> n1.p;
    n1.r1 <=> n2.p;
    n1.r2 <=> n3.p;
    n2.r1 <=> b1.p;
    n2.r2 <=> r;
    n3.r1 <=> b2.p;
    n3.r2 <=> b3.p;
  }
}
component Sys2 {
  provides I p;
  requires I r;

  system {
    Split n1;
    Split n2;
    Split n3;
    Split n4;
    Split n5;
    Split n6;
    Bot b1;
    Bot b2;
    Bot b3;
    Bot b4;
    Bot b5;
    Bot b6;

    p <=> n1.p;
    n1.r1 <=> n2.p;
    n1.r2 <=> n3.p;
    n2.r1 <=> n4.p;
    n2.r2 <=> n5.p;
    n3.r1 <=> n6.p;
    n3.r2 <=> r;
    n4.r1 <=> b1.p;
    n4.r2 <=> b2.p;
    n5.r1 <=> b3.p;
    n5.r2 <=> b4.p;
    n6.r1 <=> b5.p;
    n6.r2 <=> b6.p;
  }
}
component Sys3 {
  provides I p;
