// Commentary:
//
// Code:

//purpose: Thread synchronization by 'blocking' component.
// ===================================================================
// Marking an on event handler as 'blocking' will block the calling
// thread until an explicit thread release has been performed. Thread
// release is done by a reply() statement for the blocked port.
//
// Blocking enables the conversion of asynchronous interaction
// patterns to synchronous interaction patterns. The component
// 'MotorControl' illustrates how to provide a synchronous interface
// towards a motor with an asynchronous interface.
//
// Two implementations of a dual-axis stage illustrate the difference
// between 'blocking' interaction and asynchronous interaction. Note
// that axis motors run concurrently in both stage implementations!


component MotorControl
{
  provides IMotorSync pp;
  requires IMotorAsync rp;

  behaviour
  {
    enum State {Idle, Working, Done};
    State s = State.Idle;
    bool is_client_waiting = false;

    [s.Idle]
    {
      on pp.move(p): {rp.move(p); s = State.Working;}
      on pp.wait_arrived(): illegal;
      on rp.arrived(): illegal;
    }
    [s.Working]
    {
      on pp.move(p): illegal;
      //                    vvvvvvvv
      on pp.wait_arrived(): blocking {is_client_waiting = true;}
      //                    ^^^^^^^^
      on rp.arrived(): [is_client_waiting] {pp.reply(); is_client_waiting = false; s = State.Idle;}
      on rp.arrived(): [!is_client_waiting] {s = State.Done;}
    }
    [s.Done]
    {
      on pp.move(p): illegal;
      on pp.wait_arrived(): s = State.Idle;
      on rp.arrived(): illegal;
    }
  }
}


extern Position $Position$;


interface IMotorAsync
{
  in void move(Position p);
  out void arrived();

  behaviour
  {
    bool is_moving = false;

    on move: [!is_moving] is_moving = true;
    on move: [is_moving] illegal;

    on inevitable: [is_moving] {arrived; is_moving = false;}
  }
}


interface IMotorSync
{
  in void move(Position p);
  in void wait_arrived();
  
  behaviour
  {
    bool is_moving = false;

    [!is_moving]
    {
      on move: is_moving = true;
      on wait_arrived: illegal;
    }
    [otherwise]
    {
      on move: illegal;
      on wait_arrived: is_moving = false;
    }
  }
}


interface IStageSync
{
  in void move(Position px, Position py);
    
  behaviour
  {
    on move: {}
  }
}


component Stage2DSync
{
  provides IStageSync pp;
  requires IMotorSync x;
  requires IMotorSync y;

  behaviour
  {
    on pp.move(px, py): {x.move(px); y.move(py); x.wait_arrived(); y.wait_arrived();}
    // Note that x-motor and y-motor move concurrently.
  }
}


component StageSync
{
  provides IStageSync pp;
  requires IMotorAsync x;
  requires IMotorAsync y;
    
  system
  {
    Stage2DSync s;
    MotorControl x_motor;
    MotorControl y_motor;
        
    pp <=> s.pp;
    s.x <=> x_motor.pp;
    s.y <=> y_motor.pp;
    x_motor.rp <=> x;
    y_motor.rp <=> y;
  }
}


interface IStageAsync
{
  in void move(Position px, Position py);
  out void arrived();

  behaviour
  {
    bool is_moving = false;

    [!is_moving]
    {
      on move: is_moving = true;
    }
    [is_moving]
    {
      on move: illegal;
      on inevitable: {arrived; is_moving = false;}
    }
  }
}


component StageAsync
{
  provides IStageAsync pp;
  requires IMotorAsync x;
  requires IMotorAsync y;

  behaviour
  {
    subint Count {0..2};
    Count moving_motors = 0;

    [moving_motors == 0]
    {
      on pp.move(px, py): {x.move(px); y.move(py); moving_motors = 2;}
      on x.arrived(), y.arrived(): illegal;
    }
    [otherwise]
    {
      on pp.move(px, py): illegal;
      on x.arrived(), y.arrived(): {moving_motors = moving_motors - 1; if (moving_motors == 0) pp.arrived();}
    }
  }
}
