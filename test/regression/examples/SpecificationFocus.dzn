///////////////////////////////////////////////////////////////////////////////
// This example shows 4 different ways of specifying the same behaviour. 
// The example reflects the multiplexing of two sensors. 
// The difference in behaviour specification is determined by the focus point,
// is it state based, is it group of states or is it event based.
// Tip: Check the views for the components
///////////////////////////////////////////////////////////////////////////////

interface ISensor
{
  in void Activate();
  in void Deactivate();
  out void DetectedMovement();

  behaviour
  {
    enum States {Deactivated, Activated, Triggered};
    States state = States.Deactivated;
    [state.Deactivated]
    {
      on Activate:
        state = States.Activated;
      on Deactivate:
        illegal;
    }
    [state.Activated]
    {
      on Deactivate:
        state = States.Deactivated;
      on optional:
      {
        DetectedMovement;
        state = States.Triggered;
      }
      on Activate: 
        illegal;
    }
    [state.Triggered]
    {
      on Deactivate:
        state = States.Deactivated;
      on Activate:
        illegal;
    }
  }
}

component SpecificationFocus
{
  provides ISensor sensors;
  requires ISensor aSensor;
  requires ISensor bSensor;

  behaviour
  {
    enum States {Deactivated, Activated, Triggered};
    States state = States.Deactivated;
    [state.Deactivated]
    {
      on sensors.Activate():
      {
        aSensor.Activate();
        bSensor.Activate();
        state = States.Activated;
      }
      on sensors.Deactivate(), 
        aSensor.DetectedMovement(), 
        bSensor.DetectedMovement():
        illegal;
    }
    [state.Activated]
    { 
      on sensors.Deactivate():
      {
        aSensor.Deactivate();
        bSensor.Deactivate();
        state = States.Deactivated;
      }
      on aSensor.DetectedMovement(),
        bSensor.DetectedMovement():
      {
        sensors.DetectedMovement();
        state = States.Triggered;
      }
      on sensors.Activate():
        illegal;
    }
    [state.Triggered]
    {
      on sensors.Deactivate():
      {
        aSensor.Deactivate();
        bSensor.Deactivate();
        state = States.Deactivated;
      }
      on aSensor.DetectedMovement(),
        bSensor.DetectedMovement():
      {}
      on sensors.Activate():
        illegal;
    }
  }
}

component SpecificationFocus2
{
  provides ISensor sensors;
  requires ISensor aSensor;
  requires ISensor bSensor;

  behaviour
  {
    enum States {Deactivated, Activated, Triggered};
    States state = States.Deactivated;
    [state.Deactivated]
    {
      on sensors.Activate():
      {
        aSensor.Activate();
        bSensor.Activate();
        state = States.Activated;
      }
      on sensors.Deactivate(), 
        aSensor.DetectedMovement(), 
        bSensor.DetectedMovement():
        illegal;
    }
    [state.Activated 
     || state.Triggered]
    {
      on sensors.Deactivate():
      {
        aSensor.Deactivate();
        bSensor.Deactivate();
        state = States.Deactivated;
      }
    }  
    [state.Activated]
    { 
      on aSensor.DetectedMovement(),
        bSensor.DetectedMovement():
      {
        sensors.DetectedMovement();
        state = States.Triggered;
      }
      on sensors.Activate():
        illegal;
    }
    [state.Triggered]
    {
      on aSensor.DetectedMovement(),
        bSensor.DetectedMovement():
      {}
      on sensors.Activate():
        illegal;
    }
  }
}

component SpecificationFocus3
{
  provides ISensor sensors;
  requires ISensor aSensor;
  requires ISensor bSensor;

  behaviour
  {
    enum States {Deactivated, Activated, Triggered};
    States state = States.Deactivated;
    [state.Deactivated]
    {
      on sensors.Activate():
      {
        aSensor.Activate();
        bSensor.Activate();
        state = States.Activated;
      }
      on sensors.Deactivate(), 
        aSensor.DetectedMovement(), 
        bSensor.DetectedMovement():
        illegal;
    }
    [state.Activated 
     || state.Triggered]
    {
      on sensors.Deactivate():
      {
        aSensor.Deactivate();
        bSensor.Deactivate();
        state = States.Deactivated;
      }
    }  
    [state.Activated
     || state.Triggered] 
    { 
      on aSensor.DetectedMovement(),
        bSensor.DetectedMovement():
      {
        if (state.Activated) 
        {
          sensors.DetectedMovement();
          state = States.Triggered;
        }
      }
      on sensors.Activate():
        illegal;
    }
  }
}

component SpecificationFocus4
{
  provides ISensor sensors;
  requires ISensor aSensor;
  requires ISensor bSensor;

  behaviour
  {
    enum States {Deactivated, Activated, Triggered};
    States state = States.Deactivated;
    on sensors.Activate():
    {
      [state.Deactivated]
      {
        aSensor.Activate();
        bSensor.Activate();
        state = States.Activated;
      }
      [otherwise]
        illegal;
    }  
    on sensors.Deactivate():
    {
      [state.Activated 
       || state.Triggered]    
      {
        aSensor.Deactivate();
        bSensor.Deactivate();
        state = States.Deactivated;
      }
      [otherwise]
        illegal;
    }  
    on aSensor.DetectedMovement(), 
        bSensor.DetectedMovement():
    {
      [state.Activated]
      {
        sensors.DetectedMovement();
        state = States.Triggered;
      }
      [state.Triggered]
      {}
      [state.Deactivated]
        illegal;
    }
  }
}
