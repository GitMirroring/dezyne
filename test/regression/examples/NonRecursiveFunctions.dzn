///////////////////////////////////////////////////////////////////////////////
// This example shows the use of non recursive functions to specify behaviour.
///////////////////////////////////////////////////////////////////////////////

// This is an interface specification which states that event "e" triggers
// action "h"
interface I
{
  in void e();
  out void h();

  behaviour
  {
    on e: h;
  }
}

// This is a component specification for a component which implements interface "I"
component NonRecursiveFunctions
{
  provides I i;

  behaviour
  {
    bool b = true;

    void f()
    {
      g();
      i.h();
    }
    void g()
    {
      b = false;
    }
    // Event "e" triggers the execution of function "f" which in its turn
    // triggers the execution of function "g" and the triggering of action "h"
    on i.e():
    {
      f();
      // This line would reveal an illegal behaviour if function "f"
      // would not execute correctly
      if(b){ illegal; }
    }
  }
}
