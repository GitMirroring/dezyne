// Code:

// purpose: Show how to model two parallel state-machines
// The following interface contains two parallel state-machines.
// The events "left" and "right" interact with the state-machine for the x-axis.
// The events "up" and "down" interact with the state-machine for the y-axis.
// The event "center" interacts with both state-machines.

interface I {
	in void left();
	in void right();
	in void up();
	in void down();
	in void center();
	
	behaviour {
		enum PosX { Left, Middle, Right };
		enum PosY { Bottom, Middle, Top };
		
		PosX x = PosX.Left;
		PosY y = PosY.Bottom;
		
		// state-machine for x-axis
		[x.Left] {
			on left:	illegal;
			on right:   x = PosX.Middle;
		}
		[x.Middle] { 	
			on left:	x = PosX.Left;
			on right:   x = PosX.Right;
		}
		[x.Right] { 	
			on left:   	x = PosX.Middle;
			on right: 	illegal;
		}
		
		// state-machine for y-axis
		[y.Bottom]{
			on down: 	illegal;
			on up: 		y = PosY.Middle;
		}
		[y.Middle] {
			on down: 	y = PosY.Bottom;
			on up:		y = PosY.Top;
		}
		[y.Top] {
			on down: 	y = PosY.Middle;
			on up:		illegal;
		}
		
		// interacts on both state-machine
		on center: {
			x = PosX.Middle;
			y = PosY.Middle;
		}
	}
}

// The same approach as for the previous interface
// but now with event leading instead of state leading.
interface I_ {
	in void left();
	in void right();
	in void down();
	in void up();
	in void center();
	
	behaviour {
		enum PosX { Left, Middle, Right };
		enum PosY { Bottom, Middle, Top };
		
		PosX x = PosX.Left;
		PosY y = PosY.Bottom;
		
		on left: {
			[x.Left]	illegal;
			[x.Middle] 	x = PosX.Left;
			[x.Right] 	x = PosX.Middle;
		}
		on right: {
			[x.Left]	x = PosX.Middle;
			[x.Middle] 	x = PosX.Right;
			[x.Right] 	illegal;
		}
		
		on down: {
			[y.Bottom]	illegal;
			[y.Middle] 	y = PosY.Bottom;
			[y.Top] 	y = PosY.Middle;
		}
		on up: {
			[y.Bottom]	y = PosY.Middle;
			[y.Middle] 	y = PosY.Top;
			[y.Top] 	illegal;
		}
		
		on center: {
			x = PosX.Middle;
			y = PosY.Middle;
		}
	}
}



