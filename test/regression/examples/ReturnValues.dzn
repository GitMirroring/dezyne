///////////////////////////////////////////////////////////////////////////////
// This example shows definition and usage of return values.
///////////////////////////////////////////////////////////////////////////////

enum result_t {
   OK,
   NOK
};


interface IDevice {

    in result_t initialize();
    in result_t calibrate();
    in result_t perform_action1();
    in result_t perform_action2();

    behaviour {
        enum State {
            Uninitialized,
            Initialized,
            Calibrated
        };
        State s = State.Uninitialized;

        [s.Uninitialized] {
            on initialize: {
                [true] { reply(result_t.OK);   s = State.Initialized;   }
                [true] { reply(result_t.NOK);                           }
            }
            on calibrate,
               perform_action1,
               perform_action2:
                illegal;
        }
        [s.Initialized] {
            on calibrate: {
                [true] { reply(result_t.OK);    s = State.Calibrated;  }
                [true] { reply(result_t.NOK);                          }
            }
            on initialize:
                reply(result_t.OK);
            on perform_action1,
               perform_action2:
                illegal;
        }
        [s.Calibrated] {
            on perform_action1,
               perform_action2: {
                [true] { reply(result_t.OK);                           }
                [true] { reply(result_t.NOK);   s = State.Initialized; }
            }
            on calibrate:
                reply(result_t.OK);
            on initialize:
                reply(result_t.OK);
        }

    }
}

interface IComp {
    in result_t initialize();
    in result_t recover();
    in result_t perform_actions();

    behaviour {
        enum State {
            Uninitialized,
            Initialized,
            Error
        };
        State s = State.Uninitialized;

        [s.Uninitialized] {
            on initialize: {
                [true] { reply(result_t.OK);    s = State.Initialized;   }
                [true] { reply(result_t.NOK);                            }
            }
            on recover,
               perform_actions:
                illegal;
        }
        [s.Initialized] {
            on perform_actions: {
                [true] { reply(result_t.OK);                     }
                [true] { reply(result_t.NOK);   s = State.Error; }
            }
            on initialize,
               recover:
                 illegal;
        }
        [s.Error] {
            on recover: {
                [true] { reply(result_t.OK);  s = State.Initialized; }
                [true] { reply(result_t.NOK);                        }
            }
            on initialize,
               perform_actions:
                 illegal;
        }
    }
}

component ReturnValues {
    provides IComp client;
    requires IDevice device_A;
    requires IDevice device_B;

    behaviour {
        enum State {
            Uninitialized,
            Initialized,
            Error
        };
        State s = State.Uninitialized;

        [s.Uninitialized] {
            on client.initialize(): {
                result_t res = device_A.initialize();
                if (res.OK) {
                    res = device_B.initialize();
                }
                if (res.OK) {
                    res = device_A.calibrate();
                }
                if (res.OK) {
                    res = device_B.calibrate();
                }

                if (res.OK) {
                    reply(result_t.OK);
                    s = State.Initialized;
                } else {
                    reply(result_t.NOK);
                }
            }
            on client.recover,
               client.perform_actions:
                 illegal;
        }
        [s.Initialized] {
            on client.perform_actions(): {
                result_t res = device_A.perform_action1();
                if (res.OK) {
                    res = device_B.perform_action1();
                }
                if (res.OK) {
                    res = device_A.perform_action2();
                }
                if (res.OK) {
                    res = device_B.perform_action2();
                }

                if (res.OK) {
                    reply(result_t.OK);
                } else {
                    reply(result_t.NOK);
                    s = State.Error;
                }
            }
            on client.initialize,
               client.recover:
                    illegal;
        }
        [s.Error] {
            on client.recover(): {
                result_t res = device_A.calibrate();
                if (res.OK) {
                    res = device_B.calibrate();
                }

                if (res.OK) {
                    reply(result_t.OK);
                    s = State.Initialized;
                } else {
                    reply(result_t.NOK);
                }
            }
            on client.initialize,
               client.perform_actions:
                    illegal;
        }
    }
}

component Device
{
  provides IDevice i;
  behaviour
    {
      enum State {
        Uninitialized,
        Initialized,
        Calibrated
      };

      State s = State.Uninitialized;
      on i.initialize(): {
        [s.Uninitialized] { reply(result_t.OK); s = State.Initialized; }
        [otherwise] reply(result_t.OK);
      }
      on i.calibrate(): {
        [!s.Uninitialized] { reply(result_t.OK); s = State.Calibrated;  }
        [otherwise] illegal;
      }
      on i.perform_action1(): {
        [s.Calibrated] { reply(result_t.OK); }
        [otherwise] illegal;
      }
      on i.perform_action2(): {
        [s.Calibrated] { reply(result_t.NOK); s = State.Initialized; }
        [otherwise] illegal;
      }
    }
}

component TwoDevices 
{
  provides IComp client;
  system 
  {
    ReturnValues rv;
    Device deviceA;
    Device deviceB;
    
    client <=> rv.client;
    rv.device_A <=> deviceA.i;
    rv.device_B <=> deviceB.i;
  }
  
}
