interface LimitSwitchIF {
  enum Position {Opened, Closed, Unknown};
  in void doorOpening();
  in void doorClosing();
  in void doorStopped();
  out void doorOpened();
  out void doorClosed();
  out void proximityWarning();
  in Position queryPosition();
  in void initialise();

  behaviour {
    enum DoorState {Uninitialized, Opening, Closing, Idle};
    DoorState door = DoorState.Uninitialized;
    Position state = Position.Unknown;

    [door.Uninitialized]
    {
      on initialise:
      door = DoorState.Idle;
      on doorOpening, doorClosing, doorStopped, queryPosition:
      illegal;
    }
    [door.Opening]
    {
      on initialise, doorOpening, doorClosing:
      illegal;
      on doorStopped:
      door = DoorState.Idle;
      on queryPosition:
      reply(state);
      on inevitable:
      {
        [true]
        {
          doorOpened;
          state = Position.Opened;
          door = DoorState.Idle;
        }
        [true]
        state = Position.Unknown;
      }
    }
    [door.Closing]
    {
      on initialise, doorOpening, doorClosing:
      illegal;
      on doorStopped:
      door = DoorState.Idle;
      on queryPosition:
      reply(state);
      on inevitable:
      {
        [true]
        {
          doorClosed;
          state = Position.Closed;
          door = DoorState.Idle;
        }
        [state.Opened]
        state = Position.Unknown;
      }
      on optional:
      proximityWarning;
    }
    [door.Idle]
    {
      on initialise, doorStopped:
      illegal;
      on doorOpening:
      door = DoorState.Opening;
      on doorClosing:
      door = DoorState.Closing;
      on queryPosition:
      reply(state);
    }
  }
}

interface MotorControlIF {
  in void initialise();
  in void start();
  in void stop();
  in void setOpen();
  in void setClose();
  out void driveFault();
  out void powerWarning();

  behaviour {
    enum State {NotReady, Ready};
    enum OnOff {MotorOn, MotorOff};
    enum Direction {DoorOpen, DoorClose};
    OnOff motor = OnOff.MotorOff;
    Direction dir = Direction.DoorOpen;
    State state = State.NotReady;

    [motor.MotorOn]
    {
      on start, setOpen, setClose:
      {
        [state.Ready]
        illegal;
        [state.NotReady]
        illegal;
      }
      on stop:
      {
        [state.Ready]
        motor = OnOff.MotorOff;
        [state.NotReady]
        illegal;
      }
      on optional:
      {
        [state.Ready]
        {
          driveFault;
          motor = OnOff.MotorOff;
        }
        [state.Ready]
        powerWarning;
      }
      on initialise:
      {
        [state.Ready]
        illegal;
        [state.NotReady]
        {
          state = State.Ready;
          motor = OnOff.MotorOff;
        }
      }
    }
    [motor.MotorOff]
    {
      on start:
      {
        [state.Ready]
        motor = OnOff.MotorOn;
        [state.NotReady]
        illegal;
      }
      on setOpen:
      {
        [state.Ready]
        dir = Direction.DoorOpen;
        [state.NotReady]
        illegal;
      }
      on setClose:
      {
        [state.Ready]
        dir = Direction.DoorClose;
        [state.NotReady]
        illegal;
      }
      on stop:
      {
        [state.Ready]
        illegal;
        [state.NotReady]
        illegal;
      }
      on initialise:
      {
        [state.Ready]
        illegal;
        [state.NotReady]
        {
          state = State.Ready;
          motor = OnOff.MotorOff;
        }
      }
    }
  }
}

interface SwitchPressIF {
  out void switchPressed();
  in void acknowledge();

  behaviour {
    enum State {Ready, NotReady};
    State state = State.Ready;

    [state.Ready]
    {
      on inevitable:
      {
        switchPressed;
        state = State.NotReady;
      }
      on acknowledge:
      illegal;
    }
    [state.NotReady]
    on acknowledge:
    state = State.Ready;
  }
}

interface ITimer {
  extern double $double$;
  extern long $long$;
  in void CreateTimer(double t);
  in void CreateTimerEx(long tsec, long tnsec);
  in void CreateTimerMSec(long tmsec);
  in void CancelTimer();
  out void Timeout();

  behaviour {
    enum States {Inactive, Active};
    States state = States.Inactive;

    [state.Inactive]
    {
      on CancelTimer:
      state = States.Inactive;
      on CreateTimer, CreateTimerEx, CreateTimerMSec:
      state = States.Active;
    }
    [state.Active]
    {
      on CancelTimer:
      state = States.Inactive;
      on CreateTimer, CreateTimerEx, CreateTimerMSec:
      illegal;
      on inevitable:
      {
        Timeout;
        state = States.Inactive;
      }
    }
  }
}

interface DoorControlIF {
  in void initialise();
  in void reset();
  out void warning();
  out void error();

  behaviour {
    enum State {NotReady, Ready, Error};
    State state = State.NotReady;

    [state.NotReady]
    {
      on initialise:
      state = State.Ready;
      on reset:
      illegal;
    }
    [state.Ready]
    {
      on initialise, reset:
      illegal;
      on inevitable:
      {
        [true]
        warning;
        [true]
        {
          error;
          state = State.Error;
        }
      }
    }
    [state.Error]
    {
      on initialise:
      illegal;
      on reset:
      state = State.Ready;
    }
  }
}

component GarageDoorControl {
  provides DoorControlIF doorControl;
  requires SwitchPressIF switchPress;
  requires MotorControlIF motorControl;
  requires LimitSwitchIF limitSw;
  requires ITimer timer;

  behaviour {
    enum State {NotReady, Ready, Opening, Closing, Error};
    State state = State.NotReady;
    bool secondSwitchPress = false;
    LimitSwitchIF.Position position = LimitSwitchIF.Position.Unknown;

    void switchPressCheck() {
      if (!secondSwitchPress) {
        timer.CreateTimerMSec($500$);
        motorControl.stop();
        limitSw.doorStopped();
        secondSwitchPress = true;
      }
      else {
        timer.CancelTimer();
        state = State.Ready;
        secondSwitchPress = false;
      }
      return;
    }

    [state.NotReady]
    {
      on doorControl.initialise():
      {
        limitSw.initialise();
        motorControl.initialise();
        state = State.Ready;
      }
      on doorControl.reset(), timer.Timeout(), limitSw.doorClosed(), limitSw.doorOpened(), limitSw.proximityWarning():
      illegal;
      on switchPress.switchPressed():
      switchPress.acknowledge();
      on motorControl.powerWarning():
      doorControl.warning();
      on motorControl.driveFault():
      {
        limitSw.doorStopped();
        timer.CancelTimer();
        doorControl.error();
        state = State.Error;
      }
    }
    [state.Ready]
    {
      on doorControl.initialise(), doorControl.reset(), timer.Timeout(), limitSw.doorClosed(), limitSw.doorOpened(), limitSw.proximityWarning():
      illegal;
      on switchPress.switchPressed():
      {
        switchPress.acknowledge();
        secondSwitchPress = false;
        position = limitSw.queryPosition();
        if (position == LimitSwitchIF.Position.Opened) {
          motorControl.setClose();
          motorControl.start();
          limitSw.doorClosing();
          state = State.Closing;
        }
        else if (position == LimitSwitchIF.Position.Closed || position == LimitSwitchIF.Position.Unknown) {
          motorControl.setOpen();
          motorControl.start();
          limitSw.doorOpening();
          state = State.Opening;
        }
      }
      on motorControl.powerWarning():
      doorControl.warning();
      on motorControl.driveFault():
      {
        limitSw.doorStopped();
        timer.CancelTimer();
        doorControl.error();
        state = State.Error;
      }
    }
    [state.Opening]
    {
      on doorControl.initialise(), doorControl.reset(), limitSw.doorClosed(), limitSw.proximityWarning():
      illegal;
      on switchPress.switchPressed():
      {
        switchPress.acknowledge();
        switchPressCheck();
      }
      on timer.Timeout():
      {
        secondSwitchPress = false;
        motorControl.setClose();
        motorControl.start();
        limitSw.doorClosing();
        state = State.Closing;
      }
      on limitSw.doorOpened():
      {
        motorControl.stop();
        state = State.Ready;
        timer.CancelTimer();
      }
      on motorControl.powerWarning():
      doorControl.warning();
      on motorControl.driveFault():
      {
        limitSw.doorStopped();
        timer.CancelTimer();
        doorControl.error();
        state = State.Error;
      }
    }
    [state.Closing]
    {
      on doorControl.initialise(), doorControl.reset(), limitSw.doorOpened():
      illegal;
      on switchPress.switchPressed():
      {
        switchPress.acknowledge();
        switchPressCheck();
      }
      on timer.Timeout():
      {
        secondSwitchPress = false;
        motorControl.setOpen();
        motorControl.start();
        limitSw.doorOpening();
        state = State.Opening;
      }
      on limitSw.doorClosed():
      {
        motorControl.stop();
        state = State.Ready;
      }
      on limitSw.proximityWarning():
      {
        motorControl.stop();
        limitSw.doorStopped();
        motorControl.setOpen();
        motorControl.start();
        limitSw.doorOpening();
        state = State.Opening;
      }
      on motorControl.powerWarning():
      doorControl.warning();
      on motorControl.driveFault():
      {
        limitSw.doorStopped();
        timer.CancelTimer();
        doorControl.error();
        state = State.Error;
      }
    }
    [state.Error]
    {
      on doorControl.initialise(), timer.Timeout():
      illegal;
      on doorControl.reset():
      state = State.Ready;
      on switchPress.switchPressed():
      switchPress.acknowledge();
      on limitSw.doorClosed(), limitSw.doorOpened(), limitSw.proximityWarning():
      {}
      on motorControl.powerWarning():
      doorControl.warning();
      on motorControl.driveFault():
      {
        limitSw.doorStopped();
        timer.CancelTimer();
        doorControl.error();
        state = State.Error;
      }
    }
  }
}

