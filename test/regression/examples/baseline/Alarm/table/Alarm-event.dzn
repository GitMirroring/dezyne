interface IConsole {
  in void arm();
  in void disarm();
  out void detected();
  out void deactivated();

  behaviour {
    enum State {Disarmed, Armed, Triggered, Disarming};
    State state = State.Disarmed;

    on arm:
    {
      [state.Disarmed]
      state = State.Armed;
      [state.Disarming || state.Triggered || state.Armed]
      illegal;
    }
    on disarm:
    {
      [state.Disarming || state.Disarmed]
      illegal;
      [state.Triggered || state.Armed]
      state = State.Disarming;
    }
    on optional:
    [state.Armed]
    {
      detected;
      state = State.Triggered;
    }
    on inevitable:
    [state.Disarming]
    {
      deactivated;
      state = State.Disarmed;
    }
  }
}

interface ISensor {
  in void enable();
  in void disable();
  out void triggered();
  out void disabled();

  behaviour {
    enum State {Disabled, Enabled, Disabling, Triggered};
    State state = State.Disabled;

    on enable:
    {
      [state.Disabled]
      state = State.Enabled;
      [state.Triggered || state.Disabling || state.Enabled]
      illegal;
    }
    on disable:
    {
      [state.Disabling || state.Disabled]
      illegal;
      [state.Triggered || state.Enabled]
      state = State.Disabling;
    }
    on optional:
    [state.Enabled]
    {
      triggered;
      state = State.Triggered;
    }
    on inevitable:
    [state.Disabling]
    {
      disabled;
      state = State.Disabled;
    }
  }
}

interface ISiren {
  in void turnon();
  in void turnoff();

  behaviour {
    enum State {Off, On};
    State state = State.Off;

    on turnon:
    {
      [state.Off]
      state = State.On;
      [state.On]
      illegal;
    }
    on turnoff:
    {
      [state.Off]
      illegal;
      [state.On]
      state = State.Off;
    }
  }
}

component Alarm {
  provides IConsole console;
  requires ISensor sensor;
  requires ISiren siren;

  behaviour {
    enum State {Disarmed, Armed, Triggered, Disarming};
    State state = State.Disarmed;
    bool sounding = false;

    on console.arm():
    {
      [state.Disarmed]
      {
        sensor.enable();
        state = State.Armed;
      }
      [state.Disarming || state.Triggered || state.Armed]
      illegal;
    }
    on console.disarm():
    {
      [state.Disarming || state.Disarmed]
      illegal;
      [state.Armed]
      {
        sensor.disable();
        state = State.Disarming;
      }
      [state.Triggered]
      {
        sensor.disable();
        sounding = false;
        state = State.Disarming;
      }
    }
    on sensor.triggered():
    {
      [state.Disarming || state.Triggered || state.Disarmed]
      illegal;
      [state.Armed]
      {
        console.detected();
        siren.turnon();
        sounding = true;
        state = State.Triggered;
      }
    }
    on sensor.disabled():
    {
      [state.Triggered || state.Armed || state.Disarmed]
      illegal;
      [state.Disarming]
      {
        [sounding]
        {
          console.deactivated();
          sounding = false;
          state = State.Disarmed;
        }
        [otherwise]
        {
          console.deactivated();
          state = State.Disarmed;
        }
      }
    }
  }
}

