interface Device1IF {
  in void turnon();
  in void turnoff();
  out void ok();
  out void nok();

  behaviour {
    enum State {Off, GoingOn, On};
    State state = State.Off;

    on turnon:
    {
      [state.Off]
      state = State.GoingOn;
      [state.On || state.GoingOn]
      illegal;
    }
    on turnoff:
    {
      [state.GoingOn || state.Off]
      illegal;
      [state.On]
      state = State.Off;
    }
    on inevitable:
    {
      [state.GoingOn]
      {
        ok;
        state = State.On;
      }
      [state.GoingOn]
      {
        nok;
        state = State.Off;
      }
    }
  }
}

interface Device2IF {
  enum Result {OK, NOK};
  in Result turnon();
  in void turnoff();

  behaviour {
    enum State {Off, On};
    State state = State.Off;

    on turnon:
    {
      [state.Off]
      {
        reply(Result.OK);
        state = State.On;
      }
      [state.Off]
      reply(Result.NOK);
      [state.On]
      illegal;
    }
    on turnoff:
    {
      [state.Off]
      illegal;
      [state.On]
      state = State.Off;
    }
  }
}

interface StartControlIF {
  enum Result {OK, NOK};
  in void startAll();
  in void stopAll();
  out void allStarted();
  out void startFailed();

  behaviour {
    enum States {Idle, Starting, Started};
    States state = States.Idle;

    on startAll:
    {
      [state.Idle]
      state = States.Starting;
      [state.Started || state.Starting]
      illegal;
    }
    on stopAll:
    {
      [state.Starting || state.Idle]
      illegal;
      [state.Started]
      state = States.Idle;
    }
    on inevitable:
    {
      [state.Starting]
      {
        state = States.Idle;
        startFailed;
      }
      [state.Starting]
      {
        state = States.Started;
        allStarted;
      }
    }
  }
}

component StartDevices {
  provides StartControlIF startIF;
  requires Device1IF device1IF;
  requires Device2IF device2IF;

  behaviour {
    subint Count {0..5};
    enum States {Idle, Starting, Started};
    Device2IF.Result result2 = Device2IF.Result.NOK;
    States state = States.Idle;
    Count count = 0;

    on startIF.startAll():
    {
      [result2.NOK || result2.OK]
      [state.Idle]
      {
        count = 0;
        state = States.Starting;
        device1IF.turnon();
      }
      [result2.NOK || result2.OK]
      [state.Starting]
      illegal;
      [result2.NOK || result2.OK]
      [state.Started]
      illegal;
    }
    on device1IF.ok():
    {
      [result2.NOK || result2.OK]
      [state.Idle]
      illegal;
      [result2.OK]
      [state.Starting]
      {
        result2 = device2IF.turnon();
        state = States.Started;
        startIF.allStarted();
      }
      [result2.NOK || result2.OK]
      [state.Started]
      illegal;
      [result2.NOK]
      [state.Starting]
      {
        result2 = device2IF.turnon();
        state = States.Idle;
        startIF.startFailed();
      }
    }
    on device1IF.nok():
    {
      [result2.NOK || result2.OK]
      [state.Idle]
      illegal;
      [result2.NOK || result2.OK]
      [state.Starting]
      if (count < 5) {
        count = count + 1;
        device1IF.turnon();
      }
      else {
        state = States.Idle;
        startIF.startFailed();
      }
      [result2.NOK || result2.OK]
      [state.Started]
      illegal;
    }
    on startIF.stopAll():
    {
      [result2.NOK || result2.OK]
      [state.Idle]
      illegal;
      [result2.NOK || result2.OK]
      [state.Starting]
      illegal;
      [result2.NOK || result2.OK]
      [state.Started]
      {
        device1IF.turnoff();
        device2IF.turnoff();
        state = States.Idle;
      }
    }
  }
}

