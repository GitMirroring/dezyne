interface Device1IF {
  in void turnon();
  in void turnoff();
  out void ok();
  out void nok();

  behaviour {
    enum State {Off, GoingOn, On};
    State state = State.Off;

    [state.Off]
    {
      on turnon:
      state = State.GoingOn;
      on turnoff:
      illegal;
    }
    [state.GoingOn]
    {
      on turnon, turnoff:
      illegal;
      on inevitable:
      {
        [true]
        {
          ok;
          state = State.On;
        }
        [true]
        {
          nok;
          state = State.Off;
        }
      }
    }
    [state.On]
    {
      on turnon:
      illegal;
      on turnoff:
      state = State.Off;
    }
  }
}

interface Device2IF {
  enum Result {OK, NOK};
  in Result turnon();
  in void turnoff();

  behaviour {
    enum State {Off, On};
    State state = State.Off;

    [state.Off]
    {
      on turnon:
      {
        [true]
        {
          reply(Result.OK);
          state = State.On;
        }
        [true]
        reply(Result.NOK);
      }
      on turnoff:
      illegal;
    }
    [state.On]
    {
      on turnon:
      illegal;
      on turnoff:
      state = State.Off;
    }
  }
}

interface StartControlIF {
  enum Result {OK, NOK};
  in void startAll();
  in void stopAll();
  out void allStarted();
  out void startFailed();

  behaviour {
    enum States {Idle, Starting, Started};
    States state = States.Idle;

    [state.Idle]
    {
      on startAll:
      state = States.Starting;
      on stopAll:
      illegal;
    }
    [state.Starting]
    {
      on startAll, stopAll:
      illegal;
      on inevitable:
      {
        [true]
        {
          state = States.Idle;
          startFailed;
        }
        [true]
        {
          state = States.Started;
          allStarted;
        }
      }
    }
    [state.Started]
    {
      on startAll:
      illegal;
      on stopAll:
      state = States.Idle;
    }
  }
}

component StartDevices {
  provides StartControlIF startIF;
  requires Device1IF device1IF;
  requires Device2IF device2IF;

  behaviour {
    subint Count {0..5};
    enum States {Idle, Starting, Started};
    Device2IF.Result result2 = Device2IF.Result.NOK;
    States state = States.Idle;
    Count count = 0;

    [result2.OK]
    {
      on startIF.startAll():
      {
        [state.Idle]
        {
          count = 0;
          state = States.Starting;
          device1IF.turnon();
        }
        [state.Started || state.Starting]
        illegal;
      }
      on device1IF.ok():
      {
        [state.Started || state.Idle]
        illegal;
        [state.Starting]
        {
          result2 = device2IF.turnon();
          state = States.Started;
          startIF.allStarted();
        }
      }
      on device1IF.nok():
      {
        [state.Started || state.Idle]
        illegal;
        [state.Starting]
        if (count < 5) {
          count = count + 1;
          device1IF.turnon();
        }
        else {
          state = States.Idle;
          startIF.startFailed();
        }
      }
      on startIF.stopAll():
      {
        [state.Starting || state.Idle]
        illegal;
        [state.Started]
        {
          device1IF.turnoff();
          device2IF.turnoff();
          state = States.Idle;
        }
      }
    }
    [result2.NOK]
    {
      on startIF.startAll():
      {
        [state.Idle]
        {
          count = 0;
          state = States.Starting;
          device1IF.turnon();
        }
        [state.Started || state.Starting]
        illegal;
      }
      on device1IF.ok():
      {
        [state.Started || state.Idle]
        illegal;
        [state.Starting]
        {
          result2 = device2IF.turnon();
          state = States.Idle;
          startIF.startFailed();
        }
      }
      on device1IF.nok():
      {
        [state.Started || state.Idle]
        illegal;
        [state.Starting]
        if (count < 5) {
          count = count + 1;
          device1IF.turnon();
        }
        else {
          state = States.Idle;
          startIF.startFailed();
        }
      }
      on startIF.stopAll():
      {
        [state.Starting || state.Idle]
        illegal;
        [state.Started]
        {
          device1IF.turnoff();
          device2IF.turnoff();
          state = States.Idle;
        }
      }
    }
  }
}

