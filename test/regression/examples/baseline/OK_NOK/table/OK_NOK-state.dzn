enum result_t {OK, NOK};

interface IDevice {
  in result_t initialise();
  in result_t calibrate();
  in result_t perform_action1();
  in result_t perform_action2();

  behaviour {
    enum State {Uninitialised, Initialised, Calibrated};
    State s = State.Uninitialised;

    [s.Uninitialised]
    {
      on initialise:
      {
        [true]
        {
          reply(result_t.OK);
          s = State.Initialised;
        }
        [true]
        reply(result_t.NOK);
      }
      on calibrate, perform_action1, perform_action2:
      illegal;
    }
    [s.Initialised]
    {
      on initialise:
      reply(result_t.OK);
      on calibrate:
      {
        [true]
        {
          reply(result_t.OK);
          s = State.Calibrated;
        }
        [true]
        reply(result_t.NOK);
      }
      on perform_action1, perform_action2:
      illegal;
    }
    [s.Calibrated]
    {
      on initialise, calibrate:
      reply(result_t.OK);
      on perform_action1, perform_action2:
      {
        [true]
        reply(result_t.OK);
        [true]
        {
          reply(result_t.NOK);
          s = State.Initialised;
        }
      }
    }
  }
}

interface IComp {
  in result_t initialise();
  in result_t recover();
  in result_t perform_actions();

  behaviour {
    enum State {Uninitialised, Initialised, Error};
    State s = State.Uninitialised;

    [s.Uninitialised]
    {
      on initialise:
      {
        [true]
        {
          reply(result_t.OK);
          s = State.Initialised;
        }
        [true]
        reply(result_t.NOK);
      }
      on recover, perform_actions:
      illegal;
    }
    [s.Initialised]
    {
      on initialise, recover:
      illegal;
      on perform_actions:
      {
        [true]
        reply(result_t.OK);
        [true]
        {
          reply(result_t.NOK);
          s = State.Error;
        }
      }
    }
    [s.Error]
    {
      on initialise, perform_actions:
      illegal;
      on recover:
      {
        [true]
        {
          reply(result_t.OK);
          s = State.Initialised;
        }
        [true]
        reply(result_t.NOK);
      }
    }
  }
}

component OK_NOK {
  provides IComp client;
  requires IDevice device_A;
  requires IDevice device_B;

  behaviour {
    enum State {Uninitialised, Initialised, Error};
    State s = State.Uninitialised;

    [s.Uninitialised]
    {
      on client.initialise():
      {
        result_t res = device_A.initialise();
        if (res.OK) res = device_B.initialise();
        if (res.OK) res = device_A.calibrate();
        if (res.OK) res = device_B.calibrate();
        if (res.OK) {
          reply(result_t.OK);
          s = State.Initialised;
        }
        else reply(result_t.NOK);
      }
      on client.recover(), client.perform_actions():
      illegal;
    }
    [s.Initialised]
    {
      on client.initialise(), client.recover():
      illegal;
      on client.perform_actions():
      {
        result_t res = device_A.perform_action1();
        if (res.OK) res = device_B.perform_action1();
        if (res.OK) res = device_A.perform_action2();
        if (res.OK) res = device_B.perform_action2();
        if (res.OK) reply(result_t.OK);
        else {
          reply(result_t.NOK);
          s = State.Error;
        }
      }
    }
    [s.Error]
    {
      on client.initialise(), client.perform_actions():
      illegal;
      on client.recover():
      {
        result_t res = device_A.calibrate();
        if (res.OK) res = device_B.calibrate();
        if (res.OK) {
          reply(result_t.OK);
          s = State.Initialised;
        }
        else reply(result_t.NOK);
      }
    }
  }
}

component Device {
  provides IDevice i;

  behaviour {
    enum State {Uninitialised, Initialised, Calibrated};
    State s = State.Uninitialised;

    [s.Uninitialised]
    {
      on i.initialise():
      {
        reply(result_t.OK);
        s = State.Initialised;
      }
      on i.calibrate(), i.perform_action1(), i.perform_action2():
      illegal;
    }
    [s.Initialised]
    {
      on i.initialise():
      reply(result_t.OK);
      on i.calibrate():
      {
        reply(result_t.OK);
        s = State.Calibrated;
      }
      on i.perform_action1(), i.perform_action2():
      illegal;
    }
    [s.Calibrated]
    {
      on i.initialise(), i.perform_action1():
      reply(result_t.OK);
      on i.calibrate():
      {
        reply(result_t.OK);
        s = State.Calibrated;
      }
      on i.perform_action2():
      {
        reply(result_t.NOK);
        s = State.Initialised;
      }
    }
  }
}

component TwoDevices {
  provides IComp client;

  system {
    nameOK_NOK rv;
    nameDevice deviceA;
    nameDevice deviceB;

    client <=> rv.client;
    rv.device_A <=> deviceA.i;
    rv.device_B <=> deviceB.i;
  }
}

