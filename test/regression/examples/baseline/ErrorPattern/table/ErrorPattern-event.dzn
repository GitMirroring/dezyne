interface IDevice {
  in void initialize();
  in void open();
  in void close();
  in void terminate();
  out void error();

  behaviour {
    enum State {Uninitialized, Closed, Open, Error};
    State s = State.Uninitialized;

    on initialize:
    {
      [s.Uninitialized]
      s = State.Closed;
      [s.Error || s.Open || s.Closed]
      illegal;
    }
    on open:
    {
      [s.Open || s.Uninitialized]
      illegal;
      [s.Closed]
      s = State.Open;
      [s.Error]
      {}
    }
    on close:
    {
      [s.Closed || s.Uninitialized]
      illegal;
      [s.Open]
      s = State.Closed;
      [s.Error]
      {}
    }
    on terminate:
    {
      [s.Error || s.Open || s.Closed || s.Uninitialized]
      s = State.Uninitialized;
    }
    on optional:
    {
      [s.Open || s.Closed]
      {
        s = State.Error;
        error;
      }
    }
  }
}

component Component {
  provides IDevice p;
  requires IDevice a;
  requires IDevice b;

  behaviour {
    enum State {Uninitialized, Closed, Open, Error};
    State s = State.Uninitialized;

    on p.initialize():
    {
      [s.Uninitialized]
      {
        s = State.Closed;
        a.initialize();
        b.initialize();
      }
      [s.Error || s.Open || s.Closed]
      illegal;
    }
    on p.open():
    {
      [s.Open || s.Uninitialized]
      illegal;
      [s.Closed]
      {
        s = State.Open;
        a.open();
        b.open();
      }
      [s.Error]
      {}
    }
    on p.close():
    {
      [s.Closed || s.Uninitialized]
      illegal;
      [s.Open]
      {
        s = State.Closed;
        a.close();
        b.close();
      }
      [s.Error]
      {}
    }
    on a.error():
    {
      [s.Uninitialized]
      illegal;
      [s.Open || s.Closed]
      {
        s = State.Error;
        p.error();
      }
      [s.Error]
      {}
    }
    on b.error():
    {
      [s.Uninitialized]
      illegal;
      [s.Open || s.Closed]
      {
        s = State.Error;
        p.error();
      }
      [s.Error]
      {}
    }
    on p.terminate():
    {
      [s.Error || s.Open || s.Closed || s.Uninitialized]
      {
        s = State.Uninitialized;
        a.terminate();
        b.terminate();
      }
    }
  }
}

