interface IDevice {
  in void initialize();
  in void open();
  in void close();
  in void terminate();
  out void error();

  behaviour {
    enum State {Uninitialized, Closed, Open, Error};
    State s = State.Uninitialized;

    [s.Uninitialized]
    {
      on initialize:
      s = State.Closed;
      on open, close:
      illegal;
      on terminate:
      s = State.Uninitialized;
    }
    [s.Closed]
    {
      on initialize, close:
      illegal;
      on open:
      s = State.Open;
      on optional:
      {
        s = State.Error;
        error;
      }
      on terminate:
      s = State.Uninitialized;
    }
    [s.Open]
    {
      on initialize, open:
      illegal;
      on close:
      s = State.Closed;
      on optional:
      {
        s = State.Error;
        error;
      }
      on terminate:
      s = State.Uninitialized;
    }
    [s.Error]
    {
      on initialize:
      illegal;
      on open, close:
      {}
      on terminate:
      s = State.Uninitialized;
    }
  }
}

component Component {
  provides IDevice p;
  requires IDevice a;
  requires IDevice b;

  behaviour {
    enum State {Uninitialized, Closed, Open, Error};
    State s = State.Uninitialized;

    [s.Uninitialized]
    {
      on p.initialize():
      {
        s = State.Closed;
        a.initialize();
        b.initialize();
      }
      on p.open(), p.close(), a.error(), b.error():
      illegal;
      on p.terminate():
      {
        s = State.Uninitialized;
        a.terminate();
        b.terminate();
      }
    }
    [s.Closed]
    {
      on p.initialize(), p.close():
      illegal;
      on p.open():
      {
        s = State.Open;
        a.open();
        b.open();
      }
      on a.error(), b.error():
      {
        s = State.Error;
        p.error();
      }
      on p.terminate():
      {
        s = State.Uninitialized;
        a.terminate();
        b.terminate();
      }
    }
    [s.Open]
    {
      on p.initialize(), p.open():
      illegal;
      on p.close():
      {
        s = State.Closed;
        a.close();
        b.close();
      }
      on a.error(), b.error():
      {
        s = State.Error;
        p.error();
      }
      on p.terminate():
      {
        s = State.Uninitialized;
        a.terminate();
        b.terminate();
      }
    }
    [s.Error]
    {
      on p.initialize():
      illegal;
      on p.open(), p.close(), a.error(), b.error():
      {}
      on p.terminate():
      {
        s = State.Uninitialized;
        a.terminate();
        b.terminate();
      }
    }
  }
}

