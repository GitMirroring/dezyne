component SystemComposition {
  provides I p;
  requires I r;

  system {
    nameSplit n1;
    nameBot n2;
    nameSys1 s1;
    nameSys2 s2;
    nameSys3 s3;

    p <=> n1.p;
    n1.r1 <=> s1.p;
    s1.r <=> s2.p;
    s2.r <=> r;
    n1.r2 <=> s3.p;
    s3.r <=> n2.p;
  }
}

