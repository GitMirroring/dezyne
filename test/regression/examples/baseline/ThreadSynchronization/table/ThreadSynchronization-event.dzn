extern Position $Position$;

interface IMotorAsync {
  in void move(Position p);
  out void arrived();

  behaviour {
    bool is_moving = false;

    on move:
    {
      [!is_moving]
      is_moving = true;
      [is_moving]
      illegal;
    }
    on inevitable:
    [is_moving]
    {
      arrived;
      is_moving = false;
    }
  }
}

interface IMotorSync {
  in void move(Position p);
  in void wait_arrived();

  behaviour {
    bool is_moving = false;

    on move:
    {
      [!is_moving]
      is_moving = true;
      [is_moving]
      illegal;
    }
    on wait_arrived:
    {
      [!is_moving]
      illegal;
      [is_moving]
      is_moving = false;
    }
  }
}

interface IStageSync {
  in void move(Position px, Position py);

  behaviour {

    on move:
    [true]
    {}
  }
}

interface IStageAsync {
  in void move(Position px, Position py);
  out void arrived();

  behaviour {
    bool is_moving = false;

    on move:
    {
      [!is_moving]
      is_moving = true;
      [is_moving]
      illegal;
    }
    on inevitable:
    [is_moving]
    {
      arrived;
      is_moving = false;
    }
  }
}

component MotorControl {
  provides IMotorSync pp;
  requires IMotorAsync rp;

  behaviour {
    enum State {Idle, Working, Done};
    State s = State.Idle;
    bool is_client_waiting = false;

    on pp.move(p):
    {
      [s.Idle]
      {
        rp.move(p);
        s = State.Working;
      }
      [s.Done || s.Working]
      illegal;
    }
    on pp.wait_arrived():
    {
      [s.Idle]
      illegal;
      [s.Working]
      blocking is_client_waiting = true;
      [s.Done]
      s = State.Idle;
    }
    on rp.arrived():
    {
      [s.Done || s.Idle]
      illegal;
      [s.Working]
      [is_client_waiting]
      {
        pp.reply();
        is_client_waiting = false;
        s = State.Idle;
      }
      [s.Working]
      [!is_client_waiting]
      s = State.Done;
    }
  }
}

component Stage2DSync {
  provides IStageSync pp;
  requires IMotorSync x;
  requires IMotorSync y;

  behaviour {

    on pp.move(px, py):
    [true]
    {
      x.move(px);
      y.move(py);
      x.wait_arrived();
      y.wait_arrived();
    }
  }
}

component StageAsync {
  provides IStageAsync pp;
  requires IMotorAsync x;
  requires IMotorAsync y;

  behaviour {
    subint Count {0..2};
    Count moving_motors = 0;

    on pp.move(px, py):
    {
      [moving_motors.0]
      {
        x.move(px);
        y.move(py);
        moving_motors = 2;
      }
      [moving_motors.2 || moving_motors.1]
      illegal;
    }
    on x.arrived():
    {
      [moving_motors.0]
      illegal;
      [moving_motors.2 || moving_motors.1]
      moving_motors = moving_motors - 1;
    }
    on y.arrived():
    {
      [moving_motors.0]
      illegal;
      [moving_motors.2 || moving_motors.1]
      moving_motors = moving_motors - 1;
    }
  }
}

component StageSync {
  provides IStageSync pp;
  requires IMotorAsync x;
  requires IMotorAsync y;

  system {
    Stage2DSync s;
    MotorControl x_motor;
    MotorControl y_motor;

    pp <=> s.pp;
    s.x <=> x_motor.pp;
    s.y <=> y_motor.pp;
    x_motor.rp <=> x;
    y_motor.rp <=> y;
  }
}

