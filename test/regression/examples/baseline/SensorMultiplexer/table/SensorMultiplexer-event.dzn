interface ISensor {
  in void Activate();
  in void Deactivate();
  out void DetectedMovement();

  behaviour {
    enum States {Deactivated, Activated, Triggered};
    States state = States.Deactivated;

    on Activate:
    {
      [state.Deactivated]
      state = States.Activated;
      [state.Triggered || state.Activated]
      illegal;
    }
    on Deactivate:
    {
      [state.Deactivated]
      illegal;
      [state.Triggered || state.Activated]
      state = States.Deactivated;
    }
    on optional:
    [state.Activated]
    {
      DetectedMovement;
      state = States.Triggered;
    }
  }
}

component SensorMultiplexer {
  provides ISensor sensors;
  requires ISensor aSensor;
  requires ISensor bSensor;

  behaviour {
    enum States {Deactivated, Activated, Triggered};
    States state = States.Deactivated;

    on sensors.Activate():
    {
      [state.Deactivated]
      {
        aSensor.Activate();
        bSensor.Activate();
        state = States.Activated;
      }
      [state.Triggered || state.Activated]
      illegal;
    }
    on sensors.Deactivate():
    {
      [state.Deactivated]
      illegal;
      [state.Triggered || state.Activated]
      {
        aSensor.Deactivate();
        bSensor.Deactivate();
        state = States.Deactivated;
      }
    }
    on aSensor.DetectedMovement():
    {
      [state.Deactivated]
      illegal;
      [state.Activated]
      {
        sensors.DetectedMovement();
        state = States.Triggered;
      }
      [state.Triggered]
      {}
    }
    on bSensor.DetectedMovement():
    {
      [state.Deactivated]
      illegal;
      [state.Activated]
      {
        sensors.DetectedMovement();
        state = States.Triggered;
      }
      [state.Triggered]
      {}
    }
  }
}

