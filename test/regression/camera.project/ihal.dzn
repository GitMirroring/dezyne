///////////////////////////////////////////////////////////////////////////////
// This model is part of the Camera Dezyne Example Project.
// The model contains the behavioural specification for the interfaces
// to the hardware. This is the list of interface specifications in this model:
// - the IMemory
// - the ISensor
// - the IFlash
// - the ILens
// - the IShutter
// - the IHardware
// For a behavioural specification for components in which this interfaces are
// provided, or respectively required, see the simhal.dzn model file.
// For the main purpose of this example please see the camera.dzn model file.
///////////////////////////////////////////////////////////////////////////////

interface IMemory
{
  in void store();
  behaviour
  {
    on store:{}
  }
}

interface ISensor
{
  in void enable();
  in void acquire();
  in void cancel();
  in void lock();
  out void higher_contrast();
  out void lower_contrast();
  out void image();

  behaviour
  {
    enum State {Idle, Ready, Acquire};
    State state = State.Idle;
    bool contrast = true;

    [state.Idle]
    {
      on enable: {contrast = true; state = State.Ready;}
      on acquire,
      cancel,
      lock: illegal;
    }
    [state.Ready]
    {
      on enable: illegal;
      on acquire: {state = State.Acquire;}
      on cancel: {state = State.Idle;}
      on lock: {contrast = false;}
      [contrast]
      {
        on inevitable: {higher_contrast;}
        on inevitable: {lower_contrast;}
      }
    }
    [state.Acquire]
    {
      on enable,
      acquire,
      lock: illegal;
      on cancel: {state = State.Idle;}
      on inevitable: {image; state = State.Idle;}
    }
  }
}

interface IFlash
{
  in void prepare();
  in void flash();
  in void cancel();
  out void ready();

  behaviour
  {
    enum State {Idle, Prepare, Ready};
    State state = State.Idle;
    on prepare:
    {
      [state.Idle] {state = State.Prepare;}
      [otherwise]  illegal;
    }
    on cancel: state = State.Idle;
    on inevitable:
    {
      [state.Prepare] {ready; state = State.Ready;}
    }
    on flash:
    {
      [state.Ready] {state = State.Idle;}
      [otherwise]   illegal;
    }
  }
}

interface ILens
{
  in void zoom_in();
  in void zoom_out();
  behaviour
  {
    on zoom_in:{}
    on zoom_out:{}
  }
}

interface IShutter
{
  in void expose();
  behaviour
  {
    on expose: {}
  }
}

interface IHardware
{
  in void kick();
  in void cancel();
  out void interrupt();

  behaviour
  {
    bool idle = true;

    on kick:
    {
      [idle] idle = false;
      [!idle] illegal;
    }
    [!idle] on inevitable: {interrupt; idle = true;}
    on cancel: idle = true;
  }
}
