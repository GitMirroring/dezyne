interface IControl {
  in void setup();
  in void shoot();
  in void release();
  out void ready();
  out void focus();
  out void image();

  behaviour {
    enum State {Idle, Setup, Ready, Acquire};
    State state = State.Idle;

    on setup:
    {
      [state.Idle]
      state = State.Setup;
      [state.Acquire || state.Ready || state.Setup]
      illegal;
    }
    on shoot:
    {
      [state.Acquire || state.Idle]
      illegal;
      [state.Ready || state.Setup]
      state = State.Acquire;
    }
    on release:
    {
      [state.Acquire || state.Idle]
      illegal;
      [state.Ready || state.Setup]
      state = State.Idle;
    }
    on inevitable:
    {
      [state.Ready || state.Setup]
      focus;
      [state.Setup]
      {
        ready;
        state = State.Ready;
      }
      [state.Acquire]
      {
        image;
        state = State.Idle;
      }
    }
  }
}

interface IAcquisition {
  in void contrast_gradient();
  in void cancel();
  in void acquire();
  out void image();
  out void higher_contrast();
  out void lower_contrast();

  behaviour {
    enum State {Idle, Contrast, Acquire};
    State state = State.Idle;

    on contrast_gradient:
    {
      [state.Idle]
      state = State.Contrast;
      [state.Acquire || state.Contrast]
      illegal;
    }
    on acquire:
    {
      [state.Acquire || state.Idle]
      illegal;
      [state.Contrast]
      state = State.Acquire;
    }
    on cancel:
    {
      [state.Idle]
      illegal;
      [state.Acquire || state.Contrast]
      state = State.Idle;
    }
    on inevitable:
    {
      [state.Contrast]
      {
        [true]
        lower_contrast;
        [true]
        higher_contrast;
      }
      [state.Acquire]
      {
        image;
        state = State.Idle;
      }
    }
  }
}

interface IOptics {
  in void prepare();
  in void capture();
  in void cancel();
  out void ready();
  in void focus_in();
  in void focus_out();

  behaviour {
    enum State {Idle, Prepare, Ready};
    State state = State.Idle;

    on prepare:
    {
      [state.Idle]
      state = State.Prepare;
      [state.Ready || state.Prepare]
      illegal;
    }
    on cancel:
    {
      [state.Ready || state.Prepare || state.Idle]
      state = State.Idle;
    }
    on capture:
    {
      [state.Idle]
      illegal;
      [state.Ready || state.Prepare]
      state = State.Idle;
    }
    on focus_in:
    {
      [state.Ready || state.Prepare || state.Idle]
      {}
    }
    on focus_out:
    {
      [state.Ready || state.Prepare || state.Idle]
      {}
    }
    on inevitable:
    [state.Prepare]
    {
      ready;
      state = State.Ready;
    }
  }
}

component Driver {
  provides IControl control;
  requires IAcquisition acquisition;
  requires IOptics optics;

  behaviour {
    enum State {Idle, Setup, Ready, Acquire};
    enum Contrast {Down, Up, Max};
    enum Zoom {In, Out};
    State state = State.Idle;
    Contrast contrast = Contrast.Down;
    Zoom zoom = Zoom.In;
    bool ready = false;

    on control.setup():
    {
      [state.Idle]
      {
        optics.prepare();
        acquisition.contrast_gradient();
        state = State.Setup;
      }
      [state.Acquire || state.Ready || state.Setup]
      illegal;
    }
    on control.shoot():
    {
      [state.Acquire || state.Idle]
      illegal;
      [state.Ready || state.Setup]
      {
        acquisition.acquire();
        optics.capture();
        state = State.Acquire;
      }
    }
    on control.release():
    {
      [state.Acquire || state.Idle]
      illegal;
      [state.Ready || state.Setup]
      {
        acquisition.cancel();
        state = State.Idle;
      }
    }
    on acquisition.image():
    {
      [state.Ready || state.Setup || state.Idle]
      illegal;
      [state.Acquire]
      {
        control.image();
        state = State.Idle;
      }
    }
    on acquisition.higher_contrast():
    {
      [state.Acquire || state.Idle]
      illegal;
      [state.Setup]
      {
        if (zoom.In) optics.focus_in();
        else optics.focus_out();
        contrast = Contrast.Up;
        control.focus();
      }
      [state.Ready]
      control.focus();
    }
    on acquisition.lower_contrast():
    {
      [state.Acquire || state.Idle]
      illegal;
      [state.Setup]
      {
        [contrast.Up]
        {
          if (zoom.In) {
            optics.focus_out();
            zoom = Zoom.Out;
          }
          else {
            optics.focus_in();
            zoom = Zoom.In;
          }
          contrast = Contrast.Max;
          if (ready) {
            contrast = Contrast.Down;
            control.ready();
            ready = false;
            state = State.Ready;
          }
          else control.focus();
        }
        [contrast.Down]
        {
          if (zoom.In) {
            optics.focus_out();
            zoom = Zoom.Out;
          }
          else {
            optics.focus_in();
            zoom = Zoom.In;
          }
          contrast = Contrast.Down;
          control.focus();
        }
        [otherwise]
        control.focus();
      }
      [state.Ready]
      control.focus();
    }
    on optics.ready():
    {
      [state.Idle]
      illegal;
      [state.Setup]
      if (contrast.Max) {
        control.ready();
        ready = false;
        state = State.Ready;
      }
      else ready = true;
      [state.Ready]
      control.focus();
      [state.Acquire]
      {}
    }
  }

}

component Acquire {
  provides IAcquisition port;
  requires IMemory memory;
  requires ISensor sensor;

  behaviour {
    enum State {Idle, Contrast, Acquire};
    State state = State.Idle;

    on port.contrast_gradient():
    {
      [state.Idle]
      {
        sensor.enable();
        state = State.Contrast;
      }
      [state.Acquire || state.Contrast]
      illegal;
    }
    on port.acquire():
    {
      [state.Acquire || state.Idle]
      illegal;
      [state.Contrast]
      {
        sensor.acquire();
        state = State.Acquire;
      }
    }
    on port.cancel():
    {
      [state.Idle]
      illegal;
      [state.Acquire || state.Contrast]
      {
        sensor.cancel();
        state = State.Idle;
      }
    }
    on sensor.higher_contrast():
    {
      [state.Acquire || state.Idle]
      illegal;
      [state.Contrast]
      port.higher_contrast();
    }
    on sensor.lower_contrast():
    {
      [state.Acquire || state.Idle]
      illegal;
      [state.Contrast]
      port.lower_contrast();
    }
    on sensor.image():
    {
      [state.Contrast || state.Idle]
      illegal;
      [state.Acquire]
      {
        port.image();
        state = State.Idle;
      }
    }
  }

}

component OpticsControl {
  provides IOptics port;
  requires ILens lens;
  requires IShutter shutter;
  requires IFlash flash;

  behaviour {
    enum State {Idle, Prepare, Ready};
    State state = State.Idle;
    bool ready = false;

    on port.prepare():
    {
      [state.Idle]
      {
        state = State.Prepare;
        flash.prepare();
      }
      [state.Ready || state.Prepare]
      illegal;
    }
    on port.cancel():
    {
      [state.Ready || state.Prepare || state.Idle]
      {
        flash.cancel();
        state = State.Idle;
      }
    }
    on flash.ready():
    {
      [state.Ready || state.Idle]
      {}
      [state.Prepare]
      {
        state = State.Ready;
        port.ready();
      }
    }
    on port.capture():
    {
      [state.Idle]
      illegal;
      [state.Prepare]
      {
        state = State.Idle;
        flash.cancel();
        shutter.expose();
      }
      [state.Ready]
      {
        state = State.Idle;
        flash.flash();
        shutter.expose();
      }
    }
    on port.focus_in():
    {
      [state.Ready || state.Prepare || state.Idle]
      lens.zoom_in();
    }
    on port.focus_out():
    {
      [state.Ready || state.Prepare || state.Idle]
      lens.zoom_out();
    }
  }

}

component Acquisition {
  provides IAcquisition port;
  requires IHardware acquire_hardware;
  requires IHardware contrast_hardware;

  system {
    nameAcquire acquire;
    nameMemory memory;
    nameCMOS sensor;

    port <=> acquire.port;
    acquire.memory <=> memory.port;
    acquire.sensor <=> sensor.port;
    acquire_hardware <=> sensor.acquire_hardware;
    contrast_hardware <=> sensor.contrast_hardware;
  }
}

component Optics {
  provides IOptics port;
  requires IHardware flash_hardware;

  system {
    nameOpticsControl optics;
    nameLens lens;
    nameShutter shutter;
    nameFlash flash;

    port <=> optics.port;
    optics.lens <=> lens.port;
    optics.shutter <=> shutter.port;
    optics.flash <=> flash.port;
    flash_hardware <=> flash.hardware;
  }
}

component HardwareLayer {
  provides IHardware acquire;
  provides IHardware contrast;
  provides IHardware flash;

  system {
    nameHardware acquire_hardware;
    nameHardware contrast_hardware;
    nameHardware flash_hardware;

    acquire <=> acquire_hardware.port;
    contrast <=> contrast_hardware.port;
    flash <=> flash_hardware.port;
  }
}

component Camera {
  provides IControl control;

  system {
    nameDriver driver;
    nameAcquisition acquisition;
    nameOptics optics;
    nameHardwareLayer hardware;

    control <=> driver.control;
    driver.acquisition <=> acquisition.port;
    driver.optics <=> optics.port;
    hardware.acquire <=> acquisition.acquire_hardware;
    hardware.contrast <=> acquisition.contrast_hardware;
    hardware.flash <=> optics.flash_hardware;
  }
}

component Camera2 {
  provides IControl control;

  system {
    nameDriver driver;
    nameAcquire acquisition;
    nameMemory memory;
    nameCMOS sensor;
    nameHardware acquire_hardware;
    nameHardware contrast_hardware;
    nameOpticsControl optics;
    nameLens lens;
    nameShutter shutter;
    nameFlash flash;
    nameHardware flash_hardware;

    control <=> driver.control;
    driver.acquisition <=> acquisition.port;
    driver.optics <=> optics.port;
    acquisition.memory <=> memory.port;
    acquisition.sensor <=> sensor.port;
    acquire_hardware.port <=> sensor.acquire_hardware;
    contrast_hardware.port <=> sensor.contrast_hardware;
    optics.lens <=> lens.port;
    optics.shutter <=> shutter.port;
    optics.flash <=> flash.port;
    flash_hardware.port <=> flash.hardware;
  }
}

