// Code:

interface I {
  in void e();
  behaviour {
    on e: {}
  }
}

interface II {
  in void e();
  in void f();
  out void cb();
  behaviour {
    bool busy = false;
    [!busy]
       on e: busy = true;
    [busy] {
       on e: illegal;
       on optional: { cb; busy = false; }
    }
    on f: {}
  }
}

component SimpleBlockingDeadlock {
  provides I p;
  requires II r;
  behaviour {
    bool busy = false;
    [!busy] {
       on p.e(): blocking { r.e(); busy = true; }
       on r.cb(): illegal;
    }
    [busy] {
       on p.e(): illegal;
       on r.cb(): { p.reply(); busy = false; }
    }
  }
}

