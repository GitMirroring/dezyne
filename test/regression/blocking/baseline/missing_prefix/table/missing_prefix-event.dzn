// Code:

interface I {
  in bool e();

  behaviour {

    on e:
    {
      [true]
      reply(true);
      [true]
      reply(false);
    }
  }
}

interface II {
  out void trigger();

  behaviour {

    on inevitable:
    [true]
    trigger;
  }
}

component missing_prefix {
  provides I i;
  requires II ii;

  behaviour {
    enum State {One, Two, Three};
    State state = State.One;
    bool blocked = false;

    on i.e():
    {
      [state.Three || state.Two || state.One]
      {
        [state.One]
        blocking {
          state = State.Two;
          reply(false);
        }
        [state.Two]
        blocking {
          state = State.Three;
          reply(false);
        }
        [state.Three]
        blocking blocked = true;
      }
    }
    on ii.trigger():
    {
      [state.Two || state.One]
      [!blocked || blocked]
      {}
      [state.Three]
      {
        [blocked]
        {
          state = State.One;
          blocked = false;
          reply(true);
        }
        [otherwise]
        {}
      }
    }
  }
}

