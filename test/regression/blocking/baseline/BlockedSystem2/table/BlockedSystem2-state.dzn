interface IBlocked {
  in void e();

  behaviour {

    [true]
    on e:
    {}
  }
}

interface IAsync {
  in void trigger();
  out void notify();

  behaviour {
    bool pending = false;

    [!pending]
    on trigger:
    pending = true;
    [pending]
    {
      on trigger:
      illegal;
      on inevitable:
      {
        pending = false;
        notify;
      }
    }
  }
}

component Blocked {
  provides IBlocked provided;
  requires IAsync required;

  behaviour {

    [true]
    {
      on provided.e():
      blocking required.trigger();
      on required.notify():
      provided.reply();
    }
  }
}

component BlockedSystem2 {
  provides IBlocked port1;
  provides IBlocked port2;
  requires IAsync async1;
  requires IAsync async2;

  system {
    Blocked blocked1;
    Blocked blocked2;

    blocked1.provided <=> port1;
    blocked2.provided <=> port2;
    blocked1.required <=> async1;
    blocked2.required <=> async2;
  }
}

