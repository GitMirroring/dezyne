interface IConsole {
  in void arm();
  in void disarm();
  out void detected();

  behaviour {
    enum States {Disarmed, Armed, Triggered, Disarming};
    States state = States.Disarmed;

    on arm:
    {
      [state.Disarmed]
      state = States.Armed;
      [state.Triggered || state.Armed]
      illegal;
    }
    on disarm:
    {
      [state.Disarmed]
      illegal;
      [state.Triggered || state.Armed]
      state = States.Disarmed;
    }
    on optional:
    [state.Armed]
    {
      detected;
      state = States.Triggered;
    }
  }
}

interface ISensor {
  in void enable();
  in void disable();
  out void triggered();
  out void disabled();

  behaviour {
    enum States {Disabled, Enabled, Disabling, Triggered};
    States state = States.Disabled;

    on enable:
    {
      [state.Disabled]
      state = States.Enabled;
      [state.Triggered || state.Disabling || state.Enabled]
      illegal;
    }
    on disable:
    {
      [state.Disabling || state.Disabled]
      illegal;
      [state.Triggered || state.Enabled]
      state = States.Disabling;
    }
    on optional:
    [state.Enabled]
    {
      triggered;
      state = States.Triggered;
    }
    on inevitable:
    [state.Disabling]
    {
      disabled;
      state = States.Disabled;
    }
  }
}

interface ISiren {
  in void turnon();
  in void turnoff();

  behaviour {
    enum States {Off, On};
    States state = States.Off;

    on turnon:
    {
      [state.Off]
      state = States.On;
      [state.On]
      illegal;
    }
    on turnoff:
    {
      [state.Off]
      illegal;
      [state.On]
      state = States.Off;
    }
  }
}

component AlarmBlock {
  provides IConsole console;
  requires ISensor sensor;
  requires ISiren siren;

  behaviour {
    enum States {Disarmed, Armed, Triggered, Disarming};
    States state = States.Disarmed;
    bool sounding = false;

    on console.arm():
    {
      [state.Disarmed]
      {
        sensor.enable();
        state = States.Armed;
      }
      [state.Disarming || state.Triggered || state.Armed]
      illegal;
    }
    on console.disarm():
    {
      [state.Disarming || state.Disarmed]
      illegal;
      [state.Armed]
      blocking {
        sensor.disable();
        state = States.Disarming;
      }
      [state.Triggered]
      blocking {
        sensor.disable();
        siren.turnoff();
        sounding = false;
        state = States.Disarming;
      }
    }
    on sensor.triggered():
    {
      [state.Triggered || state.Disarmed]
      illegal;
      [state.Armed]
      {
        console.detected();
        siren.turnon();
        sounding = true;
        state = States.Triggered;
      }
      [state.Disarming]
      {}
    }
    on sensor.disabled():
    {
      [state.Triggered || state.Armed || state.Disarmed]
      illegal;
      [state.Disarming]
      {
        [sounding]
        {
          siren.turnoff();
          state = States.Disarmed;
          console.reply();
          sounding = false;
        }
        [otherwise]
        {
          state = States.Disarmed;
          console.reply();
        }
      }
    }
  }
}

