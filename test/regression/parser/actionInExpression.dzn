interface Sensor {
  enum Status { OK, NOK };
  in Status activate();
  behaviour { 
    on activate: { reply(Status.OK); }
  }
}
component SensorComp {
  provides Sensor sensor1;
  requires Sensor sensor2;
  behaviour {
    Sensor.Status s = sensor2.activate();
    bool b= true;
    on sensor1.activate(): {
      if (sensor2.activate() == Sensor.Status.OK) { }
      reply(sensor2.activate());
    }
  }
}

