interface IDummy {
  in void ia();
  out void oa();

  behaviour {

    on ia:
    [true]
    {}
    on optional:
    [true]
    oa;
  }
}

interface INotifier {
  out void oa();

  behaviour {
    bool isPaired = false;

    on optional:
    {
      [!isPaired]
      {
        oa;
        oa;
        isPaired = !isPaired;
      }
      [isPaired]
      {
        oa;
        isPaired = !isPaired;
      }
    }
  }
}

component IgnoreNotification {
  provides IDummy pp;
  requires INotifier rp;

  behaviour {
    bool communicate = false;

    on pp.ia():
    {
      [communicate || !communicate]
      {}
    }
    on rp.oa():
    {
      [!communicate]
      {}
      [communicate]
      pp.oa();
    }
  }
}

