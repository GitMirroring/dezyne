// Code:

interface Sensor1 {
  enum Status { OK, NOK };
  in Status activate();
  behaviour { 
    on activate: { reply(Status.OK); }
  }
}
interface Sensor2 {
  enum Status { OK, NOK };
  in Status activate();
  behaviour { 
    on activate: { reply(Status.OK); }
  }
}
component SensorComp {
  provides Sensor1 sensor;
  requires Sensor2 req;
  behaviour {
    on sensor.activate(): {
      if (true) reply(Sensor2.Status.NOK);
    }
  }
}

