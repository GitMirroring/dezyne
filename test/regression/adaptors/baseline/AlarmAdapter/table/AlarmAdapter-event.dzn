interface IConsole {
  in void arm();
  in void disarm();
  out void detected();
  out void deactivated();

  behaviour {
    enum States {Disarmed, Armed, Triggered, Disarming};
    States state = States.Disarmed;

    on arm:
    {
      [state.Disarmed]
      state = States.Armed;
      [state.Disarming || state.Triggered || state.Armed]
      illegal;
    }
    on disarm:
    {
      [state.Disarming || state.Disarmed]
      illegal;
      [state.Triggered || state.Armed]
      state = States.Disarming;
    }
    on optional:
    [state.Armed]
    {
      detected;
      state = States.Triggered;
    }
    on inevitable:
    [state.Disarming]
    {
      deactivated;
      state = States.Disarmed;
    }
  }
}

interface ISensor {
  in void enable();
  in void disable();
  out void triggered();
  out void disabled();

  behaviour {
    enum States {Disabled, Enabled, Disabling, Triggered};
    States state = States.Disabled;

    on enable:
    {
      [state.Disabled]
      state = States.Enabled;
      [state.Triggered || state.Disabling || state.Enabled]
      illegal;
    }
    on disable:
    {
      [state.Disabling || state.Disabled]
      illegal;
      [state.Triggered || state.Enabled]
      state = States.Disabling;
    }
    on optional:
    [state.Enabled]
    {
      triggered;
      state = States.Triggered;
    }
    on inevitable:
    [state.Disabling]
    {
      disabled;
      state = States.Disabled;
    }
  }
}

interface ISiren {
  in void turnon();
  in void turnoff();

  behaviour {
    enum States {Off, On};
    States state = States.Off;

    on turnon:
    {
      [state.Off]
      state = States.On;
      [state.On]
      illegal;
    }
    on turnoff:
    {
      [state.Off]
      illegal;
      [state.On]
      state = States.Off;
    }
  }
}

interface IRun {
  in void run();

  behaviour {

    on run:
    [true]
    {}
  }
}

component Sensor {
  provides ISensor sensor;

  behaviour {

    on sensor.enable():
    [true]
    sensor.triggered();
    on sensor.disable():
    [true]
    sensor.disabled();
  }
}

component Siren {
  provides ISiren siren;

  behaviour {
    enum States {Off, On};
    States state = States.Off;

    on siren.turnon():
    {
      [state.Off]
      state = States.On;
      [state.On]
      illegal;
    }
    on siren.turnoff():
    {
      [state.Off]
      illegal;
      [state.On]
      state = States.Off;
    }
  }
}

component Alarm {
  provides IConsole console;
  requires ISensor sensor;
  requires ISiren siren;

  behaviour {
    enum States {Disarmed, Armed, Triggered, Disarming};
    States state = States.Disarmed;
    bool sounding = false;

    on console.arm():
    {
      [state.Disarmed]
      {
        sensor.enable();
        state = States.Armed;
      }
      [state.Disarming || state.Triggered || state.Armed]
      illegal;
    }
    on console.disarm():
    {
      [state.Disarming || state.Disarmed]
      illegal;
      [state.Armed]
      {
        sensor.disable();
        state = States.Disarming;
      }
      [state.Triggered]
      {
        sensor.disable();
        sounding = false;
        state = States.Disarming;
      }
    }
    on sensor.triggered():
    {
      [state.Disarming || state.Triggered || state.Disarmed]
      illegal;
      [state.Armed]
      {
        console.detected();
        siren.turnon();
        sounding = true;
        state = States.Triggered;
      }
    }
    on sensor.disabled():
    {
      [state.Triggered || state.Armed || state.Disarmed]
      illegal;
      [state.Disarming]
      {
        [sounding]
        {
          console.deactivated();
          sounding = false;
          state = States.Disarmed;
        }
        [otherwise]
        {
          console.deactivated();
          state = States.Disarmed;
        }
      }
    }
  }
}

component Adaptor {
  provides IRun runner;
  requires IConsole console;

  behaviour {
    enum State {Idle, Active, Terminating};
    subint Twice {0..2};
    State state = State.Idle;
    Twice count = 0;

    on runner.run():
    {
      [state.Idle]
      {
        [count < 2]
        {
          console.arm();
          state = State.Active;
        }
        [otherwise]
        {}
      }
      [state.Terminating || state.Active]
      {}
    }
    on console.detected():
    {
      [state.Terminating || state.Idle]
      illegal;
      [state.Active]
      {
        count = count + 1;
        console.disarm();
        state = State.Terminating;
      }
    }
    on console.deactivated():
    {
      [state.Active || state.Idle]
      illegal;
      [state.Terminating]
      {
        [count < 2]
        {
          console.arm();
          state = State.Active;
        }
        [otherwise]
        state = State.Idle;
      }
    }
  }
}

component AlarmSystem {
  provides IConsole console;

  system {
    nameSensor sensor;
    nameSiren siren;
    nameAlarm alarm;

    console <=> alarm.console;
    sensor.sensor <=> alarm.sensor;
    siren.siren <=> alarm.siren;
  }
}

component Main {
  provides IRun runner;

  system {
    nameAdaptor adaptor;
    nameAlarmSystem alarm;

    runner <=> adaptor.runner;
    adaptor.console <=> alarm.console;
  }
}

