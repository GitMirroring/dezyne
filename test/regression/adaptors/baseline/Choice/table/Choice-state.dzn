interface IChoice {
  in void e();
  out void a();

  behaviour {
    enum State {Off, Idle, Busy};
    State s = State.Off;

    [s.Off]
    on e:
    {
      s = State.Idle;
      a;
    }
    [s.Idle]
    on e:
    {
      s = State.Busy;
      a;
    }
    [s.Busy]
    on e:
    {
      s = State.Idle;
      a;
    }
  }
}

interface IRun {
  in void run();

  behaviour {

    [true]
    on run:
    {}
  }
}

component Choice {
  provides IChoice c;

  behaviour {
    enum State {Off, Idle, Busy};
    State s = State.Off;

    [s.Off]
    on c.e():
    {
      s = State.Idle;
      c.a();
    }
    [s.Idle]
    on c.e():
    {
      s = State.Busy;
      c.a();
    }
    [s.Busy]
    on c.e():
    {
      s = State.Idle;
      c.a();
    }
  }
}

component Adaptor {
  provides IRun runner;
  requires IChoice choice;

  behaviour {
    enum State {Idle, Active, Terminating};
    subint Twice {0..2};
    State state = State.Idle;
    Twice count = 0;

    [state.Idle]
    {
      on runner.run():
      {
        [count < 2]
        {
          choice.e();
          state = State.Active;
        }
        [otherwise]
        {}
      }
      on choice.a():
      {}
    }
    [state.Active]
    {
      on runner.run():
      {}
      on choice.a():
      {
        count = count + 1;
        choice.e();
        state = State.Terminating;
      }
    }
    [state.Terminating]
    {
      on runner.run():
      {}
      on choice.a():
      {
        [count < 2]
        {
          choice.e();
          state = State.Active;
        }
        [otherwise]
        state = State.Idle;
      }
    }
  }
}

component ChoiceSystem {
  provides IChoice c;

  system {
    nameChoice choice;

    c <=> choice.c;
  }
}

component Main {
  provides IRun runner;

  system {
    nameAdaptor adaptor;
    nameChoiceSystem choice;

    runner <=> adaptor.runner;
    adaptor.choice <=> choice.c;
  }
}

