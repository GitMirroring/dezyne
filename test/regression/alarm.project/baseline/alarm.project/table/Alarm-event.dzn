component Alarm {
  provides IConsole console;
  requires ISensor sensor;
  requires ISiren siren;

  behaviour {
    enum States {Disarmed, Armed, Triggered, Disarming};
    States state = States.Disarmed;
    bool sounding = false;

    on console.arm():
    {
      [state.Disarmed]
      {
        sensor.enable();
        state = States.Armed;

      }
      [state.Disarming || state.Triggered || state.Armed]
      illegal;

    }
    on console.disarm():
    {
      [state.Disarming || state.Disarmed]
      illegal;
      [state.Armed]
      {
        sensor.disable();
        state = States.Disarming;

      }
      [state.Triggered]
      {
        sensor.disable();
        siren.turnoff();
        sounding = false;
        state = States.Disarming;

      }

    }
    on sensor.triggered():
    {
      [state.Triggered || state.Disarmed]
      illegal;
      [state.Armed]
      {
        console.detected();
        siren.turnon();
        sounding = true;
        state = States.Triggered;

      }
      [state.Disarming]
      {}

    }
    on sensor.disabled():
    {
      [state.Triggered || state.Armed || state.Disarmed]
      illegal;
      [state.Disarming]
      {
        [sounding]
        {
          console.deactivated();
          siren.turnoff();
          state = States.Disarmed;
          sounding = false;

        }
        [otherwise]
        {
          console.deactivated();
          state = States.Disarmed;

        }

      }

    }
  }

}

