interface dzn.ISensor
{
  // Application interface ISensor
  in void Activate(); /*- Activate the sensor -*/ 
  in void Deactivate(); /*- Deactivate the sensor; asynchronous: Deactivated notifies completion -*/ 

  // Notification interface ISensor_NI
  out void DetectedMovement(); /*- Sensor has detected movement -*/ 
  out void Deactivated(); /*- Notification that Deactive has completed -*/ 

  // Modelling Interface Internal has been replaced by optional/inevitable

  behaviour
  {
    enum States {Deactivated, Activated, Deactivating, Triggered};

    States state_ = States.Deactivated;

    [state_.Deactivated]
    {
      on Activate:
      {
         /*- Activate sensor -*/ 
        state_ = States.Activated;
      }
      on Deactivate /*- Illegal - already deactivated -*/ :
      {
        illegal;
      }
    }

    [state_.Activated]
    {
      on Deactivate:
      {
         /*- Deactivate sensor -*/ 
        state_ = States.Deactivating;
      }
      on optional:
      {
         /*- Sensor detected movement -*/ 
        DetectedMovement;
        state_ = States.Triggered;
      }
      on Activate /*- Illegal - already activated -*/ :
      {
        illegal;
      }
    }

    [state_.Deactivating]
    {
      on inevitable:
      {
         /*- Completely deactivated -*/ 
        Deactivated;
        state_ = States.Deactivated;
      }
      on Activate /*- Illegal - not yet deactivated -*/ , 
          Deactivate /*- Ilegal - already deactivated -*/ :
      {
        illegal;
      }
    }

    [state_.Triggered]
    {
      on Deactivate:
      {
         /*- Deactivate sensor -*/ 
        state_ = States.Deactivating;
      }
      on Activate /*- Illegal - already activated -*/ :
      {
        illegal;
      }
    }

  }
}
