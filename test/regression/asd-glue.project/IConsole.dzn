// 
// Alarm system that can be switched on/off by one key. If sensor is activated it can sense activity; if it does it trips the alarm. In case of alarm the siren will make noise.
// 
// /////////////////////////////////////////////////////////////////////////////
// 
// TAGS:
// 
// tag: Tag
// Description
// 
// /////////////////////////////////////////////////////////////////////////////



interface dzn.IConsole
{
  // Application interface IAlarmSystem
  enum IAlarmSystem_Values {Ok, Failed};

  in IAlarmSystem_Values SwitchOn(); /*- Switch on the alarm system -*/ 
  in void SwitchOff(); /*- Switch off the alarm system; asynchronous: SwitchedOff notifies completion -*/ 

  // Notification interface IAlarmSystem_NI
  out void Tripped(); /*- Alarm system has detected movement -*/ 
  out void SwitchedOff(); /*- Notification that SwitchOff has completed -*/ 

  // Modelling Interface Internal has been replaced by optional/inevitable

  behaviour
  {
    enum States {NotActivated /*- AlarmSystem exists but is not active -*/ , Activated_Idle /*- AlarmSystem is active and actively guarding house -*/ , Activated_AlarmMode /*- AlarmSystem is active and in AlarmMode because the sensor has tripped -*/ , Deactivating /*- AlarmSystem is being switched off -*/ };

    States state_ = States.NotActivated;

    [state_.NotActivated]
    {
      on SwitchOn:
      {
        [true]
        {
           /*- Succesfully activated alarm system -*/ 
          reply(IAlarmSystem_Values.Ok);
          state_ = States.Activated_Idle;
        }
        [true]
        {
           /*- Illegal - alarm not activated yet  -*/ 
          reply(IAlarmSystem_Values.Failed);
        }
      }
      on SwitchOff /*- Illegal - alarm not activated yet  -*/ :
      {
        illegal;
      }
    }

    [state_.Activated_Idle]
    {
      on SwitchOff:
      {
         /*- Busy deactivating -*/ 
        state_ = States.Deactivating;
      }
      on optional:
      {
         /*- Sensor has tripped the alarm -*/ 
        Tripped;
        state_ = States.Activated_AlarmMode;
      }
      on SwitchOn /*- Illegal - alarm already activated -*/ :
      {
        illegal;
      }
    }

    [state_.Activated_AlarmMode]
    {
      on SwitchOff:
      {
         /*- Busy deactivating -*/ 
        state_ = States.Deactivating;
      }
      on SwitchOn /*- Illegal - alarm already activated -*/ :
      {
        illegal;
      }
    }

    [state_.Deactivating]
    {
      on inevitable:
      {
         /*- Alarm system is deactivated -*/ 
        SwitchedOff;
        state_ = States.NotActivated;
      }
      on SwitchOn /*- Illegal - busy deactivating -*/ , 
          SwitchOff /*- Illegal - already deactivating -*/ :
      {
        illegal;
      }
    }

  }
}
