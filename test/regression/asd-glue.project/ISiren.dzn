interface dzn.ISiren
{
  // Application interface ISiren
  in void TurnOn(); /*- Turn the siren on -*/ 
  in void TurnOff(); /*- Turn the siren off -*/ 

  behaviour
  {
    enum States {SirenOff, SirenOn};

    States state_ = States.SirenOff;

    [state_.SirenOff]
    {
      on TurnOn:
      {
        state_ = States.SirenOn;
      }
      on TurnOff /*- Illegal - Siren already off -*/ :
      {
        illegal;
      }
    }

    [state_.SirenOn]
    {
      on TurnOff:
      {
        state_ = States.SirenOff;
      }
      on TurnOn /*- Illegal - Siren already on -*/ :
      {
        illegal;
      }
    }

  }
}
