interface Device1IF
{
//	enum Result { OK, NOK };
	in void turnon();
	in void turnoff();
	out void ok();
	out void nok();
	
	behaviour
	{
		enum State { Off, GoingOn, On };
		State state = State.Off;
		
		[state.Off]
		{
			on turnon: state = State.GoingOn; 
			on turnoff: illegal;
		}
		
		[state.GoingOn]
		{
			on inevitable: { ok; state = State.On; }
			on inevitable: { nok; state = State.Off;  }
			on turnon: illegal;
			on turnoff: illegal;			
		} 		
		
		[state.On]
		{
			on turnon: illegal;
			on turnoff: { state = State.Off; }
		}
	}
}

interface Device2IF
{
	enum Result { OK, NOK };
	in Result turnon();
	in void turnoff();
	
	behaviour
	{
		enum State { Off, On };
		State state = State.Off;
		
		[state.Off]
		{
			on turnon: { reply( Result.OK ); state = State.On; }
			on turnon: { reply( Result.NOK); }
			on turnoff: illegal;
		}
		[state.On]
		{
			on turnon: illegal;
			on turnoff: { state = State.Off; }
		}		
	}
}
