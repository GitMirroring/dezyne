interface Device1IF {
  in void turnon();
  in void turnoff();
  out void ok();
  out void nok();

  behaviour {
    enum State {Off, GoingOn, On};
    State state = State.Off;

    [state.Off]
    {
      on turnon:
      state = State.GoingOn;
      on turnoff:
      illegal;
    }
    [state.GoingOn]
    {
      on turnon, turnoff:
      illegal;
      on inevitable:
      {
        [true]
        {
          ok;
          state = State.On;
        }
        [true]
        {
          nok;
          state = State.Off;
        }
      }
    }
    [state.On]
    {
      on turnon:
      illegal;
      on turnoff:
      state = State.Off;
    }
  }
}

interface Device2IF {
  enum Result {OK, NOK};
  in Result turnon();
  in void turnoff();

  behaviour {
    enum State {Off, On};
    State state = State.Off;

    [state.Off]
    {
      on turnon:
      {
        [true]
        {
          reply(Result.OK);
          state = State.On;
        }
        [true]
        reply(Result.NOK);
      }
      on turnoff:
      illegal;
    }
    [state.On]
    {
      on turnon:
      illegal;
      on turnoff:
      state = State.Off;
    }
  }
}

