interface Device1IF {
  in void turnon();
  in void turnoff();
  out void ok();
  out void nok();

  behaviour {
    enum State {Off, GoingOn, On};
    State state = State.Off;

    on turnon:
    {
      [state.Off]
      state = State.GoingOn;
      [state.On || state.GoingOn]
      illegal;
    }
    on turnoff:
    {
      [state.GoingOn || state.Off]
      illegal;
      [state.On]
      state = State.Off;
    }
    on inevitable:
    {
      [state.GoingOn]
      {
        ok;
        state = State.On;
      }
      [state.GoingOn]
      {
        nok;
        state = State.Off;
      }
    }
  }
}

interface Device2IF {
  enum Result {OK, NOK};
  in Result turnon();
  in void turnoff();

  behaviour {
    enum State {Off, On};
    State state = State.Off;

    on turnon:
    {
      [state.Off]
      {
        reply(Result.OK);
        state = State.On;
      }
      [state.Off]
      reply(Result.NOK);
      [state.On]
      illegal;
    }
    on turnoff:
    {
      [state.Off]
      illegal;
      [state.On]
      state = State.Off;
    }
  }
}

