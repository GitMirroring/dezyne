interface IConstrainedMove
{
	in void calibrate();
	out void homed();

	in void move();
	out void arrived();

	in void stop();

	
	behaviour
	{
		enum State {lost, idle, calibrating, moving};
		State s = State.lost;
		
		on calibrate: [s.lost] s = State.calibrating;
		on calibrate: [s.lost] {s = State.idle; homed;}
		on calibrate: [!s.lost] illegal;
		
		on move: [s.idle] s = State.moving;
		on move:  {s = State.idle; arrived;}
		on move: [!s.idle] illegal;
		on stop: s = State.lost;
		
		[s.moving] on inevitable: {s = State.idle; arrived;}
		[s.calibrating] on inevitable: {s = State.idle; homed;}
	}
}

interface ITouchSense
{
  enum TouchState {Pressed, Released};
  
  in TouchState enable();
  out void pressed();
  out void released();
  in void disable();

  behaviour
  {
    bool disabled = true;
    TouchState ts = TouchState.Released;
    
    [disabled]
    {
      on enable: {ts = TouchState.Pressed; reply(ts); disabled = false;}
      on enable: {ts = TouchState.Released; reply(ts); disabled = false;}
      on disable: {}
    }
    [!disabled]
    {
      on enable: illegal;
      on disable: disabled = true;
      on inevitable: [ts.Released] {ts = TouchState.Pressed; pressed;}
      on inevitable: [ts.Pressed] {ts = TouchState.Released; released;}
    }
  }
}

component ConstrainedMove
{
	provides IConstrainedMove ctrl;
	requires ITouchSense homeSensor;
	requires ITouchSense endSensor;
	
	behaviour
	{
		enum State {lost, idle, moving, calibratingHome, calibratingLength};
		State s = State.lost;
		
		void slowForward() {}
		void slowBackward() {}
		void recordHome() {homeSensor.disable();}
		void recordLength() {endSensor.disable();}
		void startAbsoluteMove() {
			ITouchSense.TouchState ignore = ITouchSense.TouchState.Released;
			ignore = homeSensor.enable();
			ignore = endSensor.enable();
			s = State.moving;
		}
		void notifyArrived() {
			homeSensor.disable();
			endSensor.disable();
		    s = State.idle;
		    ctrl.arrived();
		}
		
		on ctrl.stop(): {homeSensor.disable(); endSensor.disable(); s = State.lost;}
		
		[s.lost]
		{
			on ctrl.calibrate():
			{
				ITouchSense.TouchState hss = homeSensor.enable();
				if (hss == ITouchSense.TouchState.Pressed)
				{
					recordHome();
					ITouchSense.TouchState ess = endSensor.enable();
					if (ess == ITouchSense.TouchState.Pressed)
					{
						recordLength();
						s = State.idle;
						ctrl.homed();
					}
					else
					{
						slowForward();
						s = State.calibratingLength;
					}
				}
				else
				{
					slowBackward();
					s = State.calibratingHome;
				}
			}
			on ctrl.move(): illegal;
		}
		
		[s.calibratingHome]
		{
			on homeSensor.pressed():
			{
				recordHome();
				ITouchSense.TouchState ess = endSensor.enable();
				if (ess == ITouchSense.TouchState.Pressed)
				{
					recordLength();
					s = State.idle;
					ctrl.homed();
				}
				else 
				{
					slowForward();
					s = State.calibratingLength;
				}
			}

			on ctrl.calibrate(): illegal;
			on ctrl.move(): illegal;
			on homeSensor.released: illegal;
			on endSensor.pressed: illegal;
            on endSensor.released: illegal;
		}
		
		[s.calibratingLength]
		{
			on endSensor.pressed(): {recordLength(); ctrl.homed(); s = State.idle;}
			
			on ctrl.calibrate(): illegal;
			on ctrl.move(): illegal;
		}
		
		[s.idle]
		{
			on ctrl.calibrate(): illegal;
			on ctrl.move():
			{
			    ITouchSense.TouchState ignore = ITouchSense.TouchState.Released;
			    ignore = homeSensor.enable();
			    ignore = endSensor.enable();
			    s = State.moving;
			}
		}

		[s.moving]
		{
			on ctrl.calibrate(): illegal;
			on ctrl.move(): illegal;
			on homeSensor.pressed(): {notifyArrived();}
			on homeSensor.released(): {}
            on endSensor.pressed(): {notifyArrived();}
			on endSensor.released(): {}
		}
	
		[!s.moving && !s.calibratingHome]	
		{
			on homeSensor.pressed: illegal;
			on homeSensor.released: illegal;
            on endSensor.pressed: illegal;
			on endSensor.released: illegal;
		}
	}
}