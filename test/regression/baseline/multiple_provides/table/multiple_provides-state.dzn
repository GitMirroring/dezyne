interface imultiple_provides {
  in void left();
  out void right();

  behaviour {
    bool b = false;

    [!b]
    on left:
    {
      [true]
      right;
      [true]
      b = true;
    }
    [b]
    {
      on left:
      illegal;
      on inevitable:
      {
        b = false;
        right;
      }
    }
  }
}

component multiple_provides {
  provides imultiple_provides p_left;
  provides imultiple_provides p_right;
  requires imultiple_provides r;

  behaviour {
    enum Direction {Left, Right};
    Direction dir = Direction.Left;
    bool b_left = false;
    bool b_right = false;

    [dir.Left]
    {
      on p_left.left():
      {
        [!b_left && !b_right]
        {
          dir = Direction.Left;
          r.left();
          b_left = true;
        }
        [b_left || b_right]
        {
          [b_left]
          illegal;
          [!b_left]
          p_left.right();
        }
      }
      on p_right.left():
      {
        [!b_left && !b_right]
        {
          dir = Direction.Right;
          r.left();
          b_right = true;
        }
        [b_left || b_right]
        {
          [b_right]
          illegal;
          [!b_right]
          p_right.right();
        }
      }
      on r.right():
      {
        [!b_left && !b_right]
        illegal;
        [b_left || b_right]
        {
          b_left = false;
          p_left.right();
        }
      }
    }
    [dir.Right]
    {
      on p_left.left():
      {
        [!b_left && !b_right]
        {
          dir = Direction.Left;
          r.left();
          b_left = true;
        }
        [b_left || b_right]
        {
          [b_left]
          illegal;
          [!b_left]
          p_left.right();
        }
      }
      on p_right.left():
      {
        [!b_left && !b_right]
        {
          dir = Direction.Right;
          r.left();
          b_right = true;
        }
        [b_left || b_right]
        {
          [b_right]
          illegal;
          [!b_right]
          p_right.right();
        }
      }
      on r.right():
      {
        [!b_left && !b_right]
        illegal;
        [b_left || b_right]
        {
          b_right = false;
          p_right.right();
        }
      }
    }
  }
}

