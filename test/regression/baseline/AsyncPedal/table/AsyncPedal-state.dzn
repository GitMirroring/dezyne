interface IPedal {
  in void press();
  in void release();
  out void pressed();
  out void released();

  behaviour {
    enum State {Pressed, Released};
    State pedal = State.Released;
    State led = State.Released;

    [pedal.Pressed]
    {
      on press:
      illegal;
      on release:
      pedal = State.Released;
      on optional:
      [led.Released]
      {
        led = State.Pressed;
        pressed;
      }
    }
    [pedal.Released]
    {
      on press:
      pedal = State.Pressed;
      on release:
      illegal;
      on optional:
      {
        [led.Released]
        {
          led = State.Pressed;
          pressed;
        }
        [led.Pressed]
        {
          led = State.Released;
          released;
        }
      }
    }
  }
}

interface IFunctional {
  in void signal();
  in void nosignal();

  behaviour {

    [true]
    on signal, nosignal:
    {}
  }
}

interface IAsync {
  in void ping();
  out void pong();

  behaviour {
    bool pending = false;

    [!pending]
    on ping:
    pending = true;
    [pending]
    {
      on ping:
      illegal;
      on inevitable:
      {
        pong;
        pending = false;
      }
    }
  }
}

component Client {
  provides IPedal pedal;
  requires IPedal left;
  requires IPedal right;

  behaviour {
    enum State {Pressed, Released};
    enum Side {Left, Right};
    State state = State.Released;
    Side side = Side.Right;

    [state.Pressed]
    {
      on pedal.press():
      illegal;
      on pedal.release():
      {
        [side.Left]
        {
          left.release();
          state = State.Released;
        }
        [side.Right]
        {
          right.release();
          state = State.Released;
        }
      }
      on left.pressed():
      if (side.Left) pedal.pressed();
      on left.released():
      if (side.Left) pedal.released();
      on right.pressed():
      if (side.Right) pedal.pressed();
      on right.released():
      if (side.Right) pedal.released();
    }
    [state.Released]
    {
      on pedal.press():
      {
        [side.Left]
        {
          left.press();
          state = State.Pressed;
        }
        [side.Right]
        {
          right.press();
          state = State.Pressed;
        }
      }
      on pedal.release():
      illegal;
      on left.pressed():
      if (side.Left) pedal.pressed();
      on left.released():
      if (side.Left) pedal.released();
      on right.pressed():
      if (side.Right) pedal.pressed();
      on right.released():
      if (side.Right) pedal.released();
    }
  }

}

component PedalPair {
  provides IPedal left;
  provides IPedal right;
  requires IPedal pedal;

  behaviour {
    bool left_pressed = false;
    bool right_pressed = false;

    [!left_pressed]
    {
      on left.press():
      {
        left_pressed = true;
        if (!right_pressed) pedal.press();
      }
      on right.press():
      {
        [!right_pressed]
        {
          right_pressed = true;
          pedal.press();
        }
        [otherwise]
        illegal;
      }
      on left.release():
      illegal;
      on right.release():
      {
        [right_pressed]
        {
          right_pressed = false;
          pedal.release();
        }
        [otherwise]
        illegal;
      }
      on pedal.pressed():
      {
        left.pressed();
        right.pressed();
      }
      on pedal.released():
      {
        left.released();
        right.released();
      }
    }
    [left_pressed]
    {
      on left.press():
      illegal;
      on right.press():
      {
        [!right_pressed]
        right_pressed = true;
        [otherwise]
        illegal;
      }
      on left.release():
      {
        left_pressed = false;
        if (!right_pressed) pedal.release();
      }
      on right.release():
      {
        [right_pressed]
        right_pressed = false;
        [otherwise]
        illegal;
      }
      on pedal.pressed():
      {
        left.pressed();
        right.pressed();
      }
      on pedal.released():
      {
        left.released();
        right.released();
      }
    }
  }

}

component Acquisition {
  provides IPedal activation;
  provides IPedal fluo;
  requires IFunctional functional;
  requires IAsync async;

  behaviour {
    enum State {Pressed, Released};
    State aled = State.Released;
    State fled = State.Released;
    bool p = false;
    bool a = false;
    bool f = false;

    [aled.Pressed]
    {
      on activation.press():
      {
        [!a]
        {
          if (!p) {
            async.ping();
            p = true;
          }
          a = true;
          if (f) functional.signal();
        }
        [otherwise]
        illegal;
      }
      on activation.release():
      {
        [a]
        {
          if (!p) {
            async.ping();
            p = true;
          }
          a = false;
          if (f) functional.nosignal();
        }
        [otherwise]
        illegal;
      }
      on fluo.press():
      {
        [!f]
        {
          if (!p) {
            async.ping();
            p = true;
          }
          f = true;
          if (a) functional.signal();
        }
        [otherwise]
        illegal;
      }
      on fluo.release():
      {
        [f]
        {
          if (!p) {
            async.ping();
            p = true;
          }
          f = false;
          if (a) functional.nosignal();
        }
        [otherwise]
        illegal;
      }
      on async.pong():
      {
        p = false;
        if (!a) {
          aled = State.Released;
          activation.released();
        }
        if (f && fled.Released) {
          fled = State.Pressed;
          fluo.pressed();
        }
        else if (!f && fled.Pressed) {
          fled = State.Released;
          fluo.released();
        }
      }
    }
    [aled.Released]
    {
      on activation.press():
      {
        [!a]
        {
          if (!p) {
            async.ping();
            p = true;
          }
          a = true;
          if (f) functional.signal();
        }
        [otherwise]
        illegal;
      }
      on activation.release():
      {
        [a]
        {
          if (!p) {
            async.ping();
            p = true;
          }
          a = false;
          if (f) functional.nosignal();
        }
        [otherwise]
        illegal;
      }
      on fluo.press():
      {
        [!f]
        {
          if (!p) {
            async.ping();
            p = true;
          }
          f = true;
          if (a) functional.signal();
        }
        [otherwise]
        illegal;
      }
      on fluo.release():
      {
        [f]
        {
          if (!p) {
            async.ping();
            p = true;
          }
          f = false;
          if (a) functional.nosignal();
        }
        [otherwise]
        illegal;
      }
      on async.pong():
      {
        p = false;
        if (a) {
          aled = State.Pressed;
          activation.pressed();
        }
        else {}
        if (f && fled.Released) {
          fled = State.Pressed;
          fluo.pressed();
        }
        else if (!f && fled.Pressed) {
          fled = State.Released;
          fluo.released();
        }
      }
    }
  }

}

component PedalList {
  provides IPedal one;
  provides IPedal two;
  provides IPedal three;
  requires IPedal pedal;

  system {
    namePedalPair demux1;
    namePedalPair demux2;

    one <=> demux1.left;
    two <=> demux1.right;
    three <=> demux2.right;
    demux1.pedal <=> demux2.left;
    demux2.pedal <=> pedal;
  }
}

component PedalConfig {
  provides IPedal activation1;
  provides IPedal activation2;
  provides IPedal activation3;
  provides IPedal fluo1;
  provides IPedal fluo2;
  provides IPedal fluo3;
  requires IPedal activation;
  requires IPedal fluo;

  system {
    namePedalList activationPedals;
    namePedalList fluoPedals;

    activation1 <=> activationPedals.one;
    activation2 <=> activationPedals.two;
    activation3 <=> activationPedals.three;
    activationPedals.pedal <=> activation;
    fluo1 <=> fluoPedals.one;
    fluo2 <=> fluoPedals.two;
    fluo3 <=> fluoPedals.three;
    fluoPedals.pedal <=> fluo;
  }
}

component ASC {
  provides IPedal activation1;
  provides IPedal activation2;
  provides IPedal activation3;
  provides IPedal fluo1;
  provides IPedal fluo2;
  provides IPedal fluo3;
  requires IFunctional functional;
  requires IAsync async;

  system {
    namePedalConfig config;
    nameAcquisition acquisition;

    activation1 <=> config.activation1;
    activation2 <=> config.activation2;
    activation3 <=> config.activation3;
    fluo1 <=> config.fluo1;
    fluo2 <=> config.fluo2;
    fluo3 <=> config.fluo3;
    config.activation <=> acquisition.activation;
    config.fluo <=> acquisition.fluo;
    acquisition.functional <=> functional;
    acquisition.async <=> async;
  }
}

component System {
  provides IPedal c1;
  provides IPedal c2;
  provides IPedal c3;
  requires IFunctional functional;
  requires IAsync async;

  system {
    nameClient client1;
    nameClient client2;
    nameClient client3;
    nameASC asc;

    c1 <=> client1.pedal;
    c2 <=> client2.pedal;
    c3 <=> client3.pedal;
    client1.left <=> asc.activation1;
    client1.right <=> asc.activation2;
    client2.left <=> asc.activation3;
    client2.right <=> asc.fluo1;
    client3.left <=> asc.fluo2;
    client3.right <=> asc.fluo3;
    asc.functional <=> functional;
    asc.async <=> async;
  }
}

