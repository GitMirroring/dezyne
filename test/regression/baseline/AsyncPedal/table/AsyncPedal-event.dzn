interface IPedal {
  in void press();
  in void release();
  out void pressed();
  out void released();

  behaviour {
    enum State {Pressed, Released};
    State pedal = State.Released;
    State led = State.Released;

    on press:
    {
      [pedal.Pressed]
      illegal;
      [pedal.Released]
      pedal = State.Pressed;

    }
    on release:
    {
      [pedal.Pressed]
      pedal = State.Released;
      [pedal.Released]
      illegal;

    }
    on optional:
    {
      [pedal.Released || pedal.Pressed]
      [led.Released]
      {
        led = State.Pressed;
        pressed;

      }
      [pedal.Released]
      [led.Pressed]
      {
        led = State.Released;
        released;

      }

    }
  }
}

interface IFunctional {
  in void signal();
  in void nosignal();

  behaviour {

    on signal:
    [true]
    {}
    on nosignal:
    [true]
    {}
  }
}

interface IAsync {
  in void ping();
  out void pong();

  behaviour {
    bool pending = false;

    on ping:
    {
      [!pending]
      pending = true;
      [pending]
      illegal;

    }
    on inevitable:
    [pending]
    {
      pong;
      pending = false;

    }
  }
}

component Client {
  provides IPedal pedal;
  requires IPedal left;
  requires IPedal right;

  behaviour {
    enum State {Pressed, Released};
    enum Side {Left, Right};
    State state = State.Released;
    Side side = Side.Right;

    on pedal.press():
    {
      [state.Pressed]
      illegal;
      [state.Released]
      {
        [side.Left]
        {
          left.press();
          state = State.Pressed;

        }
        [side.Right]
        {
          right.press();
          state = State.Pressed;

        }

      }

    }
    on pedal.release():
    {
      [state.Pressed]
      {
        [side.Left]
        {
          left.release();
          state = State.Released;

        }
        [side.Right]
        {
          right.release();
          state = State.Released;

        }

      }
      [state.Released]
      illegal;

    }
    on left.pressed():
    {
      [state.Released || state.Pressed]
      if (side.Left) pedal.pressed();

    }
    on left.released():
    {
      [state.Released || state.Pressed]
      if (side.Left) pedal.released();

    }
    on right.pressed():
    {
      [state.Released || state.Pressed]
      if (side.Right) pedal.pressed();

    }
    on right.released():
    {
      [state.Released || state.Pressed]
      if (side.Right) pedal.released();

    }
  }

}

component PedalPair {
  provides IPedal left;
  provides IPedal right;
  requires IPedal pedal;

  behaviour {
    bool left_pressed = false;
    bool right_pressed = false;

    on left.press():
    {
      [!left_pressed]
      {
        left_pressed = true;
        if (!right_pressed) pedal.press();

      }
      [left_pressed]
      illegal;

    }
    on right.press():
    {
      [!left_pressed]
      {
        [!right_pressed]
        {
          right_pressed = true;
          pedal.press();

        }
        [otherwise]
        illegal;

      }
      [left_pressed]
      {
        [!right_pressed]
        right_pressed = true;
        [otherwise]
        illegal;

      }

    }
    on left.release():
    {
      [!left_pressed]
      illegal;
      [left_pressed]
      {
        left_pressed = false;
        if (!right_pressed) pedal.release();

      }

    }
    on right.release():
    {
      [!left_pressed]
      {
        [right_pressed]
        {
          right_pressed = false;
          pedal.release();

        }
        [otherwise]
        illegal;

      }
      [left_pressed]
      {
        [right_pressed]
        right_pressed = false;
        [otherwise]
        illegal;

      }

    }
    on pedal.pressed():
    {
      [left_pressed || !left_pressed]
      {
        left.pressed();
        right.pressed();

      }

    }
    on pedal.released():
    {
      [left_pressed || !left_pressed]
      {
        left.released();
        right.released();

      }

    }
  }

}

component Acquisition {
  provides IPedal activation;
  provides IPedal fluo;
  requires IFunctional functional;
  requires IAsync async;

  behaviour {
    enum State {Pressed, Released};
    State aled = State.Released;
    State fled = State.Released;
    bool p = false;
    bool a = false;
    bool f = false;

    on activation.press():
    {
      [aled.Released || aled.Pressed]
      {
        [!a]
        {
          if (!p) {
            async.ping();
            p = true;

          }
          a = true;
          if (f) functional.signal();

        }
        [otherwise]
        illegal;

      }

    }
    on activation.release():
    {
      [aled.Released || aled.Pressed]
      {
        [a]
        {
          if (!p) {
            async.ping();
            p = true;

          }
          a = false;
          if (f) functional.nosignal();

        }
        [otherwise]
        illegal;

      }

    }
    on fluo.press():
    {
      [aled.Released || aled.Pressed]
      {
        [!f]
        {
          if (!p) {
            async.ping();
            p = true;

          }
          f = true;
          if (a) functional.signal();

        }
        [otherwise]
        illegal;

      }

    }
    on fluo.release():
    {
      [aled.Released || aled.Pressed]
      {
        [f]
        {
          if (!p) {
            async.ping();
            p = true;

          }
          f = false;
          if (a) functional.nosignal();

        }
        [otherwise]
        illegal;

      }

    }
    on async.pong():
    {
      [aled.Pressed]
      {
        p = false;
        if (!a) {
          aled = State.Released;
          activation.released();

        }
        if (f && fled.Released) {
          fled = State.Pressed;
          fluo.pressed();

        }
        else
        if (!f && fled.Pressed) {
          fled = State.Released;
          fluo.released();

        }

      }
      [aled.Released]
      {
        p = false;
        if (a) {
          aled = State.Pressed;
          activation.pressed();

        }
        else
        {}
        if (f && fled.Released) {
          fled = State.Pressed;
          fluo.pressed();

        }
        else
        if (!f && fled.Pressed) {
          fled = State.Released;
          fluo.released();

        }

      }

    }
  }

}

component PedalList {
  provides IPedal one;
  provides IPedal two;
  provides IPedal three;
  requires IPedal pedal;

  system {
    namePedalPair demux1;
    namePedalPair demux2;

    one <=> demux1.left;
    two <=> demux1.right;
    three <=> demux2.right;
    demux1.pedal <=> demux2.left;
    demux2.pedal <=> pedal;
  }
}

component PedalConfig {
  provides IPedal activation1;
  provides IPedal activation2;
  provides IPedal activation3;
  provides IPedal fluo1;
  provides IPedal fluo2;
  provides IPedal fluo3;
  requires IPedal activation;
  requires IPedal fluo;

  system {
    namePedalList activationPedals;
    namePedalList fluoPedals;

    activation1 <=> activationPedals.one;
    activation2 <=> activationPedals.two;
    activation3 <=> activationPedals.three;
    activationPedals.pedal <=> activation;
    fluo1 <=> fluoPedals.one;
    fluo2 <=> fluoPedals.two;
    fluo3 <=> fluoPedals.three;
    fluoPedals.pedal <=> fluo;
  }
}

component ASC {
  provides IPedal activation1;
  provides IPedal activation2;
  provides IPedal activation3;
  provides IPedal fluo1;
  provides IPedal fluo2;
  provides IPedal fluo3;
  requires IFunctional functional;
  requires IAsync async;

  system {
    namePedalConfig config;
    nameAcquisition acquisition;

    activation1 <=> config.activation1;
    activation2 <=> config.activation2;
    activation3 <=> config.activation3;
    fluo1 <=> config.fluo1;
    fluo2 <=> config.fluo2;
    fluo3 <=> config.fluo3;
    config.activation <=> acquisition.activation;
    config.fluo <=> acquisition.fluo;
    acquisition.functional <=> functional;
    acquisition.async <=> async;
  }
}

component System {
  provides IPedal c1;
  provides IPedal c2;
  provides IPedal c3;
  requires IFunctional functional;
  requires IAsync async;

  system {
    nameClient client1;
    nameClient client2;
    nameClient client3;
    nameASC asc;

    c1 <=> client1.pedal;
    c2 <=> client2.pedal;
    c3 <=> client3.pedal;
    client1.left <=> asc.activation1;
    client1.right <=> asc.activation2;
    client2.left <=> asc.activation3;
    client2.right <=> asc.fluo1;
    client3.left <=> asc.fluo2;
    client3.right <=> asc.fluo3;
    asc.functional <=> functional;
    asc.async <=> async;
  }
}

