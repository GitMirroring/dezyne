// Code:

interface I {
  in void e();
  out void fix();
  out void g();

  behaviour {

    on e:
    [true]
    {}
  }
}

interface II {
  in void e();

  behaviour {

    on e:
    [true]
    {}
  }
}

component combinedon {
  provides II p;
  requires I a;
  requires I b;

  behaviour {

    on p.e():
    [true]
    {}
    on a.fix():
    [true]
    {}
    on b.fix():
    [true]
    {}
    on a.g():
    [true]
    illegal;
    on b.g():
    [true]
    illegal;
  }
}

