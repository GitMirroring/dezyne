interface ITauEmitMulti
{
  out void a();
  out void b();
  in void c();
  out void d();
  in void e();

  behaviour 
  {
    bool isWaiting = false;
    on inevitable:
    [!isWaiting]
    {
      a;
      isWaiting = true;
      b;
    }
    on c:
    {
      [!isWaiting]
      illegal;
      [isWaiting]
      {
        d;
        isWaiting = false;
      }
    }
    on e:
    {
      [!isWaiting]
      {
      }
      [isWaiting]
      illegal;
    }
  }
}
interface ITauEmitSingle
{
  out void a();
  in void c();

  behaviour 
  {
    bool isWaiting = false;
    on inevitable:
    [!isWaiting]
    {
      a;
      isWaiting = true;
    }
    on c:
    {
      [!isWaiting]
      illegal;
      [isWaiting]
      isWaiting = false;
    }
  }
}
interface IDummy
{
  in void start();

  behaviour 
  {
    on start:
    [true]
    {
    }
  }
}
component TauEmitMultiple
{
  provides IDummy ctrl;
  requires ITauEmitMulti rpa;
  requires ITauEmitSingle rps;

  behaviour 
  {
    bool expect_b = false;
    bool expect_d = false;
    on ctrl.start():
    {
      [expect_b || !expect_b]
      {
      }
    }
    on rpa.a():
    {
      [expect_b || !expect_b]
      {
        expect_b = true;
        rpa.c();
        expect_d = true;
      }
    }
    on rpa.b():
    {
      [!expect_b]
      illegal;
      [expect_b]
      {
      }
    }
    on rpa.d():
    {
      [expect_b || !expect_b]
      {
        [expect_d]
        rpa.e();
        [otherwise]
        illegal;
      }
    }
    on rps.a():
    {
      [expect_b || !expect_b]
      rps.c();
    }
  }
}

