interface ITauEmitMulti
{
  out void a();
  out void b();
  in void c();
  out void d();
  in void e();

  behaviour 
  {
    bool isWaiting = false;
    [!isWaiting]
    {
      on inevitable:
      {
        a;
        isWaiting = true;
        b;
      }
      on c:
      illegal;
      on e:
      {
      }
    }
    [isWaiting]
    {
      on c:
      {
        d;
        isWaiting = false;
      }
      on e:
      illegal;
    }
  }
}
interface ITauEmitSingle
{
  out void a();
  in void c();

  behaviour 
  {
    bool isWaiting = false;
    [!isWaiting]
    {
      on optional:
      {
        a;
        isWaiting = true;
      }
      on c:
      illegal;
    }
    [isWaiting]
    on c:
    isWaiting = false;
  }
}
interface IDummy
{
  in void start();

  behaviour 
  {
    [true]
    on start:
    {
    }
  }
}
component TauEmitMultiple
{
  provides IDummy ctrl;
  requires ITauEmitMulti rpa;
  requires ITauEmitSingle rps;

  behaviour 
  {
    bool expect_b = false;
    bool expect_d = false;
    [!expect_b]
    {
      on ctrl.start():
      {
      }
      on rpa.a():
      {
        expect_b = true;
        rpa.c();
        expect_d = true;
      }
      on rpa.b():
      illegal;
      on rpa.d():
      {
        [expect_d]
        rpa.e();
        [otherwise]
        illegal;
      }
      on rps.a():
      rps.c();
    }
    [expect_b]
    {
      on ctrl.start(), rpa.b():
      {
      }
      on rpa.a():
      {
        expect_b = true;
        rpa.c();
        expect_d = true;
      }
      on rpa.d():
      {
        [expect_d]
        rpa.e();
        [otherwise]
        illegal;
      }
      on rps.a():
      rps.c();
    }
  }
}

