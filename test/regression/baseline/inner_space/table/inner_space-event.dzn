// Code:

interface inner.foo.I {
  enum Bool {f, t};
  in .Bool e();
  out void a();

  behaviour {

    on e:
    [true]
    {
      a;
      reply(.Bool.t);
    }
  }
}

interface foo.I {
  enum Bool {F, T};
  in .Bool e();
  out void a();

  behaviour {

    on e:
    [true]
    {
      a;
      reply(.Bool.T);
    }
  }
}

component inner.space {
  provides inner_foo_I inner;
  provides foo_I fooi;

  behaviour {
    foo.I.Bool inner_state = foo.I.Bool.t;
    .foo.I.Bool foo_state = .foo.I.Bool.T;

    on inner.e():
    {
      [inner_state.t || inner_state.f]
      {
        inner.a();
        reply(inner_state);
      }
    }
    on fooi.e():
    {
      [inner_state.t || inner_state.f]
      {
        fooi.a();
        reply(foo_state);
      }
    }
  }

}

component bar.c {
  provides foo_I i;

  behaviour {
    .foo.I.Bool state = .foo.I.Bool.T;

    on i.e():
    {
      [state.T || state.F]
      {
        i.a();
        reply(state);
      }
    }
  }

}

