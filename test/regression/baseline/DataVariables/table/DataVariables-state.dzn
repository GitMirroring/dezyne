interface IDataVariables {
  extern integer $int$;
  extern boolean $int$;
  extern string $int$;
  extern DataVariableType $int$;
  in void inInt(integer number);
  in void outBool(out boolean condition);
  in void inoutString(inout string text);
  out void inDataVariable(DataVariableType dv);

  behaviour {

    [true]
    {
      on inInt, outBool, inoutString:
      {}
      on optional:
      inDataVariable;

    }
  }
}

component DataVariables {
  provides IDataVariables pp;
  requires IDataVariables rp;

  behaviour {
    IDataVariables.integer idv = $42$;
    IDataVariables.boolean bdv = ;
    IDataVariables.string sdv = $0$;
    IDataVariables.DataVariableType dvtdv = $0$;

    void f(inout IDataVariables.string s) {
      s = $1$;
      rp.inoutString(s);
      return false;

    }

    [true]
    {
      on pp.inInt(idv):
      {}
      on pp.outBool(bdv):
      bdv = $0$;
      on pp.inoutString(s):
      {
        IDataVariables.string local = s;
        f, (local), falses = local;

      }
      on rp.inDataVariable(idv):
      pp.inDataVariable(dvtdv);

    }
  }

}

