// Code:

interface IChoice {
  enum Style {State, Mixed, Event};
  in Style choose();
  out void ss();
  out void sm();
  out void se();
  out void es();
  out void em();
  out void ee();
  out void ms();
  out void mm();
  out void me();

  behaviour {
    Style preference = Style.State;

    on choose:
    {
      [preference.State]
      {
        preference = Style.State;
        ss;
        reply(preference);

      }
      [preference.State]
      {
        preference = Style.Mixed;
        sm;
        reply(preference);

      }
      [preference.State]
      {
        preference = Style.Event;
        se;
        reply(preference);

      }
      [preference.Mixed]
      {
        preference = Style.State;
        ms;
        reply(preference);

      }
      [preference.Mixed]
      {
        [true]
        {
          preference = Style.Mixed;
          mm;
          reply(preference);

        }
        [true]
        {
          preference = Style.Event;
          me;
          reply(preference);

        }

      }
      [preference.Event]
      {
        preference = Style.State;
        es;
        reply(preference);

      }
      [preference.Event]
      {
        preference = Style.Mixed;
        em;
        reply(preference);

      }
      [preference.Event]
      {
        preference = Style.Event;
        ee;
        reply(preference);

      }

    }
  }
}

