interface ClientIF
{
  enum Result { OK, NOK };
  in Result startAll();

  behaviour 
  {
    enum States { All };
    [true]
    on startAll:
    {
      reply(Result.OK);
      reply(Result.NOK);
    }
  }
}
interface DeviceIF
{
  enum Result { OK, NOK };
  in void turnon();
  in void turnoff();
  out void ok();
  out void nok();

  behaviour 
  {
    enum State { Off, On };
    State state = State.Off;
    [state.Off]
    {
      on turnon:
      {
        [true]
        {
          ok;
          state = State.On;
        }
        [true]
        nok;
      }
      on turnoff:
      illegal;
    }
    [state.On]
    {
      on turnon:
      illegal;
      on turnoff:
      state = State.Off;
    }
  }
}
component OutEventSetReply
{
  provides ClientIF clientIF;
  requires DeviceIF deviceIF;

  behaviour 
  {
    subint Count {0..5};
    enum States { Idle, Starting, Retrying, Started };
    States state = States.Idle;
    Count count = 0;
    [state.Idle]
    {
      on clientIF.startAll():
      {
        count = 0;
        deviceIF.turnon();
        state = States.Starting;
      }
      on deviceIF.ok(), deviceIF.nok():
      illegal;
    }
    [state.Starting]
    {
      on clientIF.startAll():
      illegal;
      on deviceIF.ok():
      state = States.Started;
      on deviceIF.nok():
      {
        state = States.Retrying;
        count = count + 1;
        deviceIF.turnon();
      }
    }
    [state.Retrying]
    {
      on clientIF.startAll():
      illegal;
      on deviceIF.ok():
      {
      }
      on deviceIF.nok():
      if (count < 5)
      {
        count = count + 1;
        deviceIF.turnon();
      }
      else
      reply(ClientIF.Result.NOK);
    }
  }
}

