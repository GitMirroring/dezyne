interface RGuardthreetopon
{
  in void e();
  out void a();

  behaviour 
  {
    [true]
    on e:
    illegal;
  }
}
interface IGuardthreetopon
{
  in void e();
  in void t();
  in void s();
  out void a();

  behaviour 
  {
    bool b = false;
    [!b]
    on e, t, s:
    a;
    [b]
    on e, t, s:
    a;
  }
}
component Guardthreetopon
{
  provides IGuardthreetopon i;
  requires RGuardthreetopon r;

  behaviour 
  {
    bool b = false;
    [!b]
    {
      on i.e():
      {
        bool c = true;
        if (c)
        i.a();
      }
      on i.t(), i.s():
      i.a();
      on r.a():
      {
      }
    }
    [b]
    {
      on i.e(), i.t(), i.s():
      i.a();
      on r.a():
      {
      }
    }
  }
}

