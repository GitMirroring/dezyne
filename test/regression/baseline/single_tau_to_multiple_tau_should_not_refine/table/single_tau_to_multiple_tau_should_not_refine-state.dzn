interface isingle_tau_to_multiple_tau_should_not_refine {
  in void e();
  out void c();

  behaviour {
    bool b = true;

    [!b]
    on e:
    b = !b;
    [b]
    {
      on e:
      b = !b;
      on inevitable:
      c;
    }
  }
}

component single_tau_to_multiple_tau_should_not_refine {
  provides isingle_tau_to_multiple_tau_should_not_refine p;
  requires isingle_tau_to_multiple_tau_should_not_refine r;

  behaviour {

    [true]
    {
      on p.e():
      r.e();
      on r.c():
      {
        p.c();
        p.c();
      }
    }
  }

}

