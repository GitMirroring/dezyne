interface IIterator {
  extern ListElement $int$;
  enum IsPastEnd {Yes, No};
  in IsPastEnd getFirstElmt(ListElement elmt);
  in IsPastEnd getNextElmt(ListElement elmt);

  behaviour {
    IsPastEnd isPastEnd = IsPastEnd.Yes;

    on getFirstElmt:
    {
      [isPastEnd.No || isPastEnd.Yes]
      {
        isPastEnd = IsPastEnd.No;
        reply(isPastEnd);

      }
      [isPastEnd.No || isPastEnd.Yes]
      {
        isPastEnd = IsPastEnd.Yes;
        reply(isPastEnd);

      }

    }
    on getNextElmt:
    {
      [isPastEnd.No || isPastEnd.Yes]
      reply(isPastEnd);
      [isPastEnd.No]
      {
        isPastEnd = IsPastEnd.Yes;
        reply(isPastEnd);

      }

    }
  }
}

interface IDriver {
  in void step();

  behaviour {

    on step:
    [true]
    {}
  }
}

component SynchronousLivelock {
  provides IDriver pp;
  requires IIterator listIt;

  behaviour {

    nameIIteratorIsPastEnd consumeListHead() {
      IIterator.ListElement elmt = ;
      IIterator.IsPastEnd v = listIt.getFirstElmt(elmt);
      return v;

    }

    void consumeListTail(IIterator.IsPastEnd pastEnd) {
      if (pastEnd == IIterator.IsPastEnd.No) {
        IIterator.ListElement elmt = ;
        pastEnd = listIt.getNextElmt(elmt);
        consumeListTail, (pastEnd), false
      }
      return false;

    }

    on pp.step():
    [true]
    {
      IIterator.IsPastEnd ipe = consumeListHead();
      consumeListTail, (ipe), false
    }
  }

}

