interface I {
  enum Status {Yes, No};
  in Status done();

  behaviour {
    bool dummy = false;

    nameIStatus fun() {
      return Status.Yes;

    }

    nameIStatus fun_arg(Status s) {
      return s;

    }

    on done:
    {
      [dummy || !dummy]
      {
        [true]
        {
          Status s = fun();
          reply(s);

        }
        [true]
        {
          Status s = fun_arg(Status.No);
          reply(s);

        }

      }

    }
  }
}

interface U {
  enum Status {Ok, Nok};
  in Status what();

  behaviour {
    bool dummy = false;

    nameUStatus fun() {
      return Status.Ok;

    }

    nameUStatus fun_arg(Status s) {
      return s;

    }

    on what:
    {
      [dummy || !dummy]
      {
        [true]
        {
          Status s = fun();
          reply(s);

        }
        [true]
        {
          Status s = fun_arg(Status.Nok);
          reply(s);

        }

      }

    }
  }
}

component Reply5 {
  provides I i;
  requires U u;

  behaviour {
    bool dummy = false;

    nameIStatus fun() {
      return I.Status.Yes;

    }

    nameIStatus fun_arg(I.Status s) {
      return s;

    }

    on i.done():
    {
      [dummy || !dummy]
      {
        U.Status s = u.what();
        s = u.what();
        if (s == U.Status.Ok) {
          I.Status s = fun();
          reply(s);

        }
        else
        {
          I.Status s = fun_arg(I.Status.No);
          reply(s);

        }

      }

    }
  }

}

