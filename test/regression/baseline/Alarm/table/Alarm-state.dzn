interface IConsole {
  in void arm();
  in void disarm();
  out void detected();
  out void deactivated();

  behaviour {
    enum States {Disarmed, Armed, Triggered, Disarming};
    States state = States.Disarmed;

    [state.Disarmed]
    {
      on arm:
      state = States.Armed;
      on disarm:
      illegal;
    }
    [state.Armed]
    {
      on arm:
      illegal;
      on disarm:
      state = States.Disarming;
      on optional:
      {
        detected;
        state = States.Triggered;
      }
    }
    [state.Triggered]
    {
      on arm:
      illegal;
      on disarm:
      state = States.Disarming;
    }
    [state.Disarming]
    {
      on arm, disarm:
      illegal;
      on inevitable:
      {
        deactivated;
        state = States.Disarmed;
      }
    }
  }
}

interface ISensor {
  in void enable();
  in void disable();
  out void triggered();
  out void disabled();

  behaviour {
    enum States {Disabled, Enabled, Disabling, Triggered};
    States state = States.Disabled;

    [state.Disabled]
    {
      on enable:
      state = States.Enabled;
      on disable:
      illegal;
    }
    [state.Enabled]
    {
      on enable:
      illegal;
      on disable:
      state = States.Disabling;
      on optional:
      {
        triggered;
        state = States.Triggered;
      }
    }
    [state.Disabling]
    {
      on enable, disable:
      illegal;
      on inevitable:
      {
        disabled;
        state = States.Disabled;
      }
    }
    [state.Triggered]
    {
      on enable:
      illegal;
      on disable:
      state = States.Disabling;
    }
  }
}

interface ISiren {
  in void turnon();
  in void turnoff();

  behaviour {
    enum States {Off, On};
    States state = States.Off;

    [state.Off]
    {
      on turnon:
      state = States.On;
      on turnoff:
      illegal;
    }
    [state.On]
    {
      on turnon:
      illegal;
      on turnoff:
      state = States.Off;
    }
  }
}

component Alarm {
  provides IConsole console;
  requires ISensor sensor;
  requires ISiren siren;

  behaviour {
    enum States {Disarmed, Armed, Triggered, Disarming};
    States state = States.Disarmed;
    bool sounding = false;

    [state.Disarmed]
    {
      on console.arm():
      {
        sensor.enable();
        state = States.Armed;
      }
      on console.disarm(), sensor.triggered(), sensor.disabled():
      illegal;
    }
    [state.Armed]
    {
      on console.arm(), sensor.disabled():
      illegal;
      on console.disarm():
      {
        sensor.disable();
        state = States.Disarming;
      }
      on sensor.triggered():
      {
        console.detected();
        siren.turnon();
        sounding = true;
        state = States.Triggered;
      }
    }
    [state.Triggered]
    {
      on console.arm(), sensor.triggered(), sensor.disabled():
      illegal;
      on console.disarm():
      {
        sensor.disable();
        siren.turnoff();
        sounding = false;
        state = States.Disarming;
      }
    }
    [state.Disarming]
    {
      on console.arm(), console.disarm():
      illegal;
      on sensor.triggered():
      {}
      on sensor.disabled():
      {
        [sounding]
        {
          console.deactivated();
          siren.turnoff();
          state = States.Disarmed;
          sounding = false;
        }
        [otherwise]
        {
          console.deactivated();
          state = States.Disarmed;
        }
      }
    }
  }

}

