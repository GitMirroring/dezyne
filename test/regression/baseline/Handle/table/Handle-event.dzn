interface IHandle
{
  in void calibrate();
  out void calibrated();
  in void stop();
  in void operate();
  out void finished();

  behaviour 
  {
    enum State { Lost, Calibrating, Idle, Operating };
    State s = State.Lost;
    on stop:
    {
      [s.Operating || s.Idle || s.Calibrating || s.Lost]
      s = State.Lost;
    }
    on calibrate:
    {
      [s.Lost]
      s = State.Calibrating;
      [s.Lost]
      {
        calibrated;
        s = State.Idle;
      }
      [s.Operating || s.Idle || s.Calibrating]
      illegal;
      [s.Operating || s.Idle || s.Calibrating]
      {
      }
    }
    on operate:
    {
      [s.Operating || s.Calibrating || s.Lost]
      illegal;
      [s.Operating || s.Calibrating || s.Lost]
      {
      }
      [s.Idle]
      s = State.Operating;
      [s.Idle]
      finished;
    }
    on inevitable:
    {
      [s.Calibrating]
      {
        calibrated;
        s = State.Idle;
      }
      [s.Operating]
      {
        s = State.Idle;
        finished;
      }
    }
  }
}
interface ITransfer
{
  extern TrPosition $int32_t$;
  in void calibrate();
  out void calibrated();
  in void stop();
  in void move(TrPosition x,TrPosition y);
  out void arrived();
  in void transfer(TrPosition x,TrPosition y);
  out void picked();
  out void placed();

  behaviour 
  {
    enum State { Lost, Calibrating, Ready, Moving, Transferring };
    State s = State.Lost;
    bool isPicked = false;
    on stop:
    {
      [s.Transferring || s.Moving || s.Ready || s.Calibrating || s.Lost]
      s = State.Lost;
    }
    on calibrate:
    {
      [s.Lost]
      s = State.Calibrating;
      [s.Lost]
      {
        calibrated;
        s = State.Ready;
      }
      [s.Transferring || s.Moving || s.Ready || s.Calibrating]
      illegal;
    }
    on move:
    {
      [s.Transferring || s.Moving || s.Calibrating || s.Lost]
      illegal;
      [s.Ready]
      s = State.Moving;
      [s.Ready]
      arrived;
    }
    on transfer:
    {
      [s.Transferring || s.Moving || s.Calibrating || s.Lost]
      illegal;
      [s.Ready]
      {
        s = State.Transferring;
        isPicked = false;
      }
      [s.Ready]
      {
        s = State.Transferring;
        picked;
        isPicked = true;
      }
      [s.Ready]
      {
        s = State.Ready;
        picked;
        placed;
      }
    }
    on inevitable:
    {
      [s.Calibrating]
      {
        calibrated;
        s = State.Ready;
      }
      [s.Moving]
      {
        arrived;
        s = State.Ready;
      }
      [s.Transferring]
      [!isPicked]
      {
        picked;
        isPicked = true;
      }
      [s.Transferring]
      [isPicked]
      {
        placed;
        s = State.Ready;
      }
    }
  }
}
interface IInspect
{
  in void calibrate();
  out void calibrated();
  in void stop();
  in void inspect();
  out void accepted();
  out void rejected();
  in void prepare();
  out void prepared();

  behaviour 
  {
    enum State { Lost, Ready, Calibrating, Inspecting, Waiting, Preparing };
    State s = State.Lost;
    on stop:
    {
      [s.Preparing || s.Waiting || s.Inspecting || s.Calibrating || s.Ready || s.Lost]
      s = State.Lost;
    }
    on calibrate:
    {
      [s.Lost]
      s = State.Calibrating;
      [s.Lost]
      {
        calibrated;
        s = State.Ready;
      }
      [s.Preparing || s.Waiting || s.Inspecting || s.Calibrating || s.Ready]
      illegal;
    }
    on inspect:
    {
      [s.Preparing || s.Waiting || s.Inspecting || s.Calibrating || s.Lost]
      illegal;
      [s.Ready]
      s = State.Inspecting;
    }
    on prepare:
    {
      [s.Preparing || s.Inspecting || s.Calibrating || s.Ready || s.Lost]
      illegal;
      [s.Waiting]
      s = State.Preparing;
      [s.Waiting]
      {
        prepared;
        s = State.Ready;
      }
    }
    on inevitable:
    {
      [s.Calibrating]
      {
        calibrated;
        s = State.Ready;
      }
      [s.Inspecting]
      {
        accepted;
        s = State.Waiting;
      }
      [s.Inspecting]
      {
        rejected;
        s = State.Waiting;
      }
      [s.Preparing]
      {
        prepared;
        s = State.Ready;
      }
    }
  }
}
interface IFeed
{
  in void calibrate();
  out void calibrated();
  in void stop();
  in void produceBall();
  out void consumeNextBall();
  out void consumeLastBall();

  behaviour 
  {
    enum State { Lost, Calibrating, Idle, Preparing, Prepared };
    State s = State.Lost;
    on stop:
    {
      [s.Prepared || s.Preparing || s.Idle || s.Calibrating || s.Lost]
      s = State.Lost;
    }
    on calibrate:
    {
      [s.Lost]
      s = State.Calibrating;
      [s.Lost]
      {
        calibrated;
        s = State.Idle;
      }
      [s.Prepared || s.Preparing || s.Idle || s.Calibrating]
      illegal;
    }
    on produceBall:
    {
      [s.Preparing || s.Calibrating || s.Lost]
      illegal;
      [s.Prepared || s.Idle]
      s = State.Preparing;
      [s.Prepared || s.Idle]
      {
        consumeNextBall;
        s = State.Prepared;
      }
      [s.Prepared || s.Idle]
      {
        consumeLastBall;
        s = State.Idle;
      }
    }
    on inevitable:
    {
      [s.Calibrating]
      {
        calibrated;
        s = State.Idle;
      }
      [s.Preparing]
      {
        consumeNextBall;
        s = State.Prepared;
      }
      [s.Preparing]
      {
        consumeLastBall;
        s = State.Idle;
      }
    }
  }
}
interface IConvey
{
  in void convey();
  out void conveyed();
  in void stop();

  behaviour 
  {
    enum State { Idle, Conveying };
    State s = State.Idle;
    on stop:
    {
      [s.Conveying || s.Idle]
      s = State.Idle;
    }
    on convey:
    {
      [s.Idle]
      s = State.Conveying;
      [s.Idle]
      conveyed;
      [s.Conveying]
      illegal;
    }
    on inevitable:
    [s.Conveying]
    {
      conveyed;
      s = State.Idle;
    }
  }
}
component Handle
{
  provides IHandle ctrl;
  requires ITransfer robot;
  requires IInspect inspector;
  requires IFeed feedPort;
  requires IConvey acceptPort;
  requires IConvey rejectPort;

  behaviour 
  {
    enum State { Lost, Calibrating, Idle, Operating };
    subint usedCount {0..4};
    enum Operation { PreparingInput, TransferringInput, PreparingOutput, TransferringOutput, Finalizing };
    State s = State.Lost;
    usedCount calibrated = 0;
    usedCount requiredCalibrations = 3;
    Operation o = Operation.PreparingInput;
    bool isLastBall = false;
    bool isBallAtInput = false;
    bool isRobotAtInput = false;
    bool isRobotAtOutput = false;
    bool isInspectorAtInput = false;
    bool isInspectorAtOutput = false;
    bool isBallAccepted = false;
    bool isAcceptEmpty = true;
    bool isRejectEmpty = true;
    void tryCalibrated()
    {
      calibrated = calibrated + 1;
      if (calibrated == requiredCalibrations)
      {
        s = State.Idle;
        isInspectorAtInput = true;
        isInspectorAtOutput = false;
        ctrl.calibrated();
      }
      return;
    }

    void ignoreIllegal()
    {
      return;
    }

    void startBatch()
    {
      s = State.Operating;
      isLastBall = false;
      prepareInputTransfer();
      return;
    }

    void finalizeBatch()
    {
      s = State.Idle;
      ctrl.finished();
      return;
    }

    void prepareInputTransfer()
    {
      o = Operation.PreparingInput;
      if (!isBallAtInput)
      {
        feedPort.produceBall();
        isBallAtInput = false;
      }
      if (!isInspectorAtInput)
      {
        inspector.prepare();
        isInspectorAtInput = false;
      }
      if (!isRobotAtInput)
      {
        sendRobotToInputPick();
        isRobotAtInput = false;
      }
      tryInputTransfer();
      return;
    }

    void sendRobotToInputPick()
    {
      robot.move($config("Position::Robot::X::InputPick")$,$config("Position::Robot::Y::InputPick")$);
      isRobotAtOutput = false;
      isRobotAtInput = false;
      return;
    }

    void tryInputTransfer()
    {
      if ((isBallAtInput && isRobotAtInput) && isInspectorAtInput)
      {
        robot.transfer($config("Position::Robot::X::InputDrop")$,$config("Position::Robot::Y::InputDrop")$);
        o = Operation.TransferringInput;
      }
      return;
    }

    void tryOutputTransfer()
    {
      if (isRobotAtOutput && isInspectorAtOutput)
      {
        if (isAcceptEmpty && isBallAccepted)
        {
          robot.transfer($config("Position::Robot::X::OutputDrop")$,$config("Position::Robot::Y::AcceptDrop")$);
          o = Operation.TransferringOutput;
        }
        if (isRejectEmpty && !isBallAccepted)
        {
          robot.transfer($config("Position::Robot::X::OutputDrop")$,$config("Position::Robot::Y::RejectDrop")$);
          o = Operation.TransferringOutput;
        }
      }
      return;
    }

    void tryFinished()
    {
      if (((((isLastBall && !isBallAtInput) && isAcceptEmpty) && isRejectEmpty) && isRobotAtInput) && isInspectorAtInput)
      {
        s = State.Idle;
        ctrl.finished();
      }
      return;
    }

    void manuallyRemoveStrayMaterial()
    {
      isBallAtInput = false;
      isAcceptEmpty = true;
      isRejectEmpty = true;
      return;
    }

    on ctrl.stop():
    {
      [s.Operating || s.Idle || s.Calibrating || s.Lost]
      {
        robot.stop();
        inspector.stop();
        feedPort.stop();
        acceptPort.stop();
        rejectPort.stop();
        s = State.Lost;
        manuallyRemoveStrayMaterial();
      }
    }
    on ctrl.calibrate():
    {
      [s.Lost]
      {
        robot.calibrate();
        inspector.calibrate();
        feedPort.calibrate();
        calibrated = 0;
        s = State.Calibrating;
      }
      [s.Operating || s.Idle || s.Calibrating]
      ignoreIllegal();
    }
    on ctrl.operate():
    {
      [s.Operating || s.Calibrating || s.Lost]
      ignoreIllegal();
      [s.Idle]
      startBatch();
    }
    on robot.arrived():
    {
      [s.Idle || s.Calibrating || s.Lost]
      illegal;
      [s.Operating]
      [o.PreparingInput]
      {
        isRobotAtInput = true;
        tryInputTransfer();
      }
      [s.Operating]
      [o.TransferringInput]
      illegal;
      [s.Operating]
      [o.PreparingOutput]
      {
        isRobotAtOutput = true;
        tryOutputTransfer();
      }
      [s.Operating]
      [o.TransferringOutput]
      illegal;
      [s.Operating]
      [o.Finalizing]
      {
        isRobotAtInput = true;
        tryFinished();
      }
    }
    on robot.picked():
    {
      [s.Idle || s.Calibrating || s.Lost]
      illegal;
      [s.Operating]
      [o.PreparingInput]
      illegal;
      [s.Operating]
      [o.TransferringInput]
      [!isLastBall]
      {
        feedPort.produceBall();
        isBallAtInput = false;
      }
      [s.Operating]
      [o.TransferringInput]
      [isLastBall]
      isBallAtInput = false;
      [s.Operating]
      [o.PreparingOutput]
      illegal;
      [s.Operating]
      [o.TransferringOutput]
      {
        isInspectorAtOutput = false;
        inspector.prepare();
      }
      [s.Operating]
      [o.Finalizing]
      illegal;
    }
    on robot.placed():
    {
      [s.Idle || s.Calibrating || s.Lost]
      illegal;
      [s.Operating]
      [o.PreparingInput]
      illegal;
      [s.Operating]
      [o.TransferringInput]
      {
        isInspectorAtInput = false;
        inspector.inspect();
        isRobotAtInput = false;
        robot.move($config("Position::Robot::X::OutputPick")$,$config("Position::Robot::Y::OutputPick")$);
        o = Operation.PreparingOutput;
      }
      [s.Operating]
      [o.PreparingOutput]
      illegal;
      [s.Operating]
      [o.TransferringOutput]
      [isBallAccepted]
      {
        isAcceptEmpty = false;
        acceptPort.convey();
        sendRobotToInputPick();
        if (isLastBall && !isBallAtInput)
        o = Operation.Finalizing;
        else
        o = Operation.PreparingInput;
      }
      [s.Operating]
      [o.TransferringOutput]
      [!isBallAccepted]
      {
        isRejectEmpty = false;
        rejectPort.convey();
        sendRobotToInputPick();
        if (isLastBall && !isBallAtInput)
        o = Operation.Finalizing;
        else
        o = Operation.PreparingInput;
      }
      [s.Operating]
      [o.Finalizing]
      illegal;
    }
    on inspector.prepared():
    {
      [s.Idle || s.Calibrating || s.Lost]
      illegal;
      [s.Operating]
      [o.PreparingInput]
      {
        isInspectorAtInput = true;
        tryInputTransfer();
      }
      [s.Operating]
      [o.TransferringInput]
      illegal;
      [s.Operating]
      [o.PreparingOutput]
      illegal;
      [s.Operating]
      [o.TransferringOutput]
      isInspectorAtInput = true;
      [s.Operating]
      [o.Finalizing]
      {
        isInspectorAtInput = true;
        tryFinished();
      }
    }
    on inspector.accepted():
    {
      [s.Idle || s.Calibrating || s.Lost]
      illegal;
      [s.Operating]
      [o.PreparingInput]
      illegal;
      [s.Operating]
      [o.TransferringInput]
      illegal;
      [s.Operating]
      [o.PreparingOutput]
      {
        isBallAccepted = true;
        isInspectorAtOutput = true;
        tryOutputTransfer();
      }
      [s.Operating]
      [o.TransferringOutput]
      illegal;
      [s.Operating]
      [o.Finalizing]
      illegal;
    }
    on inspector.rejected():
    {
      [s.Idle || s.Calibrating || s.Lost]
      illegal;
      [s.Operating]
      [o.PreparingInput]
      illegal;
      [s.Operating]
      [o.TransferringInput]
      illegal;
      [s.Operating]
      [o.PreparingOutput]
      {
        isBallAccepted = false;
        isInspectorAtOutput = true;
        tryOutputTransfer();
      }
      [s.Operating]
      [o.TransferringOutput]
      illegal;
      [s.Operating]
      [o.Finalizing]
      illegal;
    }
    on feedPort.consumeNextBall():
    {
      [s.Idle || s.Calibrating || s.Lost]
      illegal;
      [s.Operating]
      [o.PreparingInput]
      {
        isLastBall = false;
        isBallAtInput = true;
        tryInputTransfer();
      }
      [s.Operating]
      [o.TransferringInput]
      {
        isLastBall = false;
        isBallAtInput = true;
      }
      [s.Operating]
      [o.PreparingOutput]
      {
        isLastBall = false;
        isBallAtInput = true;
      }
      [s.Operating]
      [o.TransferringOutput]
      {
        isLastBall = false;
        isBallAtInput = true;
      }
      [s.Operating]
      [o.Finalizing]
      illegal;
    }
    on feedPort.consumeLastBall():
    {
      [s.Idle || s.Calibrating || s.Lost]
      illegal;
      [s.Operating]
      [o.PreparingInput]
      {
        isLastBall = true;
        isBallAtInput = true;
        tryInputTransfer();
      }
      [s.Operating]
      [o.TransferringInput]
      {
        isLastBall = true;
        isBallAtInput = true;
      }
      [s.Operating]
      [o.PreparingOutput]
      {
        isLastBall = true;
        isBallAtInput = true;
      }
      [s.Operating]
      [o.TransferringOutput]
      {
        isLastBall = true;
        isBallAtInput = true;
      }
      [s.Operating]
      [o.Finalizing]
      illegal;
    }
    on acceptPort.conveyed():
    {
      [s.Idle || s.Calibrating || s.Lost]
      illegal;
      [s.Operating]
      [o.PreparingInput]
      isAcceptEmpty = true;
      [s.Operating]
      [o.TransferringInput]
      isAcceptEmpty = true;
      [s.Operating]
      [o.PreparingOutput]
      {
        isAcceptEmpty = true;
        tryOutputTransfer();
      }
      [s.Operating]
      [o.TransferringOutput]
      isAcceptEmpty = true;
      [s.Operating]
      [o.Finalizing]
      {
        isAcceptEmpty = true;
        tryFinished();
      }
    }
    on rejectPort.conveyed():
    {
      [s.Idle || s.Calibrating || s.Lost]
      illegal;
      [s.Operating]
      [o.PreparingInput]
      isRejectEmpty = true;
      [s.Operating]
      [o.TransferringInput]
      isRejectEmpty = true;
      [s.Operating]
      [o.PreparingOutput]
      {
        isRejectEmpty = true;
        tryOutputTransfer();
      }
      [s.Operating]
      [o.TransferringOutput]
      isRejectEmpty = true;
      [s.Operating]
      [o.Finalizing]
      {
        isRejectEmpty = true;
        tryFinished();
      }
    }
    on inspector.calibrated():
    {
      [s.Operating || s.Idle || s.Lost]
      illegal;
      [s.Calibrating]
      tryCalibrated();
    }
    on feedPort.calibrated():
    {
      [s.Operating || s.Idle || s.Lost]
      illegal;
      [s.Calibrating]
      tryCalibrated();
    }
    on robot.calibrated():
    {
      [s.Operating || s.Idle || s.Lost]
      illegal;
      [s.Calibrating]
      tryCalibrated();
    }
  }
}

