interface IBlocked {
  in void e();

  behaviour {

    on e:
    [true]
    {}
  }
}

interface IAsync {
  in void trigger();
  out void notify();

  behaviour {
    bool pending = false;

    on trigger:
    {
      [!pending]
      pending = true;
      [pending]
      illegal;
    }
    on inevitable:
    [pending]
    {
      pending = false;
      notify;
    }
  }
}

component Blocked {
  provides IBlocked provided;
  requires IAsync required;

  behaviour {

    [true]
    on provided.e():
    blocking required.trigger();
    on required.notify():
    [true]
    provided.reply();
  }
}

component BlockedSystem3 {
  provides IBlocked port1;
  provides IBlocked port2;
  provides IBlocked port3;
  requires IAsync async1;
  requires IAsync async2;
  requires IAsync async3;

  system {
    nameBlocked blocked1;
    nameBlocked blocked2;
    nameBlocked blocked3;

    blocked1.provided <=> port1;
    blocked2.provided <=> port2;
    blocked3.provided <=> port3;
    blocked1.required <=> async1;
    blocked2.required <=> async2;
    blocked3.required <=> async3;
  }
}

