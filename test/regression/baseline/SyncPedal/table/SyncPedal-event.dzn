interface IPedal {
  in void press();
  in void release();
  out void pressed();
  out void released();

  behaviour {
    enum State {Pressed, Released};
    State pedal = State.Released;

    on press:
    {
      [pedal.Pressed]
      illegal;
      [pedal.Released]
      {
        [true]
        {
          pedal = State.Pressed;
          pressed;
        }
        [true]
        pedal = State.Pressed;
      }
    }
    on release:
    {
      [pedal.Pressed]
      {
        [true]
        {
          pedal = State.Released;
          released;
        }
        [true]
        pedal = State.Released;
      }
      [pedal.Released]
      illegal;
    }
  }
}

component SyncPedal {
  provides IPedal left;
  provides IPedal right;
  requires IPedal pedal;

  behaviour {
    enum CLIENT {LEFT, RIGHT};
    CLIENT client = CLIENT.LEFT;
    bool left_pressed = false;
    bool right_pressed = false;

    on left.press():
    {
      [client.RIGHT || client.LEFT]
      [left_pressed]
      illegal;
      [client.RIGHT || client.LEFT]
      [!left_pressed && !right_pressed]
      {
        client = CLIENT.LEFT;
        left_pressed = true;
        pedal.press();
        right.pressed();
      }
      [client.RIGHT || client.LEFT]
      [!left_pressed && right_pressed]
      {
        left_pressed = true;
        left.pressed();
      }
    }
    on right.press():
    {
      [client.RIGHT || client.LEFT]
      [right_pressed]
      illegal;
      [client.RIGHT || client.LEFT]
      [!right_pressed && !left_pressed]
      {
        client = CLIENT.RIGHT;
        right_pressed = true;
        pedal.press();
      }
      [client.RIGHT || client.LEFT]
      [!right_pressed && left_pressed]
      {
        right_pressed = true;
        right.pressed();
      }
    }
    on left.release():
    {
      [client.RIGHT || client.LEFT]
      [!left_pressed]
      illegal;
      [client.RIGHT || client.LEFT]
      [left_pressed && !right_pressed]
      {
        client = CLIENT.LEFT;
        left_pressed = false;
        pedal.release();
      }
      [client.RIGHT || client.LEFT]
      [left_pressed && right_pressed]
      left_pressed = false;
    }
    on right.release():
    {
      [client.RIGHT || client.LEFT]
      [!right_pressed]
      illegal;
      [client.RIGHT || client.LEFT]
      [right_pressed && !left_pressed]
      {
        client = CLIENT.RIGHT;
        right_pressed = false;
        pedal.release();
      }
      [client.RIGHT || client.LEFT]
      [right_pressed && left_pressed]
      right_pressed = false;
    }
    on pedal.pressed():
    {
      [client.LEFT]
      left.pressed();
      [client.RIGHT]
      right.pressed();
    }
    on pedal.released():
    {
      [client.LEFT]
      left.released();
      [client.RIGHT]
      right.released();
    }
  }
}

