// Code:

interface name.I {
  enum Bool {f, t};
  in .Bool e();
  out void a();

  behaviour {

    [true]
    on e:
    {
      a;
      reply(.Bool.t);
    }
  }
}

component name.space {
  provides name_I i;

  behaviour {
    I.Bool state = I.Bool.t;

    [state.f]
    on i.e():
    {
      i.a();
      reply(I.Bool.t);
    }
    [state.t]
    on i.e():
    {
      i.a();
      reply(I.Bool.t);
    }
  }

}

