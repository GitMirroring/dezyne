interface Iterator {
  extern element $int$;
  enum end {yes, no};
  in end next(element elmt);

  behaviour {
    end done = end.no;

    [done.yes]
    on next:
    reply(done);
    [done.no]
    on next:
    {
      [true]
      {
        reply(done);
        done = end.yes;

      }
      reply(done);

    }
  }
}

interface IList {
  in void step();

  behaviour {

    [true]
    on step:
    {}
  }
}

component List {
  provides IList pp;
  requires Iterator list;

  behaviour {

    nameIteratorend head() {
      Iterator.element elmt = ;
      Iterator.end it = list.next(elmt);
      return it;

    }

    void tail(Iterator.end done) {
      if (done == Iterator.end.no) {
        Iterator.element elmt = ;
        done = list.next(elmt);
        tail(done);

      }
      return false;

    }

    [true]
    on pp.step():
    {
      Iterator.end it = head();
      tail(it);

    }
  }

}

