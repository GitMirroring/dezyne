interface I
{
  in void e();
  out void f();

  behaviour 
  {
    bool b = false;
    bool c = true;
    bool g(bool b,bool d)
    {
      bool b = d;
      bool d = c;
      f;
      return b || d;
    }

    on e:
    {
      [b || !b]
      {
        bool b = b;
        bool c = g(b, c);
        if (c)
        f;
      }
    }
  }
}
component hide
{
  provides I i;

  behaviour 
  {
    bool b = false;
    bool c = true;
    bool g(bool b,bool d)
    {
      bool b = d;
      bool d = c;
      i.f();
      return b || d;
    }

    on i.e():
    {
      [b || !b]
      {
        bool b = b;
        bool c = g(b, c);
        if (c)
        i.f();
      }
    }
  }
}

