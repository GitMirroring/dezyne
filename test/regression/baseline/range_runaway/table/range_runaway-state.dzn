interface I {
  in void e();

  behaviour {

    [true]
    on e:
    {}
  }
}

interface II {
  in void e();
  out void add();

  behaviour {

    [true]
    on e:
    {}
  }
}

component range_runaway {
  provides I p;
  requires II r;

  behaviour {
    subint Sub {0..4};
    Sub n = 5;

    [n.0]
    {
      on p.e():
      r.e();
      on r.add():
      n = n + 1;
    }
    [n.1]
    {
      on p.e():
      r.e();
      on r.add():
      n = n + 1;
    }
    [n.2]
    {
      on p.e():
      r.e();
      on r.add():
      n = n + 1;
    }
    [n.3]
    {
      on p.e():
      r.e();
      on r.add():
      n = n + 1;
    }
    [n.4]
    {
      on p.e():
      r.e();
      on r.add():
      n = n + 1;
    }
  }
}

