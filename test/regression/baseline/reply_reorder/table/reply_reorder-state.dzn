interface Provides
{
  in void start();
  out void busy();
  out void finish();

  behaviour 
  {
    [true]
    on start:
    {
      busy;
      finish;
    }
  }
}
interface Requires
{
  in void ping();
  out void pong();

  behaviour 
  {
    [true]
    on ping:
    {
      pong;
      pong;
    }
  }
}
component reply_reorder
{
  provides Provides p;
  requires Requires r;

  behaviour 
  {
    bool first = true;
    [!first]
    {
      on p.start():
      r.ping();
      on r.pong():
      {
        p.finish();
        first = !first;
      }
    }
    [first]
    {
      on p.start():
      r.ping();
      on r.pong():
      {
        p.busy();
        first = !first;
      }
    }
  }
}

