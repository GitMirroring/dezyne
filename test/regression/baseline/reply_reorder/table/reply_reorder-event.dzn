interface Provides {
  in void start();
  out void busy();
  out void finish();

  behaviour {

    on start:
    [true]
    {
      busy;
      finish;

    }
  }
}

interface Requires {
  in void ping();
  out void pong();

  behaviour {

    on ping:
    [true]
    {
      pong;
      pong;

    }
  }
}

component reply_reorder {
  provides Provides p;
  requires Requires r;

  behaviour {
    bool first = true;

    on p.start():
    {
      [first || !first]
      r.ping();

    }
    on r.pong():
    {
      [!first]
      {
        p.finish();
        first = !first;

      }
      [first]
      {
        p.busy();
        first = !first;

      }

    }
  }

}

