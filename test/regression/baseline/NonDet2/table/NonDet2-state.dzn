interface NonDet2
{
  in void stop();
  in void recover();
  out void ok();
  out void error();
  out void stopped();
  out void recovered();

  behaviour 
  {
    enum States { Ready, Stopping, Error, Recovering };
    States mainState = States.Ready;
    [mainState.Ready]
    {
      on stop:
      {
        [true]
        mainState = States.Stopping;
        [true]
        mainState = States.Error;
      }
      on recover:
      illegal;
    }
    [mainState.Stopping]
    {
      on stop, recover:
      illegal;
      on inevitable:
      {
        ok;
        mainState = States.Ready;
      }
    }
    [mainState.Error]
    {
      on stop:
      ok;
      on recover:
      {
        [true]
        mainState = States.Recovering;
        [true]
        {
        }
      }
      on inevitable:
      error;
    }
    [mainState.Recovering]
    {
      on stop, recover:
      illegal;
      on inevitable:
      {
        ok;
        mainState = States.Ready;
      }
    }
  }
}

