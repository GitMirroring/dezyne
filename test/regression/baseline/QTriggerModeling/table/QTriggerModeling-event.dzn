interface ICallEmitMulti {
  enum EmitResult {One, Two};
  in void req();
  in EmitResult reqValued();
  in void ack();
  in void done();
  out void ntfA();
  out void ntfB();

  behaviour {
    subint Counter {0..2};
    bool isWaiting = false;
    Counter pending = 0;

    on req:
    {
      [!isWaiting]
      {
        ntfA;
        ntfB;
        pending = 2;
        isWaiting = true;
      }
      [isWaiting]
      illegal;
    }
    on reqValued:
    {
      [!isWaiting]
      {
        ntfA;
        ntfB;
        pending = 2;
        isWaiting = true;
        reply(EmitResult.Two);
      }
      [isWaiting]
      illegal;
    }
    on ack:
    {
      [!isWaiting]
      illegal;
      [isWaiting]
      {
        [pending == 0]
        illegal;
        [otherwise]
        pending = pending - 1;
      }
    }
    on done:
    {
      [!isWaiting]
      illegal;
      [isWaiting]
      {
        [pending == 0]
        isWaiting = false;
        [otherwise]
        illegal;
      }
    }
  }
}

interface ICallTrigger {
  in void start();
  out void notLiveLock();

  behaviour {

    on start:
    [true]
    {}
  }
}

interface ITauTrigger {
  in void noDeadlock();
  out void start();

  behaviour {

    on noDeadlock:
    [true]
    {}
    on optional:
    [true]
    start;
  }
}

component QTriggerModeling {
  provides ICallTrigger ict;
  requires ITauTrigger itt;
  requires ICallEmitMulti src;

  behaviour {
    bool behave = true;
    bool useVoid = true;

    on ict.start():
    {
      [!behave]
      src.req();
      [behave]
      [useVoid]
      src.req();
      [behave]
      [otherwise]
      ICallEmitMulti.EmitResult ignored = src.reqValued();
    }
    on itt.start():
    {
      [!behave]
      src.req();
      [behave]
      [useVoid]
      src.req();
      [behave]
      [otherwise]
      ICallEmitMulti.EmitResult ignored = src.reqValued();
    }
    on src.ntfA():
    {
      [!behave]
      {
        src.ack();
        src.done();
      }
      [behave]
      [useVoid]
      src.ack();
      [behave]
      [otherwise]
      src.ack();
    }
    on src.ntfB():
    {
      [!behave]
      src.ack();
      [behave]
      [useVoid]
      {
        src.ack();
        src.done();
        useVoid = false;
      }
      [behave]
      [otherwise]
      {
        src.ack();
        src.done();
        behave = false;
      }
    }
  }

}

