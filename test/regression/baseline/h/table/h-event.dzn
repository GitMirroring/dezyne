interface IHandle {
  in void hcalibrate();
  out void hcalibrated();
  in void stop();
  in void operate();
  out void finished();

  behaviour {
    enum State {Lost, Calibrating, Idle, Operating};
    State s = State.Lost;

    on stop:
    {
      [s.Operating || s.Idle || s.Calibrating || s.Lost]
      s = State.Lost;

    }
    on hcalibrate:
    {
      [s.Lost]
      s = State.Calibrating;
      [s.Operating || s.Idle || s.Calibrating]
      illegal;
      [s.Operating || s.Idle]
      {}

    }
    on operate:
    {
      [s.Operating || s.Calibrating || s.Lost]
      illegal;
      [s.Operating || s.Calibrating || s.Lost]
      {}
      [s.Idle]
      s = State.Operating;
      [s.Idle]
      finished;

    }
    on inevitable:
    {
      [s.Calibrating]
      {
        hcalibrated;
        s = State.Idle;

      }
      [s.Operating]
      {
        s = State.Idle;
        finished;

      }

    }
  }
}

interface ITransfer {
  extern TrPosition $int$;
  in void tcalibrate();
  out void tcalibrated();
  in void stop();
  in void move(TrPosition x, TrPosition y);
  out void arrived();
  in void transfer(TrPosition x, TrPosition y);
  out void picked();
  out void placed();

  behaviour {
    enum State {Lost, Calibrating, Ready, Moving, Transferring};
    State s = State.Lost;
    bool isPicked = false;

    on stop:
    {
      [s.Transferring || s.Moving || s.Ready || s.Calibrating || s.Lost]
      s = State.Lost;

    }
    on tcalibrate:
    {
      [s.Lost]
      {
        tcalibrated;
        s = State.Ready;

      }
      [s.Calibrating]
      illegal;

    }
    on move:
    {
      [s.Calibrating || s.Lost]
      illegal;

    }
    on transfer:
    {
      [s.Calibrating || s.Lost]
      illegal;

    }
    on inevitable:
    [s.Calibrating]
    {
      tcalibrated;
      s = State.Ready;

    }
  }
}

component h {
  provides IHandle ctrl;
  requires ITransfer robot;

  behaviour {
    enum State {Lost, Calibrating, Idle, Operating};
    subint usedCount {0..4};
    enum Operation {PreparingInput, TransferringInput, PreparingOutput, TransferringOutput, Finalizing};
    State s = State.Lost;
    usedCount calibrated = 0;
    usedCount requiredCalibrations = 3;
    Operation o = Operation.PreparingInput;

    void tryCalibrated() {
      calibrated = calibrated + 1;
      if (calibrated == requiredCalibrations) {
        s = State.Idle;
        ctrl.hcalibrated();

      }
      return false;

    }

    void ignoreIllegal() {
      return false;

    }

    on ctrl.hcalibrate():
    {
      [s.Lost]
      {
        robot.tcalibrate();
        calibrated = 0;
        s = State.Calibrating;

      }
      [s.Operating || s.Idle || s.Calibrating]
      ignoreIllegal, (), false
    }
    on robot.tcalibrated():
    {
      [s.Operating || s.Idle || s.Lost]
      illegal;
      [s.Calibrating]
      tryCalibrated, (), false
    }
  }

}

