interface IHandle {
  in void hcalibrate();
  out void hcalibrated();
  in void stop();
  in void operate();
  out void finished();

  behaviour {
    enum State {Lost, Calibrating, Idle, Operating};
    State s = State.Lost;

    [s.Lost]
    {
      on stop:
      s = State.Lost;
      on hcalibrate:
      s = State.Calibrating;
      on operate:
      {
        [true]
        illegal;
        [true]
        {}
      }
    }
    [s.Calibrating]
    {
      on stop:
      s = State.Lost;
      on hcalibrate:
      illegal;
      on operate:
      {
        [true]
        illegal;
        [true]
        {}
      }
      on inevitable:
      {
        hcalibrated;
        s = State.Idle;
      }
    }
    [s.Idle]
    {
      on stop:
      s = State.Lost;
      on hcalibrate:
      {
        [true]
        illegal;
        [true]
        {}
      }
      on operate:
      {
        [true]
        s = State.Operating;
        [true]
        finished;
      }
    }
    [s.Operating]
    {
      on stop:
      s = State.Lost;
      on hcalibrate, operate:
      {
        [true]
        illegal;
        [true]
        {}
      }
      on inevitable:
      {
        s = State.Idle;
        finished;
      }
    }
  }
}

interface ITransfer {
  extern TrPosition $int$;
  in void tcalibrate();
  out void tcalibrated();
  in void stop();
  in void move(TrPosition x, TrPosition y);
  out void arrived();
  in void transfer(TrPosition x, TrPosition y);
  out void picked();
  out void placed();

  behaviour {
    enum State {Lost, Calibrating, Ready, Moving, Transferring};
    State s = State.Lost;
    bool isPicked = false;

    [s.Lost]
    {
      on stop:
      s = State.Lost;
      on tcalibrate:
      {
        tcalibrated;
        s = State.Ready;
      }
      on move, transfer:
      illegal;
    }
    [s.Calibrating]
    {
      on stop:
      s = State.Lost;
      on tcalibrate, move, transfer:
      illegal;
      on inevitable:
      {
        tcalibrated;
        s = State.Ready;
      }
    }
    [s.Ready]
    on stop:
    s = State.Lost;
    [s.Moving]
    on stop:
    s = State.Lost;
    [s.Transferring]
    on stop:
    s = State.Lost;
  }
}

component h {
  provides IHandle ctrl;
  requires ITransfer robot;

  behaviour {
    enum State {Lost, Calibrating, Idle, Operating};
    subint usedCount {0..4};
    enum Operation {PreparingInput, TransferringInput, PreparingOutput, TransferringOutput, Finalizing};
    State s = State.Lost;
    usedCount calibrated = 0;
    usedCount requiredCalibrations = 3;
    Operation o = Operation.PreparingInput;

    void tryCalibrated() {
      calibrated = calibrated + 1;
      if (calibrated == requiredCalibrations) {
        s = State.Idle;
        ctrl.hcalibrated();
      }
      return;
    }

    void ignoreIllegal() {
      return;
    }

    [s.Lost]
    {
      on ctrl.hcalibrate():
      {
        robot.tcalibrate();
        calibrated = 0;
        s = State.Calibrating;
      }
      on robot.tcalibrated():
      illegal;
    }
    [s.Calibrating]
    {
      on ctrl.hcalibrate():
      ignoreIllegal();
      on robot.tcalibrated():
      tryCalibrated();
    }
    [s.Idle]
    {
      on ctrl.hcalibrate():
      ignoreIllegal();
      on robot.tcalibrated():
      illegal;
    }
    [s.Operating]
    {
      on ctrl.hcalibrate():
      ignoreIllegal();
      on robot.tcalibrated():
      illegal;
    }
  }
}

