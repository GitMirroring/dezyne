// Code:

interface iq
{
  in void e();
  out void a();
  in void f();
  out void b();

  behaviour 
  {
    [true]
    {
      on e:
      a;
      on f:
      {
        a;
        b;
      }
    }
  }
}
interface ir
{
  in void e();
  out void a();
  in void f();
  out void b();

  behaviour 
  {
    bool s = false;
    [!s]
    {
      on e:
      {
        s = !s;
        a;
      }
      on f:
      {
        s = !s;
        b;
      }
    }
    [s]
    {
      on e:
      {
        s = !s;
        a;
      }
      on f:
      {
        s = !s;
        b;
      }
    }
  }
}
component q
{
  provides iq p;
  requires ir r;

  behaviour 
  {
    [true]
    {
      on p.e():
      r.e();
      on r.a():
      p.a();
      on p.f():
      {
        r.e();
        r.f();
      }
      on r.b():
      p.b();
    }
  }
}

