interface NonDet3 {
  in void init();
  in void work();
  in void stop();
  in void recover();
  out void ok();
  out void error();
  out void stopped();
  out void recovered();

  behaviour {
    enum States {Powered, Ready, Working, Stopping, Error};
    States mainState = States.Ready;

    on init:
    {
      [mainState.Powered]
      {
        [true]
        {
          ok;
          mainState = States.Ready;
        }
        [true]
        {
          error;
          mainState = States.Error;
        }
      }
      [mainState.Error || mainState.Stopping || mainState.Working || mainState.Ready]
      illegal;
    }
    on work:
    {
      [mainState.Error || mainState.Stopping || mainState.Working || mainState.Powered]
      illegal;
      [mainState.Ready]
      mainState = States.Working;
    }
    on recover:
    {
      [mainState.Stopping || mainState.Working || mainState.Ready || mainState.Powered]
      illegal;
      [mainState.Error]
      {
        [true]
        {
          ok;
          mainState = States.Ready;
        }
        [true]
        {
          error;
          mainState = States.Error;
        }
      }
    }
    on stop:
    {
      [mainState.Powered]
      illegal;
      [mainState.Stopping || mainState.Working || mainState.Ready]
      mainState = States.Stopping;
      [mainState.Ready]
      mainState = States.Ready;
      [mainState.Error]
      ok;
    }
    on inevitable:
    {
      [mainState.Stopping || mainState.Working]
      {
        [true]
        {
          ok;
          mainState = States.Ready;
        }
        [true]
        {
          error;
          mainState = States.Error;
        }
      }
    }
  }
}

