import Iconsole.dzn;
import Isensor.dzn;
import Isiren.dzn;

component alarm
{
  provides Iconsole console;
  requires Isensor sensor;
  requires Isiren siren;

  behaviour
  {
    enum States {Disarmed, Armed, Triggered, Disarming};

    States state_ = States.Disarmed;
    bool sounding = false;

    // Capture data at Reply (ASD semantics):

    [state_.Disarmed]
    {
      on console.arm():
      {
        sensor.enable();
        state_ = States.Armed;
      }
      on console.disarm, 
          sensor.triggered, 
          sensor.disabled:
      {
        illegal;
      }
    }

    [state_.Armed]
    {
      on console.disarm():
      {
        sensor.disable();
        state_ = States.Disarming;
      }
      on sensor.triggered():
      {
        console.detected();
        sounding = true;
        state_ = States.Triggered;
      }
      on console.arm, 
          sensor.disabled:
      {
        illegal;
      }
    }

    [state_.Triggered]
    {
      on console.disarm():
      {
        sensor.disable();
        state_ = States.Disarming;
      }
      on console.arm, 
          sensor.triggered, 
          sensor.disabled:
      {
        illegal;
      }
    }

    [state_.Disarming]
    {
      on sensor.triggered():
      {
        // NoOp
      }
      on sensor.disabled():
      {
        [sounding]
        {
          console.deactivated();
          sounding = false;
          state_ = States.Disarmed;
        }
        [otherwise]
        {
          console.deactivated();
          state_ = States.Disarmed;
        }
      }
      on console.arm, 
          console.disarm:
      {
        illegal;
      }
    }

  }
}
