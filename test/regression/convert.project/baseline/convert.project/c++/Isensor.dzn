interface Isensor
{
  // Application interface sensor_api
  in void enable();
  in void disable();

  // Notification interface sensor_cb
  out void triggered();
  out void disabled();

  // Modelling Interface modeling has been replaced by optional/inevitable

  behaviour
  {
    enum States {Disabled, Enabled, Disabling, Triggered};

    States state_ = States.Disabled;

    [state_.Disabled]
    {
      on enable:
      {
        state_ = States.Enabled;
      }
      on disable:
      {
        illegal;
      }
    }

    [state_.Enabled]
    {
      on disable:
      {
        state_ = States.Disabling;
      }
      on optional:
      {
        triggered;
        state_ = States.Triggered;
      }
      on enable:
      {
        illegal;
      }
    }

    [state_.Disabling]
    {
      on inevitable:
      {
        disabled;
        state_ = States.Disabled;
      }
      on enable, 
          disable:
      {
        illegal;
      }
    }

    [state_.Triggered]
    {
      on disable:
      {
        state_ = States.Disabling;
      }
      on enable:
      {
        illegal;
      }
    }

  }
}
