import MaterialHandler.dzn;
import Inspector.dzn;
import Conveyor.dzn;
import FeedPort.dzn;
import Feeder.dzn;
import lego.dzn;

component LegoBallSorter
{
  provides IHandle ctrl;
  // NxtBrick brick1; // INPUT
  requires imotor brick1_aA; //<=> handler.trolleyMotorHw; // robot trolley
  requires imotor brick1_aB; //<=> input.motorHw; // input
  requires imotor brick1_aC; //<=> track.motorHw; // feeder
  requires itouch brick1_s1; //<=> inspector.stageXEndSensorHw; // stage x home
  requires itouch brick1_s2; //<=> input.sensorHw;	// input
  requires itouch brick1_s3; //<=> handler.truckHomeSensorHw; // robot truck home
  requires itouch brick1_s4; //<=> track.endSensorHw; // feeder retracted switch

  //	NxtBrick brick2; // OUTPUT
  requires imotor brick2_aA; //<=> reject.motorHw; // reject
  requires imotor brick2_aB; //<=> accept.motorHw; // accept
  //requires itouch brick2_s1; //<=> handler.truckEndSensorHw; // robot truck end
  requires itouch brick2_s2; //<=> inspector.stageXHomeSensorHw;	// stage x home
  requires itouch brick2_s3; //<=> reject.sensorHw; // reject
  requires itouch brick2_s4; //<=> accept.sensorHw; // accept

  //	NxtBrick brick3; // STAGE
  requires imotor brick3_aA; //<=> inspector.stageXMotorHw; // stage x
  requires imotor brick3_aC; //<=> inspector.stageYMotorHw; // stage y
  requires ilight brick3_s1; //<=> inspector.sensor; // inspect light sensor
  requires itouch brick3_s2; //<=> inspector.stageYEndSensorHw;	// stage y end
  requires itouch brick3_s3; //<=> inspector.stageYHomeSensorHw; // stage y home

  //	NxtBrick brick4; // ROBOT
  requires imotor brick4_aA; //<=> handler.hoistMotorHw; // robot hoist
  requires imotor brick4_aB; //<=> handler.gripperMotorhw; // robot gripper
  requires imotor brick4_aC; //<=> handler.truckMotorHw; // truck
  requires itouch brick4_s1;
  requires itouch brick4_s2; //<=> handler.trolleyHomeSensorHw;	// extender home
  requires itouch brick4_s3; //<=> handler.hoistEndSensorHw; // hoist home
  system
  {
    MaterialHandler handler;
    Inspector inspector;
    FeedPort input;
    Conveyor accept;
    Conveyor reject;
    Feeder track;

    ctrl <=> handler.ctrl;
    handler.feedPort <=> input.ctrl;
    handler.inspector <=> inspector.ctrl;
    handler.acceptPort <=> accept.ctrl;
    handler.rejectPort <=> reject.ctrl;

    input.feeder <=> track.ctrl;

    brick1_aA <=> handler.trolleyMotorHw; // robot trolley
    brick1_aB <=> input.motorHw; // input
    brick1_aC <=> track.motorHw; // feeder
    brick1_s1 <=> inspector.stageXEndSensorHw; // stage x end
    brick1_s2 <=> input.sensorHw;	// input
    brick1_s3 <=> handler.truckHomeSensorHw; // robot truck home
    brick1_s4 <=> track.endSensorHw; // feeder retracted switch

    brick2_aA <=> reject.motorHw; // reject
    brick2_aB <=> accept.motorHw; // accept
    //brick2_s1 <=> handler.truckEndSensorHw; // robot truck end
    brick2_s2 <=> inspector.stageXHomeSensorHw;	// stage x home
    brick2_s3 <=> reject.sensorHw; // reject
    brick2_s4 <=> accept.sensorHw; // accept

    brick3_aA <=> inspector.stageXMotorHw; // stage x
    brick3_aC <=> inspector.stageYMotorHw; // stage y
    brick3_s1 <=> inspector.sensor; // inspect light sensor
    brick3_s2 <=> inspector.stageYEndSensorHw;	// stage y end
    brick3_s3 <=> inspector.stageYHomeSensorHw; // stage y home

    brick4_aA <=> handler.hoistMotorHw; // robot hoist
    brick4_aB <=> handler.gripperMotorhw; // robot gripper
    brick4_aC <=> handler.truckMotorHw; // truck
    brick4_s1 <=> handler.gripperEndSensorHw;
    brick4_s2 <=> handler.trolleyEndSensorHw;	// extender home
    brick4_s3 <=> handler.hoistEndSensorHw; // hoist home
  }
}
