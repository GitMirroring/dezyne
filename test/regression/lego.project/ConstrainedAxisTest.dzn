import lego.dzn;
import IConstrainedMove.dzn;
import ConstrainedAxis.dzn;

component ConstrainedAxisTest
{
  provides itest ctrl;
  requires IConstrainedMove axis;
    
  behaviour
  {
    bool testing = false;
    //        [!testing] on ctrl.test(): {axis.calibrate(); testing = true;}
    //        [testing] on ctrl.test(): {}
    on ctrl.test():
      {
        [!testing]
        {
          axis.calibrate(); testing = true;
        }
        [testing] {}
      }
    on axis.homed(): axis.move($20$);
    on axis.arrived(): {axis.stop(); testing = false;}
  }
}

component ConstrainedAxisTester
{
  provides itest port;
  requires imotor motor;
  requires itouch home_switch;
  requires itouch end_switch;
    
  system
  {
    ConstrainedAxisTest bhv;
    ConstrainedAxis axis;
        
    port <=> bhv.ctrl;
    bhv.axis <=> axis.ctrl;
    axis.motorHw <=> motor;
    axis.homeSensorHw <=> home_switch;
    axis.endSensorHw <=> end_switch;
  }
}

