import IConstrainedMove.dzn;

import TouchSensor.dzn;
import Motor.dzn;
import lego.dzn;

component EndConstrainedAxis
{
  // Sensor marks end of range which is considered position 0
  // MoveToPosition must receive negative position values!
  provides IConstrainedMove ctrl;
  requires imotor motorHw; // required by motor
  requires itouch endSensorHw; // required by sensor
	
  system
  {
    EndConstrainedMove bhv;
    Motor motor;
    TouchSensor endSensor;
		
    ctrl <=> bhv.ctrl;
    bhv.motor <=> motor.ctrl;
    bhv.endSensor <=> endSensor.ctrl;
		
    motor.hw <=> motorHw;
    endSensor.hw <=> endSensorHw;
  }
}

component EndConstrainedMove
{
  provides IConstrainedMove ctrl;
  requires IMove motor;
  requires ITouchSense endSensor;
	
  behaviour
  {
    enum State {lost, idle, moving, calibratingEnd};
    State s = State.lost;
		
    void slowForward() {motor.run($config("Power::CalibrationSpeed")$, $false$);}
    void recordHome() {
      endSensor.disable();
      motor.stop(); // brake
      motor.zero();
    }
    void startAbsoluteMove(IConstrainedMove.position_t target) {
      ITouchSense.TouchState ignore = endSensor.enable();
      motor.move($config("Power::OperationalSpeed")$, target);
      s = State.moving;
    }
    void notifyArrived() {
      motor.stop();
      endSensor.disable();
      s = State.idle;
      ctrl.arrived();
    }
		
    on ctrl.stop(): {motor.stop(); endSensor.disable(); s = State.lost;}
		
    [s.lost]
    {
      on ctrl.calibrate():
        {
          ITouchSense.TouchState ess = endSensor.enable();
          if (ess == ITouchSense.TouchState.Pressed)
          {
            recordHome();
            s = State.idle;
            ctrl.homed();
          }
          else
          {
            slowForward();
            s = State.calibratingEnd;
          }
        }
      on ctrl.move(): illegal;
      on endSensor.pressed(): illegal;
      on endSensor.released(): illegal;
      on motor.arrived(): illegal;
    }
		
    [s.calibratingEnd]
    {
      on endSensor.pressed():
        {
          recordHome();
          s = State.idle;
          ctrl.homed();
        }

      on ctrl.calibrate(): illegal;
      on ctrl.move(): illegal;
      on endSensor.released(): illegal;
      on motor.arrived(): illegal;
    }
		
    [s.idle]
    {
      on ctrl.calibrate(): illegal;
      //on ctrl.move(pos): startAbsoluteMove(pos);
      on ctrl.move(target):
        {
          ITouchSense.TouchState ignore = ITouchSense.TouchState.Released;
          ignore = endSensor.enable();
          motor.move($config("Power::OperationalSpeed")$, target);
          s = State.moving;
        }
			
      on endSensor.pressed(): illegal;
      on endSensor.released(): illegal;
      on motor.arrived(): illegal;
    }

    [s.moving]
    {
      on ctrl.calibrate(): illegal;
      on ctrl.move(): illegal;
      on endSensor.pressed(): {motor.stop(); notifyArrived();} // out of range => recalibrate?
      on endSensor.released(): {}
      on motor.arrived(): notifyArrived();
    }
  }
}
