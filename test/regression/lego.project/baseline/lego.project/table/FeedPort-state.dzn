component FeedConvey
{
  provides IFeed ctrl;
  requires IFeed feeder;
  requires IConvey conveyor;

  behaviour 
  {
    enum State { Lost, Calibrating, Idle, Preparing, Prepared };
    enum FeedPhase { Idle, Feeding, ConveyingNext, ConveyingLast };
    State s = State.Lost;
    FeedPhase p = FeedPhase.Idle;
    [s.Lost]
    {
      on ctrl.stop():
      {
        feeder.stop();
        conveyor.stop();
        s = State.Lost;
        p = FeedPhase.Idle;
      }
      on ctrl.calibrate():
      {
        feeder.calibrate();
        s = State.Calibrating;
      }
      on ctrl.produceBall(), feeder.calibrated(), feeder.consumeNextBall(), feeder.consumeLastBall(), conveyor.conveyed():
      illegal;
    }
    [s.Calibrating]
    {
      on ctrl.stop():
      {
        feeder.stop();
        conveyor.stop();
        s = State.Lost;
        p = FeedPhase.Idle;
      }
      on ctrl.calibrate(), ctrl.produceBall(), feeder.consumeNextBall(), feeder.consumeLastBall(), conveyor.conveyed():
      illegal;
      on feeder.calibrated():
      {
        ctrl.calibrated();
        s = State.Idle;
      }
    }
    [s.Idle]
    {
      on ctrl.stop():
      {
        feeder.stop();
        conveyor.stop();
        s = State.Lost;
        p = FeedPhase.Idle;
      }
      on ctrl.calibrate(), feeder.calibrated(), feeder.consumeNextBall(), feeder.consumeLastBall(), conveyor.conveyed():
      illegal;
      on ctrl.produceBall():
      {
        feeder.produceBall();
        s = State.Preparing;
        p = FeedPhase.Feeding;
      }
    }
    [s.Preparing]
    {
      on ctrl.stop():
      {
        feeder.stop();
        conveyor.stop();
        s = State.Lost;
        p = FeedPhase.Idle;
      }
      on ctrl.calibrate(), ctrl.produceBall():
      illegal;
      on feeder.calibrated():
      {
        [true]
        illegal;
        [p.ConveyingNext]
        illegal;
        [p.ConveyingLast]
        illegal;
      }
      on feeder.consumeNextBall():
      {
        [p.Feeding]
        {
          conveyor.convey();
          p = FeedPhase.ConveyingNext;
        }
        [p.ConveyingNext]
        illegal;
        [p.ConveyingLast]
        illegal;
      }
      on feeder.consumeLastBall():
      {
        [p.Feeding]
        {
          conveyor.convey();
          p = FeedPhase.ConveyingLast;
        }
        [p.ConveyingNext]
        illegal;
        [p.ConveyingLast]
        illegal;
      }
      on conveyor.conveyed():
      {
        [p.Feeding]
        illegal;
        [p.ConveyingNext]
        {
          ctrl.consumeNextBall();
          s = State.Prepared;
          p = FeedPhase.Idle;
        }
        [p.ConveyingLast]
        {
          ctrl.consumeLastBall();
          s = State.Prepared;
          p = FeedPhase.Idle;
        }
      }
    }
    [s.Prepared]
    {
      on ctrl.stop():
      {
        feeder.stop();
        conveyor.stop();
        s = State.Lost;
        p = FeedPhase.Idle;
      }
      on ctrl.calibrate(), feeder.calibrated(), feeder.consumeNextBall(), feeder.consumeLastBall(), conveyor.conveyed():
      illegal;
      on ctrl.produceBall():
      {
        feeder.produceBall();
        s = State.Preparing;
        p = FeedPhase.Feeding;
      }
    }
  }
}
component FeedPort
{
  provides IFeed ctrl;
  requires IFeed feeder;
  requires imotor motorHw;
  requires itouch sensorHw;

  system
  {
    FeedConvey bhv;
    Conveyor conveyor;

    ctrl <=> bhv.ctrl;
    bhv.conveyor <=> conveyor.ctrl;
    bhv.feeder <=> feeder;
    conveyor.motorHw <=> motorHw;
    conveyor.sensorHw <=> sensorHw;
  }
}

