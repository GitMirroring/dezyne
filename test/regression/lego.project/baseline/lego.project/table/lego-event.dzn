interface imotor
{
  extern boolean $Boolean$;
  extern position_t $Integer$;
  extern power_t $Byte$;
  enum result_t { yes, no };
  in void move(power_t power,position_t position);
  in void run(power_t power,boolean invert);
  in void stop();
  in void coast();
  in void zero();
  in void position(out position_t pos);
  in result_t at(position_t pos);

  behaviour 
  {
    on move:
    [true]
    {
    }
    on run:
    [true]
    {
    }
    on stop:
    [true]
    {
    }
    on coast:
    [true]
    {
    }
    on zero:
    [true]
    {
    }
    on position:
    [true]
    {
    }
    on at:
    {
      [true]
      reply(result_t.yes);
      [true]
      reply(result_t.no);
    }
  }
}
interface itouch
{
  enum status { pressed, released };
  in status detect();

  behaviour 
  {
    on detect:
    {
      [true]
      reply(status.pressed);
      [true]
      reply(status.released);
    }
  }
}
interface ilight
{
  enum status { accept, reject };
  in void turnon();
  in void turnoff();
  in status detect();

  behaviour 
  {
    on turnon:
    [true]
    {
    }
    on turnoff:
    [true]
    {
    }
    on detect:
    {
      [true]
      reply(status.accept);
      [true]
      reply(status.reject);
    }
  }
}
interface itimer
{
  extern milliseconds_t $Integer$;
  in void create(milliseconds_t ms);
  in void cancel();
  out void timeout();

  behaviour 
  {
    enum State { Idle, Pending };
    State state = State.Idle;
    on create:
    {
      [state.Idle]
      state = State.Pending;
      [state.Pending]
      illegal;
    }
    on cancel:
    {
      [state.Idle]
      {
      }
      [state.Pending]
      state = State.Idle;
    }
    on inevitable:
    [state.Pending]
    {
      timeout;
      state = State.Idle;
    }
  }
}
component timer
{
  provides itimer port;


}

