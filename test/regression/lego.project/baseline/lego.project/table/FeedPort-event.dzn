component FeedConvey {
  provides IFeed ctrl;
  requires IFeed feeder;
  requires IConvey conveyor;

  behaviour {
    enum State {Lost, Calibrating, Idle, Preparing, Prepared};
    enum FeedPhase {Idle, Feeding, ConveyingNext, ConveyingLast};
    State s = State.Lost;
    FeedPhase p = FeedPhase.Idle;

    on ctrl.stop():
    {
      [s.Prepared || s.Preparing || s.Idle || s.Calibrating || s.Lost]
      {
        feeder.stop();
        conveyor.stop();
        s = State.Lost;
        p = FeedPhase.Idle;
      }
    }
    on ctrl.calibrate():
    {
      [s.Lost]
      {
        feeder.calibrate();
        s = State.Calibrating;
      }
      [s.Prepared || s.Preparing || s.Idle || s.Calibrating]
      illegal;
    }
    on ctrl.produceBall():
    {
      [s.Preparing || s.Calibrating || s.Lost]
      illegal;
      [s.Prepared || s.Idle]
      {
        feeder.produceBall();
        s = State.Preparing;
        p = FeedPhase.Feeding;
      }
    }
    on feeder.calibrated():
    {
      [s.Prepared || s.Preparing || s.Idle || s.Lost]
      illegal;
      [s.Calibrating]
      {
        ctrl.calibrated();
        s = State.Idle;
      }
      [s.Preparing]
      [p.ConveyingNext]
      illegal;
      [s.Preparing]
      [p.ConveyingLast]
      illegal;
    }
    on feeder.consumeNextBall():
    {
      [s.Prepared || s.Idle || s.Calibrating || s.Lost]
      illegal;
      [s.Preparing]
      [p.Feeding]
      {
        conveyor.convey();
        p = FeedPhase.ConveyingNext;
      }
      [s.Preparing]
      [p.ConveyingNext]
      illegal;
      [s.Preparing]
      [p.ConveyingLast]
      illegal;
    }
    on feeder.consumeLastBall():
    {
      [s.Prepared || s.Idle || s.Calibrating || s.Lost]
      illegal;
      [s.Preparing]
      [p.Feeding]
      {
        conveyor.convey();
        p = FeedPhase.ConveyingLast;
      }
      [s.Preparing]
      [p.ConveyingNext]
      illegal;
      [s.Preparing]
      [p.ConveyingLast]
      illegal;
    }
    on conveyor.conveyed():
    {
      [s.Prepared || s.Idle || s.Calibrating || s.Lost]
      illegal;
      [s.Preparing]
      [p.Feeding]
      illegal;
      [s.Preparing]
      [p.ConveyingNext]
      {
        ctrl.consumeNextBall();
        s = State.Prepared;
        p = FeedPhase.Idle;
      }
      [s.Preparing]
      [p.ConveyingLast]
      {
        ctrl.consumeLastBall();
        s = State.Prepared;
        p = FeedPhase.Idle;
      }
    }
  }
}

component FeedPort {
  provides IFeed ctrl;
  requires IFeed feeder;
  requires imotor motorHw;
  requires itouch sensorHw;

  system {
    FeedConvey bhv;
    Conveyor conveyor;

    ctrl <=> bhv.ctrl;
    bhv.conveyor <=> conveyor.ctrl;
    bhv.feeder <=> feeder;
    conveyor.motorHw <=> motorHw;
    conveyor.sensorHw <=> sensorHw;
  }
}

