component LegoBallSorter
{
  provides IHandle ctrl;
  requires imotor brick1_aA;
  requires imotor brick1_aB;
  requires imotor brick1_aC;
  requires itouch brick1_s1;
  requires itouch brick1_s2;
  requires itouch brick1_s3;
  requires itouch brick1_s4;
  requires imotor brick2_aA;
  requires imotor brick2_aB;
  requires itouch brick2_s2;
  requires itouch brick2_s3;
  requires itouch brick2_s4;
  requires imotor brick3_aA;
  requires imotor brick3_aC;
  requires ilight brick3_s1;
  requires itouch brick3_s2;
  requires itouch brick3_s3;
  requires imotor brick4_aA;
  requires imotor brick4_aB;
  requires imotor brick4_aC;
  requires itouch brick4_s1;
  requires itouch brick4_s2;
  requires itouch brick4_s3;

  system
  {
    MaterialHandler handler;
    Inspector inspector;
    FeedPort input;
    Conveyor accept;
    Conveyor reject;
    Feeder track;

    ctrl <=> handler.ctrl;
    handler.feedPort <=> input.ctrl;
    handler.inspector <=> inspector.ctrl;
    handler.acceptPort <=> accept.ctrl;
    handler.rejectPort <=> reject.ctrl;
    input.feeder <=> track.ctrl;
    brick1_aA <=> handler.trolleyMotorHw;
    brick1_aB <=> input.motorHw;
    brick1_aC <=> track.motorHw;
    brick1_s1 <=> inspector.stageXEndSensorHw;
    brick1_s2 <=> input.sensorHw;
    brick1_s3 <=> handler.truckHomeSensorHw;
    brick1_s4 <=> track.endSensorHw;
    brick2_aA <=> reject.motorHw;
    brick2_aB <=> accept.motorHw;
    brick2_s2 <=> inspector.stageXHomeSensorHw;
    brick2_s3 <=> reject.sensorHw;
    brick2_s4 <=> accept.sensorHw;
    brick3_aA <=> inspector.stageXMotorHw;
    brick3_aC <=> inspector.stageYMotorHw;
    brick3_s1 <=> inspector.sensor;
    brick3_s2 <=> inspector.stageYEndSensorHw;
    brick3_s3 <=> inspector.stageYHomeSensorHw;
    brick4_aA <=> handler.hoistMotorHw;
    brick4_aB <=> handler.gripperMotorhw;
    brick4_aC <=> handler.truckMotorHw;
    brick4_s1 <=> handler.gripperEndSensorHw;
    brick4_s2 <=> handler.trolleyEndSensorHw;
    brick4_s3 <=> handler.hoistEndSensorHw;
  }
}

