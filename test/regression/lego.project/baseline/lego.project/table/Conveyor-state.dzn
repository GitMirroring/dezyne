interface IConvey {
  in void convey();
  out void conveyed();
  in void stop();

  behaviour {
    enum State {Idle, Conveying};
    State s = State.Idle;

    [s.Idle]
    {
      on stop:
      s = State.Idle;
      on convey:
      {
        [true]
        s = State.Conveying;
        [true]
        conveyed;

      }

    }
    [s.Conveying]
    {
      on stop:
      s = State.Idle;
      on convey:
      illegal;
      on inevitable:
      {
        conveyed;
        s = State.Idle;

      }

    }
  }
}

component Convey {
  provides IConvey ctrl;
  requires IMove motor;
  requires ITouchSense sensor;

  behaviour {
    enum State {Idle, Conveying};
    State s = State.Idle;

    [s.Idle]
    {
      on ctrl.stop():
      {
        motor.stop();
        sensor.disable();
        s = State.Idle;

      }
      on motor.arrived():
      {}
      on ctrl.convey():
      {
        ITouchSense.TouchState ss = sensor.enable();
        if (ss == ITouchSense.TouchState.Pressed) {
          sensor.disable();
          ctrl.conveyed();

        }
        else
        {
          motor.run($(config.get("Power::50"))$, $false$);
          s = State.Conveying;

        }

      }
      on sensor.pressed(), sensor.released():
      illegal;

    }
    [s.Conveying]
    {
      on ctrl.stop():
      {
        motor.stop();
        sensor.disable();
        s = State.Idle;

      }
      on motor.arrived():
      {}
      on ctrl.convey():
      illegal;
      on sensor.pressed(), sensor.released():
      {
        sensor.disable();
        motor.stop();
        ctrl.conveyed();
        s = State.Idle;

      }

    }
  }

}

component Conveyor {
  provides IConvey ctrl;
  requires imotor motorHw;
  requires itouch sensorHw;

  system {
    nameConvey bhv;
    nameMotor motor;
    nameTouchSensor sensor;

    ctrl <=> bhv.ctrl;
    bhv.motor <=> motor.ctrl;
    bhv.sensor <=> sensor.ctrl;
    motor.hw <=> motorHw;
    sensor.hw <=> sensorHw;
  }
}

