component ConstrainedMove {
  provides IConstrainedMove ctrl;
  requires IMove motor;
  requires ITouchSense homeSensor;
  requires ITouchSense endSensor;

  behaviour {
    enum State {lost, idle, moving, calibratingHome, calibratingLength};
    State s = State.lost;

    void slowForward() {
      motor.run($(config.get("Power::CalibrationSpeed"))$, $false$);
      return false;

    }

    void slowBackward() {
      motor.run($(config.get("Power::CalibrationSpeed"))$, $true$);
      return false;

    }

    void recordHome() {
      homeSensor.disable();
      motor.stop();
      motor.zero();
      return false;

    }

    void recordLength() {
      endSensor.disable();
      motor.stop();
      return false;

    }

    void startAbsoluteMove(IConstrainedMove.position_t target) {
      ITouchSense.TouchState ignore = ITouchSense.TouchState.Released;
      ignore = homeSensor.enable();
      ignore = endSensor.enable();
      motor.move($(config.get("Power::OperationalSpeed"))$, target);
      s = State.moving;
      return false;

    }

    void notifyArrived() {
      motor.stop();
      homeSensor.disable();
      endSensor.disable();
      s = State.idle;
      ctrl.arrived();
      return false;

    }

    [s.lost]
    {
      on ctrl.stop():
      {
        motor.stop();
        homeSensor.disable();
        endSensor.disable();
        s = State.lost;

      }
      on ctrl.calibrate():
      {
        ITouchSense.TouchState hss = homeSensor.enable();
        if (hss == ITouchSense.TouchState.Pressed) {
          recordHome, (), falseITouchSense.TouchState ess = endSensor.enable();
          if (ess == ITouchSense.TouchState.Pressed) {
            recordLength, (), falses = State.idle;
            ctrl.homed();

          }
          else
          {
            slowForward, (), falses = State.calibratingLength;

          }

        }
        else
        {
          slowBackward, (), falses = State.calibratingHome;

        }

      }
      on ctrl.move(), homeSensor.pressed(), homeSensor.released(), endSensor.pressed(), endSensor.released(), motor.arrived():
      illegal;

    }
    [s.idle]
    {
      on ctrl.stop():
      {
        motor.stop();
        homeSensor.disable();
        endSensor.disable();
        s = State.lost;

      }
      on ctrl.calibrate(), homeSensor.pressed(), homeSensor.released(), endSensor.pressed(), endSensor.released(), motor.arrived():
      illegal;
      on ctrl.move(target):
      {
        ITouchSense.TouchState ignore = ITouchSense.TouchState.Released;
        ignore = homeSensor.enable();
        ignore = endSensor.enable();
        motor.move($(config.get("Power::OperationalSpeed"))$, target);
        s = State.moving;

      }

    }
    [s.moving]
    {
      on ctrl.stop():
      {
        motor.stop();
        homeSensor.disable();
        endSensor.disable();
        s = State.lost;

      }
      on ctrl.calibrate(), ctrl.move():
      illegal;
      on homeSensor.pressed(), endSensor.pressed():
      {
        motor.stop();
        notifyArrived, (), false
      }
      on homeSensor.released(), endSensor.released():
      {}
      on motor.arrived():
      notifyArrived, (), false
    }
    [s.calibratingHome]
    {
      on ctrl.stop():
      {
        motor.stop();
        homeSensor.disable();
        endSensor.disable();
        s = State.lost;

      }
      on ctrl.calibrate(), ctrl.move(), homeSensor.released(), endSensor.pressed(), endSensor.released(), motor.arrived():
      illegal;
      on homeSensor.pressed():
      {
        recordHome, (), falseITouchSense.TouchState ess = endSensor.enable();
        if (ess == ITouchSense.TouchState.Pressed) {
          recordLength, (), falses = State.idle;
          ctrl.homed();

        }
        else
        {
          slowForward, (), falses = State.calibratingLength;

        }

      }

    }
    [s.calibratingLength]
    {
      on ctrl.stop():
      {
        motor.stop();
        homeSensor.disable();
        endSensor.disable();
        s = State.lost;

      }
      on ctrl.calibrate(), ctrl.move(), homeSensor.pressed(), homeSensor.released(), endSensor.released(), motor.arrived():
      illegal;
      on endSensor.pressed():
      {
        recordLength, (), falsectrl.homed();
        s = State.idle;

      }

    }
  }

}

component ConstrainedAxis {
  provides IConstrainedMove ctrl;
  requires imotor motorHw;
  requires itouch homeSensorHw;
  requires itouch endSensorHw;

  system {
    nameConstrainedMove bhv;
    nameMotor motor;
    nameTouchSensor homeSensor;
    nameTouchSensor endSensor;

    ctrl <=> bhv.ctrl;
    bhv.motor <=> motor.ctrl;
    bhv.homeSensor <=> homeSensor.ctrl;
    bhv.endSensor <=> endSensor.ctrl;
    motor.hw <=> motorHw;
    homeSensor.hw <=> homeSensorHw;
    endSensor.hw <=> endSensorHw;
  }
}

