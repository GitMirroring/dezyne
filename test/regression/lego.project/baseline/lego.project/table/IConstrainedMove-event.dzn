interface IConstrainedMove {
  extern position_t $Integer$;
  in void calibrate();
  out void homed();
  in void stop();
  in void move(position_t target);
  out void arrived();

  behaviour {
    enum State {lost, idle, calibrating, moving};
    State s = State.lost;

    void notifyHomed() {
      s = State.idle;
      homed;
      return false;

    }

    void notifyArrived() {
      s = State.idle;
      arrived;
      return false;

    }

    on calibrate:
    {
      [s.lost]
      s = State.calibrating;
      [s.lost]
      notifyHomed();
      [s.moving || s.calibrating || s.idle]
      illegal;

    }
    on move:
    {
      [s.moving || s.calibrating || s.lost]
      illegal;
      [s.idle]
      s = State.moving;

    }
    on stop:
    {
      [s.moving || s.calibrating || s.idle || s.lost]
      s = State.lost;

    }
    on inevitable:
    {
      [s.calibrating]
      notifyHomed();
      [s.moving]
      notifyArrived();

    }
  }
}

