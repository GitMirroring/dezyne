component EndConstrainedMove {
  provides IConstrainedMove ctrl;
  requires IMove motor;
  requires ITouchSense endSensor;

  behaviour {
    enum State {lost, idle, moving, calibratingEnd};
    State s = State.lost;

    void slowForward() {
      motor.run($(config.get("Power::CalibrationSpeed"))$, $false$);
      return false;
    }

    void recordHome() {
      endSensor.disable();
      motor.stop();
      motor.zero();
      return false;
    }

    void startAbsoluteMove(IConstrainedMove.position_t target) {
      ITouchSense.TouchState ignore = endSensor.enable();
      motor.move($(config.get("Power::OperationalSpeed"))$, target);
      s = State.moving;
      return false;
    }

    void notifyArrived() {
      motor.stop();
      endSensor.disable();
      s = State.idle;
      ctrl.arrived();
      return false;
    }

    on ctrl.stop():
    {
      [s.calibratingEnd || s.moving || s.idle || s.lost]
      {
        motor.stop();
        endSensor.disable();
        s = State.lost;
      }
    }
    on ctrl.calibrate():
    {
      [s.lost]
      {
        ITouchSense.TouchState ess = endSensor.enable();
        if (ess == ITouchSense.TouchState.Pressed) {
          recordHome();
          s = State.idle;
          ctrl.homed();
        }
        else {
          slowForward();
          s = State.calibratingEnd;
        }
      }
      [s.calibratingEnd || s.moving || s.idle]
      illegal;
    }
    on ctrl.move():
    {
      [s.calibratingEnd || s.moving || s.lost]
      illegal;
    }
    on endSensor.pressed():
    {
      [s.idle || s.lost]
      illegal;
      [s.moving]
      {
        motor.stop();
        notifyArrived();
      }
      [s.calibratingEnd]
      {
        recordHome();
        s = State.idle;
        ctrl.homed();
      }
    }
    on endSensor.released():
    {
      [s.calibratingEnd || s.idle || s.lost]
      illegal;
      [s.moving]
      {}
    }
    on motor.arrived():
    {
      [s.calibratingEnd || s.idle || s.lost]
      illegal;
      [s.moving]
      notifyArrived();
    }
    on ctrl.move(target):
    [s.idle]
    {
      ITouchSense.TouchState ignore = ITouchSense.TouchState.Released;
      ignore = endSensor.enable();
      motor.move($(config.get("Power::OperationalSpeed"))$, target);
      s = State.moving;
    }
  }
}

component EndConstrainedAxis {
  provides IConstrainedMove ctrl;
  requires imotor motorHw;
  requires itouch endSensorHw;

  system {
    nameEndConstrainedMove bhv;
    nameMotor motor;
    nameTouchSensor endSensor;

    ctrl <=> bhv.ctrl;
    bhv.motor <=> motor.ctrl;
    bhv.endSensor <=> endSensor.ctrl;
    motor.hw <=> motorHw;
    endSensor.hw <=> endSensorHw;
  }
}

