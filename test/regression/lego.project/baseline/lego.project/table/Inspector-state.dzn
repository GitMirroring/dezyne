interface IInspect {
  in void calibrate();
  out void calibrated();
  in void stop();
  in void inspect();
  out void accepted();
  out void rejected();
  in void prepare();
  out void prepared();

  behaviour {
    enum State {Lost, Ready, Calibrating, Inspecting, Waiting, Preparing};
    State s = State.Lost;

    [s.Lost]
    {
      on stop:
      s = State.Lost;
      on calibrate:
      {
        [true]
        s = State.Calibrating;
        [true]
        {
          calibrated;
          s = State.Ready;

        }

      }
      on inspect, prepare:
      illegal;

    }
    [s.Ready]
    {
      on stop:
      s = State.Lost;
      on calibrate, prepare:
      illegal;
      on inspect:
      s = State.Inspecting;

    }
    [s.Calibrating]
    {
      on stop:
      s = State.Lost;
      on calibrate, inspect, prepare:
      illegal;
      on inevitable:
      {
        calibrated;
        s = State.Ready;

      }

    }
    [s.Inspecting]
    {
      on stop:
      s = State.Lost;
      on calibrate, inspect, prepare:
      illegal;
      on inevitable:
      {
        [true]
        {
          accepted;
          s = State.Waiting;

        }
        [true]
        {
          rejected;
          s = State.Waiting;

        }

      }

    }
    [s.Waiting]
    {
      on stop:
      s = State.Lost;
      on calibrate, inspect:
      illegal;
      on prepare:
      {
        [true]
        s = State.Preparing;
        [true]
        {
          prepared;
          s = State.Ready;

        }

      }

    }
    [s.Preparing]
    {
      on stop:
      s = State.Lost;
      on calibrate, inspect, prepare:
      illegal;
      on inevitable:
      {
        prepared;
        s = State.Ready;

      }

    }
  }
}

component Inspect {
  provides IInspect ctrl;
  requires ilight sensor;
  requires IMove2D stage;
  requires itimer sensorSettleTimer;

  behaviour {
    enum State {Lost, Ready, Calibrating, Inspecting, Waiting, Preparing};
    enum InspectPosition {Unknown, Receive, Inspect, Accept, Reject};
    State s = State.Lost;
    InspectPosition p = InspectPosition.Unknown;
    IMove2D.MovePosition receiveX = $(config.get("Position::Inspector::ReceiveX"))$;
    IMove2D.MovePosition receiveY = $(config.get("Position::Inspector::ReceiveY"))$;
    IMove2D.MovePosition inspectX = $(config.get("Position::Inspector::InspectX"))$;
    IMove2D.MovePosition inspectY = $(config.get("Position::Inspector::InspectY"))$;
    IMove2D.MovePosition acceptX = $(config.get("Position::Inspector::AcceptX"))$;
    IMove2D.MovePosition acceptY = $(config.get("Position::Inspector::AcceptY"))$;
    IMove2D.MovePosition rejectX = $(config.get("Position::Inspector::RejectX"))$;
    IMove2D.MovePosition rejectY = $(config.get("Position::Inspector::RejectY"))$;

    void stop() {
      sensorSettleTimer.cancel();
      stage.stop();
      sensor.turnoff();
      p = InspectPosition.Unknown;
      s = State.Lost;
      return false;

    }

    [s.Lost]
    {
      on sensorSettleTimer.timeout(), ctrl.inspect(), ctrl.prepare(), stage.arrived(), stage.calibrated():
      illegal;
      on ctrl.stop():
      stop, (), falseon ctrl.calibrate():
      {
        s = State.Calibrating;
        p = InspectPosition.Unknown;
        stage.calibrate();

      }

    }
    [s.Ready]
    {
      on sensorSettleTimer.timeout(), ctrl.calibrate(), ctrl.prepare(), stage.arrived(), stage.calibrated():
      illegal;
      on ctrl.stop():
      stop, (), falseon ctrl.inspect():
      {
        s = State.Inspecting;
        stage.move(inspectX, inspectY);

      }

    }
    [s.Calibrating]
    {
      on sensorSettleTimer.timeout(), ctrl.calibrate(), ctrl.inspect(), ctrl.prepare():
      illegal;
      on ctrl.stop():
      stop, (), falseon stage.arrived():
      {
        [p.Receive]
        {
          ctrl.calibrated();
          s = State.Ready;

        }
        [!p.Receive]
        illegal;

      }
      on stage.calibrated():
      {
        [p.Unknown]
        {
          stage.move(receiveX, receiveY);
          p = InspectPosition.Receive;

        }
        [!p.Unknown]
        illegal;

      }

    }
    [s.Inspecting]
    {
      on sensorSettleTimer.timeout():
      {
        ilight.status ballStatus = sensor.detect();
        sensor.turnoff();
        if (ballStatus == ilight.status.accept) {
          stage.move(acceptX, acceptY);
          p = InspectPosition.Accept;

        }
        else
        {
          stage.move(rejectX, rejectY);
          p = InspectPosition.Reject;

        }

      }
      on ctrl.stop():
      stop, (), falseon ctrl.calibrate(), ctrl.inspect(), ctrl.prepare(), stage.calibrated():
      illegal;
      on stage.arrived():
      {
        [p.Receive]
        {
          p = InspectPosition.Inspect;
          sensor.turnon();
          sensorSettleTimer.create($100$);

        }
        [p.Accept]
        {
          ctrl.accepted();
          s = State.Waiting;

        }
        [p.Reject]
        {
          ctrl.rejected();
          s = State.Waiting;

        }
        [p.Inspect]
        illegal;

      }

    }
    [s.Waiting]
    {
      on sensorSettleTimer.timeout(), ctrl.calibrate(), ctrl.inspect(), stage.arrived(), stage.calibrated():
      illegal;
      on ctrl.stop():
      stop, (), falseon ctrl.prepare():
      {
        s = State.Preparing;
        p = InspectPosition.Receive;
        stage.move(receiveX, receiveY);

      }

    }
    [s.Preparing]
    {
      on sensorSettleTimer.timeout(), ctrl.calibrate(), ctrl.inspect(), ctrl.prepare(), stage.calibrated():
      illegal;
      on ctrl.stop():
      stop, (), falseon stage.arrived():
      {
        ctrl.prepared();
        s = State.Ready;

      }

    }
  }

}

component Inspector {
  provides IInspect ctrl;
  requires ilight sensor;
  requires imotor stageXMotorHw;
  requires itouch stageXHomeSensorHw;
  requires itouch stageXEndSensorHw;
  requires imotor stageYMotorHw;
  requires itouch stageYHomeSensorHw;
  requires itouch stageYEndSensorHw;

  system {
    nameInspect bhv;
    nameStage stage;
    nametimer sensorSettletimer;

    ctrl <=> bhv.ctrl;
    bhv.sensor <=> sensor;
    bhv.stage <=> stage.ctrl;
    stage.xMotorHw <=> stageXMotorHw;
    stage.xHomeSensorHw <=> stageXHomeSensorHw;
    stage.xEndSensorHw <=> stageXEndSensorHw;
    stage.yMotorHw <=> stageYMotorHw;
    stage.yHomeSensorHw <=> stageYHomeSensorHw;
    stage.yEndSensorHw <=> stageYEndSensorHw;
    bhv.sensorSettleTimer <=> sensorSettletimer.port;
  }
}

