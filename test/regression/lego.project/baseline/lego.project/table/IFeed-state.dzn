interface IFeed {
  in void calibrate();
  out void calibrated();
  in void stop();
  in void produceBall();
  out void consumeNextBall();
  out void consumeLastBall();

  behaviour {
    enum State {Lost, Calibrating, Idle, Preparing, Prepared};
    State s = State.Lost;

    [s.Lost]
    {
      on stop:
      s = State.Lost;
      on calibrate:
      {
        [true]
        s = State.Calibrating;
        [true]
        {
          calibrated;
          s = State.Idle;

        }

      }
      on produceBall:
      illegal;

    }
    [s.Calibrating]
    {
      on stop:
      s = State.Lost;
      on calibrate, produceBall:
      illegal;
      on inevitable:
      {
        calibrated;
        s = State.Idle;

      }

    }
    [s.Idle]
    {
      on stop:
      s = State.Lost;
      on calibrate:
      illegal;
      on produceBall:
      {
        [true]
        s = State.Preparing;
        [true]
        {
          consumeNextBall;
          s = State.Prepared;

        }
        [true]
        {
          consumeLastBall;
          s = State.Idle;

        }

      }

    }
    [s.Preparing]
    {
      on stop:
      s = State.Lost;
      on calibrate, produceBall:
      illegal;
      on inevitable:
      {
        [true]
        {
          consumeNextBall;
          s = State.Prepared;

        }
        [true]
        {
          consumeLastBall;
          s = State.Idle;

        }

      }

    }
    [s.Prepared]
    {
      on stop:
      s = State.Lost;
      on calibrate:
      illegal;
      on produceBall:
      {
        [true]
        s = State.Preparing;
        [true]
        {
          consumeNextBall;
          s = State.Prepared;

        }
        [true]
        {
          consumeLastBall;
          s = State.Idle;

        }

      }

    }
  }
}

