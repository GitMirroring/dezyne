interface ITouchSense
{
  enum TouchState { Pressed, Released };
  in TouchState enable();
  out void pressed();
  out void released();
  in void disable();

  behaviour 
  {
    bool disabled = true;
    TouchState ts = TouchState.Released;
    [!disabled]
    {
      on enable:
      illegal;
      on disable:
      disabled = true;
      on inevitable:
      {
        [ts.Released]
        {
          ts = TouchState.Pressed;
          pressed;
        }
        [ts.Pressed]
        {
          ts = TouchState.Released;
          released;
        }
      }
    }
    [disabled]
    {
      on enable:
      {
        [true]
        {
          ts = TouchState.Pressed;
          reply(ts);
          disabled = false;
        }
        [true]
        {
          ts = TouchState.Released;
          reply(ts);
          disabled = false;
        }
      }
      on disable:
      {
      }
    }
  }
}
component TouchSense
{
  provides ITouchSense ctrl;
  requires itimer timer;
  requires itouch sensor;

  behaviour 
  {
    ITouchSense.TouchState previous = ITouchSense.TouchState.Released;
    itimer.milliseconds_t time = $50$;
    bool disabled = true;
    ITouchSense.TouchState getStatus()
    {
      itouch.status val = sensor.detect();
      if (val == itouch.status.released)
      return ITouchSense.TouchState.Released;
      else
      return ITouchSense.TouchState.Pressed;
    }

    [previous.Pressed]
    {
      on ctrl.disable():
      {
        timer.cancel();
        disabled = true;
      }
      on ctrl.enable():
      {
        [disabled]
        {
          previous = getStatus();
          timer.create(time);
          disabled = false;
          reply(previous);
        }
        [!disabled]
        illegal;
      }
      on timer.timeout():
      {
        [disabled]
        illegal;
        [!disabled]
        {
          ITouchSense.TouchState current = getStatus();
          previous = current;
          timer.create(time);
        }
      }
    }
    [previous.Released]
    {
      on ctrl.disable():
      {
        timer.cancel();
        disabled = true;
      }
      on ctrl.enable():
      {
        [disabled]
        {
          previous = getStatus();
          timer.create(time);
          disabled = false;
          reply(previous);
        }
        [!disabled]
        illegal;
      }
      on timer.timeout():
      {
        [disabled]
        illegal;
        [!disabled]
        {
          ITouchSense.TouchState current = getStatus();
          previous = current;
          timer.create(time);
        }
      }
    }
  }
}
component TouchSensor
{
  provides ITouchSense ctrl;
  requires itouch hw;

  system
  {
    timer pollTimer;
    TouchSense bhv;

    ctrl <=> bhv.ctrl;
    bhv.timer <=> pollTimer.port;
    bhv.sensor <=> hw;
  }
}

