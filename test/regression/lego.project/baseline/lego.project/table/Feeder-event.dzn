component Feed
{
  provides IFeed ctrl;
  requires IConstrainedMove axis;

  behaviour 
  {
    enum State { Lost, Calibrating, Idle, Preparing, Prepared };
    subint Count {0..4};
    State s = State.Lost;
    bool isRetracting = false;
    bool isFeedRequested = false;
    Count inventory = 0;
    void feedNext()
    {
      if (inventory == 4)
      {
        axis.move($(config("Position::Feeder::DropFirst"))$);
      }
      if (inventory == 3)
      {
        axis.move($(config("Position::Feeder::DropSecond"))$);
      }
      if (inventory == 2)
      {
        axis.move($(config("Position::Feeder::DropThird"))$);
      }
      if (inventory == 1)
      {
        axis.move($(config("Position::Feeder::DropLast"))$);
      }
      s = State.Preparing;
      inventory = inventory - 1;
      return;
    }

    void retract()
    {
      axis.move($(config("Position::Feeder::Retracted"))$);
      isRetracting = true;
      return;
    }

    void refill()
    {
      inventory = 4;
      return;
    }

    on ctrl.stop():
    {
      [s.Prepared || s.Preparing || s.Idle || s.Calibrating || s.Lost]
      {
        axis.stop();
        s = State.Lost;
        isRetracting = false;
        isFeedRequested = false;
      }
    }
    on ctrl.calibrate():
    {
      [s.Lost]
      {
        axis.calibrate();
        s = State.Calibrating;
      }
      [s.Prepared || s.Preparing || s.Idle || s.Calibrating]
      illegal;
    }
    on ctrl.produceBall():
    {
      [s.Preparing || s.Calibrating || s.Lost]
      illegal;
      [s.Idle]
      [!isRetracting]
      feedNext();
      [s.Idle]
      [isRetracting && !isFeedRequested]
      isFeedRequested = true;
      [s.Idle]
      [isRetracting && isFeedRequested]
      illegal;
      [s.Prepared]
      feedNext();
    }
    on axis.homed():
    {
      [s.Prepared || s.Preparing || s.Idle || s.Lost]
      illegal;
      [s.Calibrating]
      {
        ctrl.calibrated();
        refill();
        s = State.Idle;
      }
    }
    on axis.arrived():
    {
      [s.Prepared || s.Calibrating || s.Lost]
      illegal;
      [s.Idle]
      [isRetracting]
      {
        refill();
        if (isFeedRequested)
        feedNext();
        isRetracting = false;
        isFeedRequested = false;
      }
      [s.Idle]
      [!isRetracting]
      illegal;
      [s.Preparing]
      [inventory > 0]
      {
        ctrl.consumeNextBall();
        s = State.Prepared;
      }
      [s.Preparing]
      [inventory == 0]
      {
        ctrl.consumeLastBall();
        retract();
        s = State.Idle;
      }
    }
  }
}
component Feeder
{
  provides IFeed ctrl;
  requires imotor motorHw;
  requires itouch endSensorHw;

  system
  {
    Feed bhv;
    EndConstrainedAxis axis;

    ctrl <=> bhv.ctrl;
    bhv.axis <=> axis.ctrl;
    axis.motorHw <=> motorHw;
    axis.endSensorHw <=> endSensorHw;
  }
}

