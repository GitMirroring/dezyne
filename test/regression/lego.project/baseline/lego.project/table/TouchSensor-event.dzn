interface ITouchSense {
  enum TouchState {Pressed, Released};
  in TouchState enable();
  out void pressed();
  out void released();
  in void disable();

  behaviour {
    bool disabled = true;
    TouchState ts = TouchState.Released;

    on enable:
    {
      [!disabled]
      illegal;
      [disabled]
      {
        ts = TouchState.Pressed;
        reply(ts);
        disabled = false;
      }
      [disabled]
      {
        ts = TouchState.Released;
        reply(ts);
        disabled = false;
      }
    }
    on disable:
    {
      [!disabled]
      disabled = true;
      [disabled]
      {}
    }
    on inevitable:
    {
      [!disabled]
      [ts.Released]
      {
        ts = TouchState.Pressed;
        pressed;
      }
      [!disabled]
      [ts.Pressed]
      {
        ts = TouchState.Released;
        released;
      }
    }
  }
}

component TouchSense {
  provides ITouchSense ctrl;
  requires itimer timer;
  requires itouch sensor;

  behaviour {
    ITouchSense.TouchState previous = ITouchSense.TouchState.Released;
    itimer.milliseconds_t time = $50$;
    bool disabled = true;

    ITouchSense.TouchState getStatus() {
      itouch.status val = sensor.detect();
      if (val == itouch.status.released) return ITouchSense.TouchState.Released;
      else return ITouchSense.TouchState.Pressed;
    }

    on ctrl.disable():
    {
      [previous.Released || previous.Pressed]
      {
        timer.cancel();
        disabled = true;
      }
    }
    on ctrl.enable():
    {
      [previous.Released || previous.Pressed]
      [disabled]
      {
        previous = getStatus();
        timer.create(time);
        disabled = false;
        reply(previous);
      }
      [previous.Released || previous.Pressed]
      [!disabled]
      illegal;
    }
    on timer.timeout():
    {
      [previous.Released || previous.Pressed]
      [disabled]
      illegal;
      [previous.Pressed]
      [!disabled]
      {
        ITouchSense.TouchState current = getStatus();
        if (current == ITouchSense.TouchState.Released) ctrl.released();
        previous = current;
        timer.create(time);
      }
      [previous.Released]
      [!disabled]
      {
        ITouchSense.TouchState current = getStatus();
        if (current == ITouchSense.TouchState.Pressed) ctrl.pressed();
        else {}
        previous = current;
        timer.create(time);
      }
    }
  }

}

component TouchSensor {
  provides ITouchSense ctrl;
  requires itouch hw;

  system {
    nametimer pollTimer;
    nameTouchSense bhv;

    ctrl <=> bhv.ctrl;
    bhv.timer <=> pollTimer.port;
    bhv.sensor <=> hw;
  }
}

