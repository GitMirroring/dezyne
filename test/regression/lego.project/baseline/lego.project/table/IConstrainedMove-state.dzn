interface IConstrainedMove
{
  extern position_t $int32_t$;
  in void calibrate();
  out void homed();
  in void stop();
  in void move(position_t target);
  out void arrived();

  behaviour 
  {
    enum State { lost, idle, calibrating, moving };
    State s = State.lost;
    void notifyHomed()
    {
      s = State.idle;
      homed;
      return;
    }

    void notifyArrived()
    {
      s = State.idle;
      arrived;
      return;
    }

    [s.lost]
    {
      on calibrate:
      {
        [true]
        s = State.calibrating;
        [true]
        notifyHomed();
      }
      on move:
      illegal;
      on stop:
      s = State.lost;
    }
    [s.idle]
    {
      on calibrate:
      illegal;
      on move:
      s = State.moving;
      on stop:
      s = State.lost;
    }
    [s.calibrating]
    {
      on calibrate, move:
      illegal;
      on stop:
      s = State.lost;
      on inevitable:
      notifyHomed();
    }
    [s.moving]
    {
      on calibrate, move:
      illegal;
      on stop:
      s = State.lost;
      on inevitable:
      notifyArrived();
    }
  }
}

