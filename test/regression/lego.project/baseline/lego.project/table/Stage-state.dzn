interface IMove2D {
  extern MovePosition $Integer$;
  in void calibrate();
  out void calibrated();
  in void stop();
  in void move(MovePosition x, MovePosition y);
  out void arrived();

  behaviour {
    enum State {Lost, Calibrating, Ready, Moving};
    State s = State.Lost;

    [s.Lost]
    {
      on stop:
      s = State.Lost;
      on calibrate:
      {
        [true]
        s = State.Calibrating;
        [true]
        {
          calibrated;
          s = State.Ready;
        }
      }
      on move:
      {
        [true]
        illegal;
        [true]
        {}
      }
    }
    [s.Calibrating]
    {
      on stop:
      s = State.Lost;
      on calibrate, move:
      {
        [true]
        illegal;
        [true]
        {}
      }
      on inevitable:
      {
        s = State.Ready;
        calibrated;
      }
    }
    [s.Ready]
    {
      on stop:
      s = State.Lost;
      on calibrate:
      {
        [true]
        illegal;
        [true]
        {}
      }
      on move:
      s = State.Moving;
    }
    [s.Moving]
    {
      on stop:
      s = State.Lost;
      on calibrate, move:
      {
        [true]
        illegal;
        [true]
        {}
      }
      on inevitable:
      {
        s = State.Ready;
        arrived;
      }
    }
  }
}

component Move2D {
  provides IMove2D ctrl;
  requires IConstrainedMove xAxis;
  requires IConstrainedMove yAxis;

  behaviour {
    subint AxisCount {0..2};
    bool isCalibrating = false;
    AxisCount nCalibrated = 0;
    AxisCount nMoving = 0;

    void tryCalibrated() {
      nCalibrated = nCalibrated + 1;
      if (nCalibrated == 2) {
        ctrl.calibrated();
        isCalibrating = false;
      }
      return false;
    }

    void tryArrived() {
      nMoving = nMoving - 1;
      if (nMoving == 0) ctrl.arrived();
      return false;
    }

    [!isCalibrating]
    {
      on ctrl.stop():
      {
        xAxis.stop();
        yAxis.stop();
        nCalibrated = 0;
        nMoving = 0;
        isCalibrating = false;
      }
      on ctrl.calibrate():
      {
        [nCalibrated == 0]
        {
          xAxis.calibrate();
          yAxis.calibrate();
          nCalibrated = 0;
          isCalibrating = true;
        }
        [true]
        {}
      }
      on xAxis.homed(), yAxis.homed():
      if (nCalibrated < 2) tryCalibrated();
      else illegal;
      on ctrl.move(x, y):
      {
        [nMoving == 0 && nCalibrated == 2]
        {
          nMoving = 2;
          xAxis.move(x);
          yAxis.move(y);
        }
        [true]
        {}
      }
      on xAxis.arrived(), yAxis.arrived():
      {
        [nMoving > 0]
        tryArrived();
        [nMoving == 0]
        illegal;
      }
    }
    [isCalibrating]
    {
      on ctrl.stop():
      {
        xAxis.stop();
        yAxis.stop();
        nCalibrated = 0;
        nMoving = 0;
        isCalibrating = false;
      }
      on ctrl.calibrate():
      {}
      on xAxis.homed(), yAxis.homed():
      if (nCalibrated < 2) tryCalibrated();
      else illegal;
      on ctrl.move(x, y):
      {
        [nMoving == 0 && nCalibrated == 2]
        {
          nMoving = 2;
          xAxis.move(x);
          yAxis.move(y);
        }
        [true]
        {}
      }
      on xAxis.arrived(), yAxis.arrived():
      {
        [nMoving > 0]
        tryArrived();
        [nMoving == 0]
        illegal;
      }
    }
  }
}

component Stage {
  provides IMove2D ctrl;
  requires imotor xMotorHw;
  requires itouch xHomeSensorHw;
  requires itouch xEndSensorHw;
  requires imotor yMotorHw;
  requires itouch yHomeSensorHw;
  requires itouch yEndSensorHw;

  system {
    nameMove2D bhv;
    nameConstrainedAxis xAxis;
    nameConstrainedAxis yAxis;

    ctrl <=> bhv.ctrl;
    bhv.xAxis <=> xAxis.ctrl;
    bhv.yAxis <=> yAxis.ctrl;
    xAxis.motorHw <=> xMotorHw;
    xAxis.homeSensorHw <=> xHomeSensorHw;
    xAxis.endSensorHw <=> xEndSensorHw;
    yAxis.motorHw <=> yMotorHw;
    yAxis.homeSensorHw <=> yHomeSensorHw;
    yAxis.endSensorHw <=> yEndSensorHw;
  }
}

