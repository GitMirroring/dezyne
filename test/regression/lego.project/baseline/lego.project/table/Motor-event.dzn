interface IMove {
  extern imove_boolean $Boolean$;
  extern imove_position_t $Integer$;
  extern imove_milliseconds_t $Integer$;
  extern imove_power_t $Byte$;
  in void move(imove_power_t power, imove_position_t position);
  out void arrived();
  in void run(imove_power_t power, imove_boolean invert);
  in void pulse(imove_power_t power, imove_boolean invert, imove_milliseconds_t duration);
  in void stop();
  in void coast();
  in void zero();
  in void position(out imove_position_t pos);

  behaviour {
    bool moving = false;

    on move:
    {
      [!moving]
      moving = true;
      [moving]
      illegal;
    }
    on zero:
    {
      [!moving]
      {}
      [moving]
      illegal;
    }
    on run:
    {
      [moving || !moving]
      {}
      [moving]
      illegal;
    }
    on pulse:
    {
      [moving || !moving]
      moving = true;
      [moving]
      illegal;
    }
    on stop:
    {
      [moving || !moving]
      moving = false;
    }
    on coast:
    {
      [moving || !moving]
      moving = false;
    }
    on position:
    {
      [moving || !moving]
      {}
    }
    on inevitable:
    [moving]
    {
      moving = false;
      arrived;
    }
  }
}

component Move {
  provides IMove ctrl;
  requires itimer timer;
  requires imotor motor;

  behaviour {
    bool moving = false;
    bool pulsing = false;
    itimer.milliseconds_t time = $(config.get("Duration::PollInterval"))$;
    imotor.position_t destination = ;

    on ctrl.move(power, position):
    {
      [!moving]
      [!pulsing]
      {
        destination = position;
        timer.create(time);
        motor.move(power, destination);
        moving = true;
      }
      [moving]
      [!pulsing]
      illegal;
    }
    on ctrl.pulse(power, invert, duration):
    [!moving]
    [!pulsing]
    {
      timer.create(duration);
      motor.run(power, invert);
      pulsing = true;
    }
    on timer.timeout():
    {
      [!moving]
      [!pulsing]
      illegal;
      [!moving]
      [pulsing]
      {
        motor.coast();
        ctrl.arrived();
        pulsing = false;
      }
      [moving]
      [!pulsing]
      {
        imotor.result_t arrive = motor.at(destination);
        if (arrive == imotor.result_t.yes) {
          ctrl.arrived();
          moving = false;
        }
        else timer.create(time);
      }
    }
    on ctrl.zero():
    {
      [!moving]
      [!pulsing]
      motor.zero();
      [!moving]
      [pulsing]
      illegal;
      [moving]
      [!pulsing]
      illegal;
    }
    on ctrl.move(pow, pos):
    [!moving]
    [pulsing]
    illegal;
    on ctrl.pulse(p, i, d):
    {
      [!moving]
      [pulsing]
      illegal;
      [moving]
      [!pulsing]
      illegal;
    }
    on ctrl.run(power, invert):
    {
      [moving || !moving]
      motor.run(power, invert);
    }
    on ctrl.stop():
    {
      [moving || !moving]
      {
        motor.stop();
        timer.cancel();
        moving = false;
        pulsing = false;
      }
    }
    on ctrl.coast():
    {
      [moving || !moving]
      {
        motor.coast();
        timer.cancel();
        moving = false;
        pulsing = false;
      }
    }
    on ctrl.position(pos):
    {
      [moving || !moving]
      motor.position(pos);
    }
  }

}

component Motor {
  provides IMove ctrl;
  requires imotor hw;

  system {
    nametimer pollTimer;
    nameMove bhv;

    ctrl <=> bhv.ctrl;
    bhv.timer <=> pollTimer.port;
    bhv.motor <=> hw;
  }
}

