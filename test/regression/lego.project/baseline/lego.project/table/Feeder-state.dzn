component Feed {
  provides IFeed ctrl;
  requires IConstrainedMove axis;

  behaviour {
    enum State {Lost, Calibrating, Idle, Preparing, Prepared};
    subint Count {0..4};
    State s = State.Lost;
    bool isRetracting = false;
    bool isFeedRequested = false;
    Count inventory = 0;

    void feedNext() {
      if (inventory == 4) {
        axis.move($(config.get("Position::Feeder::DropFirst"))$);
      }
      if (inventory == 3) {
        axis.move($(config.get("Position::Feeder::DropSecond"))$);
      }
      if (inventory == 2) {
        axis.move($(config.get("Position::Feeder::DropThird"))$);
      }
      if (inventory == 1) {
        axis.move($(config.get("Position::Feeder::DropLast"))$);
      }
      s = State.Preparing;
      inventory = inventory - 1;
      return false;
    }

    void retract() {
      axis.move($(config.get("Position::Feeder::Retracted"))$);
      isRetracting = true;
      return false;
    }

    void refill() {
      inventory = 4;
      return false;
    }

    [s.Lost]
    {
      on ctrl.stop():
      {
        axis.stop();
        s = State.Lost;
        isRetracting = false;
        isFeedRequested = false;
      }
      on ctrl.calibrate():
      {
        axis.calibrate();
        s = State.Calibrating;
      }
      on ctrl.produceBall(), axis.homed(), axis.arrived():
      illegal;
    }
    [s.Calibrating]
    {
      on ctrl.stop():
      {
        axis.stop();
        s = State.Lost;
        isRetracting = false;
        isFeedRequested = false;
      }
      on ctrl.calibrate(), ctrl.produceBall(), axis.arrived():
      illegal;
      on axis.homed():
      {
        ctrl.calibrated();
        refill();
        s = State.Idle;
      }
    }
    [s.Idle]
    {
      on ctrl.stop():
      {
        axis.stop();
        s = State.Lost;
        isRetracting = false;
        isFeedRequested = false;
      }
      on ctrl.calibrate(), axis.homed():
      illegal;
      on ctrl.produceBall():
      {
        [!isRetracting]
        feedNext();
        [isRetracting && !isFeedRequested]
        isFeedRequested = true;
        [isRetracting && isFeedRequested]
        illegal;
      }
      on axis.arrived():
      {
        [isRetracting]
        {
          refill();
          if (isFeedRequested) feedNext();
          isRetracting = false;
          isFeedRequested = false;
        }
        [!isRetracting]
        illegal;
      }
    }
    [s.Preparing]
    {
      on ctrl.stop():
      {
        axis.stop();
        s = State.Lost;
        isRetracting = false;
        isFeedRequested = false;
      }
      on ctrl.calibrate(), ctrl.produceBall(), axis.homed():
      illegal;
      on axis.arrived():
      {
        [inventory > 0]
        {
          ctrl.consumeNextBall();
          s = State.Prepared;
        }
        [inventory == 0]
        {
          ctrl.consumeLastBall();
          retract();
          s = State.Idle;
        }
      }
    }
    [s.Prepared]
    {
      on ctrl.stop():
      {
        axis.stop();
        s = State.Lost;
        isRetracting = false;
        isFeedRequested = false;
      }
      on ctrl.calibrate(), axis.homed(), axis.arrived():
      illegal;
      on ctrl.produceBall():
      feedNext();
    }
  }
}

component Feeder {
  provides IFeed ctrl;
  requires imotor motorHw;
  requires itouch endSensorHw;

  system {
    Feed bhv;
    EndConstrainedAxis axis;

    ctrl <=> bhv.ctrl;
    bhv.axis <=> axis.ctrl;
    axis.motorHw <=> motorHw;
    axis.endSensorHw <=> endSensorHw;
  }
}

