interface IConvey {
  in void convey();
  out void conveyed();
  in void stop();

  behaviour {
    enum State {Idle, Conveying};
    State s = State.Idle;

    on stop:
    {
      [s.Conveying || s.Idle]
      s = State.Idle;
    }
    on convey:
    {
      [s.Idle]
      s = State.Conveying;
      [s.Idle]
      conveyed;
      [s.Conveying]
      illegal;
    }
    on inevitable:
    [s.Conveying]
    {
      conveyed;
      s = State.Idle;
    }
  }
}

component Convey {
  provides IConvey ctrl;
  requires IMove motor;
  requires ITouchSense sensor;

  behaviour {
    enum State {Idle, Conveying};
    State s = State.Idle;

    on ctrl.stop():
    {
      [s.Conveying || s.Idle]
      {
        motor.stop();
        sensor.disable();
        s = State.Idle;
      }
    }
    on motor.arrived():
    {
      [s.Conveying || s.Idle]
      {}
    }
    on ctrl.convey():
    {
      [s.Idle]
      {
        ITouchSense.TouchState ss = sensor.enable();
        if (ss == ITouchSense.TouchState.Pressed) {
          sensor.disable();
          ctrl.conveyed();
        }
        else {
          motor.run($(config.get("Power::50"))$, $false$);
          s = State.Conveying;
        }
      }
      [s.Conveying]
      illegal;
    }
    on sensor.pressed():
    {
      [s.Idle]
      illegal;
      [s.Conveying]
      {
        sensor.disable();
        motor.stop();
        ctrl.conveyed();
        s = State.Idle;
      }
    }
    on sensor.released():
    {
      [s.Idle]
      illegal;
      [s.Conveying]
      {
        sensor.disable();
        motor.stop();
        ctrl.conveyed();
        s = State.Idle;
      }
    }
  }

}

component Conveyor {
  provides IConvey ctrl;
  requires imotor motorHw;
  requires itouch sensorHw;

  system {
    nameConvey bhv;
    nameMotor motor;
    nameTouchSensor sensor;

    ctrl <=> bhv.ctrl;
    bhv.motor <=> motor.ctrl;
    bhv.sensor <=> sensor.ctrl;
    motor.hw <=> motorHw;
    sensor.hw <=> sensorHw;
  }
}

