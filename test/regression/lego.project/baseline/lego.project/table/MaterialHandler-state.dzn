interface IHandle {
  in void calibrate();
  out void calibrated();
  in void stop();
  in void operate();
  out void finished();

  behaviour {
    enum State {Lost, Calibrating, Idle, Operating};
    State s = State.Lost;

    [s.Lost]
    {
      on stop:
      s = State.Lost;
      on calibrate:
      {
        [true]
        s = State.Calibrating;
        [true]
        {
          calibrated;
          s = State.Idle;
        }
      }
      on operate:
      {
        [true]
        illegal;
        [true]
        {}
      }
    }
    [s.Calibrating]
    {
      on stop:
      s = State.Lost;
      on calibrate, operate:
      {
        [true]
        illegal;
        [true]
        {}
      }
      on inevitable:
      {
        calibrated;
        s = State.Idle;
      }
    }
    [s.Idle]
    {
      on stop:
      s = State.Lost;
      on calibrate:
      {
        [true]
        illegal;
        [true]
        {}
      }
      on operate:
      {
        [true]
        s = State.Operating;
        [true]
        finished;
      }
    }
    [s.Operating]
    {
      on stop:
      s = State.Lost;
      on calibrate, operate:
      {
        [true]
        illegal;
        [true]
        {}
      }
      on inevitable:
      {
        s = State.Idle;
        finished;
      }
    }
  }
}

interface ITransfer {
  extern TrPosition $Integer$;
  in void calibrate();
  out void calibrated();
  in void stop();
  in void move(TrPosition x, TrPosition y);
  out void arrived();
  in void transfer(TrPosition x, TrPosition y);
  out void picked();
  out void placed();

  behaviour {
    enum State {Lost, Calibrating, Ready, Moving, Transferring};
    State s = State.Lost;
    bool isPicked = false;

    [s.Lost]
    {
      on stop:
      s = State.Lost;
      on calibrate:
      {
        [true]
        s = State.Calibrating;
        [true]
        {
          calibrated;
          s = State.Ready;
        }
      }
      on move, transfer:
      illegal;
    }
    [s.Calibrating]
    {
      on stop:
      s = State.Lost;
      on calibrate, move, transfer:
      illegal;
      on inevitable:
      {
        calibrated;
        s = State.Ready;
      }
    }
    [s.Ready]
    {
      on stop:
      s = State.Lost;
      on calibrate:
      illegal;
      on move:
      {
        [true]
        s = State.Moving;
        [true]
        arrived;
      }
      on transfer:
      {
        [true]
        {
          s = State.Transferring;
          isPicked = false;
        }
        [true]
        {
          s = State.Transferring;
          picked;
          isPicked = true;
        }
        [true]
        {
          s = State.Ready;
          picked;
          placed;
        }
      }
    }
    [s.Moving]
    {
      on stop:
      s = State.Lost;
      on calibrate, move, transfer:
      illegal;
      on inevitable:
      {
        arrived;
        s = State.Ready;
      }
    }
    [s.Transferring]
    {
      on stop:
      s = State.Lost;
      on calibrate, move, transfer:
      illegal;
      on inevitable:
      {
        [!isPicked]
        {
          picked;
          isPicked = true;
        }
        [isPicked]
        {
          placed;
          s = State.Ready;
        }
      }
    }
  }
}

interface IRetain {
  in void stop();
  in void calibrate();
  out void calibrated();
  in void retain();
  in void release();
  out void ready();

  behaviour {
    enum State {Lost, Calibrating, Ready, Moving};
    State s = State.Lost;
    bool isHolding = false;

    [s.Lost]
    {
      on stop:
      {
        s = State.Lost;
        isHolding = false;
      }
      on calibrate:
      {
        [true]
        s = State.Calibrating;
        [true]
        {
          calibrated;
          s = State.Ready;
          isHolding = true;
        }
      }
      on retain, release:
      illegal;
    }
    [s.Calibrating]
    {
      on stop:
      {
        s = State.Lost;
        isHolding = false;
      }
      on calibrate, retain, release:
      illegal;
      on inevitable:
      {
        calibrated;
        s = State.Ready;
        isHolding = true;
      }
    }
    [s.Ready]
    {
      on stop:
      {
        s = State.Lost;
        isHolding = false;
      }
      on calibrate:
      {
        [!isHolding]
        illegal;
        [isHolding]
        illegal;
      }
      on retain:
      {
        [!isHolding]
        s = State.Moving;
        [!isHolding]
        {
          ready;
          isHolding = true;
        }
        [isHolding]
        illegal;
      }
      on release:
      {
        [!isHolding]
        illegal;
        [isHolding]
        s = State.Moving;
        [isHolding]
        {
          ready;
          isHolding = false;
        }
      }
    }
    [s.Moving]
    {
      on stop:
      {
        s = State.Lost;
        isHolding = false;
      }
      on calibrate, retain, release:
      illegal;
      on inevitable:
      {
        ready;
        s = State.Ready;
        isHolding = !isHolding;
      }
    }
  }
}

component Handle {
  provides IHandle ctrl;
  requires ITransfer robot;
  requires IInspect inspector;
  requires IFeed feedPort;
  requires IConvey acceptPort;
  requires IConvey rejectPort;

  behaviour {
    enum State {Lost, Calibrating, Idle, Operating};
    subint usedCount {0..4};
    enum Operation {PreparingInput, TransferringInput, PreparingOutput, TransferringOutput, Finalizing};
    State s = State.Lost;
    usedCount calibrated = 0;
    usedCount requiredCalibrations = 3;
    Operation o = Operation.PreparingInput;
    bool isLastBall = false;
    bool isBallAtInput = false;
    bool isRobotAtInput = false;
    bool isRobotAtOutput = false;
    bool isInspectorAtInput = false;
    bool isInspectorAtOutput = false;
    bool isBallAccepted = false;
    bool isAcceptEmpty = true;
    bool isRejectEmpty = true;

    void tryCalibrated() {
      calibrated = calibrated + 1;
      if (calibrated == requiredCalibrations) {
        s = State.Idle;
        isInspectorAtInput = true;
        isInspectorAtOutput = false;
        ctrl.calibrated();
      }
      return false;
    }

    void ignoreIllegal() {
      return false;
    }

    void startBatch() {
      s = State.Operating;
      isLastBall = false;
      prepareInputTransfer();
      return false;
    }

    void finalizeBatch() {
      s = State.Idle;
      ctrl.finished();
      return false;
    }

    void prepareInputTransfer() {
      o = Operation.PreparingInput;
      if (!isBallAtInput) {
        feedPort.produceBall();
        isBallAtInput = false;
      }
      if (!isInspectorAtInput) {
        inspector.prepare();
        isInspectorAtInput = false;
      }
      if (!isRobotAtInput) {
        sendRobotToInputPick();
        isRobotAtInput = false;
      }
      tryInputTransfer();
      return false;
    }

    void sendRobotToInputPick() {
      robot.move($(config.get("Position::Robot::X::InputPick"))$, $(config.get("Position::Robot::Y::InputPick"))$);
      isRobotAtOutput = false;
      isRobotAtInput = false;
      return false;
    }

    void tryInputTransfer() {
      if (isBallAtInput && isRobotAtInput && isInspectorAtInput) {
        robot.transfer($(config.get("Position::Robot::X::InputDrop"))$, $(config.get("Position::Robot::Y::InputDrop"))$);
        o = Operation.TransferringInput;
      }
      return false;
    }

    void tryOutputTransfer() {
      if (isRobotAtOutput && isInspectorAtOutput) {
        if (isAcceptEmpty && isBallAccepted) {
          robot.transfer($(config.get("Position::Robot::X::OutputDrop"))$, $(config.get("Position::Robot::Y::AcceptDrop"))$);
          o = Operation.TransferringOutput;
        }
        if (isRejectEmpty && !isBallAccepted) {
          robot.transfer($(config.get("Position::Robot::X::OutputDrop"))$, $(config.get("Position::Robot::Y::RejectDrop"))$);
          o = Operation.TransferringOutput;
        }
      }
      return false;
    }

    void tryFinished() {
      if (isLastBall && !isBallAtInput && isAcceptEmpty && isRejectEmpty && isRobotAtInput && isInspectorAtInput) {
        s = State.Idle;
        ctrl.finished();
      }
      return false;
    }

    void manuallyRemoveStrayMaterial() {
      isBallAtInput = false;
      isAcceptEmpty = true;
      isRejectEmpty = true;
      return false;
    }

    [s.Lost]
    {
      on ctrl.stop():
      {
        robot.stop();
        inspector.stop();
        feedPort.stop();
        acceptPort.stop();
        rejectPort.stop();
        s = State.Lost;
        manuallyRemoveStrayMaterial();
      }
      on ctrl.calibrate():
      {
        robot.calibrate();
        inspector.calibrate();
        feedPort.calibrate();
        calibrated = 0;
        s = State.Calibrating;
      }
      on robot.calibrated(), inspector.calibrated(), feedPort.calibrated(), feedPort.consumeNextBall(), feedPort.consumeLastBall(), inspector.prepared(), inspector.accepted(), inspector.rejected(), robot.arrived(), robot.picked(), robot.placed(), acceptPort.conveyed(), rejectPort.conveyed():
      illegal;
      on ctrl.operate():
      ignoreIllegal();
    }
    [s.Calibrating]
    {
      on ctrl.stop():
      {
        robot.stop();
        inspector.stop();
        feedPort.stop();
        acceptPort.stop();
        rejectPort.stop();
        s = State.Lost;
        manuallyRemoveStrayMaterial();
      }
      on ctrl.calibrate(), ctrl.operate():
      ignoreIllegal();
      on robot.calibrated(), inspector.calibrated(), feedPort.calibrated():
      tryCalibrated();
      on feedPort.consumeNextBall(), feedPort.consumeLastBall(), inspector.prepared(), inspector.accepted(), inspector.rejected(), robot.arrived(), robot.picked(), robot.placed(), acceptPort.conveyed(), rejectPort.conveyed():
      illegal;
    }
    [s.Idle]
    {
      on ctrl.stop():
      {
        robot.stop();
        inspector.stop();
        feedPort.stop();
        acceptPort.stop();
        rejectPort.stop();
        s = State.Lost;
        manuallyRemoveStrayMaterial();
      }
      on ctrl.calibrate():
      ignoreIllegal();
      on robot.calibrated(), inspector.calibrated(), feedPort.calibrated(), feedPort.consumeNextBall(), feedPort.consumeLastBall(), inspector.prepared(), inspector.accepted(), inspector.rejected(), robot.arrived(), robot.picked(), robot.placed(), acceptPort.conveyed(), rejectPort.conveyed():
      illegal;
      on ctrl.operate():
      startBatch();
    }
    [s.Operating]
    {
      on ctrl.stop():
      {
        robot.stop();
        inspector.stop();
        feedPort.stop();
        acceptPort.stop();
        rejectPort.stop();
        s = State.Lost;
        manuallyRemoveStrayMaterial();
      }
      on ctrl.calibrate(), ctrl.operate():
      ignoreIllegal();
      on robot.calibrated(), inspector.calibrated(), feedPort.calibrated():
      illegal;
      on feedPort.consumeNextBall():
      {
        [o.PreparingInput]
        {
          isLastBall = false;
          isBallAtInput = true;
          tryInputTransfer();
        }
        [o.TransferringInput]
        {
          isLastBall = false;
          isBallAtInput = true;
        }
        [o.PreparingOutput]
        {
          isLastBall = false;
          isBallAtInput = true;
        }
        [o.TransferringOutput]
        {
          isLastBall = false;
          isBallAtInput = true;
        }
        [o.Finalizing]
        illegal;
      }
      on feedPort.consumeLastBall():
      {
        [o.PreparingInput]
        {
          isLastBall = true;
          isBallAtInput = true;
          tryInputTransfer();
        }
        [o.TransferringInput]
        {
          isLastBall = true;
          isBallAtInput = true;
        }
        [o.PreparingOutput]
        {
          isLastBall = true;
          isBallAtInput = true;
        }
        [o.TransferringOutput]
        {
          isLastBall = true;
          isBallAtInput = true;
        }
        [o.Finalizing]
        illegal;
      }
      on inspector.prepared():
      {
        [o.PreparingInput]
        {
          isInspectorAtInput = true;
          tryInputTransfer();
        }
        [o.TransferringInput]
        illegal;
        [o.PreparingOutput]
        illegal;
        [o.TransferringOutput]
        isInspectorAtInput = true;
        [o.Finalizing]
        {
          isInspectorAtInput = true;
          tryFinished();
        }
      }
      on inspector.accepted():
      {
        [o.PreparingInput]
        illegal;
        [o.TransferringInput]
        illegal;
        [o.PreparingOutput]
        {
          isBallAccepted = true;
          isInspectorAtOutput = true;
          tryOutputTransfer();
        }
        [o.TransferringOutput]
        illegal;
        [o.Finalizing]
        illegal;
      }
      on inspector.rejected():
      {
        [o.PreparingInput]
        illegal;
        [o.TransferringInput]
        illegal;
        [o.PreparingOutput]
        {
          isBallAccepted = false;
          isInspectorAtOutput = true;
          tryOutputTransfer();
        }
        [o.TransferringOutput]
        illegal;
        [o.Finalizing]
        illegal;
      }
      on robot.arrived():
      {
        [o.PreparingInput]
        {
          isRobotAtInput = true;
          tryInputTransfer();
        }
        [o.TransferringInput]
        illegal;
        [o.PreparingOutput]
        {
          isRobotAtOutput = true;
          tryOutputTransfer();
        }
        [o.TransferringOutput]
        illegal;
        [o.Finalizing]
        {
          isRobotAtInput = true;
          tryFinished();
        }
      }
      on robot.picked():
      {
        [o.PreparingInput]
        illegal;
        [o.TransferringInput && !isLastBall]
        {
          feedPort.produceBall();
          isBallAtInput = false;
        }
        [o.TransferringInput && isLastBall]
        isBallAtInput = false;
        [o.PreparingOutput]
        illegal;
        [o.TransferringOutput]
        {
          isInspectorAtOutput = false;
          inspector.prepare();
        }
        [o.Finalizing]
        illegal;
      }
      on robot.placed():
      {
        [o.PreparingInput]
        illegal;
        [o.TransferringInput]
        {
          isInspectorAtInput = false;
          inspector.inspect();
          isRobotAtInput = false;
          robot.move($(config.get("Position::Robot::X::OutputPick"))$, $(config.get("Position::Robot::Y::OutputPick"))$);
          o = Operation.PreparingOutput;
        }
        [o.PreparingOutput]
        illegal;
        [o.TransferringOutput && isBallAccepted]
        {
          isAcceptEmpty = false;
          acceptPort.convey();
          sendRobotToInputPick();
          if (isLastBall && !isBallAtInput) o = Operation.Finalizing;
          else o = Operation.PreparingInput;
        }
        [o.TransferringOutput && !isBallAccepted]
        {
          isRejectEmpty = false;
          rejectPort.convey();
          sendRobotToInputPick();
          if (isLastBall && !isBallAtInput) o = Operation.Finalizing;
          else o = Operation.PreparingInput;
        }
        [o.Finalizing]
        illegal;
      }
      on acceptPort.conveyed():
      {
        [o.PreparingInput]
        isAcceptEmpty = true;
        [o.TransferringInput]
        isAcceptEmpty = true;
        [o.PreparingOutput]
        {
          isAcceptEmpty = true;
          tryOutputTransfer();
        }
        [o.TransferringOutput]
        isAcceptEmpty = true;
        [o.Finalizing]
        {
          isAcceptEmpty = true;
          tryFinished();
        }
      }
      on rejectPort.conveyed():
      {
        [o.PreparingInput]
        isRejectEmpty = true;
        [o.TransferringInput]
        isRejectEmpty = true;
        [o.PreparingOutput]
        {
          isRejectEmpty = true;
          tryOutputTransfer();
        }
        [o.TransferringOutput]
        isRejectEmpty = true;
        [o.Finalizing]
        {
          isRejectEmpty = true;
          tryFinished();
        }
      }
    }
  }
}

component Transfer {
  provides ITransfer ctrl;
  requires IRetain hoist;
  requires IRetain gripper;
  requires IConstrainedMove trolley;
  requires IConstrainedMove truck;

  behaviour {
    enum State {Idle, Calibrating, Moving, Transferring};
    subint Count {0..5};
    enum TransferState {Picking, Raising, Moving, Placing, Idle};
    State s = State.Idle;
    TransferState ts = TransferState.Idle;
    Count nCalibrated = 0;
    Count nMoving = 0;
    bool isCalibrated = false;
    bool isXYMoveAllowed = false;
    bool isRetaining = true;
    ITransfer.TrPosition placeX = $0$;
    ITransfer.TrPosition placeY = $0$;

    void tryCalibrated() {
      nCalibrated = nCalibrated + 1;
      if (nCalibrated == 2) {
        isXYMoveAllowed = true;
        calibrateXY();
      }
      if (nCalibrated == 5) {
        isCalibrated = true;
        s = State.Idle;
        isRetaining = false;
        ctrl.calibrated();
      }
      return false;
    }

    void calibrateZ() {
      s = State.Calibrating;
      isXYMoveAllowed = false;
      nCalibrated = 0;
      hoist.calibrate();
      gripper.calibrate();
      return false;
    }

    void calibrateXY() {
      if (isXYMoveAllowed) {
        s = State.Calibrating;
        gripper.release();
        trolley.calibrate();
        truck.calibrate();
      }
      return false;
    }

    void startPick(ITransfer.TrPosition tgtX, ITransfer.TrPosition tgtY) {
      placeX = tgtX;
      placeY = tgtY;
      isXYMoveAllowed = false;
      s = State.Transferring;
      ts = TransferState.Picking;
      hoist.release();
      return false;
    }

    [s.Idle]
    {
      on ctrl.stop():
      {
        hoist.stop();
        gripper.stop();
        trolley.stop();
        truck.stop();
        s = State.Idle;
        isCalibrated = false;
        isRetaining = true;
        isXYMoveAllowed = false;
      }
      on ctrl.calibrate():
      {
        [!isCalibrated]
        {
          isCalibrated = false;
          isRetaining = true;
          calibrateZ();
        }
        [isCalibrated]
        illegal;
      }
      on ctrl.move():
      {
        [!isCalibrated]
        illegal;
        [isCalibrated && !isXYMoveAllowed]
        illegal;
      }
      on ctrl.transfer():
      [!isCalibrated]
      illegal;
      on ctrl.move(x, y):
      [isCalibrated && isXYMoveAllowed]
      {
        truck.move(x);
        trolley.move(y);
        nMoving = 2;
        s = State.Moving;
      }
      on ctrl.transfer(x, y):
      [isCalibrated]
      startPick(x, y);
      on hoist.calibrated(), gripper.calibrated(), trolley.homed(), truck.homed(), hoist.ready(), gripper.ready(), trolley.arrived(), truck.arrived():
      illegal;
    }
    [s.Calibrating]
    {
      on ctrl.stop():
      {
        hoist.stop();
        gripper.stop();
        trolley.stop();
        truck.stop();
        s = State.Idle;
        isCalibrated = false;
        isRetaining = true;
        isXYMoveAllowed = false;
      }
      on ctrl.calibrate(), ctrl.move(), ctrl.transfer(), hoist.ready(), trolley.arrived(), truck.arrived():
      illegal;
      on hoist.calibrated(), gripper.calibrated(), trolley.homed(), truck.homed(), gripper.ready():
      tryCalibrated();
    }
    [s.Moving]
    {
      on ctrl.stop():
      {
        hoist.stop();
        gripper.stop();
        trolley.stop();
        truck.stop();
        s = State.Idle;
        isCalibrated = false;
        isRetaining = true;
        isXYMoveAllowed = false;
      }
      on ctrl.calibrate(), ctrl.move(), ctrl.transfer(), hoist.calibrated(), gripper.calibrated(), trolley.homed(), truck.homed(), hoist.ready(), gripper.ready():
      illegal;
      on trolley.arrived(), truck.arrived():
      {
        nMoving = nMoving - 1;
        if (nMoving == 0) {
          s = State.Idle;
          ctrl.arrived();
        }
      }
    }
    [s.Transferring]
    {
      on ctrl.stop():
      {
        hoist.stop();
        gripper.stop();
        trolley.stop();
        truck.stop();
        s = State.Idle;
        isCalibrated = false;
        isRetaining = true;
        isXYMoveAllowed = false;
      }
      on ctrl.calibrate(), ctrl.move(), ctrl.transfer(), hoist.calibrated(), gripper.calibrated(), trolley.homed(), truck.homed():
      illegal;
      on hoist.ready():
      {
        [ts.Picking]
        gripper.retain();
        [ts.Raising && isRetaining]
        {
          isXYMoveAllowed = true;
          ctrl.picked();
          truck.move(placeX);
          trolley.move(placeY);
          nMoving = 2;
          ts = TransferState.Moving;
        }
        [ts.Moving]
        illegal;
        [ts.Placing]
        gripper.release();
        [ts.Raising && !isRetaining && !isRetaining]
        {
          isXYMoveAllowed = true;
          s = State.Idle;
          ts = TransferState.Idle;
          ctrl.placed();
        }
      }
      on gripper.ready():
      {
        [ts.Picking]
        {
          hoist.retain();
          isRetaining = true;
          ts = TransferState.Raising;
        }
        [ts.Raising && isRetaining]
        illegal;
        [ts.Moving]
        illegal;
        [ts.Placing]
        {
          isRetaining = false;
          hoist.retain();
          ts = TransferState.Raising;
        }
        [ts.Raising && !isRetaining]
        illegal;
      }
      on trolley.arrived(), truck.arrived():
      {
        [ts.Picking]
        illegal;
        [ts.Raising && isRetaining]
        illegal;
        [ts.Moving]
        {
          nMoving = nMoving - 1;
          if (nMoving == 0) {
            isXYMoveAllowed = false;
            hoist.release();
            ts = TransferState.Placing;
          }
        }
        [ts.Placing]
        illegal;
        [ts.Raising && !isRetaining]
        illegal;
      }
    }
  }
}

component Lift {
  provides IRetain ctrl;
  requires IConstrainedMove winch;

  behaviour {
    enum State {Lost, Calibrating, Ready, Moving};
    State s = State.Lost;
    bool isHolding = false;

    [s.Lost]
    {
      on ctrl.stop():
      {
        winch.stop();
        s = State.Lost;
        isHolding = false;
      }
      on ctrl.calibrate():
      {
        winch.calibrate();
        s = State.Calibrating;
      }
      on ctrl.retain(), ctrl.release(), winch.arrived(), winch.homed():
      illegal;
    }
    [s.Calibrating]
    {
      on ctrl.stop():
      {
        winch.stop();
        s = State.Lost;
        isHolding = false;
      }
      on ctrl.calibrate(), ctrl.retain(), ctrl.release():
      illegal;
      on winch.arrived():
      {
        ctrl.calibrated();
        s = State.Ready;
        isHolding = true;
      }
      on winch.homed():
      winch.move($(config.get("Position::Robot::Z::Up"))$);
    }
    [s.Ready]
    {
      on ctrl.stop():
      {
        winch.stop();
        s = State.Lost;
        isHolding = false;
      }
      on ctrl.calibrate(), winch.arrived():
      {
        [!isHolding]
        illegal;
        [isHolding]
        illegal;
      }
      on ctrl.retain():
      {
        [!isHolding]
        {
          winch.move($(config.get("Position::Robot::Z::Up"))$);
          s = State.Moving;
        }
        [isHolding]
        illegal;
      }
      on ctrl.release():
      {
        [!isHolding]
        illegal;
        [isHolding]
        {
          winch.move($(config.get("Position::Robot::Z::Down"))$);
          s = State.Moving;
        }
      }
      on winch.homed():
      illegal;
    }
    [s.Moving]
    {
      on ctrl.stop():
      {
        winch.stop();
        s = State.Lost;
        isHolding = false;
      }
      on ctrl.calibrate(), ctrl.retain(), ctrl.release(), winch.homed():
      illegal;
      on winch.arrived():
      {
        ctrl.ready();
        s = State.Ready;
        isHolding = !isHolding;
      }
    }
  }
}

component Grip {
  provides IRetain ctrl;
  requires IConstrainedMove gripper;

  behaviour {
    enum State {Lost, Calibrating, Ready, Moving};
    State s = State.Lost;
    bool isHolding = false;

    [s.Lost]
    {
      on ctrl.stop():
      {
        gripper.stop();
        s = State.Lost;
        isHolding = false;
      }
      on ctrl.calibrate():
      {
        gripper.calibrate();
        s = State.Calibrating;
      }
      on ctrl.retain(), ctrl.release(), gripper.homed(), gripper.arrived():
      illegal;
    }
    [s.Calibrating]
    {
      on ctrl.stop():
      {
        gripper.stop();
        s = State.Lost;
        isHolding = false;
      }
      on ctrl.calibrate(), ctrl.retain(), ctrl.release():
      illegal;
      on gripper.homed():
      gripper.move($(config.get("Position::Robot::Gripper::Closed"))$);
      on gripper.arrived():
      {
        ctrl.calibrated();
        s = State.Ready;
        isHolding = true;
      }
    }
    [s.Ready]
    {
      on ctrl.stop():
      {
        gripper.stop();
        s = State.Lost;
        isHolding = false;
      }
      on ctrl.calibrate(), gripper.homed(), gripper.arrived():
      illegal;
      on ctrl.retain():
      {
        [!isHolding]
        {
          s = State.Moving;
          gripper.move($(config.get("Position::Robot::Gripper::Closed"))$);
        }
        [isHolding]
        illegal;
      }
      on ctrl.release():
      {
        [!isHolding]
        illegal;
        [isHolding]
        {
          s = State.Moving;
          gripper.move($(config.get("Position::Robot::Gripper::Open"))$);
        }
      }
    }
    [s.Moving]
    {
      on ctrl.stop():
      {
        gripper.stop();
        s = State.Lost;
        isHolding = false;
      }
      on ctrl.calibrate(), ctrl.retain(), ctrl.release(), gripper.homed():
      illegal;
      on gripper.arrived():
      {
        ctrl.ready();
        s = State.Ready;
        isHolding = !isHolding;
      }
    }
  }
}

component MaterialHandler {
  provides IHandle ctrl;
  requires IInspect inspector;
  requires IFeed feedPort;
  requires IConvey acceptPort;
  requires IConvey rejectPort;
  requires imotor hoistMotorHw;
  requires itouch hoistEndSensorHw;
  requires imotor gripperMotorhw;
  requires itouch gripperEndSensorHw;
  requires imotor trolleyMotorHw;
  requires itouch trolleyEndSensorHw;
  requires imotor truckMotorHw;
  requires itouch truckHomeSensorHw;

  system {
    Handle bhv;
    Robot robot;

    ctrl <=> bhv.ctrl;
    bhv.robot <=> robot.ctrl;
    bhv.inspector <=> inspector;
    bhv.feedPort <=> feedPort;
    bhv.acceptPort <=> acceptPort;
    bhv.rejectPort <=> rejectPort;
    robot.gripperMotorhw <=> gripperMotorhw;
    robot.gripperEndSensorHw <=> gripperEndSensorHw;
    robot.hoistEndSensorHw <=> hoistEndSensorHw;
    robot.hoistMotorHw <=> hoistMotorHw;
    robot.trolleyEndSensorHw <=> trolleyEndSensorHw;
    robot.trolleyMotorHw <=> trolleyMotorHw;
    robot.truckHomeSensorHw <=> truckHomeSensorHw;
    robot.truckMotorHw <=> truckMotorHw;
  }
}

component Robot {
  provides ITransfer ctrl;
  requires imotor hoistMotorHw;
  requires itouch hoistEndSensorHw;
  requires imotor gripperMotorhw;
  requires itouch gripperEndSensorHw;
  requires imotor trolleyMotorHw;
  requires itouch trolleyEndSensorHw;
  requires imotor truckMotorHw;
  requires itouch truckHomeSensorHw;

  system {
    Transfer bhv;
    Hoist hoist;
    Gripper gripper;
    EndConstrainedAxis trolley;
    HomeConstrainedAxis truck;

    ctrl <=> bhv.ctrl;
    bhv.hoist <=> hoist.ctrl;
    bhv.gripper <=> gripper.ctrl;
    bhv.trolley <=> trolley.ctrl;
    bhv.truck <=> truck.ctrl;
    hoist.motorHw <=> hoistMotorHw;
    hoist.endSensorHw <=> hoistEndSensorHw;
    gripper.motorHw <=> gripperMotorhw;
    gripper.endSensorHw <=> gripperEndSensorHw;
    trolley.motorHw <=> trolleyMotorHw;
    trolley.endSensorHw <=> trolleyEndSensorHw;
    truck.motorHw <=> truckMotorHw;
    truck.homeSensorHw <=> truckHomeSensorHw;
  }
}

component Hoist {
  provides IRetain ctrl;
  requires imotor motorHw;
  requires itouch endSensorHw;

  system {
    Lift bhv;
    EndConstrainedAxis winch;

    ctrl <=> bhv.ctrl;
    bhv.winch <=> winch.ctrl;
    winch.motorHw <=> motorHw;
    winch.endSensorHw <=> endSensorHw;
  }
}

component Gripper {
  provides IRetain ctrl;
  requires imotor motorHw;
  requires itouch endSensorHw;

  system {
    Grip bhv;
    EndConstrainedAxis gripper;

    ctrl <=> bhv.ctrl;
    bhv.gripper <=> gripper.ctrl;
    gripper.motorHw <=> motorHw;
    gripper.endSensorHw <=> endSensorHw;
  }
}

