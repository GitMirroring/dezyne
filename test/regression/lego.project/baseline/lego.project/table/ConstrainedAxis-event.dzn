component ConstrainedMove {
  provides IConstrainedMove ctrl;
  requires IMove motor;
  requires ITouchSense homeSensor;
  requires ITouchSense endSensor;

  behaviour {
    enum State {lost, idle, moving, calibratingHome, calibratingLength};
    State s = State.lost;

    void slowForward() {
      motor.run($(config.get("Power::CalibrationSpeed"))$, $false$);
      return;
    }

    void slowBackward() {
      motor.run($(config.get("Power::CalibrationSpeed"))$, $true$);
      return;
    }

    void recordHome() {
      homeSensor.disable();
      motor.stop();
      motor.zero();
      return;
    }

    void recordLength() {
      endSensor.disable();
      motor.stop();
      return;
    }

    void startAbsoluteMove(IConstrainedMove.position_t target) {
      ITouchSense.TouchState ignore = ITouchSense.TouchState.Released;
      ignore = homeSensor.enable();
      ignore = endSensor.enable();
      motor.move($(config.get("Power::OperationalSpeed"))$, target);
      s = State.moving;
      return;
    }

    void notifyArrived() {
      motor.stop();
      homeSensor.disable();
      endSensor.disable();
      s = State.idle;
      ctrl.arrived();
      return;
    }

    on ctrl.stop():
    {
      [s.calibratingLength || s.calibratingHome || s.moving || s.idle || s.lost]
      {
        motor.stop();
        homeSensor.disable();
        endSensor.disable();
        s = State.lost;
      }
    }
    on ctrl.calibrate():
    {
      [s.lost]
      {
        ITouchSense.TouchState hss = homeSensor.enable();
        if (hss == ITouchSense.TouchState.Pressed) {
          recordHome();
          ITouchSense.TouchState ess = endSensor.enable();
          if (ess == ITouchSense.TouchState.Pressed) {
            recordLength();
            s = State.idle;
            ctrl.homed();
          }
          else {
            slowForward();
            s = State.calibratingLength;
          }
        }
        else {
          slowBackward();
          s = State.calibratingHome;
        }
      }
      [s.calibratingLength || s.calibratingHome || s.moving || s.idle]
      illegal;
    }
    on ctrl.move():
    {
      [s.calibratingLength || s.calibratingHome || s.moving || s.lost]
      illegal;
    }
    on homeSensor.pressed():
    {
      [s.calibratingLength || s.idle || s.lost]
      illegal;
      [s.moving]
      {
        motor.stop();
        notifyArrived();
      }
      [s.calibratingHome]
      {
        recordHome();
        ITouchSense.TouchState ess = endSensor.enable();
        if (ess == ITouchSense.TouchState.Pressed) {
          recordLength();
          s = State.idle;
          ctrl.homed();
        }
        else {
          slowForward();
          s = State.calibratingLength;
        }
      }
    }
    on homeSensor.released():
    {
      [s.calibratingLength || s.calibratingHome || s.idle || s.lost]
      illegal;
      [s.moving]
      {}
    }
    on endSensor.pressed():
    {
      [s.calibratingHome || s.idle || s.lost]
      illegal;
      [s.moving]
      {
        motor.stop();
        notifyArrived();
      }
      [s.calibratingLength]
      {
        recordLength();
        ctrl.homed();
        s = State.idle;
      }
    }
    on endSensor.released():
    {
      [s.calibratingLength || s.calibratingHome || s.idle || s.lost]
      illegal;
      [s.moving]
      {}
    }
    on motor.arrived():
    {
      [s.calibratingLength || s.calibratingHome || s.idle || s.lost]
      illegal;
      [s.moving]
      notifyArrived();
    }
    on ctrl.move(target):
    [s.idle]
    {
      ITouchSense.TouchState ignore = ITouchSense.TouchState.Released;
      ignore = homeSensor.enable();
      ignore = endSensor.enable();
      motor.move($(config.get("Power::OperationalSpeed"))$, target);
      s = State.moving;
    }
  }
}

component ConstrainedAxis {
  provides IConstrainedMove ctrl;
  requires imotor motorHw;
  requires itouch homeSensorHw;
  requires itouch endSensorHw;

  system {
    ConstrainedMove bhv;
    Motor motor;
    TouchSensor homeSensor;
    TouchSensor endSensor;

    ctrl <=> bhv.ctrl;
    bhv.motor <=> motor.ctrl;
    bhv.homeSensor <=> homeSensor.ctrl;
    bhv.endSensor <=> endSensor.ctrl;
    motor.hw <=> motorHw;
    homeSensor.hw <=> homeSensorHw;
    endSensor.hw <=> endSensorHw;
  }
}

