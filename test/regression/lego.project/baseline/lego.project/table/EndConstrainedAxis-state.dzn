component EndConstrainedMove
{
  provides IConstrainedMove ctrl;
  requires IMove motor;
  requires ITouchSense endSensor;

  behaviour 
  {
    enum State { lost, idle, moving, calibratingEnd };
    State s = State.lost;
    void slowForward()
    {
      motor.run($config("Power::CalibrationSpeed")$,$false$);
      return;
    }

    void recordHome()
    {
      endSensor.disable();
      motor.stop();
      motor.zero();
      return;
    }

    void startAbsoluteMove(IConstrainedMove.position_t target)
    {
      ITouchSense.TouchState ignore = endSensor.enable();
      motor.move($config("Power::OperationalSpeed")$,target);
      s = State.moving;
      return;
    }

    void notifyArrived()
    {
      motor.stop();
      endSensor.disable();
      s = State.idle;
      ctrl.arrived();
      return;
    }

    [s.lost]
    {
      on ctrl.stop():
      {
        motor.stop();
        endSensor.disable();
        s = State.lost;
      }
      on ctrl.calibrate():
      {
        ITouchSense.TouchState ess = endSensor.enable();
        if (ess == ITouchSense.TouchState.Pressed)
        {
          recordHome();
          s = State.idle;
          ctrl.homed();
        }
        else
        {
          slowForward();
          s = State.calibratingEnd;
        }
      }
      on ctrl.move(), endSensor.pressed(), endSensor.released(), motor.arrived():
      illegal;
    }
    [s.idle]
    {
      on ctrl.stop():
      {
        motor.stop();
        endSensor.disable();
        s = State.lost;
      }
      on ctrl.calibrate(), endSensor.pressed(), endSensor.released(), motor.arrived():
      illegal;
      on ctrl.move(target):
      {
        ITouchSense.TouchState ignore = ITouchSense.TouchState.Released;
        ignore = endSensor.enable();
        motor.move($config("Power::OperationalSpeed")$,target);
        s = State.moving;
      }
    }
    [s.moving]
    {
      on ctrl.stop():
      {
        motor.stop();
        endSensor.disable();
        s = State.lost;
      }
      on ctrl.calibrate(), ctrl.move():
      illegal;
      on endSensor.pressed():
      {
        motor.stop();
        notifyArrived();
      }
      on endSensor.released():
      {
      }
      on motor.arrived():
      notifyArrived();
    }
    [s.calibratingEnd]
    {
      on ctrl.stop():
      {
        motor.stop();
        endSensor.disable();
        s = State.lost;
      }
      on ctrl.calibrate(), ctrl.move(), endSensor.released(), motor.arrived():
      illegal;
      on endSensor.pressed():
      {
        recordHome();
        s = State.idle;
        ctrl.homed();
      }
    }
  }
}
component EndConstrainedAxis
{
  provides IConstrainedMove ctrl;
  requires imotor motorHw;
  requires itouch endSensorHw;

  system
  {
    EndConstrainedMove bhv;
    Motor motor;
    TouchSensor endSensor;

    ctrl <=> bhv.ctrl;
    bhv.motor <=> motor.ctrl;
    bhv.endSensor <=> endSensor.ctrl;
    motor.hw <=> motorHw;
    endSensor.hw <=> endSensorHw;
  }
}

