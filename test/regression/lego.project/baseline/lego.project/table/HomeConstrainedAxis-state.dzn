component HomeConstrainedMove {
  provides IConstrainedMove ctrl;
  requires IMove motor;
  requires ITouchSense homeSensor;

  behaviour {
    enum State {lost, idle, moving, calibratingHome};
    State s = State.lost;

    void slowBackward() {
      motor.run($(config.get("Power::CalibrationSpeed"))$, $true$);
      return false;
    }

    void recordHome() {
      homeSensor.disable();
      motor.stop();
      motor.zero();
      return false;
    }

    void startAbsoluteMove(IConstrainedMove.position_t target) {
      ITouchSense.TouchState ignore = ITouchSense.TouchState.Released;
      ignore = homeSensor.enable();
      motor.move($(config.get("Power::OperationalSpeed"))$, target);
      s = State.moving;
      return false;
    }

    void notifyArrived() {
      motor.stop();
      homeSensor.disable();
      s = State.idle;
      ctrl.arrived();
      return false;
    }

    [s.lost]
    {
      on ctrl.stop():
      {
        motor.stop();
        homeSensor.disable();
        s = State.lost;
      }
      on ctrl.calibrate():
      {
        ITouchSense.TouchState hss = homeSensor.enable();
        if (hss == ITouchSense.TouchState.Pressed) {
          recordHome();
          s = State.idle;
          ctrl.homed();
        }
        else {
          slowBackward();
          s = State.calibratingHome;
        }
      }
      on ctrl.move(), homeSensor.pressed(), homeSensor.released(), motor.arrived():
      illegal;
    }
    [s.idle]
    {
      on ctrl.stop():
      {
        motor.stop();
        homeSensor.disable();
        s = State.lost;
      }
      on ctrl.calibrate(), homeSensor.pressed(), homeSensor.released(), motor.arrived():
      illegal;
      on ctrl.move(target):
      {
        ITouchSense.TouchState ignore = ITouchSense.TouchState.Released;
        ignore = homeSensor.enable();
        motor.move($(config.get("Power::OperationalSpeed"))$, target);
        s = State.moving;
      }
    }
    [s.moving]
    {
      on ctrl.stop():
      {
        motor.stop();
        homeSensor.disable();
        s = State.lost;
      }
      on ctrl.calibrate(), ctrl.move():
      illegal;
      on homeSensor.pressed():
      {
        motor.stop();
        recordHome();
        notifyArrived();
      }
      on homeSensor.released():
      {}
      on motor.arrived():
      notifyArrived();
    }
    [s.calibratingHome]
    {
      on ctrl.stop():
      {
        motor.stop();
        homeSensor.disable();
        s = State.lost;
      }
      on ctrl.calibrate(), ctrl.move(), homeSensor.released(), motor.arrived():
      illegal;
      on homeSensor.pressed():
      {
        recordHome();
        s = State.idle;
        ctrl.homed();
      }
    }
  }
}

component HomeConstrainedAxis {
  provides IConstrainedMove ctrl;
  requires imotor motorHw;
  requires itouch homeSensorHw;

  system {
    HomeConstrainedMove bhv;
    Motor motor;
    TouchSensor homeSensor;

    ctrl <=> bhv.ctrl;
    bhv.motor <=> motor.ctrl;
    bhv.homeSensor <=> homeSensor.ctrl;
    motor.hw <=> motorHw;
    homeSensor.hw <=> homeSensorHw;
  }
}

