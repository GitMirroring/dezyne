interface IHandle {
  in void calibrate();
  out void calibrated();
  in void stop();
  in void operate();
  out void finished();

  behaviour {
    enum State {Lost, Calibrating, Idle, Operating};
    State s = State.Lost;

    on stop:
    {
      [s.Operating || s.Idle || s.Calibrating || s.Lost]
      s = State.Lost;
    }
    on calibrate:
    {
      [s.Lost]
      s = State.Calibrating;
      [s.Lost]
      {
        calibrated;
        s = State.Idle;
      }
      [s.Operating || s.Idle || s.Calibrating]
      illegal;
      [s.Operating || s.Idle || s.Calibrating]
      {}
    }
    on operate:
    {
      [s.Operating || s.Calibrating || s.Lost]
      illegal;
      [s.Operating || s.Calibrating || s.Lost]
      {}
      [s.Idle]
      s = State.Operating;
      [s.Idle]
      finished;
    }
    on inevitable:
    {
      [s.Calibrating]
      {
        calibrated;
        s = State.Idle;
      }
      [s.Operating]
      {
        s = State.Idle;
        finished;
      }
    }
  }
}

interface ITransfer {
  extern TrPosition $Integer$;
  in void calibrate();
  out void calibrated();
  in void stop();
  in void move(TrPosition x, TrPosition y);
  out void arrived();
  in void transfer(TrPosition x, TrPosition y);
  out void picked();
  out void placed();

  behaviour {
    enum State {Lost, Calibrating, Ready, Moving, Transferring};
    State s = State.Lost;
    bool isPicked = false;

    on stop:
    {
      [s.Transferring || s.Moving || s.Ready || s.Calibrating || s.Lost]
      s = State.Lost;
    }
    on calibrate:
    {
      [s.Lost]
      s = State.Calibrating;
      [s.Lost]
      {
        calibrated;
        s = State.Ready;
      }
      [s.Transferring || s.Moving || s.Ready || s.Calibrating]
      illegal;
    }
    on move:
    {
      [s.Transferring || s.Moving || s.Calibrating || s.Lost]
      illegal;
      [s.Ready]
      s = State.Moving;
      [s.Ready]
      arrived;
    }
    on transfer:
    {
      [s.Transferring || s.Moving || s.Calibrating || s.Lost]
      illegal;
      [s.Ready]
      {
        s = State.Transferring;
        isPicked = false;
      }
      [s.Ready]
      {
        s = State.Transferring;
        picked;
        isPicked = true;
      }
      [s.Ready]
      {
        s = State.Ready;
        picked;
        placed;
      }
    }
    on inevitable:
    {
      [s.Calibrating]
      {
        calibrated;
        s = State.Ready;
      }
      [s.Moving]
      {
        arrived;
        s = State.Ready;
      }
      [s.Transferring]
      [!isPicked]
      {
        picked;
        isPicked = true;
      }
      [s.Transferring]
      [isPicked]
      {
        placed;
        s = State.Ready;
      }
    }
  }
}

interface IRetain {
  in void stop();
  in void calibrate();
  out void calibrated();
  in void retain();
  in void release();
  out void ready();

  behaviour {
    enum State {Lost, Calibrating, Ready, Moving};
    State s = State.Lost;
    bool isHolding = false;

    on stop:
    {
      [s.Moving || s.Ready || s.Calibrating || s.Lost]
      {
        s = State.Lost;
        isHolding = false;
      }
    }
    on calibrate:
    {
      [s.Lost]
      s = State.Calibrating;
      [s.Lost]
      {
        calibrated;
        s = State.Ready;
        isHolding = true;
      }
      [s.Moving || s.Calibrating]
      illegal;
      [s.Ready]
      [!isHolding]
      illegal;
      [s.Ready]
      [isHolding]
      illegal;
    }
    on retain:
    {
      [s.Moving || s.Calibrating || s.Lost]
      illegal;
      [s.Ready]
      [!isHolding]
      s = State.Moving;
      [s.Ready]
      [!isHolding]
      {
        ready;
        isHolding = true;
      }
      [s.Ready]
      [isHolding]
      illegal;
    }
    on release:
    {
      [s.Moving || s.Calibrating || s.Lost]
      illegal;
      [s.Ready]
      [!isHolding]
      illegal;
      [s.Ready]
      [isHolding]
      s = State.Moving;
      [s.Ready]
      [isHolding]
      {
        ready;
        isHolding = false;
      }
    }
    on inevitable:
    {
      [s.Calibrating]
      {
        calibrated;
        s = State.Ready;
        isHolding = true;
      }
      [s.Moving]
      {
        ready;
        s = State.Ready;
        isHolding = !isHolding;
      }
    }
  }
}

component Handle {
  provides IHandle ctrl;
  requires ITransfer robot;
  requires IInspect inspector;
  requires IFeed feedPort;
  requires IConvey acceptPort;
  requires IConvey rejectPort;

  behaviour {
    enum State {Lost, Calibrating, Idle, Operating};
    subint usedCount {0..4};
    enum Operation {PreparingInput, TransferringInput, PreparingOutput, TransferringOutput, Finalizing};
    State s = State.Lost;
    usedCount calibrated = 0;
    usedCount requiredCalibrations = 3;
    Operation o = Operation.PreparingInput;
    bool isLastBall = false;
    bool isBallAtInput = false;
    bool isRobotAtInput = false;
    bool isRobotAtOutput = false;
    bool isInspectorAtInput = false;
    bool isInspectorAtOutput = false;
    bool isBallAccepted = false;
    bool isAcceptEmpty = true;
    bool isRejectEmpty = true;

    void tryCalibrated() {
      calibrated = calibrated + 1;
      if (calibrated == requiredCalibrations) {
        s = State.Idle;
        isInspectorAtInput = true;
        isInspectorAtOutput = false;
        ctrl.calibrated();
      }
      return;
    }

    void ignoreIllegal() {
      return;
    }

    void startBatch() {
      s = State.Operating;
      isLastBall = false;
      prepareInputTransfer();
      return;
    }

    void finalizeBatch() {
      s = State.Idle;
      ctrl.finished();
      return;
    }

    void prepareInputTransfer() {
      o = Operation.PreparingInput;
      if (!isBallAtInput) {
        feedPort.produceBall();
        isBallAtInput = false;
      }
      if (!isInspectorAtInput) {
        inspector.prepare();
        isInspectorAtInput = false;
      }
      if (!isRobotAtInput) {
        sendRobotToInputPick();
        isRobotAtInput = false;
      }
      tryInputTransfer();
      return;
    }

    void sendRobotToInputPick() {
      robot.move($(config.get("Position::Robot::X::InputPick"))$, $(config.get("Position::Robot::Y::InputPick"))$);
      isRobotAtOutput = false;
      isRobotAtInput = false;
      return;
    }

    void tryInputTransfer() {
      if (isBallAtInput && isRobotAtInput && isInspectorAtInput) {
        robot.transfer($(config.get("Position::Robot::X::InputDrop"))$, $(config.get("Position::Robot::Y::InputDrop"))$);
        o = Operation.TransferringInput;
      }
      return;
    }

    void tryOutputTransfer() {
      if (isRobotAtOutput && isInspectorAtOutput) {
        if (isAcceptEmpty && isBallAccepted) {
          robot.transfer($(config.get("Position::Robot::X::OutputDrop"))$, $(config.get("Position::Robot::Y::AcceptDrop"))$);
          o = Operation.TransferringOutput;
        }
        if (isRejectEmpty && !isBallAccepted) {
          robot.transfer($(config.get("Position::Robot::X::OutputDrop"))$, $(config.get("Position::Robot::Y::RejectDrop"))$);
          o = Operation.TransferringOutput;
        }
      }
      return;
    }

    void tryFinished() {
      if (isLastBall && !isBallAtInput && isAcceptEmpty && isRejectEmpty && isRobotAtInput && isInspectorAtInput) {
        s = State.Idle;
        ctrl.finished();
      }
      return;
    }

    void manuallyRemoveStrayMaterial() {
      isBallAtInput = false;
      isAcceptEmpty = true;
      isRejectEmpty = true;
      return;
    }

    on ctrl.stop():
    {
      [s.Operating || s.Idle || s.Calibrating || s.Lost]
      {
        robot.stop();
        inspector.stop();
        feedPort.stop();
        acceptPort.stop();
        rejectPort.stop();
        s = State.Lost;
        manuallyRemoveStrayMaterial();
      }
    }
    on ctrl.calibrate():
    {
      [s.Lost]
      {
        robot.calibrate();
        inspector.calibrate();
        feedPort.calibrate();
        calibrated = 0;
        s = State.Calibrating;
      }
      [s.Operating || s.Idle || s.Calibrating]
      ignoreIllegal();
    }
    on ctrl.operate():
    {
      [s.Operating || s.Calibrating || s.Lost]
      ignoreIllegal();
      [s.Idle]
      startBatch();
    }
    on robot.arrived():
    {
      [s.Idle || s.Calibrating || s.Lost]
      illegal;
      [s.Operating]
      [o.PreparingInput]
      {
        isRobotAtInput = true;
        tryInputTransfer();
      }
      [s.Operating]
      [o.TransferringInput]
      illegal;
      [s.Operating]
      [o.PreparingOutput]
      {
        isRobotAtOutput = true;
        tryOutputTransfer();
      }
      [s.Operating]
      [o.TransferringOutput]
      illegal;
      [s.Operating]
      [o.Finalizing]
      {
        isRobotAtInput = true;
        tryFinished();
      }
    }
    on robot.picked():
    {
      [s.Idle || s.Calibrating || s.Lost]
      illegal;
      [s.Operating]
      [o.PreparingInput]
      illegal;
      [s.Operating]
      [o.TransferringInput]
      [!isLastBall]
      {
        feedPort.produceBall();
        isBallAtInput = false;
      }
      [s.Operating]
      [o.TransferringInput]
      [isLastBall]
      isBallAtInput = false;
      [s.Operating]
      [o.PreparingOutput]
      illegal;
      [s.Operating]
      [o.TransferringOutput]
      {
        isInspectorAtOutput = false;
        inspector.prepare();
      }
      [s.Operating]
      [o.Finalizing]
      illegal;
    }
    on robot.placed():
    {
      [s.Idle || s.Calibrating || s.Lost]
      illegal;
      [s.Operating]
      [o.PreparingInput]
      illegal;
      [s.Operating]
      [o.TransferringInput]
      {
        isInspectorAtInput = false;
        inspector.inspect();
        isRobotAtInput = false;
        robot.move($(config.get("Position::Robot::X::OutputPick"))$, $(config.get("Position::Robot::Y::OutputPick"))$);
        o = Operation.PreparingOutput;
      }
      [s.Operating]
      [o.PreparingOutput]
      illegal;
      [s.Operating]
      [o.TransferringOutput]
      [isBallAccepted]
      {
        isAcceptEmpty = false;
        acceptPort.convey();
        sendRobotToInputPick();
        if (isLastBall && !isBallAtInput) o = Operation.Finalizing;
        else o = Operation.PreparingInput;
      }
      [s.Operating]
      [o.TransferringOutput]
      [!isBallAccepted]
      {
        isRejectEmpty = false;
        rejectPort.convey();
        sendRobotToInputPick();
        if (isLastBall && !isBallAtInput) o = Operation.Finalizing;
        else o = Operation.PreparingInput;
      }
      [s.Operating]
      [o.Finalizing]
      illegal;
    }
    on inspector.prepared():
    {
      [s.Idle || s.Calibrating || s.Lost]
      illegal;
      [s.Operating]
      [o.PreparingInput]
      {
        isInspectorAtInput = true;
        tryInputTransfer();
      }
      [s.Operating]
      [o.TransferringInput]
      illegal;
      [s.Operating]
      [o.PreparingOutput]
      illegal;
      [s.Operating]
      [o.TransferringOutput]
      isInspectorAtInput = true;
      [s.Operating]
      [o.Finalizing]
      {
        isInspectorAtInput = true;
        tryFinished();
      }
    }
    on inspector.accepted():
    {
      [s.Idle || s.Calibrating || s.Lost]
      illegal;
      [s.Operating]
      [o.PreparingInput]
      illegal;
      [s.Operating]
      [o.TransferringInput]
      illegal;
      [s.Operating]
      [o.PreparingOutput]
      {
        isBallAccepted = true;
        isInspectorAtOutput = true;
        tryOutputTransfer();
      }
      [s.Operating]
      [o.TransferringOutput]
      illegal;
      [s.Operating]
      [o.Finalizing]
      illegal;
    }
    on inspector.rejected():
    {
      [s.Idle || s.Calibrating || s.Lost]
      illegal;
      [s.Operating]
      [o.PreparingInput]
      illegal;
      [s.Operating]
      [o.TransferringInput]
      illegal;
      [s.Operating]
      [o.PreparingOutput]
      {
        isBallAccepted = false;
        isInspectorAtOutput = true;
        tryOutputTransfer();
      }
      [s.Operating]
      [o.TransferringOutput]
      illegal;
      [s.Operating]
      [o.Finalizing]
      illegal;
    }
    on feedPort.consumeNextBall():
    {
      [s.Idle || s.Calibrating || s.Lost]
      illegal;
      [s.Operating]
      [o.PreparingInput]
      {
        isLastBall = false;
        isBallAtInput = true;
        tryInputTransfer();
      }
      [s.Operating]
      [o.TransferringInput]
      {
        isLastBall = false;
        isBallAtInput = true;
      }
      [s.Operating]
      [o.PreparingOutput]
      {
        isLastBall = false;
        isBallAtInput = true;
      }
      [s.Operating]
      [o.TransferringOutput]
      {
        isLastBall = false;
        isBallAtInput = true;
      }
      [s.Operating]
      [o.Finalizing]
      illegal;
    }
    on feedPort.consumeLastBall():
    {
      [s.Idle || s.Calibrating || s.Lost]
      illegal;
      [s.Operating]
      [o.PreparingInput]
      {
        isLastBall = true;
        isBallAtInput = true;
        tryInputTransfer();
      }
      [s.Operating]
      [o.TransferringInput]
      {
        isLastBall = true;
        isBallAtInput = true;
      }
      [s.Operating]
      [o.PreparingOutput]
      {
        isLastBall = true;
        isBallAtInput = true;
      }
      [s.Operating]
      [o.TransferringOutput]
      {
        isLastBall = true;
        isBallAtInput = true;
      }
      [s.Operating]
      [o.Finalizing]
      illegal;
    }
    on acceptPort.conveyed():
    {
      [s.Idle || s.Calibrating || s.Lost]
      illegal;
      [s.Operating]
      [o.PreparingInput]
      isAcceptEmpty = true;
      [s.Operating]
      [o.TransferringInput]
      isAcceptEmpty = true;
      [s.Operating]
      [o.PreparingOutput]
      {
        isAcceptEmpty = true;
        tryOutputTransfer();
      }
      [s.Operating]
      [o.TransferringOutput]
      isAcceptEmpty = true;
      [s.Operating]
      [o.Finalizing]
      {
        isAcceptEmpty = true;
        tryFinished();
      }
    }
    on rejectPort.conveyed():
    {
      [s.Idle || s.Calibrating || s.Lost]
      illegal;
      [s.Operating]
      [o.PreparingInput]
      isRejectEmpty = true;
      [s.Operating]
      [o.TransferringInput]
      isRejectEmpty = true;
      [s.Operating]
      [o.PreparingOutput]
      {
        isRejectEmpty = true;
        tryOutputTransfer();
      }
      [s.Operating]
      [o.TransferringOutput]
      isRejectEmpty = true;
      [s.Operating]
      [o.Finalizing]
      {
        isRejectEmpty = true;
        tryFinished();
      }
    }
    on inspector.calibrated():
    {
      [s.Operating || s.Idle || s.Lost]
      illegal;
      [s.Calibrating]
      tryCalibrated();
    }
    on feedPort.calibrated():
    {
      [s.Operating || s.Idle || s.Lost]
      illegal;
      [s.Calibrating]
      tryCalibrated();
    }
    on robot.calibrated():
    {
      [s.Operating || s.Idle || s.Lost]
      illegal;
      [s.Calibrating]
      tryCalibrated();
    }
  }
}

component Transfer {
  provides ITransfer ctrl;
  requires IRetain hoist;
  requires IRetain gripper;
  requires IConstrainedMove trolley;
  requires IConstrainedMove truck;

  behaviour {
    enum State {Idle, Calibrating, Moving, Transferring};
    subint Count {0..5};
    enum TransferState {Picking, Raising, Moving, Placing, Idle};
    State s = State.Idle;
    TransferState ts = TransferState.Idle;
    Count nCalibrated = 0;
    Count nMoving = 0;
    bool isCalibrated = false;
    bool isXYMoveAllowed = false;
    bool isRetaining = true;
    ITransfer.TrPosition placeX = $0$;
    ITransfer.TrPosition placeY = $0$;

    void tryCalibrated() {
      nCalibrated = nCalibrated + 1;
      if (nCalibrated == 2) {
        isXYMoveAllowed = true;
        calibrateXY();
      }
      if (nCalibrated == 5) {
        isCalibrated = true;
        s = State.Idle;
        isRetaining = false;
        ctrl.calibrated();
      }
      return;
    }

    void calibrateZ() {
      s = State.Calibrating;
      isXYMoveAllowed = false;
      nCalibrated = 0;
      hoist.calibrate();
      gripper.calibrate();
      return;
    }

    void calibrateXY() {
      if (isXYMoveAllowed) {
        s = State.Calibrating;
        gripper.release();
        trolley.calibrate();
        truck.calibrate();
      }
      return;
    }

    void startPick(ITransfer.TrPosition tgtX, ITransfer.TrPosition tgtY) {
      placeX = tgtX;
      placeY = tgtY;
      isXYMoveAllowed = false;
      s = State.Transferring;
      ts = TransferState.Picking;
      hoist.release();
      return;
    }

    on ctrl.stop():
    {
      [s.Transferring || s.Moving || s.Calibrating || s.Idle]
      {
        hoist.stop();
        gripper.stop();
        trolley.stop();
        truck.stop();
        s = State.Idle;
        isCalibrated = false;
        isRetaining = true;
        isXYMoveAllowed = false;
      }
    }
    on ctrl.calibrate():
    {
      [s.Idle]
      [!isCalibrated]
      {
        isCalibrated = false;
        isRetaining = true;
        calibrateZ();
      }
      [s.Idle]
      [isCalibrated]
      illegal;
      [s.Transferring || s.Moving || s.Calibrating]
      illegal;
    }
    on ctrl.move():
    {
      [s.Idle]
      [!isCalibrated]
      illegal;
      [s.Idle]
      [isCalibrated]
      [!isXYMoveAllowed]
      illegal;
      [s.Transferring || s.Moving || s.Calibrating]
      illegal;
    }
    on ctrl.transfer():
    {
      [s.Idle]
      [!isCalibrated]
      illegal;
      [s.Transferring || s.Moving || s.Calibrating]
      illegal;
    }
    on ctrl.move(x, y):
    [s.Idle]
    [isCalibrated]
    [isXYMoveAllowed]
    {
      truck.move(x);
      trolley.move(y);
      nMoving = 2;
      s = State.Moving;
    }
    on ctrl.transfer(x, y):
    [s.Idle]
    [isCalibrated]
    startPick(x, y);
    on hoist.calibrated():
    {
      [s.Transferring || s.Moving || s.Idle]
      illegal;
      [s.Calibrating]
      tryCalibrated();
    }
    on gripper.calibrated():
    {
      [s.Transferring || s.Moving || s.Idle]
      illegal;
      [s.Calibrating]
      tryCalibrated();
    }
    on trolley.homed():
    {
      [s.Transferring || s.Moving || s.Idle]
      illegal;
      [s.Calibrating]
      tryCalibrated();
    }
    on truck.homed():
    {
      [s.Transferring || s.Moving || s.Idle]
      illegal;
      [s.Calibrating]
      tryCalibrated();
    }
    on hoist.ready():
    {
      [s.Moving || s.Calibrating || s.Idle]
      illegal;
      [s.Transferring]
      [ts.Picking]
      gripper.retain();
      [s.Transferring]
      [ts.Raising && isRetaining]
      {
        isXYMoveAllowed = true;
        ctrl.picked();
        truck.move(placeX);
        trolley.move(placeY);
        nMoving = 2;
        ts = TransferState.Moving;
      }
      [s.Transferring]
      [ts.Moving]
      illegal;
      [s.Transferring]
      [ts.Placing]
      gripper.release();
      [s.Transferring]
      [ts.Raising && !isRetaining]
      [!isRetaining]
      {
        isXYMoveAllowed = true;
        s = State.Idle;
        ts = TransferState.Idle;
        ctrl.placed();
      }
    }
    on gripper.ready():
    {
      [s.Moving || s.Idle]
      illegal;
      [s.Calibrating]
      tryCalibrated();
      [s.Transferring]
      [ts.Picking]
      {
        hoist.retain();
        isRetaining = true;
        ts = TransferState.Raising;
      }
      [s.Transferring]
      [ts.Raising && isRetaining]
      illegal;
      [s.Transferring]
      [ts.Moving]
      illegal;
      [s.Transferring]
      [ts.Placing]
      {
        isRetaining = false;
        hoist.retain();
        ts = TransferState.Raising;
      }
      [s.Transferring]
      [ts.Raising && !isRetaining]
      illegal;
    }
    on trolley.arrived():
    {
      [s.Calibrating || s.Idle]
      illegal;
      [s.Moving]
      {
        nMoving = nMoving - 1;
        if (nMoving == 0) {
          s = State.Idle;
          ctrl.arrived();
        }
      }
      [s.Transferring]
      [ts.Picking]
      illegal;
      [s.Transferring]
      [ts.Raising && isRetaining]
      illegal;
      [s.Transferring]
      [ts.Moving]
      {
        nMoving = nMoving - 1;
        if (nMoving == 0) {
          isXYMoveAllowed = false;
          hoist.release();
          ts = TransferState.Placing;
        }
      }
      [s.Transferring]
      [ts.Placing]
      illegal;
      [s.Transferring]
      [ts.Raising && !isRetaining]
      illegal;
    }
    on truck.arrived():
    {
      [s.Calibrating || s.Idle]
      illegal;
      [s.Moving]
      {
        nMoving = nMoving - 1;
        if (nMoving == 0) {
          s = State.Idle;
          ctrl.arrived();
        }
      }
      [s.Transferring]
      [ts.Picking]
      illegal;
      [s.Transferring]
      [ts.Raising && isRetaining]
      illegal;
      [s.Transferring]
      [ts.Moving]
      {
        nMoving = nMoving - 1;
        if (nMoving == 0) {
          isXYMoveAllowed = false;
          hoist.release();
          ts = TransferState.Placing;
        }
      }
      [s.Transferring]
      [ts.Placing]
      illegal;
      [s.Transferring]
      [ts.Raising && !isRetaining]
      illegal;
    }
  }
}

component Lift {
  provides IRetain ctrl;
  requires IConstrainedMove winch;

  behaviour {
    enum State {Lost, Calibrating, Ready, Moving};
    State s = State.Lost;
    bool isHolding = false;

    on ctrl.stop():
    {
      [s.Moving || s.Ready || s.Calibrating || s.Lost]
      {
        winch.stop();
        s = State.Lost;
        isHolding = false;
      }
    }
    on ctrl.calibrate():
    {
      [s.Lost]
      {
        winch.calibrate();
        s = State.Calibrating;
      }
      [s.Moving || s.Calibrating]
      illegal;
      [s.Ready]
      [!isHolding]
      illegal;
      [s.Ready]
      [isHolding]
      illegal;
    }
    on ctrl.retain():
    {
      [s.Moving || s.Calibrating || s.Lost]
      illegal;
      [s.Ready]
      [!isHolding]
      {
        winch.move($(config.get("Position::Robot::Z::Up"))$);
        s = State.Moving;
      }
      [s.Ready]
      [isHolding]
      illegal;
    }
    on ctrl.release():
    {
      [s.Moving || s.Calibrating || s.Lost]
      illegal;
      [s.Ready]
      [!isHolding]
      illegal;
      [s.Ready]
      [isHolding]
      {
        winch.move($(config.get("Position::Robot::Z::Down"))$);
        s = State.Moving;
      }
    }
    on winch.arrived():
    {
      [s.Lost]
      illegal;
      [s.Calibrating]
      {
        ctrl.calibrated();
        s = State.Ready;
        isHolding = true;
      }
      [s.Ready]
      [!isHolding]
      illegal;
      [s.Ready]
      [isHolding]
      illegal;
      [s.Moving]
      {
        ctrl.ready();
        s = State.Ready;
        isHolding = !isHolding;
      }
    }
    on winch.homed():
    {
      [s.Moving || s.Ready || s.Lost]
      illegal;
      [s.Calibrating]
      winch.move($(config.get("Position::Robot::Z::Up"))$);
    }
  }
}

component Grip {
  provides IRetain ctrl;
  requires IConstrainedMove gripper;

  behaviour {
    enum State {Lost, Calibrating, Ready, Moving};
    State s = State.Lost;
    bool isHolding = false;

    on ctrl.stop():
    {
      [s.Moving || s.Ready || s.Calibrating || s.Lost]
      {
        gripper.stop();
        s = State.Lost;
        isHolding = false;
      }
    }
    on ctrl.calibrate():
    {
      [s.Lost]
      {
        gripper.calibrate();
        s = State.Calibrating;
      }
      [s.Moving || s.Ready || s.Calibrating]
      illegal;
    }
    on ctrl.retain():
    {
      [s.Moving || s.Calibrating || s.Lost]
      illegal;
      [s.Ready]
      [!isHolding]
      {
        s = State.Moving;
        gripper.move($(config.get("Position::Robot::Gripper::Closed"))$);
      }
      [s.Ready]
      [isHolding]
      illegal;
    }
    on ctrl.release():
    {
      [s.Moving || s.Calibrating || s.Lost]
      illegal;
      [s.Ready]
      [!isHolding]
      illegal;
      [s.Ready]
      [isHolding]
      {
        s = State.Moving;
        gripper.move($(config.get("Position::Robot::Gripper::Open"))$);
      }
    }
    on gripper.homed():
    {
      [s.Moving || s.Ready || s.Lost]
      illegal;
      [s.Calibrating]
      gripper.move($(config.get("Position::Robot::Gripper::Closed"))$);
    }
    on gripper.arrived():
    {
      [s.Ready || s.Lost]
      illegal;
      [s.Calibrating]
      {
        ctrl.calibrated();
        s = State.Ready;
        isHolding = true;
      }
      [s.Moving]
      {
        ctrl.ready();
        s = State.Ready;
        isHolding = !isHolding;
      }
    }
  }
}

component MaterialHandler {
  provides IHandle ctrl;
  requires IInspect inspector;
  requires IFeed feedPort;
  requires IConvey acceptPort;
  requires IConvey rejectPort;
  requires imotor hoistMotorHw;
  requires itouch hoistEndSensorHw;
  requires imotor gripperMotorhw;
  requires itouch gripperEndSensorHw;
  requires imotor trolleyMotorHw;
  requires itouch trolleyEndSensorHw;
  requires imotor truckMotorHw;
  requires itouch truckHomeSensorHw;

  system {
    Handle bhv;
    Robot robot;

    ctrl <=> bhv.ctrl;
    bhv.robot <=> robot.ctrl;
    bhv.inspector <=> inspector;
    bhv.feedPort <=> feedPort;
    bhv.acceptPort <=> acceptPort;
    bhv.rejectPort <=> rejectPort;
    robot.gripperMotorhw <=> gripperMotorhw;
    robot.gripperEndSensorHw <=> gripperEndSensorHw;
    robot.hoistEndSensorHw <=> hoistEndSensorHw;
    robot.hoistMotorHw <=> hoistMotorHw;
    robot.trolleyEndSensorHw <=> trolleyEndSensorHw;
    robot.trolleyMotorHw <=> trolleyMotorHw;
    robot.truckHomeSensorHw <=> truckHomeSensorHw;
    robot.truckMotorHw <=> truckMotorHw;
  }
}

component Robot {
  provides ITransfer ctrl;
  requires imotor hoistMotorHw;
  requires itouch hoistEndSensorHw;
  requires imotor gripperMotorhw;
  requires itouch gripperEndSensorHw;
  requires imotor trolleyMotorHw;
  requires itouch trolleyEndSensorHw;
  requires imotor truckMotorHw;
  requires itouch truckHomeSensorHw;

  system {
    Transfer bhv;
    Hoist hoist;
    Gripper gripper;
    EndConstrainedAxis trolley;
    HomeConstrainedAxis truck;

    ctrl <=> bhv.ctrl;
    bhv.hoist <=> hoist.ctrl;
    bhv.gripper <=> gripper.ctrl;
    bhv.trolley <=> trolley.ctrl;
    bhv.truck <=> truck.ctrl;
    hoist.motorHw <=> hoistMotorHw;
    hoist.endSensorHw <=> hoistEndSensorHw;
    gripper.motorHw <=> gripperMotorhw;
    gripper.endSensorHw <=> gripperEndSensorHw;
    trolley.motorHw <=> trolleyMotorHw;
    trolley.endSensorHw <=> trolleyEndSensorHw;
    truck.motorHw <=> truckMotorHw;
    truck.homeSensorHw <=> truckHomeSensorHw;
  }
}

component Hoist {
  provides IRetain ctrl;
  requires imotor motorHw;
  requires itouch endSensorHw;

  system {
    Lift bhv;
    EndConstrainedAxis winch;

    ctrl <=> bhv.ctrl;
    bhv.winch <=> winch.ctrl;
    winch.motorHw <=> motorHw;
    winch.endSensorHw <=> endSensorHw;
  }
}

component Gripper {
  provides IRetain ctrl;
  requires imotor motorHw;
  requires itouch endSensorHw;

  system {
    Grip bhv;
    EndConstrainedAxis gripper;

    ctrl <=> bhv.ctrl;
    bhv.gripper <=> gripper.ctrl;
    gripper.motorHw <=> motorHw;
    gripper.endSensorHw <=> endSensorHw;
  }
}

