interface imotor
{
  extern boolean    $bool$;
  extern position_t $int32_t$;
  extern power_t    $uint8_t$; // [0,100]

  in void move(power_t power, position_t position);  //regulated, absolute position
  in void run(power_t power, boolean invert);        //unregulated
  in void stop();
  in void coast();
  in void zero();
  in void position(out position_t pos);
  enum result_t {yes, no};
  in result_t at(position_t pos);

  behaviour
  {
    on move: {}
    on run: {}
    on stop: {}
    on coast: {}
    on zero: {}
    on position: {}
    on at: reply(result_t.yes);
    on at: reply(result_t.no);
  }
}

interface itouch
{
  enum status {pressed, released};
  in status detect();
  behaviour
  {
    on detect: reply(status.pressed);
    on detect: reply(status.released);
  }
}

interface ilight
{
  in void turnon();
  in void turnoff();

  enum status {accept, reject};
  in status detect();

  behaviour
  {
    on turnon: {}
    on turnoff: {}
    on detect: reply(status.accept);
    on detect: reply(status.reject);
  }
}

interface itimer
{
  extern milliseconds_t $uint32_t$;
  in void create(milliseconds_t ms);
  in void cancel();
  out void timeout();

  behaviour
  {
    enum State {Idle, Pending};
    State state = State.Idle;
    [state.Idle] {
      on create: { state = State.Pending; }
      on cancel: {}
    }
    [state.Pending] {
      on create: illegal;
      on cancel: { state = State.Idle; }
      on inevitable: { timeout; state = State.Idle; }
    }
  }
}

interface itest
{
  in void test();

  behaviour
  {
    on test: {}
  }
}

component test
{
  provides itest port;

  requires imotor motor0;
  requires imotor motor1;
  requires itouch touch;
  requires ilight light;
  requires itimer timer;

  behaviour
  {
    enum State {Idle, Forward, Backward, Home};
    State state = State.Idle;

    itimer.milliseconds_t time = $50$;

    imotor.position_t home0;
    imotor.position_t home1;

    [state.Idle]
    {
      on port.test():
        {
          motor0.run($20$, $true$);
          motor1.run($20$, $true$);
          timer.create(time);
          state = State.Forward;
        }
      on timer.timeout(): illegal;
    }
    [state.Forward]
    {
      on port.test(): {}
      on timer.timeout():
        {
          itouch.status s = touch.detect();
          if(s == itouch.status.pressed)
          {
            motor0.stop();
            motor1.stop();

            motor0.zero();
            motor1.zero();

            light.turnon();
            motor0.run($20$, $false$);
            motor1.run($20$, $false$);

            state = State.Backward;
          }
          timer.create(time);
        }
    }
    [state.Backward]
    {
      on port.test(): {}
      on timer.timeout():
        {
          ilight.status s = light.detect();
          if(s == ilight.status.accept)
          {
            light.turnoff();
            motor0.stop();
            motor1.stop();

            imotor.position_t p0;
            motor0.position(p0);
            imotor.position_t p1;
            motor1.position(p1);

            home0 = $p0/2$;
            home1 = $p1/2$;

            motor0.move($50$, home0);
            motor1.move($50$, home1);

            state = State.Home;
          }
          timer.create(time);
        }
    }
    [state.Home]
    {
      on port.test(): {}
      on timer.timeout():
        {
          imotor.result_t at0 = motor0.at(home0);
          imotor.result_t at1 = motor1.at(home1);

          if(at0 == imotor.result_t.yes)    motor0.stop();
          if(at1 == imotor.result_t.yes)    motor1.stop();
          if(at0 == imotor.result_t.yes &&
             at1 == imotor.result_t.yes)    state = State.Idle;
          else                              timer.create(time);
        }
    }
  }
}

component timer
{
  provides itimer port;
  // use dzn code -m timer lego.dzn to generate stub
  // behaviour {on port.create(ms): {} on port.cancel(): {}}
}

component sut
{
  provides itest port;

  requires imotor motor0;
  requires imotor motor1;
  requires itouch touch;
  requires ilight light;

  system
  {
    test tst;
    timer tmr;

    tst.timer <=> tmr.port;

    tst.port <=> port;
    tst.motor0 <=> motor0;
    tst.motor1 <=> motor1;
    tst.touch <=> touch;
    tst.light <=> light;
  }
}

interface iactive_motor
{
  extern boolean    $bool$;
  extern position_t $int32_t$;
  extern power_t    $uint8_t$; // [0,100]

  in void move(power_t power, position_t position);  //regulated, absolute position
  out void arrived();

  in void run(power_t power, boolean invert);        //unregulated
  in void stop();
  in void coast();
  in void zero();

  behaviour
  {
    bool moving = false;
    [moving]
    {
      on move: illegal;
      on zero: illegal;
      on inevitable: {moving = false; arrived;}
    }
    [!moving]
    {
      on move: { moving = true; }
      on zero: {}
    }
    on run: {}
    on stop: {}
    on coast: {}
  }
}

component active_motor
{
  provides iactive_motor port;
  requires imotor motor;
  requires itimer timer;

  behaviour
  {
    bool moving = false;

    itimer.milliseconds_t time = $50$;
    imotor.position_t destination;

    [moving]
    {
      on port.move(power, position): illegal;
      on timer.timeout():
        {
          imotor.result_t arrive = motor.at(destination);

          if(arrive == imotor.result_t.yes) {port.arrived(); moving = false;}
          else                              timer.create(time);
        }
      on port.zero(): illegal;
    }
    [!moving]
    {
      on port.move(power, position):
        {
          destination = position;
          timer.create(time);
          motor.move(power, destination);
          moving = true;
        }
      on timer.timeout(): illegal;
      on port.zero(): motor.zero();
    }
    on port.run(power, invert): motor.run(power, invert);
    on port.stop(): motor.stop();
    on port.coast(): motor.coast();
  }
}

interface iactive_touch
{
  in void enable();
  out void pressed();
  out void released();
  in void disable();

  behaviour
  {
    bool disabled = true;
    [disabled]
    {
      on enable: disabled = false;
      on disable: illegal;
    }
    [!disabled]
    {
      on enable: illegal;
      on disable: disabled = true;
      on inevitable: pressed;
      on inevitable: released;
    }
  }
}

component active_touch
{
  provides iactive_touch port;
  requires itouch touch;
  requires itimer timer;

  behaviour
  {
    itouch.status previous = itouch.status.released;
    itimer.milliseconds_t time = $50$;
    bool disabled = true;

    [disabled]
    {
      on port.enable():
        {
          previous = touch.detect();
          timer.create(time);
          disabled = false;
        }
      on port.disable(), timer.timeout(): illegal;
    }
    [!disabled]
    {
      on port.enable(): illegal;
      on port.disable(): {timer.cancel(); disabled = true;}
      on timer.timeout():
        {
          itouch.status current = touch.detect();
          if     (previous == itouch.status.released &&
                  current  == itouch.status.pressed)     port.pressed();
          else if(previous == itouch.status.pressed &&
                  current  == itouch.status.released)    port.released();
          previous = current;
          timer.create(time);
        }
    }
  }
}

interface iactive_light
{
  in void enable();
  out void accepted();
  out void rejected();
  in void disable();

  behaviour
  {
    bool disabled = true;
    [disabled]
    {
      on enable: disabled = false;
      on disable: illegal;
    }
    [!disabled]
    {
      on enable: illegal;
      on disable: disabled = true;
      on inevitable: accepted;
      on inevitable: rejected;
    }
  }
}

component active_light
{
  provides iactive_light port;
  requires ilight light;
  requires itimer timer;

  behaviour
  {
    ilight.status previous = ilight.status.reject;
    itimer.milliseconds_t time = $50$;
    bool disabled = true;

    [disabled]
    {
      on port.enable():
        {
          light.turnon();
          previous = light.detect();
          timer.create(time);
          disabled = false;
        }
      on port.disable(), timer.timeout(): illegal;
    }
    [!disabled]
    {
      on port.enable(): illegal;
      on port.disable(): {light.turnoff(); timer.cancel(); disabled = true;}
      on timer.timeout():
        {
          ilight.status current = light.detect();
          if     (previous == ilight.status.reject &&
                  current  == ilight.status.accept) port.accepted();
          else if(previous == ilight.status.accept &&
                  current  == ilight.status.reject) port.rejected();
          previous = current;
          timer.create(time);
        }
    }
  }
}
