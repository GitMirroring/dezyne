import IConstrainedMove.dzn;
import TouchSensor.dzn;
import Motor.dzn;
import lego.dzn;

component HomeConstrainedAxis
{
  provides IConstrainedMove ctrl;
  requires imotor motorHw; // required by motor
  requires itouch homeSensorHw; // required by sensor

  system
  {
    HomeConstrainedMove bhv;
    Motor motor;
    TouchSensor homeSensor;

    ctrl <=> bhv.ctrl;
    bhv.motor <=> motor.ctrl;
    bhv.homeSensor <=> homeSensor.ctrl;

    motor.hw <=> motorHw;
    homeSensor.hw <=> homeSensorHw;
  }
}

component HomeConstrainedMove
{
  provides IConstrainedMove ctrl;
  requires IMove motor;
  requires ITouchSense homeSensor;

  behaviour
  {
    enum State {lost, idle, moving, calibratingHome};
    State s = State.lost;

    void slowBackward() {motor.run($(config.get("Power::CalibrationSpeed"))$, $true$);}
    void recordHome() {
      homeSensor.disable();
      motor.stop(); // brake
      motor.zero();
    }
    void startAbsoluteMove(IConstrainedMove.position_t target) {
      ITouchSense.TouchState ignore = ITouchSense.TouchState.Released;
      ignore = homeSensor.enable();
      motor.move($(config.get("Power::OperationalSpeed"))$, target);
      s = State.moving;
    }
    void notifyArrived() {
      motor.stop();
      homeSensor.disable();
      s = State.idle;
      ctrl.arrived();
    }

    on ctrl.stop(): {motor.stop(); homeSensor.disable(); s = State.lost;}

    [s.lost]
    {
      on ctrl.calibrate():
        {
          ITouchSense.TouchState hss = homeSensor.enable();
          if (hss == ITouchSense.TouchState.Pressed)
          {
            recordHome();
            s = State.idle;
            ctrl.homed();
          }
          else
          {
            slowBackward();
            s = State.calibratingHome;
          }
        }
      on ctrl.move(): illegal;
      on homeSensor.pressed(): illegal;
      on homeSensor.released(): illegal;
      on motor.arrived(): illegal;
    }

    [s.calibratingHome]
    {
      on homeSensor.pressed():
        {
          recordHome();
          s = State.idle;
          ctrl.homed();
        }

      on ctrl.calibrate(): illegal;
      on ctrl.move(): illegal;
      on homeSensor.released(): illegal;
      on motor.arrived(): illegal;
    }

    [s.idle]
    {
      on ctrl.calibrate(): illegal;
      //on ctrl.move(pos): startAbsoluteMove(pos);
      on ctrl.move(target):
        {
          ITouchSense.TouchState ignore = ITouchSense.TouchState.Released;
          ignore = homeSensor.enable();
          motor.move($(config.get("Power::OperationalSpeed"))$, target);
          s = State.moving;
        }

      on homeSensor.pressed(): illegal;
      on homeSensor.released(): illegal;
      on motor.arrived(): illegal;
    }

    [s.moving]
    {
      on ctrl.calibrate(): illegal;
      on ctrl.move(): illegal;
      on homeSensor.pressed(): {motor.stop(); recordHome(); notifyArrived();} // out of range => recalibrate?
      on homeSensor.released(): {}
      on motor.arrived(): notifyArrived();
    }
  }
}
