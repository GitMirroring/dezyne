#!/usr/bin/guile \
-e main -s
!#

(use-modules (srfi srfi-2))
(use-modules (srfi srfi-26))

(define (pair?? ls)
  (if (null? ls) #f
      ls))

(define (main args)
  (let ((args (cdr args)))
    (if (null? args)
        (test clients daemons)
        (let* ((args (map string->symbol args))
               (clients (or (pair?? (filter (compose (cut member <> args) car) clients)) clients))
               (daemons (or (pair?? (filter (compose (cut member <> args) car) daemons)) daemons)))
          (test clients daemons)))))

(define setup
  (list
   "pidof node && killall node || true"
   "cd ~/development"
   "rm -f build/dzn-*"
   "make dzn-client >/dev/null 2>&1"
   "DEZYNE_PREFIX=~/development/build/prefix server/main.js --debug --config=localhost > build/server.log 2>&1 &"
   "rm -rf ~/.npm"
   "rm -f ~/.dzn.json"))

(define dzn-hello
  "echo root | ~/.npm/bin/dzn -u root -p -s http://localhost:3000 hello")

(define checks
  (list
   "[ \"$(npm list -g --parseable --long dzn-daemon | grep -oE '@[0-9]\\.[0-9]\\.[0-9]:')\" = \"@0.0.4:\" ]"
   (string-append "[ \"$(" dzn-hello ")\" = \"password: hello\" ]")))

(define teardown
  (list
   "~/.npm/bin/dzn kill"
   "pidof node && killall node"))

(define clients
  (list
   (cons 'dzn-1.3.0 "npm install -g https://hosting.verum.com/download/npm/dzn-1.3.0.tar.gz")
   (cons 'dzn-2.0.0 "npm install -g http://localhost:3000/download/npm/dzn-2.0.0.tar.gz")
   ))

(define daemons
  (list
   (cons 'daemon-0.0.3 "npm install -g https://hosting.verum.com/download/npm/dzn-daemon-0.0.3.tar.gz")
   (cons 'daemon-0.0.4 "npm install -g http://localhost:3000/download/npm/dzn-daemon-0.0.4.tar.gz")
   (cons 'no-daemon "true")))

(define (sh cmd)
  (display (string-append "+" cmd)) (newline)
  (if (not (eq? 0 (status:exit-val (system cmd))))
      (exit 1)))

(define (script client daemon)
  (map sh setup)
  (sh (cdr client))
  (sh (cdr daemon))
  (sh dzn-hello)
  (map sh checks)
  (map sh teardown))

(define (test clients daemons)
  (map (lambda (client)
         (map (lambda (daemon)
                (display "TEST CASE: [")
                (display (string-join
                          (map symbol->string
                               (list (car client)
                                     (car daemon))) ", "))
                (display "]")
                (newline)
                (script client daemon))
              daemons))
       clients))
