#! /usr/bin/env node
// -*-javascript-*-
var util = require ('../lib/util');

var aspects = process.argv;
aspects.shift(); // strip 'node'
aspects.shift(); // strip the name of this script
var session = aspects.shift(); // first argument is the session
var dir = aspects.shift(); // second argument is the input directory; the rest is the aspects
var languages = require ('../lib/languages');
var aspects_languages = aspects.partition (function (al) {return languages.indexOf (al) === -1;});
require (__dirname + '/../lib/aspects').all(session, aspects_languages[0], aspects_languages[1], dir)
  .done(function(result) { process.exit(result == 'ERROR' ? 1 : result); } );
