#! /usr/bin/env node
// -*-javascript-*-

var aspects = process.argv;
aspects.shift(); // strip 'node'
aspects.shift(); // strip the name of this script
var dir = aspects.shift(); // first argument is the input directory; the rest is the aspects

require (__dirname + '/../lib/aspects').all(aspects, dir).done(function(result) { process.exit(result == 'ERROR' ? 1 : result); } );
