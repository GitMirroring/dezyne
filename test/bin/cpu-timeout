# Commentary:
#
# Usage: test/bin/cpu-timeout.sh timeout command arg .../<test>
#
# Code:
if [ $# -lt 2 ]; then
    echo "Usage: $0 timeout command arg ..."
    exit 126
fi
ulimit -t $1 || { echo "Error: cannot set timeout $1"; exit 126; }
shift
eval "$@"
