#! /bin/sh

grep -v '<- sut.<q>'\
    | sed -r\
    -e 's,.* (->|<-) (<(external|internal)>), \1 \2,'\
    -e 's,^(<(external|internal)>[^ ]*) (<-|->) .*,\1 \3 ,'\
    | grep -Eo '^illegal$|^error$|illegal -> |sut.error -> |( (<-|->) (<(external|internal)>)[.][A-Za-z0-9_-]+([.]\w+)?)|((<external>|sut)[.]\w+[.][A-Za-z0-9_-]+([.]\w+)? (-> |<- ))'\
    | sed -r\
          -e 's, -> ,,'\
          -e 's, <- ,,'\
          -e 's,^sut[.],,'\
          -e 's,^<(external|internal)>[.],,'\
    | { grep -E '^[^.]+[.][^.]+$' || true; }
