(use-modules (ice-9 match)
             (dzn shell-util)
             (test dzn dzn))


;;; Main

(define (main args)
  (match args
    ((_ file-name)
     (let ((run (string-append file-name "/run"))
           (file-name (if (string-prefix? "./test" file-name)
                          (string-drop file-name 2)
                          file-name))
           (languages (string-split (string-trim-both "@languages@") #\space)))
       (if (and (file-exists? run)
                (not (getenv "run-seen")))
           (begin (setenv "run-seen" "1")
                  (unless (getenv "languages")
                    (setenv "languages" (string-join languages)))
                  (exit (zero? (system* run file-name))))
           (exit (run-test file-name languages)))))
    (_ (error "invalid arguments"))))

