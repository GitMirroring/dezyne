#!/usr/bin/guile \
-e main -s
!#

(use-modules (srfi srfi-1))
(use-modules (srfi srfi-2))
(use-modules (srfi srfi-26))

(define url "https://test2.verum.com")
(define client-versions '("2.1.0" "2.2.0"))
(define daemon-versions '("0.0.8"))

(define (test-case client daemon)
  (format #t "  [~a, ~a]\n" (car client) (car daemon)))

(define (main args)
  (let* ((args (cdr args))
         (clients (clients client-versions))
         (daemons (daemons daemon-versions))
         (clients (or (as-pair (filter (test-cases? args) clients)) clients))
         (daemons (or (as-pair (filter (test-cases? args) daemons)) daemons)))
    (format #t "config:\n  url = ~a,\n  client-versions = ~a,\n  daemon-versions = ~a\n\n"
            url client-versions daemon-versions)
    (format #t "test-cases:\n")
    (map (lambda (client) (map (lambda (daemon) (test-case client daemon)) daemons)) clients)
    (newline)
    (test clients daemons)))

(define (as-pair ls)
  (and (pair? ls) ls))

(define (test-cases? args)
  (lambda (o)
   (if (null? args)
       #t
       (member (car o) args))))

(define (clients versions)
  (map (lambda (version)
         (cons (string-append "dzn-" version) (install-client version))) versions))

(define (daemons versions)
  (cons
   (cons "no-daemon" "true")
   (map (lambda (version)
          (cons (string-append "daemon-" version) (install-daemon version))) versions)))

(define (install-client version)
  (string-append "npm install -g " url "/download/npm/dzn-" version ".tar.gz"))

(define (install-daemon version)
  (string-append "npm install -g " url "/download/npm/dzn-daemon-" version ".tar.gz"))


(define dzn-hello
 (string-append "[ \"$(echo root | $HOME/.npm/bin/dzn -u root -p -s http://localhost:3000 hello)\" = \"password: hello\" ]"))

(define (dzn-daemon version)
  "[ \"$(npm list -g --parseable --long dzn-daemon | grep -oE '@[0-9]\\.[0-9]\\.[0-9]:')\" = \"@" version ":\" ]")

(define dzn-query
  "$HOME/.npm/bin/dzn query")

(define dzn-test
  "cd test && bin/test client")

(define setup
  '("pidof node && killall node || true"
    "rm -f $HOME/.dzn.json"
    "rm -rf $HOME/.npmrc"
    "echo prefix=$HOME/.npm > $HOME/.npmrc"
    "rm -rf $HOME/.npm"
    "mkdir -p $HOME/.npm"
    "test -e $HOME/.ccache || ln -s /home/buildmaster/.ccache $HOME/.ccache"
    "make default db-setup dzn-client dzn-daemon"
    "DEZYNE_PREFIX=build/prefix server/main.js --debug --config=localhost > build/server.log 2>&1 &"))

(define teardown
  "killall node")

(define (sh cmd)
  (display (string-append "+" cmd)) (newline)
  (if (not (eq? 0 (status:exit-val (system cmd))))
      (begin (display "FAIL: ") (display cmd) (newline) (exit 1))))

(define (script client daemon tests)
  (map sh setup)
  (sh (cdr client))
  (sh (cdr daemon))
  (map sh tests)
  (sh teardown))

(define (test clients daemons)
  (map (lambda (client)
         (map (lambda (daemon)
                (newline) (test-case client daemon) (newline)
                (script client daemon (list dzn-hello dzn-query dzn-test)))
              daemons))
       clients))

