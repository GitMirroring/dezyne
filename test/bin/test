#! /usr/bin/env node
// -*-javascript-*-

var fs = require('fs');
var path = require('path');
var q = require('q');
var util = require(__dirname + '/../lib/util');
var aspects = require(__dirname + '/../lib/aspects');
var languages = require(__dirname + '/../lib/languages');

var output = {
  result: {},
  open: function(name, title, target, outputFilePath) {
    output.filePath = outputFilePath;
    var format = path.extname(outputFilePath || '').split('.').join('');
    if (format) {
      var scriptfile = __dirname + '/../lib/' + format + '.js';
      try {
        output.write = require(scriptfile).write;
      }
      catch (error) {
        console.error("Don't know how to create " + format + '-file (missing ' + path.basename(scriptfile) + ')');
        process.exit(2);
      }
      var outputDir = path.dirname(outputFilePath);
      if (!util.writable(outputDir)) {
        console.error('Cannot write file in ' + outputDir + ' directory');
        process.exit(2);
      };
    }
    output.result.name = name;
    output.result.title = title;
    output.result.target = target;
    output.result.startTime = new Date();
    output.result.items = [];
  }
  ,
  read_outcome: function(item) {
    var outcome = aspects.empty_outcome();

    try {
      var outcome_string = fs.readFileSync(item+'/outcome.json');
      try {
        outcome = JSON.parse (outcome_string);
      } catch (e) {
        console.log('[ERROR]: '+ item + '/outcome.json is not a valid JSON object');
      }
      return outcome;
    } catch (e) {
      console.log('[ERROR]: '+ item + '/outcome.json is missing');
    }
    return outcome;
  }
  ,
  close: function() {
    function nolanguages() {
      var result = {};
      languages.each ( function(lan) {
        result[lan] = 'NOLOG';
      });
      return result;
    }

    output.result.endTime = new Date();
    output.result.elapsedTime = util.elapsedTime(output.result.startTime, output.result.endTime, false);
    output.result.items.each(function(item) {
      item.outcome = output.read_outcome(path.dirname (output.filePath)+'/'+path.basename(item.name));
    });
    set_status(output.result);

    output.result.testsets = [];
    var rootdir = output.result.target + '/..';
    var target = path.basename(output.result.target);
    var testset_entries = fs.readdirSync(rootdir)
        .filter(function(entry) {
          try {
            return entry != 'all' && entry != target && fs.lstatSync (rootdir + '/' + entry + '/').isDirectory ();
          } catch (e) {}
          return false;
        });
    testset_entries.unshift(target);
    testset_entries.each(function(entry) {
      var items = output.result.items.filter(function(item) {
        try {
          return fs.lstatSync(rootdir + '/' + entry  + '/' + path.basename(item.name) + '/').isDirectory();
        } catch(e) {};
        return false;
      });
      if (items.length) {
        output.result.testsets.push({name: entry, items: items});
      }
    });

    if (output.result.testsets.length == 0) {
      // single test...
      var name = output.result.items.length>0 && path.basename(output.result.items[0].name) || 'TEST';
      output.result.testsets.push({name: name , items: output.result.items});
    }

    if (output.write) {
      output.write(output.result, output.filePath);
      console.log ('See file://' + path.resolve (output.filePath));
    }

    return output.result;
  }
  ,
  log: function(name, result) {
    output.result.items.push({ name: name, result: result });
  }
  ,
}

function parse_opts(argv) {
  var getopt = require('node-getopt');
  var option_parser = getopt.create
  ([
    ['h', 'help', 'display this help and exit'],
    ['j', 'jobs=JOBS', 'run a maximum of JOBS in parallel, default is 1'],
    ['o', 'output=OUTPUT', 'write output to OUTPUT [out/TARGET.html]'],
    ['c', 'collect', 'do not execute, but collect results from previous runs'],
    ['f', 'failedonly', 'execute failed items from previous run'],
    ['q', 'quiet', 'suppress incremental summary on stdout'],
    ['v', 'verbose', 'provide verbose test output on stdout'],
  ]);
  option_parser.bindHelp(
'Usage: bin/test [OPTION]... TARGET (ASPECT | LANGUAGE)*\n\
Options:\n\
[[OPTIONS]]\n\
\n\
Target: a test directory such as all, check, regression-test\n\
\n\
Aspects: ' + aspects.list().sort() + '\n\
Languages: ' + languages.sort() + '\n\
\n\
Examples:\n\
  bin/test check\n\
  bin/test all/helloworld code c++\n\
  bin/test check/trip parse');
  option_parser.error(function(msg) {
    msg && console.error(msg);
    console.error(option_parser.getHelp());
    if (msg) {
      process.exit(2);
    }
  });

  var args = option_parser.parse(argv);

  args.options.jobs = args.options.jobs || 1;

  args.argv = args.argv.slice (2);

  args.options.output = args.options.output
    || 'out/' + path.basename (args.argv[0]) + '.html';

  return args;
}
var session = 0;

function get_testdir_list(dir) {
  var entries = fs.readdirSync (dir);
  entries.sort();
  if (entries.find (function (entry) { return /[.]dzn$/.test (entry) || /[.]dm$/.test (entry) || entry === 'run';}))
    return [dir];

  return [].concat.apply
  (entries
   .filter(function (entry) {
     try {
       return entry != 'baseline' && fs.lstatSync (dir + '/' + entry + '/').isDirectory ();
     } catch (e) {}
     return false;
   })
   .append_map(function (entry) {return get_testdir_list (dir + '/' + entry);}));
}

function execute(dir, args) {
  var worklist = get_testdir_list(dir)
    .map(function(item) {
      return function(session) {
        console.log('[....] ' + item);
        return util.run(session, item, args.argv.slice(1), args.options.verbose, args.options.quiet)
          .then(function(result) {
            output.log(item, result); //FIXME write the result to output
            console.log((result.exitcode === 0 ? '[PASS]' : result.status) + ' ' + item);
            return {item:item, result:result, session:session};
          });
      }});
  return util.parallel_n(worklist, args.options.jobs);
}

function executefailedonly(dir, args) {
  var worklist = get_testdir_list(dir)
      .filter(function(item) {
        var outcome = output.read_outcome(path.dirname (output.filePath)+'/'+path.basename(item));
        if (outcome) {
          outcome = outcome.status;
          failed = 0;
          Object.keys(outcome).each(function(aspect) {
            function checkstatus(status) {
              if (status=='FAILED'||status=='ERROR'||status=='NOLOG') failed++;
            }
            var aspoutcome = outcome[aspect];
            if (typeof aspoutcome !== 'string') {
              Object.keys(aspoutcome).each(function(language) {
                checkstatus(aspoutcome[language]);
              });
            } else {
              checkstatus(aspoutcome);
            }
          });
          return failed>0
        } else return true;
      })
      .map(function(item) {
        console.log("filtered item: %j",item);
        return function(session) {
          console.log('[....] ' + item);
          return util.run(session, item, args.argv.slice(1), args.options.verbose, args.options.quiet)
            .then(function(result) {
              output.log(item, result); //FIXME write the result to output
              console.log((result.exitcode === 0 ? '[PASS] ' : '[FAIL] ') + item);
              return {item:item, result:result, session:session};
            });
        }});
  if (worklist.length) {
    return util.parallel_n(worklist, args.options.jobs);
  } else {
    return 0;
  }
}

function collect(dir) {
  get_testdir_list(dir)
    .map(function(item) {
      console.log('[....] ' + item);
      output.log(item, ''); //FIXME write the result to output
    });
  return 0;
}

function process_dir (dir, args, passed, failed) {
  var aspects_languages = args.argv.slice(1);

  dir = dir.replace (/\/*$/, '');
  var dzn = dir+'/'+path.basename(dir)+'.dzn';
  var dm = dir+'/'+path.basename(dir)+'.dm';
  var run = dir+'/run';
  try {fs.lstatSync(dzn);} catch(e) {dzn=undefined;}
  try {fs.lstatSync(dm);} catch(e) {dm=undefined;}
  try {fs.lstatSync(run);} catch(e) {run=undefined;}
  if (dzn || dm || run)
    return util.run(100 + (session++ % args.options.jobs), dir, aspects_languages, args.options.verbose, args.options.verbose)
    .then(function(result) {
      result.exitcode === 0 ? ++passed.value : ++failed.value;
      output.log(dir, result);
      return [result.exitcode];
    })
    .tap(function(exitcodes) {
      console.log((exitcodes[0] === 0 ? '[PASS] ' : '[FAIL] ') + dir);
    });

  return q.denodeify(fs.readdir) (dir)
    .then(function (files) {
      return files.filter(function (f) {
        try {return fs.lstatSync (dir + '/' + f + '/').isDirectory () && f != 'baseline'} catch (e) {
          return /[.]dzn$/.test (f);
        }
      })
    })
    .then(function(items) {
      var worklist = items
          .map(function(item) {
            return function() {
              console.log('[....] ' + item);
              return process_dir (dir + '/' + item, args, passed, failed);
            };
          });
      return util.parallel_n(worklist, args.options.jobs);
    })
    .then (function (exitcodes_lists) {
      return [].concat.apply([], exitcodes_lists);
    });
}

function V(st1, st2) {
  if (st1 == 'FAILED' || st2 == 'FAILED') return 'FAILED';
  if (st1 == 'KNOWN' || st2 == 'KNOWN') return 'KNOWN';
  if (st1 == 'SOLVED' || st2 == 'SOLVED') return 'SOLVED';
  return 'PASSED';
}

function set_status(result) {
  result.status = {overall: 'PASSED', versions: {}};

  result.items.each(function(item) {
    item.status = {overall: 'PASSED', versions: {}};
    var outcome = item.outcome.status;
    Object.keys(outcome['code']).each(function(version) {
      result.status.versions[version] = result.status.versions[version] || {passed: 0, solved: 0, known: 0, failed: 0};

      var passed = 0;
      var solved = 0;
      var known = 0;
      var failed = 0;
      Object.keys(outcome).each(function(aspect) {

        function checkstatus(status) {
          if (status=='FAILED'||status=='ERROR'||status=='NOLOG') failed++;
          else if (status=='KNOWN') known++;
          else if (status=='SOLVED') solved++;
          else if (status=='PASSED'||status=='SKIPPED'||status=='OK') passed++;
          else { failed++; console.log('???????????????????? status=%j',status); }
        }
        var aspoutcome = outcome[aspect];
        if (typeof aspoutcome !== 'string') {
          if (typeof aspoutcome[version] !== 'string') {
            Object.keys(aspoutcome[version]).each(function(language) {
              checkstatus(aspoutcome[version][language]);
            });
          } else {
            checkstatus(aspoutcome[version]);
          }
        } else {
          checkstatus(aspoutcome);
        }
      });

      if (failed) {
        item.status.versions[version] = 'FAILED';
        result.status.versions[version].failed++;
        result.status.versions[version].overall = V(result.status.versions[version].overall,'FAILED');
        item.status.overall = V(item.status.overall,'FAILED');
        result.status.overall = V(result.status.overall,'FAILED');
      } else if (known) {
        item.status.versions[version] = 'KNOWN';
        result.exitcode = 0;
        result.status.versions[version].known++;
        result.status.versions[version].overall = V(result.status.versions[version].overall,'KNOWN');
        item.status.overall = V(item.status.overall,'KNOWN');
        result.status.overall = V(result.status.overall,'KNOWN');
      } else if (solved) {
        item.status.versions[version] = 'SOLVED';
        result.status.versions[version].solved++;
        result.status.versions[version].overall = V(result.status.versions[version].overall,'SOLVED');
        item.status.overall = V(item.status.overall,'SOLVED');
        result.status.overall = V(result.status.overall,'SOLVED');
      } else {
        item.status.versions[version] = 'PASSED';
        result.status.versions[version].passed++;
        result.status.versions[version].overall = V(result.status.versions[version].overall,'PASSED');
        item.status.overall = V(item.status.overall,'PASSED');
        result.status.overall = V(result.status.overall,'PASSED');
      }
    });
  });
}

function main() {
  var args = parse_opts(process.argv);

  var dir = args.argv[0]

  var failed = {value:0};
  var passed = {value:0};
  var totalTestStartTime = new Date();
  var name = 'Test Framework';
  var title = 'Regression Tests';

  util.spawn_sync_shell('mkdir -p ' + path.dirname (args.options.output))
    .then (function () {
      return output.open(name, title, dir, args.options.output);
    })
    .then(function () {
      if (args.options.collect) {
        return collect(dir);
      } else if (args.options.failedonly) {
        return executefailedonly(dir, args);
      } else {
        return execute(dir, args);
      }
    })
    .then(function(results) {
      var outcome = output.close(args);
      console.log('STATUS: ' + JSON.stringify(outcome.status, null, 2));
      var status = Object.keys (outcome.status.versions)
          .reduce (function (r, e) {return outcome.status.versions[e].failed + r;}, 0);
      process.exit(status);
    })
    .fail(function(err) {
      console.error(err.stack);
      process.exit(1);
    })
    .done ();
}

main();
