#! /usr/bin/env node
// -*-javascript-*-

var fs = require('fs');
var path = require('path');
var q = require('q');
var util = require(__dirname + '/../lib/util');
var aspects = require(__dirname + '/../lib/aspects');

var output = {
  result: {},
  open: function(name, title, target, outputFilePath) {
    output.filePath = outputFilePath;
    var format = path.extname(outputFilePath || '').split('.').join('');
    if (format) {
      var scriptfile = __dirname + '/../lib/' + format + '.js';
      try {
        output.write = require(scriptfile).write;
      }
      catch (error) {
        console.error("Don't know how to create " + fileExtension + '-file (missing ' + path.basename(scriptfile) + ')');
        process.exit(2);
      }
      var outputDir = path.dirname(outputFilePath);
      if (!util.writable(outputDir)) {
        console.error('Cannot write file in ' + outputDir + ' directory');
        process.exit(2);
      };
    }
    output.result.name = name;
    output.result.title = title;
    output.result.target = target;
    output.result.startTime = new Date();
    output.result.items = [];
  }
  ,
  close: function(passed, failed) {
    output.result.endTime = new Date();
    output.result.elapsedTime = util.elapsedTime(output.result.startTime, output.result.endTime, false);
    output.result.passed = passed;
    output.result.failed = failed;
    if (output.write) {
      output.write(output.result, output.filePath);
      console.log ('See file://' + path.resolve (output.filePath));
    }
  }
  ,
  log: function(name, result) {
    output.result.items.push({ name: name, result: result });
  }
  ,
}

function parse_opts(argv) {
  var getopt = require('node-getopt');
  var option_parser = getopt.create
  ([
    ['a', 'aspects=ASPECT[,ASPECT]...', 'test aspects ASPECT... [all]'],
    ['h', 'help', 'display this help and exit'],
    ['o', 'output=OUTPUT', 'write output to OUTPUT [out/TARGET.html]'],
    ['q', 'quiet', 'suppress test summary lines on stdout'],
    ['v', 'verbose', 'show test output on stdout'],
  ]);
  option_parser.bindHelp(
'Usage: bin/test [OPTION]... TARGET\n\
Options:\n\
[[OPTIONS]]\n\
\n\
Target: a test directory such as all, check, regression-test\n\
\n\
Aspects: ' + Object.keys (aspects).sort() + '\n\
\n\
Examples:\n\
  bin/test\n\
  bin/test -a code check\n\
  bin/test -a parse check/trip');
  option_parser.error(function(msg) {
    msg && console.error(msg);
    console.error(option_parser.getHelp());
    if (msg) {
      process.exit(2);
    }
  });
  var args = option_parser.parse(argv);
  args.files = args.argv.slice (2);
  args.files = args.files.length && args.files || ['all'];
  args.options.aspects = args.options.aspects || 'all';
  args.options.aspects = args.options.aspects.split(',');
  args.options.output = args.options.output
    || __dirname + '/../out/' + path.basename (args.files[0]) + '.html';
  if (args.argv.length > 3)
    option_parser.errorFunc('error: unknown argument: ' + args.argv[3]);
  return args;
}

function processTarget(dir, options) {
  var failed = 0;
  var passed = 0;
  var totalTestStartTime = new Date();
  var name = 'Test Framework';
  var title = 'Regression Tests';
  
  util.spawn_sync_shell('mkdir -p ' + path.dirname (options.output))
    .then (function () {
      return output.open(name, title, dir, options.output);
    })
    .then (function () {
      return q.denodeify(fs.readdir) (dir)
        .then(function (files) {
          return files.filter(function (f) {
            try {return fs.lstatSync (dir + '/' + f + '/').isDirectory () && f != 'baseline'} catch (e) {
              return /[.]dzn$/.test (f);
            }
          })
        })
    })
    .then(function(files){
      return files.map(function(f){return f.replace (/[^\/]+[.]dzn$/, '');})
    })
    .then(function(items) {
      var worklist = items
          .map(function(item) {
            return function() {
              console.log('[....] ' + item);
              var cmd = process.cwd() + '/' + dir + '/' + item + '/run';
              return util.run(cmd, options.aspects, options.verbose)
                .then(function(result) {
                  result.exitcode === 0 ? ++passed : ++failed;
                  output.log(item, result);
                  return result.exitcode;
                })
                .tap(function(exitcode) {
                  if (!options.quiet) {
                    console.log((exitcode === 0 ? '[PASS] ' : '[FAIL] ') + item);
                  }
                });
            };
          });

      return util.parallel_n(worklist, 1)
        .then(function(exitcodes) {
          console.log('EXITCODES: ' + exitcodes);
          output.close(passed, failed);
          process.exit(exitcodes.reduce(function(a, b){ return a || b; }, 0));
        })
    })
    .fail(function(err) {
      console.error(err.stack);
      process.exit(1);
    })
    .done();
}

var args = parse_opts(process.argv);
processTarget(args.files[0], args.options);
