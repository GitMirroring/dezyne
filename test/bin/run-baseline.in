(use-modules (ice-9 match)
             (dzn shell-util)
             (test dzn dzn))


;;; Main

(use-modules (ice-9 match)
             (test dzn dzn))

(define (main args)
  (match args
    ((_ file-name command ...)
     (exit (run-baseline file-name command)))
    (_ (error "run-baseline: invalid arguments" args))))

