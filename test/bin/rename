set -e

from=$1
to=$2

if [ -d test ]; then
    from=$(echo $from | sed s,^test/,,)
    to=$(echo $to | sed s,^test/,,)
    cd test
fi

if [ ! -d "$from" -o -z "$to" -o ! -d all/ -o -e "$to" ]; then
    cat <<EOF
Usage: rename FROM TO

Example:
    test/bin/rename test/all/hello test/all/bye
EOF
    exit 2
fi

rm -rf out

git mv $from $to
from_dir=$(dirname $from)
from_base=$(basename $from)
to_base=$(basename $to)

if [ $to/$from_base.dzn != $to/$to_base.dzn ]; then
    git mv $to/$from_base.dzn $to/$to_base.dzn
    sed -i -e "s,$from_base,$to_base,g" $to/$to_base.dzn
    git add $to/$to_base.dzn
fi

for i in $(cd $to && git ls-files 'main.*'); do
    sed -i -e "s,$from_base,$to_base,g" $to/$i;
done

all_from=$(echo $from | sed s,^all/,,)
all_to=$(echo $to | sed s,^all/,,)
sed -i -re "s,/$all_from([ \t]),/$all_to\1,g" all/local.mk
git add all/local.mk

for i in $(ls -1 $to/baseline 2>/dev/null); do
    if [ -L $to/baseline/$i ]; then
        continue
    fi
    sed -i -e s,$from_base,$to_base,g $to/baseline/$i/*trace* ||:
    if [ -f $to/baseline/$i/$from_base ]; then
        if [ $to/baseline/$i/$from_base != $to/baseline/$i/$to_base ]; then
            git mv $to/baseline/$i/$from_base $to/baseline/$i/$to_base
        fi
        sed -i -e s,$from,$to,g $to/baseline/$i/$to_base
        sed -i -e s,$from_base,$to_base,g $to/baseline/$i/$to_base
        git add $to/baseline/$i/$to_base
    fi

    if [ -f $to/baseline/$i/$from_base.stderr ]; then
        if [ $to/baseline/$i/$from_base.stderr != $to/baseline/$i/$to_base.stderr ]; then
            git mv $to/baseline/$i/$from_base.stderr $to/baseline/$i/$to_base.stderr
        fi
        sed -i -e s,$from,$to,g $to/baseline/$i/$to_base.stderr
        sed -i -e s,$from_base,$to_base,g $to/baseline/$i/$to_base.stderr
        git add $to/baseline/$i/$to_base.stderr
    fi
done

for i in $(find . -type l -a -name $from_base); do
    git rm -f $i
    dir=$(dirname $i)
    cd $dir
    ln -s ../$from_dir/$to_base
    git add $to_base
    cd ..
done

if [ -d $to/baseline ]; then
    cat <<EOF
check baseline, run

    ./pre-inst-env run test/$to
EOF
fi
