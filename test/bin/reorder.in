(use-modules (srfi srfi-26)
             (ice-9 rdelim)
             (ice-9 match)
             (test gaiag dzn))


;;; Main

(define (main args)
  (match args
    ((_ file-name)
     (let* ((string (with-input-from-file file-name read-string))
            (reordered (verification-reorder string)))
       (with-output-to-file file-name (cut display reordered))))
    ((_) (let* ((string (read-string))
                (reordered (verification-reorder string)))
           (display reordered)))
    (_ (error "invalid arguments"))))

