namespace space
{
  extern data_t $*unspecified*$;
  enum Bool {False, True};
  subint int {0..1};

  interface ihello
  {
    enum Bool {False, True};

    in void hello();
    out void world();

    behaviour
    {
      on hello: world;
    }
  }

  namespace nest
  {
    interface iworld
    {
      enum Bool {False, True};

      in void hello();
      out void world();

      behaviour
      {

        on hello: world;
      }
    }
  }

  component foo
  {
    provides ihello h;

    behaviour
    {

    }
  }
}

component foo
{
  provides space.ihello h;

  behaviour
  {

  }
}
