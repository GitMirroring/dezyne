interface ihello
{
  enum Bool {True,False};

  in Bool hello();
  out void world();
  behaviour {
    Bool e = Bool.True;
    [e.True] on hello: world;
  }
}

component hello
{
  provides ihello h;
  behaviour
  {
    ihello.Bool e = ihello.Bool.True;
    on h.hello (): {h.world ();reply (e);}
  }
}
