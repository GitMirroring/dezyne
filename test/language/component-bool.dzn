// keep line numbers same as component-enum.dzn

interface ihello
{
  in bool hello();
  out void world();

  behavior
  {
    bool m = true;

    [m.true] on hello:
    {
      bool b = false;
      reply (b);
    }
  }
}

component hello
{
  provides ihello p;
  requires ihello w;

  behavior
  {
    bool m = true;

    bool fun (bool b)
    {
      return b;
    }

    on p.hello ():
    {
      bool b = true;
      reply (b);
    }

    // bool w = false;
    enum Bool {False,True};
    Bool x = Bool.False;
    extern data $int$;
    data y = $0$;
    subint int {0..1};
    int z = 0;
  }
}
