subint sint {0..1};

interface ihello
{
  in sint hello();
  out void world();

  behavior
  {
    sint m = 1;

    [m.1] on hello:
    {
      sint b = 0;
      reply (b);
    }
  }
}

component hello
{
  provides ihello p;
  requires ihello w;

  behavior
  {
    sint m = 1;

    sint fun (sint b)
    {
      return b;
    }

    on p.hello ():
    {
      sint b = 1;
      reply (b);
    }

    bool w = false;
    enum Bool {False,True};
    Bool x = Bool.False;
    extern data $int$;
    data y = $0$;
    // subint int {0..1};
    // int z = 0;
  }
}
