enum Bool {False,True};

interface ihello
{
  in Bool hello();
  out void world();

  behavior
  {
    Bool m = Bool.True;

    [m.True] on hello:
    {
      Bool b = Bool.False;
      reply (b);
    }
  }
}

component hello
{
  provides ihello p;
  requires ihello w;

  behavior
  {
    Bool m = Bool.True;

    Bool fun (Bool b)
    {
      return b;
    }

    on p.hello ():
    {
      Bool b = Bool.True;
      reply (b);
    }

    bool w = false;
    // enum Bool {False,True};
    // Bool x = Bool.False;
    extern data $int$;
    data y = $0$;
    subint int {0..1};
    int z = 0;
  }
}
