interface ihello
{
  in void hello ();
  out void world ();

  behavior
  {
    on hello: world;
  }
}


interface iworld
{
  in void hello ();
  out void world ();

  behavior
  {
    on hello: world;
  }
}

component hello
{
  provides ihello hh;
  provides iworld hx;
  requires ihello ww;
  requires iworld wx;

  behavior
  {
  }
}

component system_hello
{
  provides ihello h;
  provides iworld hx;
  requires ihello w;
  requires iworld wx;

  system
    {
      hello c;
      hello d;

      h <=> c.hh;

      h <=>  ;
      w <=>  ;
      c.hh <=>  ;
      c.ww <=>  ;
      h <=> c. ;
      w <=> c. ;
      h <=> c ;
      w <=> c ;
      h <=> c  
      w <=> c  
    }
}
