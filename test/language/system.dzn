interface ihello
{
  in void hello ();
  out void world ();

  behavior
  {
    on hello: world;
  }
}

component hello
{
  provides ihello hh;
  requires ihello ww;

  behavior
  {
    on hh.hello (): ww.hello ();
    on ww.world (): hh.world ();
  }
}

component hello_system
{

  provides ihello h;

  requires ihello w;

  system
    {

      hello c;
      hello d;

      h <=> c.hh;

    }
}
