#! /bin/sh
# -*- scheme -*-
unset LANG LC_ALL
echo -n "checking for guile..."
guile=$(type -p ${GUILE-guile} 2>/dev/null|tail -n 1|sed 's,^.* ,,')
if [ -x "$guile" ]; then
    echo " $guile"
else
    pm=$({ guix --help || dpkg --help; }|head -n 1|sed 's,.*Usage: \([^ ]*\).*,\1,g')
    case "$pm" in dpkg) message="sudo apt-get install guile-2.0";; *) message="guix package -i guile";; esac
    cat <<EOF
Missing dependencies, run

    $pm
EOF
    exit 1
fi
. $(dirname $0)/VERSION
export SERVICE_VERSION
unset GUILE_LOAD_PATH GUILE_LOAD_COMPILED_PATH
export GUILE_AUTO_COMPILE=0
exec ${GUILE-guile} --no-auto-compile -e '(@@ (configure) main)' -s "$0" ${1+"$@"}
!#

(define-module (configure)
  #:use-module (srfi srfi-1)
  #:use-module (srfi srfi-26)
  #:use-module (ice-9 and-let-star)
  #:use-module (ice-9 curried-definitions)
  #:use-module (ice-9 getopt-long)
  #:use-module (ice-9 match)
  #:use-module (ice-9 optargs)
  #:use-module (ice-9 popen)
  #:use-module (ice-9 rdelim)
  #:use-module (ice-9 regex))

(define (logf port string . rest)
  (apply format (cons* port string rest))
  (force-output port)
  #t)

(define (stderr string . rest)
  (apply logf (cons* (current-error-port) string rest)))

(define (stdout string . rest)
  (apply logf (cons* (current-output-port) string rest)))

(define *shell* "bash")
(define (gulp-pipe command)
  (let* ((port (open-pipe* OPEN_READ *shell* "-c" command))
         (output (read-string port)))
    (close-port port)
    (string-trim-right output #\newline)))

(define *verbose?* #f)

(define* (PATH-search-path name #:key (default name) warn?)
  (or (search-path (string-split (getenv "PATH") #\:) name)
      (and (and warn? (format (current-error-port) "warning: not found: ~a\n" name))
           default)))

(define GDZN (or (getenv "GDZN") "gdzn"))
(define GOJS (or (getenv "GOJS") "/gnu/store/qapf0651kbb98zp1z6ikak05qnf3yphw-gojs-1.6.15.73fc41e1b41c289246994a7e5a6a32b7"))
(define GUILE_EFFECTIVE_VERSION (effective-version))
(define GUILE (PATH-search-path (or (getenv "guile") "guile")))
(define SYSCONFDIR "/etc")
(define LOCALSTATEDIR "/var")
(define BUILD_TRIPLET (gulp-pipe "gcc -dumpmachine 2>/dev/null"))
(define SRCDIR (dirname (car (command-line))))
(define SERVICE_VERSION (getenv "SERVICE_VERSION"))

(define (parse-opts args)
  (let* ((option-spec
  	  '((build (value #t))
            (help (single-char #\h))
            (bindir (value #t))
            (datadir (value #t))
            (prefix (value #t))
            (sysconfdir (value #t))
            (verbose (single-char #\v))
            ;;ignore
            (enable-fast-install)))
         (options (getopt-long args option-spec))
         (help? (option-ref options 'help #f))
         (files (option-ref options '() '()))
         (prefix (option-ref options '() #f))
         (usage? (and (not help?) #f)))
    (if (pair? files)
        (stderr "ignoring files: ~a\n" files))
    (or (and (or help? usage?)
             ((or (and usage? stderr) stdout) "\
Usage: ./configure [OPTION]...
  -h, --help           display this help
  -v, --verbose        be verbose
  --prefix=DIR         install architecture-independent files in PREFIX [~a]

  --bindir=DIR         user executables [PREFIX/bin]
  --datadir=DIR        read-only data [PREFIX]
  --sysconfdir=DIR     read-only single-machine data [PREFIX/etc]
" (or prefix (getcwd)))
             (exit (or (and usage? 2) 0)))
        options)))

(define (tuple< a b)
  (cond
   ((and (null? a) (null? b)) #t)
   ((null? a) (not (null? b)))
   ((null? b) #f)
   ((and (not (< (car a) (car b)))
         (not (< (car b) (car a))))
    (tuple< (cdr a) (cdr b)))
   (else (< (car a) (car b)))))

(define (tuple<= a b)
  (or (equal? a b) (tuple< a b)))

(define* ((->string #:optional (infix "")) h . t)
  (let ((src (if (pair? t) (cons h t) h)))
    (match src
      ((? char?) (make-string 1 src))
      ((? string?) src)
      ((? symbol?) (symbol->string src))
      ((? number?) (number->string src))
      ((h ... t) (string-join (map (->string) src) ((->string) infix)))
      (_ ""))))

(define (version->string version)
  ((->string '.) version))

(define (string->version string)
  (and-let* ((m (fold-matches "([0-9.]+)" string #("" (0 . 0))
                              (lambda (m r)
                                (if (> (string-length (match:substring m))
                                       (string-length (match:substring r)))
                                    m
                                    r))))
             (string-tuplet (match:substring m))
             (version (string-tokenize string-tuplet (char-set-adjoin char-set:digit #\.)))
             ((pair? version))
             (version (car (reverse version)))
             (version (string-tokenize version (char-set-complement (char-set #\.)))))  (map string->number version)))

(define optional '())
(define required '())
(define* (check-version name expected
                        #:key
                        optional?
                        (deb #f)
                        (version-option '--version)
                        (compare tuple<=)
                        (command name))
  (stderr "checking for ~a~a..." name
          (if (null? expected) ""
              (format #f " [~a]" (version->string expected))))
  (let* ((output (gulp-pipe (format #f "~a ~a 2>&1" command version-option)))
         (actual (string->version output))
         (pass? (and actual (compare expected actual)))
         (pass? (PATH-search-path command)))
    (stderr "~a ~a\n" (if pass? (if (pair? actual) "" " yes")
                          (if actual " no, found" "")) (version->string actual))
    (or pass?
        (if (not (pair? name)) (begin (if optional? (set! optional (cons (or deb name) optional))
                                          (set! required (cons (or deb name) required)))
                                      pass?)
            (check-version (cdr name) expected deb version-option compare)))))

(define* (check-pkg-config package expected #:optional (deb #f))
  (check-version (format #f "pkg-config --modversion ~a" package) expected deb))

(define (check-compile-header-c++ header)
  (and (= 0 (system (format #f "echo '#include \"~a\"' | gcc --language=c++ --std=c++11 -E - > /dev/null 2>&1" header)))
       'yes))

(define* (check-header-c++ header deb #:optional (check check-compile-header-c++))
  (stderr "checking for ~a..." header)
  (let ((result (check header)))
    (stderr " ~a\n" (if result result "no"))
    (if (not result)
        (set! required (cons deb required)))))

(define* (check-output deb command input expected)
  (stderr "checking if ~a works..." deb)
  (let* ((result (gulp-pipe (format #f "~a <(echo -e '~a') 2>&1" command input)))
         (m (string-match expected result)))
    (stderr " ~a\n" (if m "yes" "no"))
    (if (not m)
        (begin
          (if *verbose?* (stderr "~a\n" result))
          (set! required (cons deb required))))))

(define guix?
  (and (file-exists? "/gnu")
       (not (equal? (gulp-pipe "type -p bash") "/bin/bash"))))

(define (main args)
  (let* ((verum? (file-exists? "/verum"))
         (options (parse-opts args))
         (build-triplet (option-ref options 'build BUILD_TRIPLET))
         (host-triplet (option-ref options 'host BUILD_TRIPLET))
         (target-triplet (option-ref options 'target BUILD_TRIPLET))
         (prefix (option-ref options 'prefix #f))
         (datarootdir prefix)

         (sysconfdir (option-ref options 'sysconfdir SYSCONFDIR))
         (localstatedir (option-ref options 'localstatedir LOCALSTATEDIR))

         (package-name "dezyne-services") ; hmm
         (datadir (option-ref options 'datadir
                              (if prefix (string-append prefix "/services/" SERVICE_VERSION)
                                  (getcwd))))

         (guilemoduledir (option-ref options 'guilemoduledir (string-append datadir "/gaiag")))
         (guileobjectdir guilemoduledir)
         (prefix (or prefix (getcwd)))
         (bindir (option-ref options 'bindir (string-append prefix "/bin")))
         (libdir (option-ref options 'libdir prefix))

         (verbose? (option-ref options 'verbose #f))
         (srcdir SRCDIR)
         (abs-top-srcdir (canonicalize-path srcdir))
         (builddir (getcwd))
         (abs-top-builddir (canonicalize-path builddir)))
    (define* (substitute file-name pairs
                         #:key (target (if (string-suffix? ".in" file-name)
                                           (string-drop-right file-name 3) target)))
      (with-output-to-file target
        (lambda _
          (display
           (fold (lambda (o result)
                  (regexp-substitute/global #f (car o) result 'pre (cdr o) 'post))
                (with-input-from-file file-name read-string) pairs)))))
    (set! *verbose?* verbose?)
    (if (check-version GDZN '(0) #:optional? #t)
        (set! GDZN (PATH-search-path GDZN #:warn? #t))
        (set! GDZN "./pre-inst-env gdzn"))
    (when (pair? required)
          (stderr "\nMissing dependencies, run\n\n")
          (if guix?
              (stderr "    guix environment -l guix.scm\n")
              (stderr "    sudo apt-get install ~a\n" ((->string " ") required)))
          (exit 1))

    (let ((pairs `(("@abs_top_builddir@" . ,abs-top-builddir)
                   ("@abs_top_srcdir@" . ,abs-top-srcdir)
                   ("@prefix@" . ,prefix)

                   ("@bindir@" . ,bindir)
                   ("@datadir@" . ,datadir)
                   ("@sysconfdir@" . ,sysconfdir)
                   ("@localstatedir@" . ,localstatedir)

                   ("@guilemoduledir@" . ,guilemoduledir)
                   ("@guileobjectdir@" . ,guileobjectdir)

                   ("@srcdir@" . ,srcdir)
                   ("@builddir@" . ,builddir)

                   ("@build@" . ,build-triplet)
                   ("@host@" . ,host-triplet)
                   ("@target@" . ,target-triplet)

                   ("@prefix@" . ,prefix)
                   ("@SERVICE_VERSION@" . ,SERVICE_VERSION)

                   ("@guix@" . ,(if guix? "guix" ""))
                   ("@GUILE_EFFECTIVE_VERSION@" . ,GUILE_EFFECTIVE_VERSION)
                   ("@GUILE@" . ,GUILE)
                   ("@gdzn@" . ,GDZN)
                   ("@gojs@" . ,GOJS))))
      (substitute (string-append abs-top-srcdir "/build-aux/config.mk.in")
                  pairs
                  #:target ".config.mk")
      (substitute (string-append abs-top-srcdir "/build-aux/pre-inst-env.in")
                  pairs
                  #:target "pre-inst-env")
      (substitute (string-append abs-top-srcdir "/gaiag/gaiag/config.scm.in") pairs)
      (chmod "pre-inst-env" #o755)
      (for-each (lambda (o)
                  (substitute (string-append abs-top-srcdir "/" o) pairs)
                  (chmod (string-drop-right o 3) #o755))
                '("dzn/lib/version.js.in"
                  "dzn-daemon/lib/version.js.in"
                  "gaiag/gaiag/config.scm.in"
                  "server/version.js.in"
                  "server/install.js.in"
                  "services/lib/version.js.in"
                  "services/root/js/version.js.in"))
      (for-each (lambda (o)
                  (substitute (string-append abs-top-srcdir "/" o) pairs)
                  (chmod (string-drop-right o 3) #o755))
                '("bin/gdzn.in"
                  "bin/scm2json.in"
                  "bin/json2scm.in"))
      )
    (stdout "\nRun:
  make            to build Dezyne
  make help       for help on other targets\n")))
