interface ihello
{
  in void hello ();
  out void world ();
  behavior
  {
    on hello:;
    on inevitable: world;
  }
}

component requires_port_repyl
{
  provides blocking ihello p;
  requires blocking ihello r;
  behavior
  {
    blocking
    {
      on p.hello (): p.reply ();
      on r.world (): r.reply ();
    }
  }
}
