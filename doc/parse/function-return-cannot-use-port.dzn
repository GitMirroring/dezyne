interface ihello
{
  in bool hello ();
  behavior
  {
    on hello: return true;
    on hello: return false;
  }
}

component function_return_cannot_use_port
{
  provides ihello left;
  provides ihello right;
  behavior
  {
    void f (bool b)
    {
      left.return b;
    }
    void g (bool b)
    {
      return b;
    }
    on left.hello (): f (true);
    on right.hello (): g (false);
  }
}
