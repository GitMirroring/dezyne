      /* ...  */
      on console.key_pressed(key):                         // parameter key contains value of the key pressed on the console
      @{
        icode.result val = codestore.add_digit(key);     // add the value to the pincode
        if (val == icode.result.CODE_COMPLETE)           // if the pincode is complete
        @{
          int pin;
          codestore.get_code(pin);                              // get the value of the pin code
          ialarm_system.result val = alarm.switch_on(pin); // turn on the alarm system with the pin code
          /* ...  */
          /* ...  */
        @}
      @}
    /* ...  */
    /* ...  */
    @}
  /* ...  */
  /* ...  */
  @}
@}
@end example

