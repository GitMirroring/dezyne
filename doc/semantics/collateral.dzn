import ihello.dzn;
import iblock.dzn;

component collateral
{
  provides blocking ihello h;
  requires ihello r;
  requires blocking iblock b;

  behavior
  {
    bool idle = true;
    [idle] on h.hello(): {r.hello(); b.block(); idle = false;}
    [!idle] on r.world(): {h.world(); idle = true;}
  }
}
