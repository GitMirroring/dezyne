namespace dzn
{
  interface async (formals)
  {
    in void req (formals);
    in void clr ();
    out void ack (formals);

    behavior
    {
      bool idle = true;
      [idle]
        {
          on req: idle = false;
          on clr: {}
        }
      [!idle]
        {
          on clr: idle = true;
          on inevitable: {ack; idle = true;}
        }
    }
  }
}
