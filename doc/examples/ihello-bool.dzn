interface ihello_bool
{
  in void hello ();
  in bool cruel ();
  out void world ();

  behavior
  {
    bool idle = true;
    [idle] on hello: idle = false;
    [!idle]
      {
        on cruel: {idle = true; return idle;}
        on cruel: return idle;
        on inevitable: {world; idle = true;}
      }
  }
}
