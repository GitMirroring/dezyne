interface iprotocol_stack
{
  enum result                               // enumeration type used for the reply value of
  {                                         // the event enable
    OK,
    FAILED
  };
  in result enable();                       // in event to enable the protocol_stack
                                            //   the event will return if enabling was successful or not
  in void disable();                        // in event to disable the protocol_stack
  in void connect();
  out void connected();
  behavior                                 // the specification of the externally visible behavior
  {
    enum status {OFF, ON, CONNECTING, CONNECTED};
    status state = status.OFF;
    [state.OFF]
    {
      on enable:                        // One possible response to enable is OK
      {
        reply(result.OK);
        state = status.ON;
      }
      on enable: reply(result.FAILED);  // The other possible response to enable is FAILED
    }
    [state.ON]
    {
      on disable: state = status.OFF;
      on connect: state = status.CONNECTING;
    }
    [state.CONNECTING]
    {
      on disable: state = status.OFF;
      on inevitable:                   // inevitably the connect request will be done and a response will be given
      {
        state = status.CONNECTED;
        connected;
      }
    }
    [state.CONNECTED]
      on disable: state = status.OFF;
  }
}
