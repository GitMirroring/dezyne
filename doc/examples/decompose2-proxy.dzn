interface i1
{
  in void event();
  behaviour {}
}
interface i2
{
  in void event();
  behaviour {}
}
component c1
{
  provides i1 p1;
}
component c2
{
  provides i2 p2;
  requires i1 r2;
}
component decompose2_port
{
  provides i2 i2_proxy;
  system
  {
    c1 ci1;
    c2 ci2;
    i2_proxy <=> ci2.p2;
    ci1.p1 <=> ci2.r2;
  }
}
