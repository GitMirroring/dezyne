// Interface to a sensor
// The Sensor can be enabled via enable
// The Sensor can be disabled via disable
// The Sensor indicates that it is triggered via triggered
interface isensor
{
  in void enable();
  in void disable();
  out void triggered();
  behaviour
  {
    enum status { DISABLED, ENABLED, TRIGGERED };
    status state = status.DISABLED;
    [state.DISABLED]
      on enable:        state = status.ENABLED;
    [state.ENABLED]
    {
      on disable:       state = status.DISABLED;
      on optional:      { triggered; state = status.TRIGGERED; }
    }
    [state.TRIGGERED]
      on disable:       state = status.DISABLED;
  }
}
