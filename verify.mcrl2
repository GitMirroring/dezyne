sort 
     I'Actions = struct I'Actions'e |
     I'Actions'a;
     I'Bool = struct simple'I'Bool'f |
     simple'I'Bool't;
     I'ReplyUnion = struct reply_I'simple'I'Bool(replyValue: simple'I'Bool)?is_reply_I'simple'I'Bool |
     reply_I'Void(replyValue: Void)?is_reply_I'Void;
     
     ActionUnion = struct action_union_0(x0_0_ActionUnion: I'Actions)?is_action_union_0;
     Void = struct void;

map  I'allow_dillegals : Bool;
     space'allow_dillegals : Bool;
     QueueLength: Nat;

eqn  QueueLength = 3;

act  I'reply_out: I'Actions # I'ReplyUnion;
     I'inevitable_begin_oc;
