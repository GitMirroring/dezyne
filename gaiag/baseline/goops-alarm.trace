<external>..arm -> .alarm.console.arm
Sensor.enable
.alarm.console.return -> <external>..return
.sensor.sensor.triggered -> .alarm.sensor.triggered
Console.detected
Siren.turnon
<external>..disarm -> .alarm.console.disarm
Sensor.disable
Siren.turnoff
.alarm.console.return -> <external>..return
.sensor.sensor.disabled -> .alarm.sensor.disabled
Console.deactivated
