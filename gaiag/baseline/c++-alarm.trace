main.console.arm -> Alarm.console.arm
Alarm.sensor.enable -> Sensor.sensor.enable
Sensor.sensor.return -> Alarm.sensor.return
Alarm.console.return -> main.console.return
Sensor.sensor.triggered -> Alarm.sensor.triggered
Console.detected
Alarm.siren.turnon -> Siren.siren.turnon
Siren.siren.return -> Alarm.siren.return
main.console.disarm -> Alarm.console.disarm
Alarm.sensor.disable -> Sensor.sensor.disable
Sensor.sensor.return -> Alarm.sensor.return
Alarm.siren.turnoff -> Siren.siren.turnoff
Siren.siren.return -> Alarm.siren.return
Alarm.console.return -> main.console.return
Sensor.sensor.disabled -> Alarm.sensor.disabled
Console.deactivated
