-- component.csp.scm

channel i598_console:{i3_arm,i4_disarm,inevitable,optional}
channel i601_sensor:{i243_enable,i244_disable,inevitable,optional}
channel i604_siren:{i487_turnon,i488_turnoff}

channel i598_console_'':{i5_detected,i6_deactivated}
channel i601_sensor_'':{i245_triggered,i246_disabled}

channel i598_console_':{return}
channel i601_sensor_':{return}
channel i604_siren_':{return}


CO_i1019_Alarm_(IIG,IG) = let

i1019_Alarm_(((i619_state,i623_sounding),(stack'))) = transition_begin -> (
((i619_state == i611_States_Disarmed)) & (
i598_console?x:{i3_arm} ->
semi_(semi_((\ P',V' @ i601_sensor!i243_enable -> i601_sensor_'.return -> P'(V')),
assign_(\ ((i619_state,i623_sounding),(stack')) @ ((i611_States_Armed,i623_sounding),(stack')))),
(\ P',V' @ i242_IConsole_'.return -> P'(V')))(\ V' @ transition_end -> i1019_Alarm_(V'),((i619_state,i623_sounding),(stack')))
 []
  IIG & i598_console?x:{i4_disarm} ->
illegal_(STOP,<>)
 []
  IG & i601_sensor_''?x:{i245_triggered,i246_disabled} ->
illegal_(STOP,<>))
[]
((i619_state == i611_States_Armed)) & (
IIG & i598_console?x:{i3_arm} ->
illegal_(STOP,<>)
 []
  i598_console?x:{i4_disarm} ->
semi_(semi_((\ P',V' @ i601_sensor!i244_disable -> i601_sensor_'.return -> P'(V')),
assign_(\ ((i619_state,i623_sounding),(stack')) @ ((i611_States_Disarming,i623_sounding),(stack')))),
(\ P',V' @ i242_IConsole_'.return -> P'(V')))(\ V' @ transition_end -> i1019_Alarm_(V'),((i619_state,i623_sounding),(stack')))
 []
  i601_sensor_''?x:{i245_triggered} ->
semi_(semi_((\ P',V' @ i598_console_''!i5_detected -> P'(V')),
semi_((\ P',V' @ i604_siren!i487_turnon -> i604_siren_'.return -> P'(V')),
semi_(assign_(\ ((i619_state,i623_sounding),(stack')) @ ((i619_state,true),(stack'))),
assign_(\ ((i619_state,i623_sounding),(stack')) @ ((i611_States_Triggered,i623_sounding),(stack')))))),
skip_)(\ V' @ transition_end -> i1019_Alarm_(V'),((i619_state,i623_sounding),(stack')))
 []
  IG & i601_sensor_''?x:{i246_disabled} ->
illegal_(STOP,<>))
[]
((i619_state == i611_States_Disarming)) & (
IIG & i598_console?x:{i3_arm,i4_disarm} ->
illegal_(STOP,<>)
 []
  IG & i601_sensor_''?x:{i245_triggered} ->
illegal_(STOP,<>))
[]
(((i619_state == i611_States_Disarming) and i623_sounding)) & (
i601_sensor_''?x:{i246_disabled} ->
semi_(semi_((\ P',V' @ i598_console_''!i6_deactivated -> P'(V')),
semi_(assign_(\ ((i619_state,i623_sounding),(stack')) @ ((i619_state,false),(stack'))),
assign_(\ ((i619_state,i623_sounding),(stack')) @ ((i611_States_Disarmed,i623_sounding),(stack'))))),
skip_)(\ V' @ transition_end -> i1019_Alarm_(V'),((i619_state,i623_sounding),(stack'))))
[]
(((i619_state == i611_States_Disarming) and (not i623_sounding))) & (
i601_sensor_''?x:{i246_disabled} ->
semi_(semi_((\ P',V' @ i598_console_''!i6_deactivated -> P'(V')),
assign_(\ ((i619_state,i623_sounding),(stack')) @ ((i611_States_Disarmed,i623_sounding),(stack')))),
skip_)(\ V' @ transition_end -> i1019_Alarm_(V'),((i619_state,i623_sounding),(stack'))))
[]
((i619_state == i611_States_Triggered)) & (
IIG & i598_console?x:{i3_arm} ->
illegal_(STOP,<>)
 []
  i598_console?x:{i4_disarm} ->
semi_(semi_((\ P',V' @ i601_sensor!i244_disable -> i601_sensor_'.return -> P'(V')),
semi_(assign_(\ ((i619_state,i623_sounding),(stack')) @ ((i619_state,false),(stack'))),
assign_(\ ((i619_state,i623_sounding),(stack')) @ ((i611_States_Disarming,i623_sounding),(stack'))))),
(\ P',V' @ i242_IConsole_'.return -> P'(V')))(\ V' @ transition_end -> i1019_Alarm_(V'),((i619_state,i623_sounding),(stack')))
 []
  IG & i601_sensor_''?x:{i245_triggered,i246_disabled} ->
illegal_(STOP,<>))
)

within i1019_Alarm_(((i611_States_Disarmed,false),(<>)))

channel extensions_over_empty_channels_is_undefined
channel IN',OUT' : {i601_sensor_''.i245_triggered,i601_sensor_''.i246_disabled,extensions_over_empty_channels_is_undefined}

channel LINK' : {|IN',OUT'|}

SINGLETHREADED = true

channel reorder_in  : {i242_IConsole_'.return}
channel reorder_out : {i598_console_'.return}
channel queue_full'

SEMANTICS(in',out',link',client',modeling') = let

Q' = let

N' = 3

external chase

Cell = link'.in'?x' -> link'.out'!x' -> Cell

Back = in'?x' -> (link'.out'!x' -> Back [] in'?x' -> queue_full' -> illegal -> STOP)

Front = Cell[[link'.out' <- out']]

within
       if (N'==1) then (Back[[link'.out' <- out']])
       else if(N'==2) then chase(Back [link'.out' <-> link'.in'] Front  \ {|link'|})
       else chase((Back [link'.out' <-> link'.in'] ([link'.out'<->link'.in'] x : <1..N'-2> @ Cell)) [link'.out' <-> link'.in'] Front \ {|link'|})

R'(A') = ([] x' : A' @ x' -> R'(A'))
       []
       reorder_in?i242_IConsole_'.x' -> reorder_out!i598_console_'.x' -> R'(A')

S'    = let

N' = 3

Idle(c') = transition_begin -> ([] x' : union(client',modeling') @ x' -> Busy(c',<>))

Busy(c',r') = c' == 0 & transition_end -> (if r' == <> then Idle(0) else reorder_out!i598_console_'.head(r') -> Idle(0))
            []
            c' > 0 & transition_end -> transition_begin -> Busy(c',r')
            []
            c' <= N' & in'?x' -> Busy(c'+1,r')
            []
            c' > 0 & out'?x' -> Busy(c'-1,r')
            []
            r' == <> & reorder_in?i242_IConsole_'.x' -> Busy(c',<x'>)
            []
            r' != <> & reorder_in?i242_IConsole_'.x' -> illegal -> STOP

within Idle(0)

within Q' [|{|in',out'|}|] if SINGLETHREADED then S' else R'(Union({{|in',out',transition_begin,transition_end|},client',modeling'}))

AS_i1019_Alarm_(IIG) = let
compress(x) = let
transparent sbisim
transparent diamond
within sbisim(diamond(x))

ClientCalls = {i598_console.i3_arm,i598_console.i4_disarm}
UsedModeling = {i601_sensor.inevitable,i601_sensor.optional}
within compress((CO_i1019_Alarm_(IIG,true) [[x<-OUT'.x|x<-extensions(OUT')]] [[x<-reorder_in.x|x<-extensions(reorder_in)]]
                 [|{|OUT',transition_begin,transition_end,reorder_in,i598_console,i598_console_'|}|]
                 SEMANTICS(IN',OUT',LINK',ClientCalls,UsedModeling) \ {|OUT',transition_begin,transition_end,reorder_in|}
                 ) [[reorder_out.x<-x|x<-extensions(reorder_out)]]
                [|{|IN',i601_sensor,i601_sensor_',i604_siren,i604_siren_'|}|]
                (IF_i482_ISensor_(true,false) [[i482_ISensor.x<-i601_sensor.x|x<-extensions(i601_sensor)]][[i482_ISensor_'.x<-i601_sensor_'.x|x<-extensions(i601_sensor_')]][[i482_ISensor_''.x<-i601_sensor_''.x|x<-extensions(i601_sensor_'')]]
                 ||| IF_i593_ISiren_(true,false) [[i593_ISiren.x<-i604_siren.x|x<-extensions(i604_siren)]][[i593_ISiren_'.x<-i604_siren_'.x|x<-extensions(i604_siren_')]]
)[[x<-IN'.x|x<-extensions(IN')]])

-- end of component.csp.scm
assert COMPLETE'({i242_IConsole.inevitable,i242_IConsole.optional,i242_IConsole.i3_arm,i242_IConsole.i4_disarm}) [F= IF_i242_IConsole_(true,true) \ diff(Events,{i242_IConsole.inevitable,i242_IConsole.optional,i242_IConsole.i3_arm,i242_IConsole.i4_disarm,illegal})
assert IF_i242_IConsole_(false,false) :[deadlock free]
assert IF_i242_IConsole_(true,false)  \ {|i242_IConsole.inevitable,i242_IConsole.optional|} :[livelock free]
assert COMPLETE'({i482_ISensor.inevitable,i482_ISensor.optional,i482_ISensor.i243_enable,i482_ISensor.i244_disable}) [F= IF_i482_ISensor_(true,true) \ diff(Events,{i482_ISensor.inevitable,i482_ISensor.optional,i482_ISensor.i243_enable,i482_ISensor.i244_disable,illegal})
assert IF_i482_ISensor_(false,false) :[deadlock free]
assert IF_i482_ISensor_(true,false)  \ {|i482_ISensor.inevitable,i482_ISensor.optional|} :[livelock free]
assert COMPLETE'({i593_ISiren.i487_turnon,i593_ISiren.i488_turnoff}) [F= IF_i593_ISiren_(true,true) \ diff(Events,{i593_ISiren.i487_turnon,i593_ISiren.i488_turnoff,illegal})
assert IF_i593_ISiren_(false,false) :[deadlock free]
assert IF_i593_ISiren_(true,false) :[livelock free]
assert CO_i1019_Alarm_(true,true)[[i242_IConsole_'.x<-i598_console_'.x|x<-extensions(i598_console_')]] :[deterministic]
assert COMPLETE'({i598_console.i3_arm,i598_console.i4_disarm,i601_sensor_''.i245_triggered,i601_sensor_''.i246_disabled}) [F= CO_i1019_Alarm_(true,true)[[i242_IConsole_'.x'<-i598_console_'.x'|x'<-extensions(i598_console_')]] \ diff(Events,{i598_console.i3_arm,i598_console.i4_disarm,i601_sensor_''.i245_triggered,i601_sensor_''.i246_disabled,illegal})
assert STOP [T= AS_i1019_Alarm_(false) \ diff(Events,{illegal})
assert AS_i1019_Alarm_(false) :[deadlock free]
assert IF_i242_IConsole_(true,false) [[i242_IConsole.x<-i598_console.x|x<-extensions(i598_console)]][[i242_IConsole_'.x<-i598_console_'.x|x<-extensions(i598_console_')]][[i242_IConsole_''.x<-i598_console_''.x|x<-extensions(i598_console_'')]]\ {i598_console.inevitable,i598_console.optional} [F= AS_i1019_Alarm_(true) \ diff(Events,{|illegal,i598_console,i598_console_',i598_console_''|})
assert AS_i1019_Alarm_(true) \ diff(Events,{|illegal,i598_console,i598_console_',i598_console_''|}) :[livelock free]
