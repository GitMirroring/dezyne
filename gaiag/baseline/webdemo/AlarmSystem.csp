-- drop_one_local: V => V
drop_one_local_((M', (L', L0'))) = (M', L')

illegal_(P',V') = illegal -> STOP
-- send_: (c: channel, e:event) => (P,V)->Proc
send_(c',e')(P', V') = c'!e' -> P'(V')
-- recv_: (c: channel, e:event) => (P,V)->Proc
recv_(c',e')(P', V') =  c'?r' -> returnvalue_(\V' @ r')(P', V')
-- skip_: () => (P,V)->Proc
skip_(P', V') = P'(V')
-- call_: (B': (P,V)->Proc) => (P,V)->Proc
call_(B')(P', (M1', L1')) = B'(\(M2',V2')@ P'((M2',L1')), (M1', <>))
-- call_args_: (B': (P,V)->Proc, F': V'->V') => (P,V)->Proc
call_args_(B', F')(P', (M1', L1')) = B'(\(M2',V2')@ P'((M2',L1')), (M1', (<>, F'((M1',L1')))))
-- assign_: (F': V -> V) => (P,V) -> Proc
assign_(F')(P', V') = P'(F'(V'))
-- assign_active_: C':(P,V)->Proc, A: (V,val)->V) => (P,V)->Proc
assign_active_(C', A')(P', V') = C'(\((M', r'),L') @ P'(A'((M',L'),r')), V')
reply_(C', F')(P', V') = C'.F'(V') -> P'(V')
-- returnvalue_: (F: V->val) => (P,V)->Proc
returnvalue_(F')(P', (M',L')) = P'(((M',  F'((M', L'))), L'))
-- the_end_: P => V->Proc
the_end_(P', V') = transition_end -> P'(V')

-- semi_: (S1,S2: (P,V)->Proc) => (P,V) -> Proc
semi_(S1',S2')(P', V') = S1'(\V'' @ S2'(P', V''),V')
-- ifthenelse: (E': val,  S1,S2: (P,V)->Proc) => (P,V) -> Proc
ifthenelse_(E',S1',S2')(P', V') =  if E' then S1'(P', V') else S2'(P', V')
-- context_: (F': V->val, S': (P,V)->Proc) => (P,V)->Proc
context_(F', S')(P', (M', L')) = S'((\ (M',L2') @ P'((M',L'))), (M', (L', F'((M', L')))))
-- context_active_: (C':(P,V)->Proc, S: (P,V)->Proc) => (P,V)->Proc
context_active_(C', S')(P', V') = C'(\((M', r'),L') @ S'(\V2' @ P'(drop_one_local_(V2')), (M', (L',r'))), V')

channel illegal
channel transition_begin, transition_end

COMPLETE'(A') = []x:A' @ x-> (COMPLETE'(A') |~| illegal->STOP)

datatype event_enumeration_alphabet = i11_States_Armed | i11_States_Disarmed | i11_States_Disarming | i11_States_Triggered | i243_enable | i244_disable | i245_triggered | i246_disabled | i251_States_Disabled | i251_States_Disabling | i251_States_Enabled | i251_States_Triggered | i3_arm | i487_turnon | i488_turnoff | i491_States_Off | i491_States_On | i4_disarm | i5_detected | i611_States_Armed | i611_States_Disarmed | i611_States_Disarming | i611_States_Triggered | i6_deactivated | inevitable | optional | return | the_end'
-- interface.csp.scm

channel i242_IConsole: {i3_arm,i4_disarm,inevitable,optional,the_end'}
channel i242_IConsole_'': {i5_detected,i6_deactivated}
channel i242_IConsole_': {return}
channel i242_IConsole_in',i242_IConsole_out': {i242_IConsole_'.return}

IF_i242_IConsole_(IG,CS) = let

i242_IConsole_(((i19_state),(stack'))) =
((i19_state == i11_States_Disarmed)) & (
i242_IConsole?x:{i3_arm} ->
semi_(assign_(\ ((i19_state),(stack')) @ ((i11_States_Armed),(stack'))),
(\ P',V' @ i242_IConsole_'.return -> P'(V')))(\ V' @ i242_IConsole.the_end' -> i242_IConsole_(V'),((i19_state),(stack')))
 []
  IG & i242_IConsole?x:{i4_disarm} ->
illegal_(STOP,<>))
[]
((i19_state == i11_States_Armed)) & (
i242_IConsole?x:{i4_disarm} ->
semi_(assign_(\ ((i19_state),(stack')) @ ((i11_States_Disarming),(stack'))),
(\ P',V' @ i242_IConsole_'.return -> P'(V')))(\ V' @ i242_IConsole.the_end' -> i242_IConsole_(V'),((i19_state),(stack')))
 []
  i242_IConsole?x:{optional} ->
semi_(semi_((\ P',V' @ i242_IConsole_''!i5_detected -> P'(V')),
assign_(\ ((i19_state),(stack')) @ ((i11_States_Triggered),(stack')))),
skip_)(\ V' @ i242_IConsole.the_end' -> i242_IConsole_(V'),((i19_state),(stack')))
 []
  IG & i242_IConsole?x:{i3_arm} ->
illegal_(STOP,<>))
[]
((i19_state == i11_States_Triggered)) & (
i242_IConsole?x:{i4_disarm} ->
semi_(assign_(\ ((i19_state),(stack')) @ ((i11_States_Disarming),(stack'))),
(\ P',V' @ i242_IConsole_'.return -> P'(V')))(\ V' @ i242_IConsole.the_end' -> i242_IConsole_(V'),((i19_state),(stack')))
 []
  IG & i242_IConsole?x:{i3_arm} ->
illegal_(STOP,<>))
[]
((i19_state == i11_States_Disarming)) & (
i242_IConsole?x:{inevitable} ->
semi_(semi_((\ P',V' @ i242_IConsole_''!i6_deactivated -> P'(V')),
assign_(\ ((i19_state),(stack')) @ ((i11_States_Disarmed),(stack')))),
skip_)(\ V' @ i242_IConsole.the_end' -> i242_IConsole_(V'),((i19_state),(stack')))
 []
  IG & i242_IConsole?x:{i3_arm,i4_disarm} ->
illegal_(STOP,<>))
[]
CS & i242_IConsole?x:{inevitable,optional} -> illegal_(STOP,<>)

REORDER' = i242_IConsole?x' -> (i242_IConsole_in'?y' -> i242_IConsole.the_end' -> i242_IConsole_out'!y' -> REORDER' [] i242_IConsole.the_end' -> REORDER')

compress(x) = let
transparent sbisim
transparent diamond
within sbisim(diamond(x))

within compress((if CS
                 then i242_IConsole_(((i11_States_Disarmed),(<>)))
                 else i242_IConsole_(((i11_States_Disarmed),(<>))) [|{i242_IConsole.optional}|] CHAOS({i242_IConsole.optional})) [[x<-i242_IConsole_in'.x|x<-extensions(i242_IConsole_in')]] [|{|i242_IConsole,i242_IConsole_in',i242_IConsole.the_end'|}|] REORDER' [[i242_IConsole_out'.x<-x|x<-extensions(i242_IConsole_out')]] \ {|i242_IConsole_in',i242_IConsole.the_end'|})

-- end of interface.csp.scm
-- interface.csp.scm

channel i482_ISensor: {i243_enable,i244_disable,inevitable,optional,the_end'}
channel i482_ISensor_'': {i245_triggered,i246_disabled}
channel i482_ISensor_': {return}
channel i482_ISensor_in',i482_ISensor_out': {i482_ISensor_'.return}

IF_i482_ISensor_(IG,CS) = let

i482_ISensor_(((i259_state),(stack'))) =
((i259_state == i251_States_Disabled)) & (
i482_ISensor?x:{i243_enable} ->
semi_(assign_(\ ((i259_state),(stack')) @ ((i251_States_Enabled),(stack'))),
(\ P',V' @ i482_ISensor_'.return -> P'(V')))(\ V' @ i482_ISensor.the_end' -> i482_ISensor_(V'),((i259_state),(stack')))
 []
  IG & i482_ISensor?x:{i244_disable} ->
illegal_(STOP,<>))
[]
((i259_state == i251_States_Enabled)) & (
IG & i482_ISensor?x:{i243_enable} ->
illegal_(STOP,<>)
 []
  i482_ISensor?x:{i244_disable} ->
semi_(assign_(\ ((i259_state),(stack')) @ ((i251_States_Disabling),(stack'))),
(\ P',V' @ i482_ISensor_'.return -> P'(V')))(\ V' @ i482_ISensor.the_end' -> i482_ISensor_(V'),((i259_state),(stack')))
 []
  i482_ISensor?x:{optional} ->
semi_(semi_((\ P',V' @ i482_ISensor_''!i245_triggered -> P'(V')),
assign_(\ ((i259_state),(stack')) @ ((i251_States_Triggered),(stack')))),
skip_)(\ V' @ i482_ISensor.the_end' -> i482_ISensor_(V'),((i259_state),(stack'))))
[]
((i259_state == i251_States_Disabling)) & (
IG & i482_ISensor?x:{i243_enable,i244_disable} ->
illegal_(STOP,<>)
 []
  i482_ISensor?x:{inevitable} ->
semi_(semi_((\ P',V' @ i482_ISensor_''!i246_disabled -> P'(V')),
assign_(\ ((i259_state),(stack')) @ ((i251_States_Disabled),(stack')))),
skip_)(\ V' @ i482_ISensor.the_end' -> i482_ISensor_(V'),((i259_state),(stack'))))
[]
((i259_state == i251_States_Triggered)) & (
IG & i482_ISensor?x:{i243_enable} ->
illegal_(STOP,<>)
 []
  i482_ISensor?x:{i244_disable} ->
semi_(assign_(\ ((i259_state),(stack')) @ ((i251_States_Disabling),(stack'))),
(\ P',V' @ i482_ISensor_'.return -> P'(V')))(\ V' @ i482_ISensor.the_end' -> i482_ISensor_(V'),((i259_state),(stack'))))
[]
CS & i482_ISensor?x:{inevitable,optional} -> illegal_(STOP,<>)

REORDER' = i482_ISensor?x' -> (i482_ISensor_in'?y' -> i482_ISensor.the_end' -> i482_ISensor_out'!y' -> REORDER' [] i482_ISensor.the_end' -> REORDER')

compress(x) = let
transparent sbisim
transparent diamond
within sbisim(diamond(x))

within compress((if CS
                 then i482_ISensor_(((i251_States_Disabled),(<>)))
                 else i482_ISensor_(((i251_States_Disabled),(<>))) [|{i482_ISensor.optional}|] CHAOS({i482_ISensor.optional})) [[x<-i482_ISensor_in'.x|x<-extensions(i482_ISensor_in')]] [|{|i482_ISensor,i482_ISensor_in',i482_ISensor.the_end'|}|] REORDER' [[i482_ISensor_out'.x<-x|x<-extensions(i482_ISensor_out')]] \ {|i482_ISensor_in',i482_ISensor.the_end'|})

-- end of interface.csp.scm
-- interface.csp.scm

