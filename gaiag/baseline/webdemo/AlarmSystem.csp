semi_(assign_(\ ((i499_state),(stack')) @ ((i491_States_On),(stack'))),
(\ P',V' @ i593_ISiren_'.return -> P'(V')))(\ V' @ i593_ISiren.the_end' -> i593_ISiren_(V'),((i499_state),(stack')))
 []
  IG & i593_ISiren?x:{i488_turnoff} ->
illegal_(STOP,<>))
[]
((i499_state == i491_States_On)) & (
i593_ISiren?x:{i488_turnoff} ->
semi_(assign_(\ ((i499_state),(stack')) @ ((i491_States_Off),(stack'))),
(\ P',V' @ i593_ISiren_'.return -> P'(V')))(\ V' @ i593_ISiren.the_end' -> i593_ISiren_(V'),((i499_state),(stack')))
 []
  IG & i593_ISiren?x:{i487_turnon} ->
illegal_(STOP,<>))
[]
CS & i593_ISiren?x:{} -> illegal_(STOP,<>)

REORDER' = i593_ISiren?x' -> (i593_ISiren_in'?y' -> i593_ISiren.the_end' -> i593_ISiren_out'!y' -> REORDER' [] i593_ISiren.the_end' -> REORDER')

compress(x) = let
transparent sbisim
transparent diamond
within sbisim(diamond(x))

within compress((if CS
                 then i593_ISiren_(((i491_States_Off),(<>)))
                 else i593_ISiren_(((i491_States_Off),(<>)))) [[x<-i593_ISiren_in'.x|x<-extensions(i593_ISiren_in')]] [|{|i593_ISiren,i593_ISiren_in',i593_ISiren.the_end'|}|] REORDER' [[i593_ISiren_out'.x<-x|x<-extensions(i593_ISiren_out')]] \ {|i593_ISiren_in',i593_ISiren.the_end'|})

