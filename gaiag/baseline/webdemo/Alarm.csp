nametype bool = {false, true}

channel illegal
channel range_error
channel transition_begin, transition_end

COMPLETE'(A') = ([]x:A' @ x-> COMPLETE'(A')) |~| illegal->STOP

datatype event_enumeration_alphabet = i11_State_Armed | i11_State_Disarmed | i11_State_Disarming | i11_State_Triggered | i169_enable | i170_disable | i171_triggered | i172_disabled | i177_State_Disabled | i177_State_Disabling | i177_State_Enabled | i177_State_Triggered | i335_turnon | i336_turnoff | i339_State_Off | i339_State_On | i3_arm | i425_State_Armed | i425_State_Disarmed | i425_State_Disarming | i425_State_Triggered | i4_disarm | i5_detected | i6_deactivated | inevitable | modeling | optional | return | the_end'

-- end of combinators
-- both.csp.scm
-- end of both.csp.scm
-- interface.csp.scm

channel i168_IConsole: {i3_arm,i4_disarm,the_end'}
channel i168_IConsole_'': {i5_detected,i6_deactivated}
channel i168_IConsole_': {return}
channel i168_IConsole_in',i168_IConsole_out': {i168_IConsole_'.return}
channel i168_IConsole_''': {inevitable,optional,modeling}

IF_i168_IConsole_(IG,CS) = let

i168_IConsole_(i13_state) =
(((i13_state == i11_State_Disarmed)) & (
i168_IConsole?x:{i3_arm} -> (
  let tmp' = i11_State_Armed within
  let i13_state = tmp' within
    i168_IConsole_'.return ->
  i168_IConsole.the_end' ->
  i168_IConsole_(i13_state)
)
 []
  IG & i168_IConsole?x:{i4_disarm} -> (
  illegal -> STOP
))
[]
((i13_state == i11_State_Armed)) & (
i168_IConsole?x:{i4_disarm} -> (
  let tmp' = i11_State_Disarming within
  let i13_state = tmp' within
    i168_IConsole_'.return ->
  i168_IConsole.the_end' ->
  i168_IConsole_(i13_state)
)
 []
  i168_IConsole_'''?x:{optional} ->(
  i168_IConsole_''!i5_detected ->
  let tmp' = i11_State_Triggered within
  let i13_state = tmp' within
    i168_IConsole_'''.modeling ->
  i168_IConsole.the_end' ->
  i168_IConsole_(i13_state)
)
 []
  IG & i168_IConsole?x:{i3_arm} -> (
  illegal -> STOP
))
[]
((i13_state == i11_State_Triggered)) & (
i168_IConsole?x:{i4_disarm} -> (
  let tmp' = i11_State_Disarming within
  let i13_state = tmp' within
    i168_IConsole_'.return ->
  i168_IConsole.the_end' ->
  i168_IConsole_(i13_state)
)
 []
  IG & i168_IConsole?x:{i3_arm} -> (
  illegal -> STOP
))
[]
((i13_state == i11_State_Disarming)) & (
i168_IConsole_'''?x:{inevitable} ->(
  i168_IConsole_''!i6_deactivated ->
  let tmp' = i11_State_Disarmed within
  let i13_state = tmp' within
    i168_IConsole_'''.modeling ->
  i168_IConsole.the_end' ->
  i168_IConsole_(i13_state)
)
 []
  IG & i168_IConsole?x:{i3_arm,i4_disarm} -> (
  illegal -> STOP
))
[]
CS & i168_IConsole_'''?x:{inevitable,optional} -> illegal -> STOP
)

REORDER' = i168_IConsole?x' -> (i168_IConsole_in'?y' -> i168_IConsole.the_end' -> i168_IConsole_out'!y' -> REORDER' [] i168_IConsole.the_end' -> REORDER')
           []
           i168_IConsole_'''?x':{inevitable,optional} -> i168_IConsole_'''?x':{modeling} -> i168_IConsole.the_end' -> REORDER'

compress(x) = let
transparent sbisim
transparent diamond
within sbisim(diamond(x))

within compress((if CS
                then i168_IConsole_(i11_State_Disarmed)
                else i168_IConsole_(i11_State_Disarmed)  [|{i168_IConsole_'''.optional}|] CHAOS({i168_IConsole_'''.optional}))
               [[x<-i168_IConsole_in'.x|x<-extensions(i168_IConsole_in')]] [|{|i168_IConsole,i168_IConsole_in',i168_IConsole_'''|}|] REORDER' [[i168_IConsole_out'.x<-x|x<-extensions(i168_IConsole_out')]] \ {|i168_IConsole_in',i168_IConsole.the_end'|})

-- end of interface.csp.scm
-- both.csp.scm
-- end of both.csp.scm
