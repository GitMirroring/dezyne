[]
CS & i334_ISensor_'''?x:{inevitable,optional} -> illegal -> STOP
)

REORDER' = i334_ISensor?x' -> (i334_ISensor_in'?y' -> i334_ISensor.the_end' -> i334_ISensor_out'!y' -> REORDER' [] i334_ISensor.the_end' -> REORDER')
           []
           i334_ISensor_'''?x':{inevitable,optional} -> i334_ISensor_'''?x':{modeling} -> i334_ISensor.the_end' -> REORDER'

compress(x) = let
transparent sbisim
transparent diamond
within sbisim(diamond(x))

within compress((if CS
                then i334_ISensor_(i177_State_Disabled)
                else i334_ISensor_(i177_State_Disabled)  [|{i334_ISensor_'''.optional}|] CHAOS({i334_ISensor_'''.optional}))
               [[x<-i334_ISensor_in'.x|x<-extensions(i334_ISensor_in')]] [|{|i334_ISensor,i334_ISensor_in',i334_ISensor_'''|}|] REORDER' [[i334_ISensor_out'.x<-x|x<-extensions(i334_ISensor_out')]] \ {|i334_ISensor_in',i334_ISensor.the_end'|})

