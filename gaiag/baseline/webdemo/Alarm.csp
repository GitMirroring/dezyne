(\ P', V' @ illegal -> STOP)(STOP,<>))


within i589_Siren__(((i487_States_i485_Off),(<>))) 


i1011_Alarm_(IIG,IG) = let

i1011_Alarm__(((i611_state,i615_sounding),(stack'))) = transition_begin -> (
((i611_state == i603_States_i599_Disarmed)) & (
i590_console?x:{i3_arm} ->
semi_(semi_((\ P',V' @ i593_sensor!i243_enable -> i593_sensor.return -> P'(V')),
assign_(\ ((i611_state,i615_sounding),(stack')) @ ((i603_States_i600_Armed,i615_sounding),(stack')))),
(\ P',V' @ i590_console.return -> P'(V')))(\ V' @ transition_end -> i1011_Alarm__(V'),((i611_state,i615_sounding),(stack')))
 []
  IIG & i590_console?x:{i4_disarm} ->
(\ P', V' @ illegal -> STOP)(STOP,<>)
 []
  IG & i593_sensor?x:{i245_triggered,i246_disabled} ->
(\ P', V' @ illegal -> STOP)(STOP,<>))
[]
((i611_state == i603_States_i600_Armed)) & (
IIG & i590_console?x:{i3_arm} ->
(\ P', V' @ illegal -> STOP)(STOP,<>)
 []
  i590_console?x:{i4_disarm} ->
semi_(semi_((\ P',V' @ i593_sensor!i244_disable -> i593_sensor.return -> P'(V')),
assign_(\ ((i611_state,i615_sounding),(stack')) @ ((i603_States_i602_Disarming,i615_sounding),(stack')))),
(\ P',V' @ i590_console.return -> P'(V')))(\ V' @ transition_end -> i1011_Alarm__(V'),((i611_state,i615_sounding),(stack')))
 []
  i593_sensor?x:{i245_triggered} ->
semi_(semi_((\ P',V' @ i590_console!i5_detected -> P'(V')),
semi_((\ P',V' @ i596_siren!i483_turnon -> i596_siren.return -> P'(V')),
semi_(assign_(\ ((i611_state,i615_sounding),(stack')) @ ((i611_state,true),(stack'))),
assign_(\ ((i611_state,i615_sounding),(stack')) @ ((i603_States_i601_Triggered,i615_sounding),(stack')))))),
skip_)(\ V' @ transition_end -> i1011_Alarm__(V'),((i611_state,i615_sounding),(stack')))
 []
  IG & i593_sensor?x:{i246_disabled} ->
(\ P', V' @ illegal -> STOP)(STOP,<>))
[]
((i611_state == i603_States_i602_Disarming)) & (
IIG & i590_console?x:{i3_arm,i4_disarm} ->
(\ P', V' @ illegal -> STOP)(STOP,<>)
 []
  IG & i593_sensor?x:{i245_triggered} ->
(\ P', V' @ illegal -> STOP)(STOP,<>))
[]
(((i611_state == i603_States_i602_Disarming) and i615_sounding)) & (
i593_sensor?x:{i246_disabled} ->
semi_(semi_((\ P',V' @ i590_console!i6_deactivated -> P'(V')),
semi_(assign_(\ ((i611_state,i615_sounding),(stack')) @ ((i611_state,false),(stack'))),
assign_(\ ((i611_state,i615_sounding),(stack')) @ ((i603_States_i599_Disarmed,i615_sounding),(stack'))))),
skip_)(\ V' @ transition_end -> i1011_Alarm__(V'),((i611_state,i615_sounding),(stack'))))
[]
(((i611_state == i603_States_i602_Disarming) and (not i615_sounding))) & (
i593_sensor?x:{i246_disabled} ->
semi_(semi_((\ P',V' @ i590_console!i6_deactivated -> P'(V')),
assign_(\ ((i611_state,i615_sounding),(stack')) @ ((i603_States_i599_Disarmed,i615_sounding),(stack')))),
skip_)(\ V' @ transition_end -> i1011_Alarm__(V'),((i611_state,i615_sounding),(stack'))))
[]
((i611_state == i603_States_i601_Triggered)) & (
IIG & i590_console?x:{i3_arm} ->
(\ P', V' @ illegal -> STOP)(STOP,<>)
 []
  i590_console?x:{i4_disarm} ->
semi_(semi_((\ P',V' @ i593_sensor!i244_disable -> i593_sensor.return -> P'(V')),
semi_(assign_(\ ((i611_state,i615_sounding),(stack')) @ ((i611_state,false),(stack'))),
assign_(\ ((i611_state,i615_sounding),(stack')) @ ((i603_States_i602_Disarming,i615_sounding),(stack'))))),
(\ P',V' @ i590_console.return -> P'(V')))(\ V' @ transition_end -> i1011_Alarm__(V'),((i611_state,i615_sounding),(stack')))
 []
  IG & i593_sensor?x:{i245_triggered,i246_disabled} ->
(\ P', V' @ illegal -> STOP)(STOP,<>))
)

within i1011_Alarm__(((i603_States_i599_Disarmed,false),(<>)))

channel extensions_over_empty_channels_is_undefined
channel IN,OUT : {i593_sensor.i245_triggered,i593_sensor.i246_disabled,extensions_over_empty_channels_is_undefined}

SINGLETHREADED = true

channel transition_begin, transition_end

channel reorder_in,reorder_out : {i590_console.return}

SEMANTICS(in',out',client',modeling') = let
Q'(s') = length(s') < card({|in'|}) & in'?x' -> Q'(s'^<x'>)
       []
       length(s') > 0 & out'!head(s') -> Q'(tail(s'))
       []
       length(s') == card({|in'|}) & in'?x' -> illegal -> STOP

R'(A') = ([] x' : A' @ x' -> R'(A'))
       []
       reorder_in?x' -> reorder_out!x' -> R'(A')

S'    = let

Idle(c') = transition_begin -> ([] x' : union(client',modeling') @ x' -> Busy(c',<>))

Busy(c',r') = c' == 0 & transition_end -> (if r' == <> then Idle(0) else reorder_out!head(r') -> Idle(0))
            []
            c' > 0 & transition_end -> transition_begin -> Busy(c',r')
            []
            c' < card({|in'|}) & ([] x' : {|in'|} @ x' -> Busy(c'+1,r'))
            []
            c' > 0 & ([] x' : {|out'|} @ x' -> Busy(c'-1,r'))
            []
            r' == <> & reorder_in?x' -> Busy(c',<x'>)
            []
            r' != <> & reorder_in?x' -> illegal -> STOP

within Idle(0)

within Q'(<>) [|{|in',out'|}|] if SINGLETHREADED then S' else R'(Union({{|in',out',transition_begin,transition_end|},client',modeling'}))

i1011_Alarm__Component(IIG) = let
compress(x) = let
transparent sbisim
transparent diamond
within sbisim(diamond(x))
Exclude = {i590_console.return,i590_console.i5_detected,i590_console.i6_deactivated,i590_console.inevitable,i590_console.optional,i593_sensor.inevitable,i593_sensor.optional}
ClientCalls = {i590_console.i3_arm,i590_console.i4_disarm}
UsedModeling = {i593_sensor.inevitable,i593_sensor.optional}
within compress((i1011_Alarm_(IIG,true) [[x<-OUT.x|x<-extensions(OUT)]] [[x<-reorder_in.x|x<-extensions(reorder_in)]]
[|diff({|OUT,transition_begin,transition_end,reorder_in,i590_console,i593_sensor,i596_siren|},Exclude)|]
(((i482_Sensor_(true) [[i482_Sensor.x<-i593_sensor.x|x<-extensions(i482_Sensor)]]
 ||| i589_Siren_(true) [[i589_Siren.x<-i596_siren.x|x<-extensions(i589_Siren)]]
) [[x<-IN.x|x<-extensions(IN)]]
[|union({|IN|},UsedModeling)|]
SEMANTICS(IN,OUT,ClientCalls,UsedModeling)))) [[reorder_out.x<-x|x<-extensions(reorder_out)]]\{transition_begin,transition_end})
assert i242_Console_(false) :[deadlock free]

assert i242_Console_(true)  \ {|i242_Console.inevitable,i242_Console.optional|} :[livelock free]

assert i482_Sensor_(false) :[deadlock free]

assert i482_Sensor_(true)  \ {|i482_Sensor.inevitable,i482_Sensor.optional|} :[livelock free]

assert i589_Siren_(false) :[deadlock free]

assert i589_Siren_(true) :[livelock free]

assert i1011_Alarm_(true,true) :[deterministic]
assert STOP [T= i1011_Alarm__Component(false) \ diff(Events,{illegal})
assert i1011_Alarm__Component(false) :[deadlock free]
assert i242_Console_(true) [[i242_Console.x<-i590_console.x|x<-extensions(i242_Console)]] \ {i590_console.inevitable,i590_console.optional} [F= i1011_Alarm__Component(true) \ diff(Events,{|illegal,i590_console|})
assert i1011_Alarm__Component(true) \ diff(Events,{|illegal,i590_console|}) :[livelock free]
