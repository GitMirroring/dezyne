-- drop_one_local: V => V
drop_one_local_((M', (L', L0'))) = (M', L')

-- send_: (c: channel, e:event) => (P,V)->Proc
send_(c',e')(P', V') = c'!e' -> P'(V')
-- skip_: () => (P,V)->Proc
skip_(P', V') = P'(V')
-- sendrecv_: (c: channel, e:event) => (P,V)->Proc
sendrecv_(c',e')(P', V') =  c'!e'  -> c'?r' -> returnvalue_(\V' @ r')(P', V')
-- callvoid_: (B': (P,V)->Proc) => (P,V)->Proc
callvoid_(B')(P', V') = B'(P', V')
-- callvoid_args_: (B': (P,V)->Proc, F': V'->V') => (P,V)->Proc
callvoid_args_(B',F')(P', V') = B'(P', V', F')
-- assign_: (F': V -> V) => (P,V) -> Proc
assign_(F')(P', V') = P'(F'(V'))
-- assign_active_: C':(P,V)->Proc, A: (V,val)->V) => (P,V)->Proc
assign_active_(C', A')(P', V') = C'(\((M', r'),L') @ P'(A'((M',L'),r')), V')
-- returnvalue_: (F: V->val) => (P,V)->Proc
returnvalue_(F')(P', (M',L')) = P'(((M',  F'((M', L'))), L'))
-- the_end_: P => V->Proc
the_end_(P', V') = transition_end -> P'(V')

-- semi_: (S1,S2: (P,V)->Proc) => (P,V) -> Proc
semi_(S1',S2')(P', V') = S1'(\V'' @ S2'(P', V''),V')
-- ifthenelse: (E': val,  S1,S2: (P,V)->Proc) => (P,V) -> Proc
ifthenelse_(E',S1',S2')(P', V') =  if E' then S1'(P', V') else S2'(P', V')
-- context_: (F': V->val, S': (P,V)->Proc) => (P,V)->Proc
-- context_(F', S')(P')((M', L')) = S'((\V2' @ P'(drop_one_local_(V2'))), (M', (L', F'((M', L')))))
-- context_(v', S')(P', (M', L')) = S'((\(M',L2') @ P'((M',L'))), (M', (L', v')))
context_(F', S')(P', (M', L')) = S'((\ (M',L2') @ P'((M',L'))), (M', (L', F'((M', L')))))
-- context_active_: (C':(P,V)->Proc, S: (P,V)->Proc) => (P,V)->Proc
context_active_(C', S')(P', V') = C'(\((M', r'),L') @ S'(\V2' @ P'(drop_one_local_(V2')), (M', (L',r'))), V')
context_func_(S')(P', (M1', L1')) = S'((\(M2',L2') @ P'((M2',L1'))), (M1', <>))
context_func_args_(v', S')(P', (M1', L1')) = S'((\(M2',L2') @ P'((M2',L1'))), (M1', (<>, v')))

datatype event_enumeration_alphabet =
i11_States_i10_Disarming | i11_States_i7_Disarmed | i11_States_i8_Armed | i11_States_i9_Triggered | i243_enable | i244_disable | i245_triggered | i246_disabled | i251_States_i247_Disabled | i251_States_i248_Enabled | i251_States_i249_Disabling | i251_States_i250_Triggered | i3_arm | i483_turnon | i484_turnoff | i487_States_i485_Off | i487_States_i486_On | i4_disarm | i5_detected | i603_States_i599_Disarmed | i603_States_i600_Armed | i603_States_i601_Triggered | i603_States_i602_Disarming | i6_deactivated | inevitable | optional | return

channel illegal

channel i590_console: {i3_arm,i4_disarm,i5_detected,i6_deactivated,inevitable,optional,return}
channel i593_sensor: {i243_enable,i244_disable,i245_triggered,i246_disabled,inevitable,optional,return}
channel i596_siren: {i483_turnon,i484_turnoff,return}

channel i242_Console: {i3_arm,i4_disarm,i5_detected,i6_deactivated,inevitable,optional,return}
channel i482_Sensor: {i243_enable,i244_disable,i245_triggered,i246_disabled,inevitable,optional,return}
channel i589_Siren: {i483_turnon,i484_turnoff,return}

  i242_Console_(IG) = let

i242_Console__(((i19_state),(stack'))) =
((i19_state == i11_States_i7_Disarmed)) & (
i242_Console?x:{i3_arm} ->
semi_(assign_(\ ((i19_state),(stack')) @ ((i11_States_i8_Armed),(stack'))),
(\ P',V' @ i242_Console.return -> P'(V')))(\ V' @ i242_Console__(V'),((i19_state),(stack')))
 []
  IG & i242_Console?x:{i4_disarm} ->
(\ P', V' @ illegal -> STOP)(STOP,<>))
[]
((i19_state == i11_States_i8_Armed)) & (
i242_Console?x:{i4_disarm} ->
semi_(assign_(\ ((i19_state),(stack')) @ ((i11_States_i10_Disarming),(stack'))),
(\ P',V' @ i242_Console.return -> P'(V')))(\ V' @ i242_Console__(V'),((i19_state),(stack')))
 []
  i242_Console?x:{optional} ->
semi_(semi_((\ P',V' @ i242_Console!i5_detected -> P'(V')),
assign_(\ ((i19_state),(stack')) @ ((i11_States_i9_Triggered),(stack')))),
skip_)(\ V' @ i242_Console__(V'),((i19_state),(stack')))
 []
  IG & i242_Console?x:{i3_arm} ->
(\ P', V' @ illegal -> STOP)(STOP,<>))
[]
((i19_state == i11_States_i9_Triggered)) & (
i242_Console?x:{i4_disarm} ->
semi_(assign_(\ ((i19_state),(stack')) @ ((i11_States_i10_Disarming),(stack'))),
(\ P',V' @ i242_Console.return -> P'(V')))(\ V' @ i242_Console__(V'),((i19_state),(stack')))
 []
  IG & i242_Console?x:{i3_arm} ->
(\ P', V' @ illegal -> STOP)(STOP,<>))
[]
((i19_state == i11_States_i10_Disarming)) & (
i242_Console?x:{inevitable} ->
semi_(semi_((\ P',V' @ i242_Console!i6_deactivated -> P'(V')),
assign_(\ ((i19_state),(stack')) @ ((i11_States_i7_Disarmed),(stack')))),
skip_)(\ V' @ i242_Console__(V'),((i19_state),(stack')))
 []
  IG & i242_Console?x:{i3_arm,i4_disarm} ->
(\ P', V' @ illegal -> STOP)(STOP,<>))


within i242_Console__(((i11_States_i7_Disarmed),(<>))) [|{i242_Console .optional}|] CHAOS({i242_Console .optional})

i482_Sensor_(IG) = let

