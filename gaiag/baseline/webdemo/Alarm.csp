nametype bool = {false, true}   
                
channel illegal
channel range_error
channel transition_begin, transition_end

COMPLETE'(A') = ([]x:A' @ x-> COMPLETE'(A')) |~| illegal->STOP

datatype event_enumeration_alphabet = i11_State_Armed | i11_State_Disarmed | i11_State_Disarming | i11_State_Triggered | i243_enable | i244_disable | i245_triggered | i246_disabled | i251_State_Disabled | i251_State_Disabling | i251_State_Enabled | i251_State_Triggered | i3_arm | i483_turnon | i484_turnoff | i487_State_Off | i487_State_On | i4_disarm | i5_detected | i603_State_Armed | i603_State_Disarmed | i603_State_Disarming | i603_State_Triggered | i6_deactivated | inevitable | modeling | optional | return | the_end'

-- end of combinators
-- both.csp.scm
-- end of both.csp.scm
-- interface.csp.scm

channel i242_IConsole: {i3_arm,i4_disarm,inevitable,optional,the_end'}
channel i242_IConsole_'': {i5_detected,i6_deactivated}
channel i242_IConsole_': {return}
channel i242_IConsole_in',i242_IConsole_out': {i242_IConsole_'.return}
channel i242_IConsole_''': {modeling}

IF_i242_IConsole_(IG,CS) = let

i242_IConsole_(i19_state) =
(((i19_state == i11_State_Disarmed)) & (
i242_IConsole?x:{i3_arm} -> (
  let tmp' = i11_State_Armed within
  let i19_state = tmp' within
    i242_IConsole_'.return ->
  i242_IConsole.the_end' ->
  i242_IConsole_(i19_state)
)
 []
  IG & i242_IConsole?x:{i4_disarm} -> (
  illegal -> STOP
))
[]
((i19_state == i11_State_Armed)) & (
i242_IConsole?x:{i4_disarm} -> (
  let tmp' = i11_State_Disarming within
  let i19_state = tmp' within
    i242_IConsole_'.return ->
  i242_IConsole.the_end' ->
  i242_IConsole_(i19_state)
)
 []
  i242_IConsole?x:{optional} ->(
  i242_IConsole_''!i5_detected ->
  let tmp' = i11_State_Triggered within
  let i19_state = tmp' within
    i242_IConsole_'''.modeling ->
  i242_IConsole.the_end' ->
  i242_IConsole_(i19_state)
)
 []
  IG & i242_IConsole?x:{i3_arm} -> (
  illegal -> STOP
))
[]
((i19_state == i11_State_Triggered)) & (
i242_IConsole?x:{i4_disarm} -> (
  let tmp' = i11_State_Disarming within
  let i19_state = tmp' within
    i242_IConsole_'.return ->
  i242_IConsole.the_end' ->
  i242_IConsole_(i19_state)
)
 []
  IG & i242_IConsole?x:{i3_arm} -> (
  illegal -> STOP
))
[]
((i19_state == i11_State_Disarming)) & (
i242_IConsole?x:{inevitable} ->(
  i242_IConsole_''!i6_deactivated ->
  let tmp' = i11_State_Disarmed within
  let i19_state = tmp' within
    i242_IConsole_'''.modeling ->
  i242_IConsole.the_end' ->
  i242_IConsole_(i19_state)
)
 []
  IG & i242_IConsole?x:{i3_arm,i4_disarm} -> (
  illegal -> STOP
))
[]
CS & i242_IConsole?x:{inevitable,optional} -> illegal -> STOP
)

REORDER' = i242_IConsole?x' -> (i242_IConsole_in'?y' -> i242_IConsole.the_end' -> i242_IConsole_out'!y' -> REORDER' [] i242_IConsole.the_end' -> REORDER')

compress(x) = let
transparent sbisim
transparent diamond
within sbisim(diamond(x))

within compress((if CS
                then i242_IConsole_(i11_State_Disarmed)
                else i242_IConsole_(i11_State_Disarmed)  [|{i242_IConsole.optional}|] CHAOS({i242_IConsole.optional}))
               [[x<-i242_IConsole_in'.x|x<-extensions(i242_IConsole_in')]] [|{|i242_IConsole,i242_IConsole_in',i242_IConsole.the_end'|}|] REORDER' [[i242_IConsole_out'.x<-x|x<-extensions(i242_IConsole_out')]] \ {|i242_IConsole_in',i242_IConsole.the_end'|})

-- end of interface.csp.scm
-- both.csp.scm
-- end of both.csp.scm
-- interface.csp.scm

