CS & i589_ISiren?x:{} -> illegal -> STOP
)

REORDER' = i589_ISiren?x' -> (i589_ISiren_in'?y' -> i589_ISiren.the_end' -> i589_ISiren_out'!y' -> REORDER' [] i589_ISiren.the_end' -> REORDER')

compress(x) = let
transparent sbisim
transparent diamond
within sbisim(diamond(x))

within compress((if CS
                then i589_ISiren_(i487_State_Off)
                else i589_ISiren_(i487_State_Off) )
               [[x<-i589_ISiren_in'.x|x<-extensions(i589_ISiren_in')]] [|{|i589_ISiren,i589_ISiren_in',i589_ISiren.the_end'|}|] REORDER' [[i589_ISiren_out'.x<-x|x<-extensions(i589_ISiren_out')]] \ {|i589_ISiren_in',i589_ISiren.the_end'|})

