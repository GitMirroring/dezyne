 []
  i333_iMotorUnit?x:{i6_SpeedUp} ->
reply_(i333_iMotorUnit_', (\ ((i25_state),(stack')) @ i5_result_NOK))(\ V' @ i333_iMotorUnit.the_end' -> i333_iMotorUnit_(V'),((i25_state),(stack')))
 []
  IG & i333_iMotorUnit?x:{i8_CancelSpeedUp,i9_MotorUnitDoneAck,i10_Reset} ->
illegal_(STOP,<>))
[]
((i25_state == i17_States_SpeedingUp)) & (
IG & i333_iMotorUnit?x:{i6_SpeedUp,i9_MotorUnitDoneAck,i10_Reset} ->
