REORDER' = i333_iMotorUnit?x' -> (i333_iMotorUnit_in'?y' -> i333_iMotorUnit.the_end' -> i333_iMotorUnit_out'!y' -> REORDER' [] i333_iMotorUnit.the_end' -> REORDER')

compress(x) = let
transparent sbisim
transparent diamond
within sbisim(diamond(x))

within compress((if CS
                 then i333_iMotorUnit_(((i17_States_Idle),(<>)))
                 else i333_iMotorUnit_(((i17_States_Idle),(<>))) [|{i333_iMotorUnit.optional}|] CHAOS({i333_iMotorUnit.optional})) [[x<-i333_iMotorUnit_in'.x|x<-extensions(i333_iMotorUnit_in')]] [|{|i333_iMotorUnit,i333_iMotorUnit_in',i333_iMotorUnit.the_end'|}|] REORDER' [[i333_iMotorUnit_out'.x<-x|x<-extensions(i333_iMotorUnit_out')]] \ {|i333_iMotorUnit_in',i333_iMotorUnit.the_end'|})

