  i333_iMotorUnit?x:{i8_CancelSpeedUp} ->
semi_(assign_(\ ((i25_state),(stack')) @ ((i17_States_Idle),(stack'))),
(\ P',V' @ i333_iMotorUnit_'.return -> P'(V')))(\ V' @ i333_iMotorUnit.the_end' -> i333_iMotorUnit_(V'),((i25_state),(stack'))))
[]
((i25_state == i17_States_WaitingForAck)) & (
IG & i333_iMotorUnit?x:{i6_SpeedUp,i10_Reset} ->
illegal_(STOP,<>)
 []
  i333_iMotorUnit?x:{i8_CancelSpeedUp} ->
(\ P',V' @ i333_iMotorUnit_'.return -> P'(V'))(\ V' @ i333_iMotorUnit.the_end' -> i333_iMotorUnit_(V'),((i25_state),(stack')))
 []
  i333_iMotorUnit?x:{i9_MotorUnitDoneAck} ->
semi_(assign_(\ ((i25_state),(stack')) @ ((i17_States_Idle),(stack'))),
(\ P',V' @ i333_iMotorUnit_'.return -> P'(V')))(\ V' @ i333_iMotorUnit.the_end' -> i333_iMotorUnit_(V'),((i25_state),(stack'))))
[]
((i25_state == i17_States_Error)) & (
i333_iMotorUnit?x:{i10_Reset} ->
semi_(assign_(\ ((i25_state),(stack')) @ ((i17_States_Idle),(stack'))),
(\ P',V' @ i333_iMotorUnit_'.return -> P'(V')))(\ V' @ i333_iMotorUnit.the_end' -> i333_iMotorUnit_(V'),((i25_state),(stack')))
 []
  IG & i333_iMotorUnit?x:{i6_SpeedUp,i8_CancelSpeedUp,i9_MotorUnitDoneAck} ->
