                 [|{|OUT',transition_begin,transition_end,reorder_in,i631_cc,i631_cc_'|}|]
                 SEMANTICS(IN',OUT',LINK',ClientCalls,UsedModeling,TheEnd) \ {|OUT',transition_begin,transition_end,reorder_in|}
                 ) [[reorder_out.x<-x|x<-extensions(reorder_out)]]
                [|{|IN',i634_mu,i634_mu_',i634_mu_'''|}|]
                (IF_i333_iMotorUnit_(true,false) [[i333_iMotorUnit.x<-i634_mu.x|x<-extensions(i634_mu)]][[i333_iMotorUnit_'.x<-i634_mu_'.x|x<-extensions(i634_mu_')]][[i333_iMotorUnit_''.x<-i634_mu_''.x|x<-extensions(i634_mu_'')]][[i333_iMotorUnit_'''.x<-i634_mu_'''.x|x<-extensions(i634_mu_''')]]
)[[x<-IN'.x|x<-extensions(IN')]])

