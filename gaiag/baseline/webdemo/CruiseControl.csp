CO_i1087_CruiseController_(IIG,IG) = let

i1087_CruiseController_(((i648_state,i658_MotorUnitOk,i662_IsFatalError),(stack'))) = transition_begin -> (
((i648_state == i640_States_Idle)) & (
i631_cc?x:{i337_SpeedTooLow} ->
semi_(assign_active_(semi_(send_(i634_mu,i6_SpeedUp),recv_(i634_mu_',i6_SpeedUp)),
\ ((i648_state,i658_MotorUnitOk,i662_IsFatalError),(stack')),r' @ ((i648_state,r',i662_IsFatalError),(stack'))),
ifthenelse_(\ ((i648_state,i658_MotorUnitOk,i662_IsFatalError),(stack')) @ ((i658_MotorUnitOk == i5_result_OK)),
semi_(assign_(\ ((i648_state,i658_MotorUnitOk,i662_IsFatalError),(stack')) @ ((i640_States_Busy,i658_MotorUnitOk,i662_IsFatalError),(stack'))),
reply_(i630_iCruiseController_', (\ ((i648_state,i658_MotorUnitOk,i662_IsFatalError),(stack')) @ i336_result_OK))),
semi_(assign_active_(semi_(send_(i634_mu,i6_SpeedUp),recv_(i634_mu_',i6_SpeedUp)),
\ ((i648_state,i658_MotorUnitOk,i662_IsFatalError),(stack')),r' @ ((i648_state,r',i662_IsFatalError),(stack'))),
ifthenelse_(\ ((i648_state,i658_MotorUnitOk,i662_IsFatalError),(stack')) @ ((i658_MotorUnitOk == i5_result_OK)),
semi_(assign_(\ ((i648_state,i658_MotorUnitOk,i662_IsFatalError),(stack')) @ ((i640_States_Busy,i658_MotorUnitOk,i662_IsFatalError),(stack'))),
reply_(i630_iCruiseController_', (\ ((i648_state,i658_MotorUnitOk,i662_IsFatalError),(stack')) @ i336_result_OK))),
reply_(i630_iCruiseController_', (\ ((i648_state,i658_MotorUnitOk,i662_IsFatalError),(stack')) @ i336_result_NOK))
))
))(\ V' @ transition_end -> i1087_CruiseController_(V'),((i648_state,i658_MotorUnitOk,i662_IsFatalError),(stack')))
 []
  i631_cc?x:{i339_BrakeHit} ->
(\ P',V' @ i630_iCruiseController_'.return -> P'(V'))(\ V' @ transition_end -> i1087_CruiseController_(V'),((i648_state,i658_MotorUnitOk,i662_IsFatalError),(stack')))
 []
  IIG & i631_cc?x:{i340_HandleError} ->
illegal_(STOP,<>)
 []
  IG & i634_mu_''?x:{i11_MotorUnitDone,i12_MotorUnitError} ->
illegal_(STOP,<>))
[]
((i648_state == i640_States_Busy)) & (
i631_cc?x:{i339_BrakeHit} ->
semi_(semi_((\ P',V' @ i634_mu!i8_CancelSpeedUp -> i634_mu_'.return -> P'(V')),
assign_(\ ((i648_state,i658_MotorUnitOk,i662_IsFatalError),(stack')) @ ((i640_States_Idle,i658_MotorUnitOk,i662_IsFatalError),(stack')))),
(\ P',V' @ i630_iCruiseController_'.return -> P'(V')))(\ V' @ transition_end -> i1087_CruiseController_(V'),((i648_state,i658_MotorUnitOk,i662_IsFatalError),(stack')))
 []
  IIG & i631_cc?x:{i337_SpeedTooLow} ->
illegal_(STOP,<>)
 []
  IIG & i631_cc?x:{i340_HandleError} ->
illegal_(STOP,<>)
 []
  i634_mu_''?x:{i11_MotorUnitDone} ->
semi_(semi_((\ P',V' @ i634_mu!i9_MotorUnitDoneAck -> i634_mu_'.return -> P'(V')),
semi_((\ P',V' @ i631_cc_''!i341_SpeedReached -> P'(V')),
assign_(\ ((i648_state,i658_MotorUnitOk,i662_IsFatalError),(stack')) @ ((i640_States_Idle,i658_MotorUnitOk,i662_IsFatalError),(stack'))))),
skip_)(\ V' @ transition_end -> i1087_CruiseController_(V'),((i648_state,i658_MotorUnitOk,i662_IsFatalError),(stack')))
 []
  i634_mu_''?x:{i12_MotorUnitError} ->
semi_(semi_((\ P',V' @ i631_cc_''!i342_ErrorReported -> P'(V')),
assign_(\ ((i648_state,i658_MotorUnitOk,i662_IsFatalError),(stack')) @ ((i640_States_Error,i658_MotorUnitOk,i662_IsFatalError),(stack')))),
skip_)(\ V' @ transition_end -> i1087_CruiseController_(V'),((i648_state,i658_MotorUnitOk,i662_IsFatalError),(stack'))))
[]
((i648_state == i640_States_Error)) & (
IIG & i631_cc?x:{i337_SpeedTooLow} ->
illegal_(STOP,<>)
 []
  IIG & i631_cc?x:{i339_BrakeHit} ->
illegal_(STOP,<>)
 []
  i631_cc?x:{i340_HandleError} ->
semi_(ifthenelse_(\ ((i648_state,i658_MotorUnitOk,i662_IsFatalError),(stack')) @ (i662_IsFatalError),
skip_,
semi_((\ P',V' @ i634_mu!i10_Reset -> i634_mu_'.return -> P'(V')),
semi_((\ P',V' @ i631_cc_''!i343_ErrorHandled -> P'(V')),
assign_(\ ((i648_state,i658_MotorUnitOk,i662_IsFatalError),(stack')) @ ((i640_States_Idle,i658_MotorUnitOk,i662_IsFatalError),(stack')))))
),
(\ P',V' @ i630_iCruiseController_'.return -> P'(V')))(\ V' @ transition_end -> i1087_CruiseController_(V'),((i648_state,i658_MotorUnitOk,i662_IsFatalError),(stack')))
 []
  IG & i634_mu_''?x:{i11_MotorUnitDone} ->
illegal_(STOP,<>)
 []
  i634_mu_''?x:{i12_MotorUnitError} ->
semi_(semi_(assign_(\ ((i648_state,i658_MotorUnitOk,i662_IsFatalError),(stack')) @ ((i648_state,i658_MotorUnitOk,true),(stack'))),
(\ P',V' @ i631_cc_''!i342_ErrorReported -> P'(V'))),
skip_)(\ V' @ transition_end -> i1087_CruiseController_(V'),((i648_state,i658_MotorUnitOk,i662_IsFatalError),(stack'))))
)

within i1087_CruiseController_(((i640_States_Idle,i5_result_NOK,false),(<>)))

channel extensions_over_empty_channels_is_undefined
channel IN',OUT' : {i634_mu_''.i11_MotorUnitDone,i634_mu_''.i12_MotorUnitError,extensions_over_empty_channels_is_undefined}

channel LINK' : {|IN',OUT'|}

SINGLETHREADED = true

channel reorder_in  : {i630_iCruiseController_'.i336_result_OK,i630_iCruiseController_'.i336_result_NOK,i630_iCruiseController_'.return}
channel reorder_out : {i631_cc_'.i336_result_OK,i631_cc_'.i336_result_NOK,i631_cc_'.return}
channel queue_full'

SEMANTICS(in',out',link',client',modeling',end') = let

Q' = let

N' = 3

external chase

Cell = link'.in'?x' -> link'.out'!x' -> Cell

Back = in'?x' -> (link'.out'!x' -> Back [] in'?x' -> queue_full' -> illegal -> STOP)

Front = Cell[[link'.out' <- out']]

within
       if (N'==1) then (Back[[link'.out' <- out']])
       else if(N'==2) then chase(Back [link'.out' <-> link'.in'] Front  \ {|link'|})
       else chase((Back [link'.out' <-> link'.in'] ([link'.out'<->link'.in'] x : <1..N'-2> @ Cell)) [link'.out' <-> link'.in'] Front \ {|link'|})

R'(A') = ([] x' : A' @ x' -> R'(A'))
       []
       reorder_in?i630_iCruiseController_'.x' -> reorder_out!i631_cc_'.x' -> R'(A')

S'    = let

N' = 3


Idle(c') = transition_begin -> ([] x' : union(client',modeling') @ x' -> FillQ(c',<>))

FillQ(c',r') = (c' <= N' & in'?x' -> FillQ(c'+1,r'))
            []
            ([] x':end' @ x' ->  (Busy(c',r') [] c' == 0 & ([] x' : union(client',modeling') @ x' -> FillQ(c',<>))))
            []
            (r' == <> & reorder_in?i630_iCruiseController_'.x' -> Busy(c',<x'>))

Busy(c',r') = (c' == 0 & transition_end -> (if r' == <> then Idle(0) else reorder_out!i631_cc_'.head(r') -> Idle(0)))
              []
              (c' > 0 & transition_end -> transition_begin -> Busy(c',r'))
              []
              (c' <= N' & in'?x' -> Busy(c'+1,r'))
              []
              (c' > 0 & out'?x' -> Busy(c'-1,r'))
              []
              (r' != <> & reorder_in?i630_iCruiseController_'.x' -> illegal -> STOP)

within Idle(0)

within Q' [|{|in',out'|}|] if SINGLETHREADED then S' else R'(Union({{|in',out',transition_begin,transition_end|},client',modeling'}))

