channel i569_client:{i302_initialize,i304_recover,i306_perform_actions}
channel i572_device_A:{i3_initialize,i5_calibrate,i7_perform_action1,i9_perform_action2}
channel i575_device_B:{i3_initialize,i5_calibrate,i7_perform_action1,i9_perform_action2}


channel i569_client_':{i310_result_t_OK,i310_result_t_NOK,return}
channel i572_device_A_':{i13_result_t_OK,i13_result_t_NOK,return}
channel i575_device_B_':{i13_result_t_OK,i13_result_t_NOK,return}


CO_i1121_Comp_(IIG,IG) = let

i1121_Comp_(((i589_s),(stack'))) = transition_begin -> (
((i589_s == i581_State_Uninitialized)) & (
i569_client?x:{i302_initialize} ->
context_active_(semi_(send_(i572_device_A,i3_initialize),recv_(i572_device_A_',i3_initialize)),
semi_(\ P',((i589_s),((stack',i612_res))) @ ifthenelse_((i612_res == i13_result_t_OK),
assign_active_(semi_(send_(i575_device_B,i3_initialize),recv_(i575_device_B_',i3_initialize)),
\ (((i589_s),((stack',i612_res)))),r' @ ((i589_s),((stack',r')))),
skip_
)(P',((i589_s),((stack',i612_res)))),
semi_(\ P',((i589_s),((stack',i612_res))) @ ifthenelse_((i612_res == i13_result_t_OK),
assign_active_(semi_(send_(i572_device_A,i5_calibrate),recv_(i572_device_A_',i5_calibrate)),
\ (((i589_s),((stack',i612_res)))),r' @ ((i589_s),((stack',r')))),
skip_
)(P',((i589_s),((stack',i612_res)))),
semi_(\ P',((i589_s),((stack',i612_res))) @ ifthenelse_((i612_res == i13_result_t_OK),
assign_active_(semi_(send_(i575_device_B,i5_calibrate),recv_(i575_device_B_',i5_calibrate)),
\ (((i589_s),((stack',i612_res)))),r' @ ((i589_s),((stack',r')))),
skip_
)(P',((i589_s),((stack',i612_res)))),
\ P',((i589_s),((stack',i612_res))) @ ifthenelse_((i612_res == i13_result_t_OK),
semi_(reply_(i568_IComp_', (\ ((i589_s),((stack',i612_res))) @ i310_result_t_OK)),
assign_(\ ((i589_s),((stack',i612_res))) @ ((i581_State_Initialized),((stack',i612_res))))),
reply_(i568_IComp_', (\ ((i589_s),((stack',i612_res))) @ i310_result_t_NOK))
)(P',((i589_s),((stack',i612_res))))))))(\ V' @ transition_end -> i1121_Comp_(V'),((i589_s),(stack')))
 []
  IIG & i569_client?x:{i304_recover,i306_perform_actions} ->
illegal_(STOP,<>))
[]
((i589_s == i581_State_Initialized)) & (
i569_client?x:{i306_perform_actions} ->
context_active_(semi_(send_(i572_device_A,i7_perform_action1),recv_(i572_device_A_',i7_perform_action1)),
semi_(\ P',((i589_s),((stack',i808_res))) @ ifthenelse_((i808_res == i13_result_t_OK),
assign_active_(semi_(send_(i575_device_B,i7_perform_action1),recv_(i575_device_B_',i7_perform_action1)),
\ (((i589_s),((stack',i808_res)))),r' @ ((i589_s),((stack',r')))),
skip_
)(P',((i589_s),((stack',i808_res)))),
semi_(\ P',((i589_s),((stack',i808_res))) @ ifthenelse_((i808_res == i13_result_t_OK),
assign_active_(semi_(send_(i572_device_A,i9_perform_action2),recv_(i572_device_A_',i9_perform_action2)),
\ (((i589_s),((stack',i808_res)))),r' @ ((i589_s),((stack',r')))),
skip_
)(P',((i589_s),((stack',i808_res)))),
semi_(\ P',((i589_s),((stack',i808_res))) @ ifthenelse_((i808_res == i13_result_t_OK),
assign_active_(semi_(send_(i575_device_B,i9_perform_action2),recv_(i575_device_B_',i9_perform_action2)),
\ (((i589_s),((stack',i808_res)))),r' @ ((i589_s),((stack',r')))),
skip_
)(P',((i589_s),((stack',i808_res)))),
\ P',((i589_s),((stack',i808_res))) @ ifthenelse_((i808_res == i13_result_t_OK),
reply_(i568_IComp_', (\ ((i589_s),((stack',i808_res))) @ i310_result_t_OK)),
semi_(reply_(i568_IComp_', (\ ((i589_s),((stack',i808_res))) @ i310_result_t_NOK)),
assign_(\ ((i589_s),((stack',i808_res))) @ ((i581_State_Error),((stack',i808_res)))))
)(P',((i589_s),((stack',i808_res))))))))(\ V' @ transition_end -> i1121_Comp_(V'),((i589_s),(stack')))
 []
  IIG & i569_client?x:{i302_initialize,i304_recover} ->
illegal_(STOP,<>))
[]
((i589_s == i581_State_Error)) & (
i569_client?x:{i304_recover} ->
context_active_(semi_(send_(i572_device_A,i5_calibrate),recv_(i572_device_A_',i5_calibrate)),
semi_(\ P',((i589_s),((stack',i1004_res))) @ ifthenelse_((i1004_res == i13_result_t_OK),
assign_active_(semi_(send_(i575_device_B,i5_calibrate),recv_(i575_device_B_',i5_calibrate)),
\ (((i589_s),((stack',i1004_res)))),r' @ ((i589_s),((stack',r')))),
skip_
)(P',((i589_s),((stack',i1004_res)))),
\ P',((i589_s),((stack',i1004_res))) @ ifthenelse_((i1004_res == i13_result_t_OK),
