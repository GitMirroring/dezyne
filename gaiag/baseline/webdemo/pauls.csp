 []
  i301_IDevice?x:{i5_calibrate} ->
reply_(i301_IDevice_', (\ ((i25_s),(stack')) @ i13_result_t_NOK))(\ V' @ i301_IDevice_(V'),((i25_s),(stack'))))
[]
((i25_s == i17_State_Initialized)) & (
i301_IDevice?x:{i3_initialize} ->
reply_(i301_IDevice_', (\ ((i25_s),(stack')) @ i13_result_t_OK))(\ V' @ i301_IDevice_(V'),((i25_s),(stack')))
 []
  IG & i301_IDevice?x:{i7_perform_action1,i9_perform_action2} ->
illegal_(STOP,<>))
[]
(((i25_s == i17_State_Calibrated) and true)) & (
i301_IDevice?x:{i7_perform_action1,i9_perform_action2} ->
reply_(i301_IDevice_', (\ ((i25_s),(stack')) @ i13_result_t_OK))(\ V' @ i301_IDevice_(V'),((i25_s),(stack')))
 []
  i301_IDevice?x:{i7_perform_action1,i9_perform_action2} ->
semi_(reply_(i301_IDevice_', (\ ((i25_s),(stack')) @ i13_result_t_NOK)),
assign_(\ ((i25_s),(stack')) @ ((i17_State_Initialized),(stack'))))(\ V' @ i301_IDevice_(V'),((i25_s),(stack'))))
[]
((i25_s == i17_State_Calibrated)) & (
