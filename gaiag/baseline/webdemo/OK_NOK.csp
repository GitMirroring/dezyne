IF_i301_IDevice_(IG,CS) = let

i301_IDevice_(((i25_s),(stack'))) =
(((i25_s == i17_State_Uninitialized) and true)) & (
i301_IDevice?x:{i6_initialize} ->
semi_(reply_(i301_IDevice_', (\ ((i25_s),(stack')) @ i5_result_t_OK)),
assign_(\ ((i25_s),(stack')) @ ((i17_State_Initialized),(stack'))))(\ V' @ i301_IDevice.the_end' -> i301_IDevice_(V'),((i25_s),(stack')))
 []
  i301_IDevice?x:{i6_initialize} ->
reply_(i301_IDevice_', (\ ((i25_s),(stack')) @ i5_result_t_NOK))(\ V' @ i301_IDevice.the_end' -> i301_IDevice_(V'),((i25_s),(stack'))))
[]
((i25_s == i17_State_Uninitialized)) & (
IG & i301_IDevice?x:{i8_calibrate,i10_perform_action1,i12_perform_action2} ->
illegal_(STOP,<>))
[]
(((i25_s == i17_State_Initialized) and true)) & (
i301_IDevice?x:{i8_calibrate} ->
semi_(reply_(i301_IDevice_', (\ ((i25_s),(stack')) @ i5_result_t_OK)),
assign_(\ ((i25_s),(stack')) @ ((i17_State_Calibrated),(stack'))))(\ V' @ i301_IDevice.the_end' -> i301_IDevice_(V'),((i25_s),(stack')))
 []
  i301_IDevice?x:{i8_calibrate} ->
reply_(i301_IDevice_', (\ ((i25_s),(stack')) @ i5_result_t_NOK))(\ V' @ i301_IDevice.the_end' -> i301_IDevice_(V'),((i25_s),(stack'))))
[]
((i25_s == i17_State_Initialized)) & (
i301_IDevice?x:{i6_initialize} ->
reply_(i301_IDevice_', (\ ((i25_s),(stack')) @ i5_result_t_OK))(\ V' @ i301_IDevice.the_end' -> i301_IDevice_(V'),((i25_s),(stack')))
 []
  IG & i301_IDevice?x:{i10_perform_action1,i12_perform_action2} ->
illegal_(STOP,<>))
[]
(((i25_s == i17_State_Calibrated) and true)) & (
i301_IDevice?x:{i10_perform_action1,i12_perform_action2} ->
reply_(i301_IDevice_', (\ ((i25_s),(stack')) @ i5_result_t_OK))(\ V' @ i301_IDevice.the_end' -> i301_IDevice_(V'),((i25_s),(stack')))
 []
  i301_IDevice?x:{i10_perform_action1,i12_perform_action2} ->
semi_(reply_(i301_IDevice_', (\ ((i25_s),(stack')) @ i5_result_t_NOK)),
assign_(\ ((i25_s),(stack')) @ ((i17_State_Initialized),(stack'))))(\ V' @ i301_IDevice.the_end' -> i301_IDevice_(V'),((i25_s),(stack'))))
[]
((i25_s == i17_State_Calibrated)) & (
i301_IDevice?x:{i8_calibrate,i6_initialize} ->
reply_(i301_IDevice_', (\ ((i25_s),(stack')) @ i5_result_t_OK))(\ V' @ i301_IDevice.the_end' -> i301_IDevice_(V'),((i25_s),(stack'))))
[]
CS & i301_IDevice?x:{} -> illegal_(STOP,<>)

REORDER' = i301_IDevice?x' -> (i301_IDevice_in'?y' -> i301_IDevice.the_end' -> i301_IDevice_out'!y' -> REORDER' [] i301_IDevice.the_end' -> REORDER')

compress(x) = let
transparent sbisim
transparent diamond
within sbisim(diamond(x))

within compress((if CS
                 then i301_IDevice_(((i17_State_Uninitialized),(<>)))
                 else i301_IDevice_(((i17_State_Uninitialized),(<>)))) [[x<-i301_IDevice_in'.x|x<-extensions(i301_IDevice_in')]] [|{|i301_IDevice,i301_IDevice_in',i301_IDevice.the_end'|}|] REORDER' [[i301_IDevice_out'.x<-x|x<-extensions(i301_IDevice_out')]] \ {|i301_IDevice_in',i301_IDevice.the_end'|})

-- end of interface.csp.scm
