CO_i1031_OK_NOK_(IIG,IG) = let

i1031_OK_NOK_(((i589_s),(stack'))) = transition_begin -> (
((i589_s == i581_State_Uninitialized)) & (
i569_client?x:{i302_initialize} ->
context_active_(semi_(send_(i572_device_A,i6_initialize),recv_(i572_device_A_',i6_initialize)),
semi_(ifthenelse_(\ ((i589_s),((stack',i612_res))) @ ((i612_res == i5_result_t_OK)),
assign_active_(semi_(send_(i575_device_B,i6_initialize),recv_(i575_device_B_',i6_initialize)),
\ ((i589_s),((stack',i612_res))),r' @ ((i589_s),((stack',r')))),
skip_
),
semi_(ifthenelse_(\ ((i589_s),((stack',i612_res))) @ ((i612_res == i5_result_t_OK)),
assign_active_(semi_(send_(i572_device_A,i8_calibrate),recv_(i572_device_A_',i8_calibrate)),
\ ((i589_s),((stack',i612_res))),r' @ ((i589_s),((stack',r')))),
skip_
),
semi_(ifthenelse_(\ ((i589_s),((stack',i612_res))) @ ((i612_res == i5_result_t_OK)),
assign_active_(semi_(send_(i575_device_B,i8_calibrate),recv_(i575_device_B_',i8_calibrate)),
\ ((i589_s),((stack',i612_res))),r' @ ((i589_s),((stack',r')))),
skip_
),
ifthenelse_(\ ((i589_s),((stack',i612_res))) @ ((i612_res == i5_result_t_OK)),
semi_(reply_(i568_IComp_', (\ ((i589_s),((stack',i612_res))) @ i310_result_t_OK)),
assign_(\ ((i589_s),((stack',i612_res))) @ ((i581_State_Initialized),((stack',i612_res))))),
reply_(i568_IComp_', (\ ((i589_s),((stack',i612_res))) @ i310_result_t_NOK))
)))))(\ V' @ transition_end -> i1031_OK_NOK_(V'),((i589_s),(stack')))
 []
  IIG & i569_client?x:{i304_recover,i306_perform_actions} ->
illegal_(STOP,<>))
[]
((i589_s == i581_State_Initialized)) & (
i569_client?x:{i306_perform_actions} ->
context_active_(semi_(send_(i572_device_A,i10_perform_action1),recv_(i572_device_A_',i10_perform_action1)),
semi_(ifthenelse_(\ ((i589_s),((stack',i772_res))) @ ((i772_res == i5_result_t_OK)),
assign_active_(semi_(send_(i575_device_B,i10_perform_action1),recv_(i575_device_B_',i10_perform_action1)),
\ ((i589_s),((stack',i772_res))),r' @ ((i589_s),((stack',r')))),
skip_
),
semi_(ifthenelse_(\ ((i589_s),((stack',i772_res))) @ ((i772_res == i5_result_t_OK)),
assign_active_(semi_(send_(i572_device_A,i12_perform_action2),recv_(i572_device_A_',i12_perform_action2)),
\ ((i589_s),((stack',i772_res))),r' @ ((i589_s),((stack',r')))),
skip_
),
semi_(ifthenelse_(\ ((i589_s),((stack',i772_res))) @ ((i772_res == i5_result_t_OK)),
assign_active_(semi_(send_(i575_device_B,i12_perform_action2),recv_(i575_device_B_',i12_perform_action2)),
\ ((i589_s),((stack',i772_res))),r' @ ((i589_s),((stack',r')))),
skip_
),
ifthenelse_(\ ((i589_s),((stack',i772_res))) @ ((i772_res == i5_result_t_OK)),
reply_(i568_IComp_', (\ ((i589_s),((stack',i772_res))) @ i310_result_t_OK)),
semi_(reply_(i568_IComp_', (\ ((i589_s),((stack',i772_res))) @ i310_result_t_NOK)),
assign_(\ ((i589_s),((stack',i772_res))) @ ((i581_State_Error),((stack',i772_res)))))
)))))(\ V' @ transition_end -> i1031_OK_NOK_(V'),((i589_s),(stack')))
 []
  IIG & i569_client?x:{i302_initialize,i304_recover} ->
illegal_(STOP,<>))
[]
((i589_s == i581_State_Error)) & (
i569_client?x:{i304_recover} ->
context_active_(semi_(send_(i572_device_A,i8_calibrate),recv_(i572_device_A_',i8_calibrate)),
semi_(ifthenelse_(\ ((i589_s),((stack',i932_res))) @ ((i932_res == i5_result_t_OK)),
assign_active_(semi_(send_(i575_device_B,i8_calibrate),recv_(i575_device_B_',i8_calibrate)),
\ ((i589_s),((stack',i932_res))),r' @ ((i589_s),((stack',r')))),
skip_
),
ifthenelse_(\ ((i589_s),((stack',i932_res))) @ ((i932_res == i5_result_t_OK)),
