  i822_sensors_''?x:{i329_DetectedMovement} ->
skip_(\ V' @ transition_end -> i1768_bareSiliconAlarm_(V'),((i838_state),(stack'))))
)

within i1768_bareSiliconAlarm_(((i830_States_NotActivated),(<>)))

channel extensions_over_empty_channels_is_undefined
channel IN,OUT : {i819_preAlarmTimer_''.i165_Timeout,i822_sensors_''.i329_DetectedMovement,extensions_over_empty_channels_is_undefined}

SINGLETHREADED = true

channel reorder_in  : {i809_IAlarmSystem_'.i509_Values_OK,i809_IAlarmSystem_'.i509_Values_Failed,i809_IAlarmSystem_'.return}
channel reorder_out : {i810_alarmSystem_'.i509_Values_OK,i810_alarmSystem_'.i509_Values_Failed,i810_alarmSystem_'.return}

SEMANTICS(in',out',client',modeling') = let
Q'(s') = length(s') < card({|in'|}) & in'?x' -> Q'(s'^<x'>)
       []
       length(s') > 0 & out'!head(s') -> Q'(tail(s'))
       []
       length(s') == card({|in'|}) & in'?x' -> illegal -> STOP

R'(A') = ([] x' : A' @ x' -> R'(A'))
       []
       reorder_in?i809_IAlarmSystem_'.x' -> reorder_out!i810_alarmSystem_'.x' -> R'(A')

S'    = let

Idle(c') = transition_begin -> ([] x' : union(client',modeling') @ x' -> Busy(c',<>))

Busy(c',r') = c' == 0 & transition_end -> (if r' == <> then Idle(0) else reorder_out!i810_alarmSystem_'.head(r') -> Idle(0))
            []
            c' > 0 & transition_end -> transition_begin -> Busy(c',r')
            []
            c' < card({|in'|}) & ([] x' : {|in'|} @ x' -> Busy(c'+1,r'))
            []
            c' > 0 & ([] x' : {|out'|} @ x' -> Busy(c'-1,r'))
            []
            r' == <> & reorder_in?i809_IAlarmSystem_'.x' -> Busy(c',<x'>)
            []
            r' != <> & reorder_in?i809_IAlarmSystem_'.x' -> illegal -> STOP

within Idle(0)

within Q'(<>) [|{|in',out'|}|] if SINGLETHREADED then S' else R'(Union({{|in',out',transition_begin,transition_end|},client',modeling'}))

