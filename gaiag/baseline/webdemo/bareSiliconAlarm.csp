UsedModeling = {i819_preAlarmTimer.inevitable,i822_sensors.optional}
within compress((CO_i1768_bareSiliconAlarm_(IIG,true) [[x<-OUT.x|x<-extensions(OUT)]] [[x<-reorder_in.x|x<-extensions(reorder_in)]]
[|diff({|OUT,transition_begin,transition_end,reorder_in,i810_alarmSystem,i810_alarmSystem_',i813_siren,i813_siren_',i816_secretCode,i816_secretCode_',i819_preAlarmTimer,i819_preAlarmTimer_',i822_sensors,i822_sensors_'|},Exclude)|]
(((IF_i109_ISiren_(true) [[i109_ISiren.x<-i813_siren.x|x<-extensions(i813_siren)]][[i109_ISiren_'.x<-i813_siren_'.x|x<-extensions(i813_siren_')]]
 ||| IF_i160_ISecretCode_(true) [[i160_ISecretCode.x<-i816_secretCode.x|x<-extensions(i816_secretCode)]][[i160_ISecretCode_'.x<-i816_secretCode_'.x|x<-extensions(i816_secretCode_')]]
 ||| IF_i326_ITimer_(true) [[i326_ITimer.x<-i819_preAlarmTimer.x|x<-extensions(i819_preAlarmTimer)]][[i326_ITimer_'.x<-i819_preAlarmTimer_'.x|x<-extensions(i819_preAlarmTimer_')]][[i326_ITimer_''.x<-i819_preAlarmTimer_''.x|x<-extensions(i819_preAlarmTimer_'')]]
 ||| IF_i506_ISensors_(true) [[i506_ISensors.x<-i822_sensors.x|x<-extensions(i822_sensors)]][[i506_ISensors_'.x<-i822_sensors_'.x|x<-extensions(i822_sensors_')]][[i506_ISensors_''.x<-i822_sensors_''.x|x<-extensions(i822_sensors_'')]]
) [[x<-IN.x|x<-extensions(IN)]]
[|union({|IN|},UsedModeling)|]
SEMANTICS(IN,OUT,ClientCalls,UsedModeling)))) [[reorder_out.x<-x|x<-extensions(reorder_out)]]\{transition_begin,transition_end})

