interface nep
{
  typedef int[0..99] Reply;

  in void e;
  out void a;

  behaviour
  {
    Reply b = 0;
    void f(Reply p)
    {
      b = p;
      a;
      f2(b);
    }
    void f2(Reply p)
    {
      b = p;
      a;
      f3(b);
    }
    void f3(Reply p)
    {
      b = p;
      a;
      //f4(b);
    }
    // void f4(Reply p)
    // {
    //   b = p;
    //   a;
    //   f5(b);
    // }
    // void f5(Reply p)
    // {
    // }
    on e:
    {
      Reply r = 1;
      f(r);
    }
  }
}
