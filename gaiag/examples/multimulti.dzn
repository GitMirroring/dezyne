// Code:

interface imulti
{
  in void left();
  out void right();
  behaviour
  {
    on left: right;
  }
}

component multi
{
  provides imulti p_left;
  provides imulti p_right;
  requires imulti r;

  behaviour
  {
    enum Direction {Left, Right};
    Direction dir = Direction.Left;
    on p_left.left(): {dir = Direction.Left; r.left();}
    on p_right.left():{dir = Direction.Right; r.left();}
    on r.right(): if(dir.Left){p_left.right();} else {p_right.right();}
  }
}
