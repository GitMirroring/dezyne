interface ivar {
  enum Bool {f,t};
  in Bool e;
  out void foo;
  behaviour {
    enum state { one, two };
    on e: reply(Bool.t);
  }
}

component var {
  provides ivar i;
  requires ivar o;
  behaviour {
    enum state { one, two };
    state m = state.one;
    on i.e(): reply(ivar.Bool.t);
  }
}
