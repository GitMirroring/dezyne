// Code:

extern Integer $int$;
enum Bool {f,t};

interface iblockdata {
  in Bool b(out Integer s);
  in void success(Integer s);
  in void fail(Integer status);
  out void a();
  behaviour {on b: a; on success: {} on fail: {}}
}

component blockdata {
  provides iblockdata p1;
  provides iblockdata p2;
  behaviour {
      blocking on p1.b(status): {
        p1.a();
      }
      on p2.success(status): {
        p1.status = status;
        p1.reply(Bool.t);
      }

      on p2.fail(status): {
        p1.reply(Bool.f);
      }

      on p1.success (x): {}
      on p1.fail (x): {}
      on p2.b (x): {p2.a(); reply(Bool.t);}
  }
}
