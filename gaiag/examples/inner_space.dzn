namespace inner {
  namespace foo {
    interface I {
      enum Bool {f,t};
      in Bool e();
      out void a();
      behaviour {
        on e: {a;reply(Bool.t);}
      }
    }
  }
  component space {
    provides foo.I inner;
    provides .foo.I foo;
    behaviour {
      foo.I.Bool inner_state = foo.I.Bool.t;
      .foo.I.Bool foo_state = .foo.I.Bool.T;
      on inner.e(): {inner.a();reply (inner_state);}
      on foo.e(): {foo.a();reply (foo_state);}
    }
  }
}

interface foo.I {
  enum Bool {F,T};
  in Bool e();
  out void a();
  behaviour {
    on e: {a;reply (Bool.T);}
  }
}

component bar.c {
  provides foo.I i;
  behaviour {
    foo.I.Bool state = foo.I.Bool.T;
    on i.e(): {i.a();reply (state);}
  }
}
