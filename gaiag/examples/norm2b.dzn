extern Integer $int$;
enum Bool {f,t};

interface inorm2b {
  in Bool b(out Integer s);
  in void success(Integer s);
  in void fail(Integer status);
  out void a();
  behaviour {on b: a; on success: {} on fail: {}}
}

component norm2b {
  provides inorm2b p1;
  provides inorm2b p2;
  behaviour {
    enum State {Idle, Running};
    State state = State.Idle;
    Integer idle_status;
    Integer running_status;
    [state.Idle] {
      blocking on p1.b(status <- idle_status): {
        p1.a();
      }
      on p2.success(status): {
        idle_status = status;
        state = State.Running;
        p1.reply(Bool.t);
      }
    }

    [state.Running] {
      on p1.b(statusx): {
        p1.a();
        statusx = running_status;
        state = State.Idle;
        reply(Bool.f);
      }
      on p2.success(status): {
        running_status = status;
      }
    }

    on p2.fail(status): {
      p1.reply(Bool.f);
    }

    on p1.success (x): {}
    on p1.fail (x): {}
    on p2.b (x): {p2.a(); reply(Bool.t);}
  }
}
