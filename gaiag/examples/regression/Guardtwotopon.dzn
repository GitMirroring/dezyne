interface IGuardtwotopon
{
  in void e();
  in void t();
  out void a();
  behaviour
    {
      bool b = false;
      [true] {
        on e: [b] { a; }
        on e: [!b] { a; }
      }
      on t: [!b] { a; }
    }
}

component Guardtwotopon
{
  provides IGuardtwotopon i;

  behaviour
    {
      bool b = false;
      [true] {
        on i.e(): [b] { i.a(); }
        on i.e(): [!b] { bool c = true; if (c) i.a(); }
      }
      on i.t(): i.a();
    }
}
