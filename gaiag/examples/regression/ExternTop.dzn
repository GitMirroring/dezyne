extern xint32 = $int32_t$;
enum Global { a, b, c };

interface IExternTop
{
  extern xint = $int$;

  in void e();

  behaviour
  {
    on e: illegal;
  }
}

component ExternTop
{
  provides IExternTop port;

  behaviour
  {
    enum X { y, z };
    IExternTop.xint i = $0$;
    IExternTop.xint j;
    //IExternTop.xint32 k;
    xint32 l;
    X x = X.y;
    Global g = Global.a;
    on port.e(): illegal;
  }
}
