interface IChoice
{
  in void e();
  out void a();

  behaviour
    { 
      enum State { Off, Idle, Busy };
      State s = State.Off;
      on e: 
        {     
          [s.Off] { s = State.Idle; a; }
          [s.Idle] { s = State.Busy; a; }
          [s.Busy] { s = State.Idle; a; }
        }
    }
}

component Choice
{
  provides IChoice c;

  behaviour
    {
      enum State { Off, Idle, Busy };
      State s = State.Off;
      
      on c.e(): 
      {     
        [s.Off] { s = State.Idle; c.a(); }
        [s.Idle] { s = State.Busy; c.a(); }
        [s.Busy] { s = State.Idle; c.a(); }
      }
    }
}

component ChoiceSystem
{
  provides IChoice c;

  system
    {
      Choice choice;

      c <=> choice.c;
    }
}

interface IRun
{
  in void run();
  behaviour{ on run:{}}
}

component Adaptor
{
  provides IRun runner;
  requires IChoice choice;

  behaviour
    {
      enum State {Idle, Active, Terminating};
      typedef int[0..2] Twice;

      State state = State.Idle;
      Twice count = 0;

      [state.Idle]
        {
          on runner.run():
          {
            [count < 2]
              {
                choice.e(); state = State.Active;
              }
            [otherwise] {}
          }
          on choice.a(): {}
        }
      [state.Active]
        {
          on runner.run(): {}
          on choice.a(): { count = count +1; choice.e(); state = State.Terminating; }
        }
      [state.Terminating]
        {
          on runner.run(): {}
          on choice.a(): { [count < 2] { choice.e(); state = State.Active; } [otherwise] state = State.Idle; }
        }
    }
}

component Main
{
  provides IRun runner;

  system
    {
      Adaptor adaptor;
      ChoiceSystem choice;

      runner <=> adaptor.runner;
      adaptor.choice <=> choice.c;
    }
}
