interface IControl
{
  in void setup;
  in void shoot;
  in void release;

  out void ready;
  out void focus;
  out void image;

  behaviour
  {
    enum State {Idle, Setup, Ready, Acquire};
    State state = State.Idle;

    [state.Idle] {
      on setup:{ state = State.Setup; }
      on shoot,
      release: illegal;
    }
    [state.Setup] {
      on setup: illegal;
      on shoot: { state = State.Acquire; }
      on release: { state = State.Idle; }
      on inevitable: { focus; }
      on inevitable: { ready; state = State.Ready; }
    }
    [state.Ready] {
      on setup: illegal;
      on release: { state = State.Idle; }
      on shoot: { state = State.Acquire; }
      on inevitable: { focus; }
    }
    [state.Acquire] {
      on setup,
      release,
      shoot: illegal;
      on inevitable: { image; state = State.Idle; }
    }
  }
}

component Camera
{
  provides IControl control;

  system
  {
    Driver driver;

    Acquisition acquisition;
    Memory memory;
    CMOS sensor;
    Hardware acquire_hardware;
    Hardware contrast_hardware;

    Optics optics;
    Lens lens;
    Shutter shutter;
    Flash flash;
    Hardware flash_hardware;

    control <=> driver.control;
    driver.acquisition <=> acquisition.port;
    driver.optics <=> optics.port;

    acquisition.memory <=> memory.port;
    acquisition.sensor <=> sensor.port;
    acquire_hardware.port <=> sensor.acquire_hardware;
    contrast_hardware.port <=> sensor.contrast_hardware;


    optics.lens <=> lens.port;
    optics.shutter <=> shutter.port;
    optics.flash <=> flash.port;
    flash_hardware.port <=> flash.hardware;
  }
}

component Driver
{
  provides IControl control;
  requires IAcquisition acquisition;
  requires IOptics optics;

  behaviour
  {
    enum State {Idle, Setup, Ready, Acquire};
    enum Contrast {Down, Up, Max};
    enum Zoom {In, Out};

    State state = State.Idle;
    Contrast contrast = Contrast.Down;
    Zoom zoom = Zoom.In;
    bool ready = false;

    [state.Idle]
    {
      on control.setup: {optics.prepare; acquisition.contrast_gradient; state = State.Setup;}
      on control.shoot,
      control.release,
      acquisition.image,
      acquisition.higher_contrast,
      acquisition.lower_contrast,
      optics.ready: illegal;
    }
    [state.Setup]
    {
      on acquisition.lower_contrast:
      {
        [contrast.Up]
        {
          if(zoom.In) {optics.zoom_out; zoom = Zoom.Out;}
          else        {optics.zoom_in; zoom = Zoom.In;}

          contrast = Contrast.Max;

          if(ready)   {contrast = Contrast.Down; control.ready; ready = false; state = State.Ready;}
          else        {control.focus;}
        }
        [contrast.Down]
        {
          if(zoom.In) {optics.zoom_out; zoom = Zoom.Out;}
          else        {optics.zoom_in; zoom = Zoom.In;}
          contrast = Contrast.Down;
          control.focus;
        }
        [otherwise]   {control.focus;}
      }
      on acquisition.higher_contrast:
      {
        if(zoom.In) {optics.zoom_in;}
        else        {optics.zoom_out;}
        contrast = Contrast.Up;
        control.focus;
      }
      on optics.ready:
      {
        if(contrast.Max) {control.ready; ready = false; state = State.Ready;}
        else             {ready = true;}
      }
      on control.release: {acquisition.cancel; optics.cancel; state = State.Idle;}
      on control.shoot: {acquisition.acquire; optics.capture; state = State.Acquire;}
      on control.setup,
      acquisition.image: illegal;
    }
    [state.Ready]
    {
      on control.shoot: {acquisition.acquire; optics.capture; state = State.Acquire;}
      on control.release: {acquisition.cancel; optics.cancel; state = State.Idle;}
      on control.setup,
      acquisition.image: illegal;
      on acquisition.lower_contrast,
      acquisition.higher_contrast,
      optics.ready: {control.focus;}
    }
    [state.Acquire]
    {
      on acquisition.image: {control.image; state = State.Idle;}
      on control.setup,
      control.shoot,
      control.release,
      acquisition.higher_contrast,
      acquisition.lower_contrast: illegal;
      on optics.ready: {}
    }
  }
}

interface IAcquisition
{
  in void contrast_gradient;
  in void cancel;
  in void acquire;
  out void image;
  out void higher_contrast;
  out void lower_contrast;

  behaviour
  {
    enum State {Idle, Contrast, Acquire};
    State state = State.Idle;

    on contrast_gradient:
    {
      [state.Idle] {state = State.Contrast;}
      [otherwise]  illegal;
    }
    on acquire:
    {
      [state.Contrast] {state = State.Acquire;}
      [otherwise]      illegal;
    }
    on cancel:
    {
      [state.Idle] illegal;
      [otherwise]  {state = State.Idle;}
    }
    on inevitable:
    {
      [state.Contrast] lower_contrast;
      [state.Contrast] higher_contrast;
      [state.Acquire]  {image; state = State.Idle;}
    }
  }
}

component Acquisition
{
  provides IAcquisition port;
  requires IMemory memory;
  requires ISensor sensor;
  behaviour
  {
    enum State {Idle, Contrast, Acquire};
    State state = State.Idle;

    [state.Idle]
    {
      on port.contrast_gradient:
      {
        sensor.enable;
        state = State.Contrast;
      }
      on port.acquire,
      port.cancel,
      sensor.higher_contrast,
      sensor.lower_contrast,
      sensor.image: illegal;
    }
    [state.Contrast]
    {
      on port.contrast_gradient: illegal;
      on port.acquire: {sensor.acquire; state = State.Acquire;}
      on port.cancel: {sensor.cancel; state = State.Idle;}
      on sensor.higher_contrast:
      {
        port.higher_contrast;
      }
      on sensor.lower_contrast:
      {
        port.lower_contrast;
      }
      on sensor.image: illegal;
    }
    [state.Acquire]
    {
      on port.cancel: {sensor.cancel; state = State.Idle;}
      on sensor.image:{memory.store; port.image; state = State.Idle;}
      on port.contrast_gradient,
      port.acquire,
      sensor.higher_contrast,
      sensor.lower_contrast: illegal;
    }
  }
}

interface IOptics
{
  in void prepare;
  in void capture;
  in void cancel;
  out void ready;

  in void zoom_in;
  in void zoom_out;

  behaviour
  {
    enum State {Idle, Prepare, Ready};
    State state = State.Idle;
    on prepare:
    {
      [state.Idle] state = State.Prepare;
      [otherwise]  illegal;
    }
    on cancel:
    {
      state = State.Idle;
    }
    on inevitable: [state.Prepare] {ready; state = State.Ready;}
    on capture:
    {
      [state.Idle] illegal;
      [otherwise]  state = State.Idle;
    }
    on zoom_in:  {}
    on zoom_out: {}
  }
}

component Optics
{
  provides IOptics port;

  requires ILens lens;
  requires IShutter shutter;
  requires IFlash flash;

  behaviour
  {
    enum State {Idle, Prepare, Ready};
    State state = State.Idle;
    bool ready = false;
    on port.prepare:
    {
      [state.Idle] {state = State.Prepare; flash.prepare;}
      [otherwise]  illegal;
    }
    on port.cancel:
    {
      flash.cancel;
      state = State.Idle;
    }
    on flash.ready:
    {
      if(state.Prepare) {state = State.Ready; port.ready;}
    }
    on port.capture:
    {
      [state.Idle]    illegal;
      [state.Prepare] {state = State.Idle; flash.cancel; shutter.expose;}
      [state.Ready]   {state = State.Idle; flash.flash;  shutter.expose; }
    }
    on port.zoom_in: lens.zoom_in;
    on port.zoom_out: lens.zoom_out;
  }
}
interface IMemory
{
  in void store;
  behaviour
  {
    on store:{}
  }
}

interface ISensor
{
  in void enable;
  in void acquire;
  in void cancel;
  in void lock;
  out void higher_contrast;
  out void lower_contrast;
  out void image;

  behaviour
  {
    enum State {Idle, Ready, Acquire};
    State state = State.Idle;
    bool contrast = true;

    [state.Idle]
    {
      on enable: {contrast = true; state = State.Ready;}
      on acquire,
      cancel,
      lock: illegal;
    }
    [state.Ready]
    {
      on enable: illegal;
      on acquire: {state = State.Acquire;}
      on cancel: {state = State.Idle;}
      on lock: {contrast = false;}
      [contrast]
      {
        on inevitable: {higher_contrast;}
        on inevitable: {lower_contrast;}
      }
    }
    [state.Acquire]
    {
      on enable,
      acquire,
      lock: illegal;
      on cancel: {state = State.Idle;}
      on inevitable: {image; state = State.Idle;}
    }
  }
}

interface IFlash
{
  in void prepare;
  in void flash;
  in void cancel;
  out void ready;

  behaviour
  {
    enum State {Idle, Prepare, Ready};
    State state = State.Idle;
    on prepare:
    {
      [state.Idle] {state = State.Prepare;}
      [otherwise]  illegal;
    }
    on cancel: state = State.Idle;
    on inevitable:
    {
      [state.Prepare] {ready; state = State.Ready;}
    }
    on flash:
    {
      [state.Ready] {state = State.Idle;}
      [otherwise]   illegal;
    }
  }
}

interface ILens
{
  in void zoom_in;
  in void zoom_out;
  behaviour
  {
    on zoom_in:{}
    on zoom_out:{}
  }
}

interface IShutter
{
  in void expose;
  behaviour
  {
    on expose: {}
  }
}

component Memory
{
  provides IMemory port;
  behaviour
  {
    on port.store: {}
  }
}

component CMOS
{
  provides ISensor port;
  requires IHardware contrast_hardware;
  requires IHardware acquire_hardware;

  behaviour
  {
    enum State {Idle, Ready, Acquire};
    enum Contrast {Left, Max, Right};
    State state = State.Idle;
    Contrast contrast = Contrast.Left;

    void reset() {
       contrast = Contrast.Left;
       contrast_hardware.cancel;
       acquire_hardware.cancel;
       state = State.Idle;
    }

    [state.Idle]
    {
      on port.enable: {state = State.Ready; contrast_hardware.kick;}
      on port.acquire,
      port.cancel,
      port.lock: illegal;
      on contrast_hardware.interrupt,
      acquire_hardware.interrupt: illegal;
    }
    [state.Ready]
    {
      on port.enable: illegal;
      on port.acquire: {state = State.Acquire; contrast_hardware.cancel; acquire_hardware.kick;}
      on port.cancel: { reset(); }
      on port.lock: {contrast_hardware.cancel;}
      on contrast_hardware.interrupt:
      {
        if (contrast.Left) {
          contrast = Contrast.Max; port.higher_contrast;
        }
        else if (contrast.Max) {
          contrast = Contrast.Right; port.lower_contrast;
        }
        else if (contrast.Right) {
          contrast = Contrast.Max; port.higher_contrast;
        }
        contrast_hardware.kick;
      }
      on acquire_hardware.interrupt: illegal;
    }
    [state.Acquire]
    {
      on port.enable,
      port.acquire,
      port.lock: illegal;
      on port.cancel: { reset(); }
      on acquire_hardware.interrupt: {port.image; reset();}
      on contrast_hardware.interrupt: illegal;
    }
  }
}

component Lens
{
  provides ILens port;
  behaviour
  {
    on port.zoom_in:{}
    on port.zoom_out:{}
  }
}

component Shutter
{
  provides IShutter port;
  behaviour
  {
    on port.expose:{}
  }
}

component Flash
{
  provides IFlash port;
  requires IHardware hardware;
  behaviour
  {
    enum State {Idle, Prepare, Ready};
    State state = State.Idle;
    bool pending = false;
    on port.prepare:
    {
      [state.Idle]
      {
        [pending]   {state = State.Prepare;}
        [otherwise] {state = State.Prepare; hardware.kick; pending = true;}
      }
      [otherwise] illegal;
    }
    on hardware.interrupt:
    {
      [state.Prepare] {pending = false; port.ready; state = State.Ready;}
      [otherwise]     illegal;
    }
    on port.flash:
    {
      [state.Ready] {state = State.Idle;}
      [otherwise]   illegal;
    }
    on port.cancel: {pending = false; hardware.cancel; state = State.Idle;}
  }
}

interface IHardware
{
  in void kick;
  in void cancel;
  out void interrupt;

  behaviour
  {
    bool idle = true;
    [idle]  on kick: idle = false;
    [!idle] {
        on kick: illegal;
        on inevitable: {interrupt; idle = true;}
    }
    on cancel: idle = true;
  }
}

component Hardware
{
  provides IHardware port;
}
