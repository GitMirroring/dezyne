##ifndef ENUM_TO_STRING_#((c++:scope-join #f '_) scope)_#name
##define ENUM_TO_STRING_#((c++:scope-join #f '_) scope)_#name  1
inline std::string to_string(#((c++:scope-join #f) scope)::#name ::type v)
{
  switch(v)
  {
  #(->string (map (lambda (field) (->string (list "case " ((c++:scope-join #f) scope) "::" name "::" field ": return \"" name "_" field "\";\n"))) fields))
  }
  return "";
}
##endif // ENUM_TO_STRING_#((c++:scope-join #f '_) scope)_#name
