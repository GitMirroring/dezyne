inline const #scope #(if scope "::")#name ::type to_#scope #(if scope '_)#name(std::string s)
{
  static std::map<std::string, #scope #(if scope "::")#name ::type> m = {
        #(->string (map (lambda (field) (->string (list "{" "\"" name "_" field "\"," scope (if scope "::") name "::" field "},\n"))) fields)) };
  if (m.find(s) != m.end())
  {
    return m[s];
  }
  return (#scope #(if scope "::")#name ::type)-1;
}
