         (diff-noisy-equal?
          (csp-transform*
           i-ast
           expression-via)
          "context_(\\ ((s,b,c),(stack')) @ false,
assign_(\\ ((s,b,c),((stack',t))) @ ((s,b,c),((stack',(s == S_S1))))))"))


