(define doc
"
  on i.e:
    {
      b = ! b;
      bool c = g (b);
      bool d = g (c);

      {
        bool cc = g (c);
        bool dd = g (d);

        if(c)
        {
          f;
        }
      }
   }

")

;; '

(define callvalued-on-deep
  '(on (triggers (trigger i e (arguments)))
       (compound
        (assign b (expression (! (var b))))
        (variable c (type bool) (call g (arguments (expression (var b))) #f))
        (variable d (type bool) (call g (arguments (expression (var c))) #f))
        (compound
         (variable cc (type bool) (call g (arguments (expression (var c))) #f))
         (variable dd (type bool) (call g (arguments (expression (var d))) #f))
         (if (expression (var dd))
             (compound (action (trigger i f (arguments)))))))))

(define csp-callvalued-on-deep
  '(on
  (triggers (trigger i e (arguments)))
  (compound
    (compound
      (assign
        b
        (expression (! (var b))))
      (variable
        c
        (type bool)
        (call g (arguments (expression (var b))) #f))
      (variable
        d
        (type bool)
        (call g (arguments (expression (var c))) #f))
      (compound
        (variable
          cc
          (type bool)
          (call g (arguments (expression (var c))) #f))
        (variable
          dd
          (type bool)
          (call g (arguments (expression (var d))) #f))
        (if
          (expression (var dd))
          (compound (action (trigger i f (arguments))))
          #f)))
    (voidreply))))

(pass-if "ast-transform-callvalued-deep"
         (csp-pretty-noisy-equal?

          ;; from:
          (ast-transform* callvalued-c-ast callvalued-on-deep)

          ;; via:
          csp-callvalued-on-deep))

