if not ((0 <= c and c <= 2)) then range_error -> illegal -> STOP else
i!f ->
let tmp' = S_S2 within
let s = tmp' within
i_'.return ->
i.the_end' ->
i_(s,b,c)
)
else
(if c then
let tmp' = false within
let b = tmp' within
i_''!h ->
let tmp' = S_S2 within
let s = tmp' within
i_'.return ->
i.the_end' ->
i_(s,b,c)
else
let tmp' = true within
let b = tmp' within
i_''!g ->
let tmp' = S_S2 within
let s = tmp' within
i_'.return ->
i.the_end' ->
i_(s,b,c)
)
)
else
(if b then
(if c then
i_''!g ->
let tmp' = false within
let c = tmp' within
if not ((0 <= c and c <= 2)) then range_error -> illegal -> STOP else
i!f ->
let tmp' = S_S2 within
let s = tmp' within
i_'.return ->
i.the_end' ->
i_(s,b,c)
else
let tmp' = false within
let c = tmp' within
if not ((0 <= c and c <= 2)) then range_error -> illegal -> STOP else
i!f ->
let tmp' = S_S2 within
let s = tmp' within
i_'.return ->
i.the_end' ->
i_(s,b,c)
)
else
(if c then
let tmp' = false within
let b = tmp' within
i_''!h ->
let tmp' = S_S2 within
let s = tmp' within
i_'.return ->
i.the_end' ->
i_(s,b,c)
else
let tmp' = true within
let b = tmp' within
i_''!g ->
let tmp' = S_S2 within
let s = tmp' within
i_'.return ->
i.the_end' ->
i_(s,b,c)
)
)
)
)"))


(define c-ast
  (append i-ast
  (cdr
  (dzn->ast
   #{
component c
{
  provides i j;
  requires i k;

  behaviour B
  {
    enum S { S1, S2 };
    S s = S.S1;
    bool b = false;
    bool c = true;
    i.xint xi = $0$;
    on j.e():
    {
    }
  }
}
     #}))))

