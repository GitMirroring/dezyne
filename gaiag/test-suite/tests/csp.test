;; -*-scheme-*-

(read-set! keywords 'prefix)

(define-module (test-handler)
  :use-module (test-suite lib)
  :use-module (test-suite misc)

  :use-module (gaiag ast:)
  :use-module (gaiag csp)
  :use-module (gaiag resolve)
  :use-module (gaiag gom))

(pass-if "csp-first-dummy-test"
         #t)

(define i-ast '(interface i
                 (types)
                 (events)
                 (behaviour
                  B
                  (types (enum S (S1 S2)))
                  (variables
                   (variable (type S) s (action (trigger S S1)))
                   (variable (type bool) b (expression false))
                   (variable (type bool) c (expression true)))
                  (functions (function toggle (signature (type void)) #f (compound)))
                  (compound))))

(define ast-return-ast
  '(compound
    (on (e)
        (compound))))

(define csp-return-ast
  '(on (e)
       (eventreturn)
       (the-end (s b c))))

(pass-if "ast-transform-return-return"
         (gom-pretty-noisy-equal?

          ;; from:
          (ast-transform-return* i-ast ast-return-ast)

          ;; via:
          '(on (e)
               (compound
                (eventreturn))
               (the-end (s b c)))))

(pass-if "ast-transform-return"
         (gom-pretty-noisy-equal?

          ;; from:
          (ast-transform* i-ast ast-return-ast)

          ;; via:
          csp-return-ast))


(pass-if "csp-transform-return"
         (diff-noisy-equal?

          ;; from/via:
          (csp-transform* i-ast csp-return-ast)

          ;; to:
          "i?x:{e} ->
(\\ P',V' @ i.return -> P'(V'))(\\ V' @ i_B_(V'),((s,b,c),(stack')))")) ;; FIXME: NO skip_?


(pass-if "ast-transform-return-reply"
         (gom-pretty-noisy-equal?

          ;; from:
          (ast-transform-return*
           i-ast
           '(compound
             (on (e)
                 (reply (expression (literal #f Status Yes))))))

          ;; via:
          '(on (e)
               (compound
                (reply (expression (literal #f Status Yes))))
               (the-end (s b c)))))

(pass-if "csp-transform-return-reply"
         (diff-noisy-equal?

          ;; from:
          (csp-transform*

           i-ast

           '(on (e)
               (semi
                (reply (expression (literal #f Status Yes)))
                (return))
               (the-end (s b c))))

          ;; via:
          "i?x:{e} ->
semi_((\\ P',V' @ i.Status_Yes -> P'(V')),
skip_)(\\ V' @ i_B_(V'),((s,b,c),(stack')))"))



(pass-if "ast-transform-reply"
         (gom-pretty-noisy-equal?

          ;; from:
