(define ast-transform-assign
  '(assign (ctx ((s b c)))
           (expression (ctx ((s b true))))))

(pass-if "ast-transform-assign-bool"
         (gom-pretty-noisy-equal?

          ;; from:
          (ast-transform* i-ast '(assign c (expression true)))

          ;; via:
          ast-transform-assign))

(pass-if "csp-transform-assign-bool"
         (gom-noisy-equal?

          ;; via/from:
          (csp-transform* i-ast ast-transform-assign)

          ;; to:
          "assign_(\\ ((s,b,c),(stack')) @ ((s,b,true),(stack')))"))

;; \\)

(define ast-transform-assign-2
  '(context
    ((ctx ((s b c))) la (expression true))
    (context
     ((ctx ((s b c) la)) lb (expression false))
     (assign (ctx ((s b c) la lb))
             (expression (ctx ((s b c) true lb)))))))

(pass-if "ast-transform-assign-2-bool"
         (gom-pretty-noisy-equal?

          ;; from:
          (ast-transform*

           i-ast

           '(compound
             (variable (type bool) la (expression true))
             (variable (type bool) lb (expression false))
             (assign la (expression true))))

          ;; via:
          ast-transform-assign-2))

(pass-if "csp-transform-assign-2-bool"
         (diff-noisy-equal?

          ;; via/from:
          (csp-transform* i-ast ast-transform-assign-2)

          ;; to:
          "context_(\\ ((s,b,c),(stack')) @ true,
context_(\\ ((s,b,c),((stack',la))) @ false,
assign_(\\ ((s,b,c),(((stack',la),lb))) @ ((s,b,c),(((stack',true),lb))))))"))

;; \\) \\) \\)

(define ast-transform-assign-enum-via
  '(assign
    (ctx ((s b c)))
    (expression (ctx (((literal #f S S2) b c))))))

(pass-if "ast-transform-assign-enum"
