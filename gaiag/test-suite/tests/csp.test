                 (compound
                  (call toggle)))))

          ;; via:
          csp-function-call-ast))

(pass-if "csp-transform-function-call"
         (diff-noisy-equal?

          ;; from:
          (csp-transform* i-ast csp-function-call-ast)

          ;; via:
          "i?x:{e} ->
