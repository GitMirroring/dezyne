          ;; to:
          "i?x:{e} ->
semi_(reply_(i_', (\\ ((s,b,c),(stack')) @ Status_Yes)),
(\\ P',V' @ i_'.return -> P'(V')))(\\ V' @ i.the_end' -> i_B(V'),((s,b,c),(stack')))"))

;; \\)

(pass-if "ast-transform-action"
