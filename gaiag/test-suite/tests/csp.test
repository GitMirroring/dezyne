(define ast-transform-semi
  '(semi (csp-if (context (s b c))
             (expression b)
             ()
             ())
         (csp-assign (context (unused)) b (context (s b c)) (context (s true c)))))

(pass-if "ast-transform-semi"
         (csp-pretty-noisy-equal?

          ;; from:
          (ast-transform*

           i-ast

           '(compound
             (if (expression b)
                 (compound))
             (assign b (expression true))))

          ;; via:
          ast-transform-semi))

(pass-if "csp-transform-semi"
         (diff-noisy-equal?

          ;; via/from:
          (csp-transform* i-ast ast-transform-semi)

          ;; to:
          "semi_(ifthenelse_(\\ ((s,b,c),(stack')) @ (b),
skip_,
skip_
),
assign_(\\ ((s,b,c),(stack')) @ ((s,true,c),(stack'))))"))

;; \\)

(define csp-transform-via
  '(csp-on (context (s b c)) (e)
    (semi (semi (csp-if (context (s b c))
                  (expression (or c b))
                  (semi (action (trigger #f f)) (action (trigger #f g)))
                  ())
                (semi (csp-if (context (s b c))
                        (expression b)
                        (semi (csp-if (context (s b c))
                                  (expression c)
                                  (action (trigger #f g))
                                  ())
                              (semi (csp-assign (context (unused)) c
                                      (context (s b c))
                                      (context (s b false)))
                                    (action (trigger #f f))))
                        (csp-if (context (s b c))
                          (expression c)
                          (semi (csp-assign (context (unused)) b (context (s b c))
                                            (context (s false c)))
                                (action (trigger #f h)))
                          (semi (csp-assign (context (unused)) b (context (s b c))
                                            (context (s true c)))
                                (action (trigger #f g)))))
                      (csp-assign (context (unused)) s
                        (context (s b c))
                        (context ((literal #f S S2) b c)))))
          (voidreply))))

(pass-if "ast-transform"
         (csp-pretty-noisy-equal?

          ;; from:
          (ast-transform*

           i-ast

           '(compound
             (on (e)
                 (compound

                  (if (expression (or c b))
                      (compound (action (trigger #f f))
                                (action (trigger #f g))))
                  (if (expression b)
                      (compound
                       (if (expression c)
                           (compound (action (trigger #f g))))
                       (assign c (expression false))
                       (action (trigger #f f)))
                      (compound
                       (if (expression c)
                           (compound
                            (assign b (expression false))
                            (action (trigger #f h)))
                           (compound
                            (assign b (expression true))
                            (action (trigger #f g))))))
                  (assign s (expression (literal #f S S2)))))))

          ;; via:
          csp-transform-via))

(pass-if "csp-transform"
         (diff-noisy-equal?

          ;; from/via:
          (csp-transform* i-ast csp-transform-via)

          ;; to:
          "i?x:{e} ->
semi_(semi_(ifthenelse_(\\ ((s,b,c),(stack')) @ ((c or b)),
semi_((\\ P',V' @ i!f -> P'(V')),
(\\ P',V' @ i_''!g -> P'(V'))),
skip_
),
semi_(ifthenelse_(\\ ((s,b,c),(stack')) @ (b),
semi_(ifthenelse_(\\ ((s,b,c),(stack')) @ (c),
(\\ P',V' @ i_''!g -> P'(V')),
skip_
),
semi_(assign_int_((\\ ((s,b,c),(stack')) @ ((s,b,false),(stack'))),(\\ ((s,b,c),(stack')) @ 0<=c and c<=2)),
(\\ P',V' @ i!f -> P'(V')))),
ifthenelse_(\\ ((s,b,c),(stack')) @ (c),
semi_(assign_(\\ ((s,b,c),(stack')) @ ((s,false,c),(stack'))),
(\\ P',V' @ i_''!h -> P'(V'))),
semi_(assign_(\\ ((s,b,c),(stack')) @ ((s,true,c),(stack'))),
(\\ P',V' @ i_''!g -> P'(V')))
)
),
assign_(\\ ((s,b,c),(stack')) @ ((S_S2,b,c),(stack'))))),
(\\ P',V' @ i_'.return -> P'(V')))(\\ V' @ i.the_end' -> i_B(V'),((s,b,c),(stack')))"))


(define c-ast (append
               i-ast
               '((component
                  c
                  (ports (provides i j)
                         (requires i k))
                  (behaviour
                   B
                   (types (enum S (S1 S2)))
                   (variables
                    (variable s (type S) (expression (literal #f S S1)))
                    (variable b (type bool) (expression false))
                    (variable c (type bool) (expression true))
                    (variable xi (type xint i) (data 0)))
                   (compound
                    (on ((trigger j e))
                        (compound))))))))

(define c-csp-transform-return-via
  '(csp-on (context (s b c)) ((trigger j e))
       (voidreply)))

(pass-if "c-ast-transform-return"
         (csp-pretty-noisy-equal?

          ;; from:
          (ast-transform*

           c-ast

           '(compound
             (on ((trigger j e))
                 (compound))))

          ;; via:
          c-csp-transform-return-via))

(pass-if "c-csp-transform-return"
         (csp-noisy-equal?

          ;; via/from:
          (csp-transform* c-ast c-csp-transform-return-via)

          ;; to:
          "j?x:{e} ->
(\\ P',V' @ i_'.return -> P'(V'))(\\ V' @ transition_end -> c_B(V'),((s,b,c),(stack')))"))


