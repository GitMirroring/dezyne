           i-ast
           csp-transform-return-reply)

          ;; to
          "i?x:{f} -> (
if not member(Status_Yes,extensions(i_')) then type_error -> illegal -> STOP else
i_'!Status_Yes ->
i.the_end' ->
i_(s,b,c)
)"))

