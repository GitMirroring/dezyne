(pass-if "csp-transform-OM-PARSER-variable-action"
         (diff-noisy-equal?

          ;; via/from:
          (csp-transform* reply-ast csp-transform-OM-PARSER-variable-action-via)

          ;; to:
          "i?x:{e} ->
context_active_(semi_(send_(u,what),recv_(u_',what)),
(\\ P',V' @ I_'.return -> P'(V')))(\\ V' @ transition_end -> Reply_(V'),((dummy),(stack')))"))

;; OM-PARSER parser test
(define csp-transform-OM-PARSER-assign-action-via
  '(csp-on (context (dummy)) ((trigger i e))
    (semi (csp-assign
           (context (dummy)) r' (action (trigger u what))
           (context (dummy)))
          (voidreply))))

(pass-if "ast-transform-OM-PARSER-assign-action"
         (csp-pretty-noisy-equal?

          ;; from:
          (ast-transform* reply-ast
                         '(on
                           ((trigger i e))
                           (compound
                            (assign res (action (trigger u what))))))

          ;; via:
          csp-transform-OM-PARSER-assign-action-via))

(pass-if "csp-transform-OM-PARSER-assign-action"
         (diff-noisy-equal?

          ;; via/from:
          (csp-transform* reply-ast csp-transform-OM-PARSER-assign-action-via)

          ;; to:
          "i?x:{e} ->
semi_(assign_active_(semi_(send_(u,what),recv_(u_',what)),
\\ (((dummy),(stack'))),r' @ ((dummy),(stack'))),
(\\ P',V' @ I_'.return -> P'(V')))(\\ V' @ transition_end -> Reply_(V'),((dummy),(stack')))"))

;; '

(define component (gom:component (ast->gom c-ast)))

(pass-if "provides?"
  (csp-pretty-noisy-equal?
   ((provides? component)
    (ast->gom '(trigger j e)))
   #t))

(pass-if "not provides?"
  (csp-pretty-noisy-equal?
   ((provides? component)
    (ast->gom '(trigger k e)))
   #f))

(pass-if "requires?"
  (csp-pretty-noisy-equal?
   ((requires? component)
    (ast->gom '(trigger k e)))
   #t))

(pass-if "not requires?"
  (csp-pretty-noisy-equal?
   ((requires? component)
    (ast->gom '(trigger j e)))
   #f))

(pass-if "statement-on-p/r"
  (csp-pretty-noisy-equal?
   ((statement-on-p/r identity)
    (ast->gom
     '(on (arm) (compound))))
   '(on (arm) (compound))))

(pass-if "statement-on-p/r-filter"
  (csp-pretty-noisy-equal?
   ((statement-on-p/r (provides? component))
    (ast->gom
     '(on (arm) (compound))))
   #f))

(pass-if "statement-on-p/r-filter"
  (csp-pretty-noisy-equal?
   ((statement-on-p/r (provides? component))
    (ast->gom
     '(on ((j e)) (compound))))
   '(on ((j e)) (compound))))

(define member-i-ast
  '((interface i
      (types)
      (events)
      (behaviour
       B
       (compound)))))

(define member-c-ast
  (append
   member-i-ast
   '((component c
               (ports)
               (behaviour
                B
                (compound))))))

(pass-if "no-members"
         (diff-noisy-equal?
          (csp-transform* member-i-ast '(csp-on (context) (e) (voidreply)))
          "i?x:{e} ->
(\\ P',V' @ i_'.return -> P'(V'))(\\ V' @ i_B(V'),((<>),(stack')))"))

(pass-if "unbehaved"
         (diff-noisy-equal?
          (behaviour->csp (gom:component (ast->gom member-c-ast)) "<empty>")
          "<empty>"))

(define guard-i-ast
  '((interface i
      (types)
      (events)
      (behaviour
       B
       (compound (guard (expression true) (compound)))))))

(pass-if "behaviour-guard-true"
  (diff-noisy-equal?
   (behaviour->csp (gom:interface (ast->gom guard-i-ast)) "boo")
   "(true) & (
)"))

(pass-if "enum-type"
  (noisy-equal?
   (enum-type (gom:interface (ast->gom i-ast)) 's)
   'S))

(pass-if "enum-type"
  (noisy-equal?
   (enum-type (gom:interface (ast->gom i-ast)) 'q)
   #f))


(define (2gom ast)
  ((compose ast->gom ast:resolve) ast))

(define expression-via
  '(csp-variable (context (s b c)) t (type bool) (expression false)
    (assign (context (s b c) (t))
            (expression (context (s b c) ((== (var s) (literal #f S S1))))))))

(pass-if "expression"
         (csp-pretty-noisy-equal?
          (ast-transform*
           i-ast
           '(compound
            (variable t (type bool) (expression false))
            (assign t
                    (expression
                     (== (var s) (literal #f S S1))))))
          expression-via))

(pass-if "expression-csp"
         (diff-noisy-equal?
          (csp-transform*
           i-ast
           expression-via)
          "context_(\\ ((s,b,c),(stack')) @ false,
assign_(\\ ((s,b,c),((stack',t))) @ ((s,b,c),((stack',(s == S_S1))))))"))


(define behaviourless-component-ast
  '((interface I
      (events (in (signature (type void)) e))
      (behaviour
       #f
       (compound (on ((e)) (compound)))))
    (component
     C
     (ports (provides I i)))))

(pass-if "behaviourless-component-ast"
         (csp-noisy-equal? (gom:model-with-behaviour
                            (ast->gom behaviourless-component-ast))
                           '(interface I
                              (events (in (signature (type void)) e))
                              (behaviour
                               #f
                               (compound (on ((e)) (compound)))))))
