                 (action (trigger console detected))
                 (action (trigger siren turnon))
                 (assign sounding (expression true))
                 (assign state (expression (literal #f States Triggered))))))
          ;;via
           csp-transform-alarm-snippet-via))

(pass-if "c-csp-transform-alarm-snippet-via"
         (diff-noisy-equal?

          ;; from/via:
          (csp-transform* alarm-ast csp-transform-alarm-snippet-via)
          ;; to:
"sensor_''?x:{triggered} ->
semi_(semi_((\\ P',V' @ console_''!detected -> P'(V')),
semi_((\\ P',V' @ siren!turnon -> siren_'.return -> P'(V')),
semi_(assign_(\\ ((state,sounding),(stack')) @ ((state,true),(stack'))),
assign_(\\ ((state,sounding),(stack')) @ ((States_Triggered,sounding),(stack')))))),
skip_)(\\ V' @ transition_end -> Alarm_d(V'),((state,sounding),(stack')))"
))


;; reply event

(define reply-ast
  '((interface
        I
   (types (enum Status (Yes No)))
   (events (in (signature (type Status)) done)
           (in (signature (type void)) e))
   (behaviour
    #f
    (types)
    (variables
     (variable dummy (type bool) (expression false)))
    (functions)
     (compound
      (on (triggers (trigger #f done))
          (compound
           (guard (expression true)
                    (compound
                     (reply (expression (value Status Yes)))))
           (guard (expression true)
                  (compound (reply (expression (value Status No))))))))))
    (interface
        U
      (types (enum Status (Ok Nok)))
      (events (in (signature (type Status)) what))
      (behaviour
       #f
       (types)
       (variables
        (variable dummy (type bool) (expression false)))
       (functions)
       (compound
        (on (triggers (trigger #f what))
            (compound
             (guard (expression true)
                    (compound (reply (expression (value Status Ok)))))
             (guard (expression true)
                    (compound
                     (reply (expression (value Status Nok))))))))))
    (component
     Reply
     (ports (provides I i) (requires U u))
     (behaviour
      #f
      (types)
      (variables
       (variable dummy (type bool) (expression false)))
      (functions)
      (compound
       (guard (expression true)
              (compound
               (on (triggers (trigger i done))
                   (compound
                    (variable s (type U (type Status)) (expression (value u what)))
                    (if (expression (== (var s) (literal U Status Ok)))
                        (compound
                         (reply (expression (literal I Status Yes))))
                        (compound
                         (reply (expression (literal I Status No))))))))))))))

(define var-ast
  '((interface
        ivar
      (types (enum E (v)))
      (events (in (signature (type E)) foo)
              (out (signature (type void)) bar))
      (behaviour
       #f
       (types)
       (variables)
       (functions)
       (compound
        (on (triggers (trigger #f foo))
            (reply (expression (literal #f E v)))))))
    (component
     var
     (ports (provides ivar i) (requires ivar o))
     (behaviour
      #f
      (types)
      (variables)
      (functions)
      (compound
       (on (triggers (trigger i foo))
           (compound)))))))

