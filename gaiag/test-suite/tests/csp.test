(define doc
"
  on i.e:
    {
      b = ! b;
      bool c = g (b);
      bool d = g (c);

      {
        bool cc = g (c);
        bool dd = g (d);

        if(c)
        {
          f;
        }
      }
   }

")

;; '

(define callvalued-on-deep
  '(on (triggers (trigger i e))
       (compound
        (assign b (expression (! (var b))))
        (variable c (type bool #f) (call g (arguments (expression (var b))) #f))
        (variable d (type bool #f) (call g (arguments (expression (var c))) #f))
        (compound
         (variable cc (type bool #f) (call g (arguments (expression (var c))) #f))
         (variable dd (type bool #f) (call g (arguments (expression (var d))) #f))
         (if (expression (var dd))
             (compound (action (trigger i f))))))))

(define csp-callvalued-on-deep
  '(csp-on
  (context (b) ())
  (triggers (trigger i e (arguments)))
  (compound
    (compound
      (csp-assign
        (context (b) ())
        b
        (expression (! (var b)))
        (context (r') ()))
      (csp-variable
        (context (b) ())
        c
        (type bool #f)
        (call g (arguments (expression (var b))) #f))
      (csp-variable
        (context (b) (c))
        d
        (type bool #f)
        (call g (arguments (expression (var c))) #f))
      (compound
        (csp-variable
          (context (b) (c d))
          cc
          (type bool #f)
          (call g (arguments (expression (var c))) #f))
        (csp-variable
          (context (b) (c d cc))
          dd
          (type bool #f)
          (call g (arguments (expression (var d))) #f))
        (csp-if
          (context (b) (c d cc dd))
          (expression (var dd))
          (compound (action (trigger i f (arguments))))
          ())))
    (voidreply))))

(pass-if "ast-transform-callvalued-deep"
         (csp-pretty-noisy-equal?

          ;; from:
          (ast-transform* callvalued-c-ast callvalued-on-deep)

          ;; via:
          csp-callvalued-on-deep))

