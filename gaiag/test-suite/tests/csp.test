               (expression (and (! IG) b))
               ()
               (illegal))))

(define ast-transform-semi
  '(semi (if (ctx ((s b c)))
             (expression b)
             ()
             ())
         (assign (ctx ((s b c))) (expression (ctx ((s true c)))))))

(pass-if "ast-transform-semi"
         (gom-pretty-noisy-equal?

          ;; from:
          (ast-transform*

           i-ast

           '(compound
             (if (expression b)
                 (compound))
             (assign b (expression true))))

          ;; via:
          ast-transform-semi))

(pass-if "csp-transform-semi"
         (diff-noisy-equal?

          ;; via/from:
          (csp-transform* i-ast ast-transform-semi)

          ;; to:
          "semi_(\\ P',((s,b,c),(stack')) @ ifthenelse_(b,
(\\ P',V' @ P'(V')),
(\\ P',V' @ P'(V'))
)(P',((s,b,c),(stack'))),
assign_(\\ ((s,b,c),(stack')) @ ((s,true,c),(stack'))))"))

;; \\)

(define ast-transform-via
  '(on (e)
    (semi (semi (if (ctx ((s b c)))
                  (expression (or c b))
                  (semi (action (trigger #f f)) (action (trigger #f g)))
                  ())
                (semi (if (ctx ((s b c)))
                        (expression b)
                        (semi (if (ctx ((s b c)))
                                  (expression c)
                                  (action (trigger #f g))
                                  ())
                              (semi (assign
                                      (ctx ((s b c)))
                                      (expression (ctx ((s b false)))))
                                    (action (trigger #f f))))
                        (if (ctx ((s b c)))
                          (expression c)
                          (semi (assign (ctx ((s b c)))
                                        (expression (ctx ((s false c)))))
                                (action (trigger #f h)))
                          (semi (assign (ctx ((s b c)))
                                        (expression (ctx ((s true c)))))
                                (action (trigger #f g)))))
                      (assign
                        (ctx ((s b c)))
                        (expression (ctx (((literal #f S S2) b c)))))))
          (eventreturn))
    (the-end (s b c))))

(pass-if "ast-transform"
         (gom-pretty-noisy-equal?

          ;; from:
          (ast-transform*

           i-ast

           '(compound
             (on (e)
                 (compound

                  (if (expression (or c b))
                      (compound (action (trigger #f f))
                                (action (trigger #f g))))
                  (if (expression b)
                      (compound
                       (if (expression c)
                           (compound (action (trigger #f g))))
                       (assign c (expression false))
                       (action (trigger #f f)))
                      (compound
                       (if (expression c)
                           (compound
                            (assign b (expression false))
                            (action (trigger #f h)))
                           (compound
                            (assign b (expression true))
                            (action (trigger #f g))))))
                  (assign s (expression (literal #f S S2)))))))

          ;; via:
          ast-transform-via))

(pass-if "csp-transform"
         (diff-noisy-equal?

          ;; from/via:
          (csp-transform* i-ast ast-transform-via)

          ;; to:
          "i?x:{e} ->
semi_(semi_(\\ P',((s,b,c),(stack')) @ ifthenelse_((c or b),
                             semi_((\\ P',V' @ i!f -> P'(V')),
                                  (\\ P',V' @ i!g -> P'(V'))),
                             (\\ P',V' @ P'(V'))
                             )(P',((s,b,c),(stack'))),
     semi_(\\ P',((s,b,c),(stack')) @ ifthenelse_(b,
                                  semi_(\\ P',((s,b,c),(stack')) @ ifthenelse_(c,
                                                               (\\ P',V' @ i!g -> P'(V')),
                                                               (\\ P',V' @ P'(V'))
                                                               )(P',((s,b,c),(stack'))),
                                       semi_(assign_(\\ ((s,b,c),(stack')) @ ((s,b,false),(stack'))),
                                            (\\ P',V' @ i!f -> P'(V')))),
                                  \\ P',((s,b,c),(stack')) @ ifthenelse_(c,
                                                          semi_(assign_(\\ ((s,b,c),(stack')) @ ((s,false,c),(stack'))),
                                                               (\\ P',V' @ i!h -> P'(V'))),
                                                          semi_(assign_(\\ ((s,b,c),(stack')) @ ((s,true,c),(stack'))),
                                                               (\\ P',V' @ i!g -> P'(V')))
                                                          )(P',((s,b,c),(stack')))
                                  )(P',((s,b,c),(stack'))),
          assign_(\\ ((s,b,c),(stack')) @ ((S_S2,b,c),(stack'))))),
(\\ P',V' @ i.return -> P'(V')))(\\ V' @ i_B_(V'),((s,b,c),(stack')))"))


(define c-ast `(,(ast:make
               'component
               `(c
                 (ports (provides i j)
                        (requires i k))
                 ,(ast:make
                   'behaviour
                   '(
                     B
                     (types (enum S (S1 S2)))
                     (variables
                      (variable (type S) s (expression (literal #f S S1)))
                      (variable (type bool) b (expression false))
                      (variable (type bool) c (expression true)))
                     (compound)))))))

(define c-ast-transform-return-via
  '(on ((trigger j e))
       (eventreturn)
       (the-end (s b c))))

(pass-if "c-ast-transform-return"
         (gom-pretty-noisy-equal?

          ;; from:
          (ast-transform*

