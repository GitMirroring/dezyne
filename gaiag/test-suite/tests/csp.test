;; OM-PARSER parser test
(define csp-transform-OM-PARSER-assign-action-via
  '(csp-on
    (context (dummy))
    (triggers (trigger i e (arguments)))
    (semi (csp-variable
           (context (dummy))
           res
           (type Status U)
           (expression (literal U Status Ok))
           (csp-assign
            (context (dummy) (res))
            res
            (action (trigger u what (arguments)))
            (context (dummy) (r'))))
          (voidreply))))

(pass-if "ast-transform-OM-PARSER-assign-action"
         (csp-pretty-noisy-equal?

          ;; from:
          (ast-transform* reply-ast
                         '(on
                           ((trigger i e))
                           (compound
                            (variable res (type Status U) (expression (literal U Status Ok)))
                            (assign res (action (trigger u what))))))

          ;; via:
          csp-transform-OM-PARSER-assign-action-via))

(pass-if "csp-transform-OM-PARSER-assign-action"
         (diff-noisy-equal?

          ;; via/from:
          (csp-transform* reply-ast csp-transform-OM-PARSER-assign-action-via)

          ;; to:
          "i?x:{e} ->
semi_(context_(\\ ((dummy),(stack')) @ Status_Ok,
assign_active_(semi_(send_(u,what),recv_(u_',what)),
\\ ((dummy),((stack',res))),r' @ ((dummy),((stack',r'))))),
(\\ P',V' @ I_'.return -> P'(V')))(\\ V' @ transition_end -> Reply_(V'),((dummy),(stack')))"))

