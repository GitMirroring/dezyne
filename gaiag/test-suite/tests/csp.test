(define member-i-ast
  '((interface i
      (types)
      (events (in (signature (type void)) e))
      (behaviour
       B
       (compound)))))

(define member-c-ast
  (append
   member-i-ast
   '((component c
               (ports)
               (behaviour
                B
                (compound))))))

