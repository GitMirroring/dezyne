              (on (triggers (trigger i e))
                  (compound))))))))

(define callvalued-on
  '(on (triggers (trigger i e))
       (compound
        (assign b (expression (! (var b))))
        (variable c (type bool #f) (call g (arguments (expression (var b)))))
        (assign b (call g (arguments (expression (var c)))))
        (if (expression (var c))
            (compound (action (trigger i f)))))))

(define csp-callvalued-on
  '(csp-on
  (context (b) ())
  (triggers (trigger i e (arguments)))
  (compound
    (compound
      (csp-assign
        (context (b) ())
        b
        (expression (! (var b)))
        (context (r') ()))
      (csp-variable
        (context (b) ())
        c
        (type bool #f)
        (call g (arguments (expression (var b))) #f))
      (csp-assign
        (context (b) (c))
        b
        (call g (arguments (expression (var c))) #f)
        (context (r') (c)))
      (csp-if
        (context (b) (c))
        (expression (var c))
        (compound (action (trigger i f (arguments))))
        ()))
    (voidreply))))

(pass-if "ast-transform-callvalued"
