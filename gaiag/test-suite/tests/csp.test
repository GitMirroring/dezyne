(define alarm-ast
  '((component
     Alarm
     (ports (provides Console console)
            (requires Sensor sensor)
            (requires Siren siren))
     (behaviour
      d
      (types (enum States
                   (Disarmed Armed Triggered Disarming)))
      (variables
       (variable state (type States) (expression (literal #f States Disarmed)))
       (variable sounding (type bool) (expression false)))
      (compound
       (on ((trigger sensor triggered))
           (compound
            (action (trigger console detected))
            (action (trigger siren turnon))
            (assign sounding (expression true))
            (assign state (expression (literal #f States Triggered))))))))))


(define csp-transform-alarm-snippet-via
  '(csp-on (context (state sounding)) ((trigger sensor triggered))
    (semi (semi (action (trigger console detected))
                (semi (action (trigger siren turnon))
                      (semi (assign
                             (context (state sounding))
                             (expression (context (state true))))
                            (assign
                             (context (state sounding))
                              (expression
                               (context ((literal #f States Triggered) sounding)))))))
          (voidreply))))

(pass-if "c-ast-transform-alarm-snippet"
         (csp-pretty-noisy-equal?
          (ast-transform*
           alarm-ast

           ;;from
           '(on ((trigger sensor triggered))
                (compound
                 (action (trigger console detected))
                 (action (trigger siren turnon))
                 (assign sounding (expression true))
                 (assign state (expression (literal #f States Triggered))))))
          ;;via
           csp-transform-alarm-snippet-via))

(pass-if "c-csp-transform-alarm-snippet-via"
         (diff-noisy-equal?

          ;; from/via:
          (csp-transform* alarm-ast csp-transform-alarm-snippet-via)
          ;; to:
"sensor?x:{triggered} ->
semi_(semi_((\\ P',V' @ console!detected -> P'(V')),
semi_((\\ P',V' @ siren!turnon -> siren_'.return -> P'(V')),
semi_(assign_(\\ ((state,sounding),(stack')) @ ((state,true),(stack'))),
assign_(\\ ((state,sounding),(stack')) @ ((States_Triggered,sounding),(stack')))))),
skip_)(\\ V' @ transition_end -> Alarm_d(V'),((state,sounding),(stack')))"
))


;; reply event

(define reply-ast
  '((interface
        I
   (types (enum Status (Yes No)))
   (events (in (signature (type Status)) done)
           (in (signature (type void)) e))
   (behaviour
    #f
    (types)
    (variables
     (variable dummy (type bool) (expression false)))
    (functions)
     (compound
      (on (triggers (trigger #f done))
          (compound
           (guard (expression true)
                    (compound
                     (reply (expression (value Status Yes)))))
           (guard (expression true)
