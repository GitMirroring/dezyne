(pass-if "csp-transform-expression"
         (gom-noisy-equal?

          ;; from:
          (csp-expression->string

           i-ast

           (csp->sugar '(expression (! (and (or (!= c  b) true) (== c b))))))

          ;; to:
          "(not ((((c != b) or true) and (c == b))))"))


(define ast-transform-ifthenelse-via
  '(if (ctx ((s b c)))
       (expression b)
       ()
       ()))

(pass-if "ast-transform-ifthenelse"
         (gom-pretty-noisy-equal?

          ;; from:
          (ast-transform*

           i-ast

           '(if (expression b)
                (compound)
                (compound)))

          ;; via:
          ast-transform-ifthenelse-via))

(pass-if "csp-transform-ifthenelse"
         (diff-noisy-equal?

          ;; via/from:
          (csp-transform* i-ast ast-transform-ifthenelse-via)

          ;; to:
          "\\ P',((s,b,c),(stack')) @ ifthenelse_(b,
(\\ P',V' @ P'(V')),
(\\ P',V' @ P'(V'))
)(P',((s,b,c),(stack')))"))

(pass-if "ast-transform-ifthen-illegal"
         (gom-pretty-noisy-equal?

          ;; from:
          (ast-transform*

           i-ast

           '(if (expression b)
                (illegal)
                ()))

          ;; via:
