(define member-i-ast
  '((interface (name imember)
      (types)
      (events (event e (signature (type void)) in))
      (behaviour
       B
       (types)
       (variables)
       (functions)
       (compound)))))

(define member-c-ast
  (append
   member-i-ast
   '((component (name c)
               (ports)
               (behaviour
                B
                (types)
                (variables)
                (functions)
                (compound))))))

