          ;; to:
          "assign_(\\ ((s,b,c),(stack')) @ ((S_S2,b,c),(stack')))"))

;; \\)

(pass-if "ast-transform-ifthen"
         (gom-pretty-noisy-equal?

          ;; from:
          (ast-transform*

           i-ast

           '(if (expression b)
                (compound)))

          ;; via:
          '(if (ctx ((s b c)))
               (expression b)
