;; reply event

(define reply-ast
  '((interface
     (name IReply)
   (types (enum (name IReply Status) (fields Yes No)))
   (events (event done (signature (type (name IReply Status))) in)
           (event e (signature (type void)) in))
   (behaviour
    #f
    (types)
    (variables
     (variable dummy (type bool) (expression false)))
    (functions)
     (compound
      (on (triggers (trigger #f done (arguments)))
          (compound
           (guard (expression true)
                    (compound
                     (reply (expression (name IReply Status Yes)) #f)))
           (guard (expression true)
                  (compound (reply (expression (name IReply Status No)) #f))))))))
    (interface
        (name UReply)
      (types (enum (name UReply Status) (fields Ok Nok)))
      (events (event what (signature (type (name UReply Status))) in))
      (behaviour
       #f
       (types)
       (variables
        (variable dummy (type bool) (expression false)))
       (functions)
       (compound
        (on (triggers (trigger #f what (arguments)))
            (compound
             (guard (expression true)
                    (compound (reply (expression (name UReply Status Ok)) #f)))
             (guard (expression true)
                    (compound
                     (reply (expression (name UReply Status Nok)) #f))))))))
    (component
     (name Reply)
     (ports (port i (name IReply) provides) (port u (name UReply) requires))
     (behaviour
      #f
      (types)
      (variables
       (variable dummy (type bool) (expression false)))
      (functions)
      (compound
       (guard (expression true)
              (compound
               (on (triggers (trigger i done (arguments)))
                   (compound
                    (variable s (type (name UReply Status)) (expression (name u what)))
                    (if (expression (== (var s) (literal (name UReply Status) Ok)))
                        (compound
