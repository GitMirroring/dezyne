(define ast-return-ast
  '(compound
    (on (triggers (trigger #f e))
        (compound))))

(define csp-return-ast
  '(csp-on
    (context (s b c))
      (triggers (trigger #f e (arguments)))
      (compound (voidreply))))

(pass-if "ast-transform-return-return"
         (csp-pretty-noisy-equal?

          ;; from:
          (ast-transform-return* i-ast ast-return-ast)

          ;; via:
          '(csp-on (context (s b c)) (e)
               (compound (voidreply)))))

(pass-if "ast-transform-return"
         (csp-pretty-noisy-equal?

          ;; from:
          (ast-transform* i-ast ast-return-ast)

          ;; via:
          csp-return-ast))


(pass-if "csp-transform-return"
         (diff-noisy-equal?

          ;; from/via:
          (csp-transform* i-ast csp-return-ast)

          ;; to:
          "i?x:{e} -> (
i_'.return ->
i.the_end' ->
i_B(s,b,c)
)"))


(pass-if "ast-transform-return-reply"
