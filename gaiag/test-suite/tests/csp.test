(define csp-transform-via
  '(on
  (triggers (trigger #f e (arguments)))
  (compound
    (compound
      (if
        (expression (or c b))
        (compound
          (action (trigger #f f (arguments)))
          (action (trigger #f g (arguments))))
        #f)
      (if
        (expression b)
        (compound
          (if
            (expression c)
            (compound (action (trigger #f g (arguments))))
            #f)
          (assign
            c
            (expression false))
          (action (trigger #f f (arguments))))
        (compound
          (if
            (expression c)
            (compound
              (assign
                b
                (expression false))
              (action (trigger #f h (arguments))))
            (compound
              (assign
                b
                (expression true))
              (action (trigger #f g (arguments)))))))
      (assign
        s
        (expression (literal (name i S) S2))))
    (voidreply))))

(pass-if "ast-transform"
         (csp-pretty-noisy-equal?

          ;; from:
          (ast-transform*

           i-ast

           '(compound
             (on (triggers (trigger #f e (arguments)))
                 (compound

                  (if (expression (or c b))
                      (compound (action (trigger #f f (arguments)))
                                (action (trigger #f g (arguments))))
                      #f)
                  (if (expression b)
                      (compound
                       (if (expression c)
                           (compound (action (trigger #f g (arguments))))
                           #f)
                       (assign c (expression false))
                       (action (trigger #f f (arguments))))
                      (compound
                       (if (expression c)
                           (compound
                            (assign b (expression false))
                            (action (trigger #f h (arguments))))
                           (compound
                            (assign b (expression true))
                            (action (trigger #f g (arguments)))))))
                  (assign s (expression (literal (name i S) S2)))))))

          ;; via:
          csp-transform-via))

(pass-if "csp-transform"
         (diff-noisy-equal?

