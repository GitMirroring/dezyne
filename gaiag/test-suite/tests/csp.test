                   :locals (list (make <context-vector> :elements '( d e f)) 's))))
    (csp-pretty-noisy-equal?
     (extend context (make <context-vector> :elements '(s d)))
     '(context (hide_member0' b c) ((vector hide_local0' e f) hide_local3' (vector s d))))))

