   "(true) & (
STOP)"))

(define expression-via
  '(compound
  (csp-variable
    (context (s b c) ())
    t
    (type bool #f)
    (expression false))
  (csp-assign
    (context (s b c) (t))
    t
    (expression (== (var s) (literal #f S S1)))
    (context (s b c) (r')))))

(pass-if "expression"
         (csp-pretty-noisy-equal?
          (ast-transform*
           i-ast
           '(compound
            (variable t (type bool) (expression false))
            (assign t
                    (expression
                     (== (var s) (literal #f S S1))))))
          expression-via))

(pass-if "expression-csp"
         (diff-noisy-equal?
          (csp-transform*
           i-ast
           expression-via)
          "let t = false within
let tmp' = (s == S_S1) within
let t = tmp' within
"))


