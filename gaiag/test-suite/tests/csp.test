;; \\)

(define csp-transform-assign-2-via
  '(csp-variable
    (context (s b c)) la (type bool) (expression true)
    (csp-variable
     (context (s b c) (la)) lb (type bool) (expression false)
     (csp-assign (context (unused)) la (context (s b c) (la lb))
                 (context (s b c) (true lb))))))

(pass-if "ast-transform-assign-2-bool"
         (csp-pretty-noisy-equal?

          ;; from:
          (ast-transform*
           i-ast
           '(compound
             (variable la (type bool) (expression true))
             (variable lb (type bool) (expression false))
             (assign la (expression true))))

          ;; via:
          csp-transform-assign-2-via))

(pass-if "csp-transform-assign-2-bool"
         (diff-noisy-equal?

          ;; via/from:
          (csp-transform* i-ast csp-transform-assign-2-via)

          ;; to:
          "context_(\\ ((s,b,c),(stack')) @ true,
context_(\\ ((s,b,c),((stack',la))) @ false,
assign_(\\ ((s,b,c),(((stack',la),lb))) @ ((s,b,c),(((stack',true),lb))))))"))

;; \\) \\) \\)

