(define ast-transform-compound
  '(compound
  (csp-if
    (context (s b c) ())
    (expression b)
    (compound)
    ())
  (csp-assign
    (context (s b c) ())
    b
    (expression true)
    (context (s r' c) ()))))

(pass-if "ast-transform-compound"
         (csp-pretty-noisy-equal?

          ;; from:
          (ast-transform*

           i-ast

           '(compound
             (if (expression b)
                 (compound))
             (assign b (expression true))))

          ;; via:
          ast-transform-compound))

(pass-if "csp-transform-compound"
         (diff-noisy-equal?

          ;; via/from:
          (csp-transform* i-ast ast-transform-compound)

          ;; to:
          "(if b then
let tmp' = true within
let b = tmp' within
else
let tmp' = true within
let b = tmp' within
)
"))


(define csp-transform-via
  '(csp-on
  (context (s b c) ())
  (triggers (trigger #f e (arguments)))
  (compound
    (compound
      (csp-if
        (context (s b c) ())
        (expression (or c b))
        (compound
          (action (trigger #f f (arguments)))
          (action (trigger #f g (arguments))))
        ())
      (csp-if
        (context (s b c) ())
        (expression b)
        (compound
          (csp-if
            (context (s b c) ())
            (expression c)
            (compound (action (trigger #f g (arguments))))
            ())
          (csp-assign
            (context (s b c) ())
            c
            (expression false)
            (context (s b r') ()))
          (action (trigger #f f (arguments))))
        (compound
          (csp-if
            (context (s b c) ())
            (expression c)
            (compound
              (csp-assign
                (context (s b c) ())
                b
                (expression false)
                (context (s r' c) ()))
              (action (trigger #f h (arguments))))
            (compound
              (csp-assign
                (context (s b c) ())
                b
                (expression true)
                (context (s r' c) ()))
              (action (trigger #f g (arguments)))))))
      (csp-assign
        (context (s b c) ())
        s
        (expression (literal #f S S2))
        (context (r' b c) ())))
    (voidreply))))

(pass-if "ast-transform"
         (csp-pretty-noisy-equal?

          ;; from:
          (ast-transform*

           i-ast

           '(compound
             (on (triggers (trigger #f e))
                 (compound

                  (if (expression (or c b))
                      (compound (action (trigger #f f))
                                (action (trigger #f g))))
                  (if (expression b)
                      (compound
                       (if (expression c)
                           (compound (action (trigger #f g))))
                       (assign c (expression false))
                       (action (trigger #f f)))
                      (compound
                       (if (expression c)
                           (compound
                            (assign b (expression false))
                            (action (trigger #f h)))
                           (compound
                            (assign b (expression true))
                            (action (trigger #f g))))))
                  (assign s (expression (literal #f S S2)))))))

          ;; via:
          csp-transform-via))

(pass-if "csp-transform"
         (diff-noisy-equal?

          ;; from/via:
          (csp-transform* i-ast csp-transform-via)

          ;; to:
          "i?x:{e} -> (
(if (c or b) then
i!f ->
i_''!g ->
(if b then
(if c then
i_''!g ->
let tmp' = false within
let c = tmp' within
if not ((0 <= c and c <= 2)) then illegal -> STOP else
i!f ->
let tmp' = S_S2 within
let s = tmp' within
i_'.return ->
i.the_end' ->
i_B(s,b,c)
else
let tmp' = false within
let c = tmp' within
if not ((0 <= c and c <= 2)) then illegal -> STOP else
i!f ->
let tmp' = S_S2 within
let s = tmp' within
i_'.return ->
i.the_end' ->
i_B(s,b,c)
)
else
(if c then
let tmp' = false within
let b = tmp' within
i_''!h ->
let tmp' = S_S2 within
let s = tmp' within
i_'.return ->
i.the_end' ->
i_B(s,b,c)
else
let tmp' = true within
let b = tmp' within
i_''!g ->
let tmp' = S_S2 within
let s = tmp' within
i_'.return ->
i.the_end' ->
i_B(s,b,c)
)
)
else
(if b then
(if c then
i_''!g ->
let tmp' = false within
let c = tmp' within
if not ((0 <= c and c <= 2)) then illegal -> STOP else
i!f ->
let tmp' = S_S2 within
let s = tmp' within
i_'.return ->
i.the_end' ->
i_B(s,b,c)
else
let tmp' = false within
let c = tmp' within
if not ((0 <= c and c <= 2)) then illegal -> STOP else
i!f ->
let tmp' = S_S2 within
let s = tmp' within
i_'.return ->
i.the_end' ->
i_B(s,b,c)
)
else
(if c then
let tmp' = false within
let b = tmp' within
i_''!h ->
let tmp' = S_S2 within
let s = tmp' within
i_'.return ->
i.the_end' ->
i_B(s,b,c)
else
let tmp' = true within
let b = tmp' within
i_''!g ->
let tmp' = S_S2 within
let s = tmp' within
i_'.return ->
i.the_end' ->
i_B(s,b,c)
)
)
)
)"))


(define c-ast (append
               i-ast
               '((component
                  c
                  (ports (port j i provides)
                         (port k i requires))
                  (behaviour
                   B
                   (types (enum S #f (fields S1 S2)))
                   (variables
                    (variable s (type S) (expression (literal #f S S1)))
                    (variable b (type bool) (expression false))
                    (variable c (type bool) (expression true))
                    (variable xi (type xint i) (data 0)))
                   (functions)
                   (compound
                    (on (triggers (trigger j e))
