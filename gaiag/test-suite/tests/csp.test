skip_(\\ V' @ transition_end -> c_B_(V'),((s,b,c),(stack')))"))


(define alarm-ast
  ' (component
     Alarm
     (ports (provides Console console)
            (requires Sensor sensor)
            (requires Siren siren))
     (behaviour
      d
      (types (enum States
                   (Disarmed Armed Triggered Disarming)))
      (variables
       (variable
        (type States)
        state
        (expression (literal #f States Disarmed)))
       (variable (type bool) sounding (expression false)))
      (compound))))


(define ast-transform-alarm-snippet-via
  '(on ((trigger sensor triggered))
    (semi (semi (action (trigger console detected))
                (semi (action (trigger siren turnon))
                      (semi (assign
                              (ctx ((state sounding)))
                              (expression (ctx ((state true)))))
                            (assign
                              (ctx ((state sounding)))
                              (expression
                               (ctx (((literal #f States Triggered) sounding))))))))
          (eventreturn))
    (the-end (state sounding))))

(pass-if "c-ast-transform-alarm-snippet"
         (gom-pretty-noisy-equal?
          (ast-transform*
           alarm-ast

           ;;from
           '(on ((trigger sensor triggered))
                (compound
                 (action (trigger console detected))
                 (action (trigger siren turnon))
                 (assign sounding (expression true))
                 (assign state (expression (literal #f States Triggered))))))
          ;;via
           ast-transform-alarm-snippet-via))

(pass-if "c-csp-transform-alarm-snippet-via"
         (diff-noisy-equal?

          ;; from/via:
          (csp-transform* alarm-ast ast-transform-alarm-snippet-via)
          ;; to:
"sensor?x:{triggered} ->
semi_(semi_((\\ P',V' @ console!detected -> P'(V')),
semi_((\\ P',V' @ siren!turnon -> siren.return -> P'(V')),
semi_(assign_(\\ ((state,sounding),(stack')) @ ((state,true),(stack'))),
assign_(\\ ((state,sounding),(stack')) @ ((States_Triggered,sounding),(stack')))))),
skip_)(\\ V' @ transition_end -> Alarm_d_(V'),((state,sounding),(stack')))"
))


;; reply event

(define i-reply-ast
  '(interface I
     (types (enum Status (Yes No)))
     (events (in ((type Status)) done))
     (behaviour
      #f
      (types)
      (variables)
      (compound
       (on (done)
           (compound
            (guard (expression true)
                   (compound (reply (expression (literal #f Status Yes)))))
            (guard (expression true) (compound (reply (expression (literal #f Status No)))))))))))

(define u-reply-ast
  '(interface U
     (types (enum Status (Ok Nok)))
     (events (in ((type Status)) what))
     (behaviour
      #f
      (types)
      (variables)
      (compound
       (on (what)
           (compound
            (guard (expression true) (compound (reply (expression (literal #f Status Ok)))))
            (guard (expression true)
                   (compound (reply (expression (literal #f Status Nok)))))))))))

(define c-reply-ast
  '(component C
              (ports (provides I i) (requires U u))
              (behaviour
               #f
               (types)
               (variables
                (variable (type bool) dummy (expression false)))
               (compound
                (guard (expression true)
                       (compound
                        (on ((trigger i done))
                            (compound
                             (variable
                              (type U (type Status))
                              s
                              (value u what))
                             (if (expression (== s (literal u Status Ok)))
                                 (compound (reply (expression (literal I Status Yes))))
                                 (compound (reply (expression (literal I Status No)))))))))))))


(define var-ast
  '((interface
        ivar
      (types (enum E (v)))
      (events (in (signature (type E)) foo))
      (behaviour
       #f
       (types)
       (variables)
       (functions)
       (compound
        (on (triggers (trigger #f foo))
            (reply (expression (literal #f E v)))))))
    (component
     var
     (ports (provides ivar i) (requires ivar o))
     (behaviour
      #f
      (types)
      (variables)
      (functions)
      (compound
       (on (triggers (trigger i foo))
           (variable (type ivar (type E)) e (action o foo)))
       (reply (expression e)))))))

(define ast-transform-variable-valued-action-via
  '(on ((trigger o foo))
       (compound
        (variable (type ivar (type E)) e (action (trigger o foo))))))

(define ast-transform-ast-transform-variable-valued-action-via
  '(on (triggers (trigger o foo))
       (context-active
        ((ctx (()))
         e
         (action (trigger o foo)))
        (eventreturn))
       (the-end ())))

(pass-if "ast-transform-ast-transform-variable-valued-action"
         (gom-pretty-noisy-equal?

          ;; from:
          (ast-transform*
           (cdr var-ast)
           ast-transform-variable-valued-action-via)
          ast-transform-ast-transform-variable-valued-action-via))

(pass-if "csp-transform-variable-valued-action"
         (diff-noisy-equal?

          ;; from/via:
          (csp-transform* (cdr var-ast) ast-transform-ast-transform-variable-valued-action-via)

          ;; to:
          "o?x:{foo} ->
context_active_(sendrecv_(o,foo),
skip_)(\\ V' @ transition_end -> var__(V'),((stack')))"))

(pass-if "ast-csp-transform-variable-valued-action"
         (diff-noisy-equal?

          ;; from:
          (csp-transform* (cdr var-ast)
                          (ast-transform*
                           (cdr var-ast)
                           ast-transform-variable-valued-action-via))

          ;; via:
          "o?x:{foo} ->
context_active_(sendrecv_(o,foo),
skip_)(\\ V' @ transition_end -> var__(V'),((stack')))"))

(define csp-function-call-ast
  '(on (e)
       (semi
        (call (ctx ((s b c))) toggle)
        (eventreturn))
       (the-end (s b c))))

(pass-if "ast-transform-function-call"
         (gom-pretty-noisy-equal?

          ;; from:
