;; -*-scheme-*-

(read-set! keywords 'prefix)

(define-module (test-handler)
  :use-module (test-suite lib)
  :use-module (test-suite misc)

  :use-module (ice-9 and-let-star)
  :use-module (ice-9 pretty-print)
  :use-module (ice-9 match)

  :use-module (oop goops)
  :use-module (gaiag csp)
  :use-module (gaiag misc)
  :use-module (gaiag resolve)
  :use-module (gaiag gom))

(define ast-transform- (@@ (gaiag csp) ast-transform-))
(define ast-transform-return (@@ (gaiag csp) ast-transform-return))

(define (ast-transform* ast src)
  (let ((root (csp->gom ast)))
    ((gom:register csp:norm) root #t)
    (ast-transform- root (ast-transform-return root (csp->gom src)))))

(define (ast-transform-return* ast src)
  (let ((root (csp->gom ast)))
    ((gom:register csp->gom) root #t)
    (ast-transform-return root (csp->gom src))))

(define (csp-transform* ast src)
  (let ((root (csp->gom ast)))
    ((gom:register csp->gom) root #t)
    (csp-transform root (csp->gom src))))

(define (csp->sugar ast)
  (match ast
    (('expression expression)
     (make <expression> :value (csp->gom expression)))
    (('csp-on context ('triggers triggers) statement)
     (make <csp-on>
       :context (csp->gom context)
       :triggers (csp->gom (caddr ast))
       :statement (csp->gom statement)))
    (('csp-on context triggers statement)
     (make <csp-on>
       :context (csp->gom context)
       :triggers (make <triggers>
                   :elements (csp->gom (map ast->trigger-sugar triggers)))
       :statement (csp->gom statement)))
    (('csp-if context expression then else)
     (make <csp-if>
       :context (csp->gom context)
       :expression (csp->gom expression)
       :then (csp->gom then)
       :else (csp->gom else)))
    (('csp-call context name)
     (make <csp-call>
       :context (csp->gom context)
       :identifier name))
    (('csp-call context name arguments)
     (make <csp-call>
       :context (csp->gom context)
       :identifier name
       :arguments (csp->gom arguments)))
    (('csp-reply context expression)
     (make <csp-reply>
       :context (csp->gom context)
       :expression (csp->gom expression)))
    (('csp-return context expression)
     (make <csp-return>
       :context (csp->gom context)
       :expression (csp->gom expression)))
    (('context) (make <context>))
    (('context members) (make <context> :members (csp->gom members)))
    (('context members locals) (make <context> :members (csp->gom members) :locals (csp->gom locals)))
    (('literal scope type field) (make <literal> :scope scope :type type :field field))
    (('csp-variable context name type expression continuation)
     (make <csp-variable>
       :context (csp->gom context)
       :name name
       :type (csp->gom type)
       :expression (csp->gom expression)
       :continuation (csp->gom continuation)))
    (('csp-assign context identifier expression expressions)
     (make <csp-assign>
       :context (csp->gom context)
       :identifier identifier
       :expression (csp->gom expression)
       :expressions (csp->gom expressions)))
    (('semi statement continuation)
     (make <semi> :statement (csp->gom statement) :continuation (csp->gom continuation)))
    (('voidreply) (make <voidreply>))
    (('vector identifiers ...) (make <context-vector> :elements identifiers))
    (('skip) (make <skip>))
    ((h t ...) (map csp->sugar ast))
    (_ ast)))

(define (csp->gom ast)
  ((compose ast->gom csp->sugar ast->sugar) ast))


(define (csp-noisy-equal? actual expected)
  (let ((actual* (gom->list (csp->gom actual)))
        (expected* (gom->list (csp->gom expected))))
   (or (equal? actual* expected*)
       (fail "~a\n!=\n~a\n" expected* actual*))))

(define (csp-pretty-noisy-equal? actual expected)
  (let ((actual* (gom->list (csp->gom actual)))
        (expected* (gom->list (csp->gom expected))))
  (or (equal? actual* expected*)
      (fail "~a!=\n~a" (pretty-string expected*) (pretty-string actual*)))))


(pass-if "csp-first-dummy-test"
         #t)

(define i-ast '((interface i
                  (types (enum Status (Yes No)))
                  (events (in (signature (type void)) e)
                          (in (signature (type Status)) f))
                  (behaviour
                   B
                   (types (enum S (S1 S2)))
                   (variables
                    (variable s (type S) (action (trigger S S1)))
                    (variable b (type bool) (expression false))
                    (variable c (type bool) (expression true)))
                   (functions (function toggle (signature (type void)) #f (compound)))
                   (compound)))))

(define ast-return-ast
  '(compound
    (on (e)
        (compound))))

(define csp-return-ast
  '(csp-on (context (s b c)) (e)
       (voidreply)))

(pass-if "ast-transform-return-return"
         (csp-pretty-noisy-equal?

          ;; from:
          (ast-transform-return* i-ast ast-return-ast)

          ;; via:
          '(csp-on (context (s b c)) (e)
               (compound (voidreply)))))

(pass-if "ast-transform-return"
         (csp-pretty-noisy-equal?

          ;; from:
          (ast-transform* i-ast ast-return-ast)

          ;; via:
          csp-return-ast))


(pass-if "csp-transform-return"
         (diff-noisy-equal?

          ;; from/via:
          (csp-transform* i-ast csp-return-ast)

          ;; to:
          "i?x:{e} ->
(\\ P',V' @ i_'.return -> P'(V'))(\\ V' @ i_B(V'),((s,b,c),(stack')))")) ;; FIXME: NO skip_?


(pass-if "ast-transform-return-reply"
         (csp-pretty-noisy-equal?

          ;; from:
          (ast-transform-return*
           i-ast
           '(compound
             (on (f)
                 (reply (expression (literal #f Status Yes))))))

          ;; via:
          '(csp-on (context (s b c)) (f)
               (compound
                (reply (expression (literal #f Status Yes)))))))

(pass-if "csp-transform-return-reply"
         (diff-noisy-equal?

          ;; from:
          (csp-transform*

           i-ast

           '(csp-on (context (s b c)) (e)
                (semi
                 (csp-reply (context (s b c)) (expression (literal #f Status Yes)))
                 (return))))

          ;; via:
          "i?x:{e} ->
semi_(reply_(i_', (\\ ((s,b,c),(stack')) @ Status_Yes)),
skip_)(\\ V' @ i_B(V'),((s,b,c),(stack')))"))

(define csp-transform-reply-via
 '(csp-on (context (s b c)) (f)
      (csp-reply (context (s b c)) (expression (literal #f Status Yes)))))

(pass-if "ast-transform-reply"
