;; \\)

(define csp-transform-assign-2-via
  '(csp-variable
    (context (s b c)) la (type bool) (expression true)
    (csp-variable
     (context (s b c) (la)) lb (type bool) (expression false)
     (assign (context (s b c) (la lb))
             (expression (context (s b c) (true lb)))))))

(pass-if "ast-transform-assign-2-bool"
         (csp-pretty-noisy-equal?

          ;; from:
          (ast-transform*
           i-ast
           '(compound
             (variable la (type bool) (expression true))
             (variable lb (type bool) (expression false))
             (assign la (expression true))))

          ;; via:
