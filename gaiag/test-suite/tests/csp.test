let state = tmp' within
transition_end ->
Alarm_d(state,sounding)
)"))


;; reply event

(define reply-ast
  '((interface
        I
   (types (enum Status #f (fields Yes No)))
   (events (event done (signature (type Status)) in)
           (event e (signature (type void)) in))
   (behaviour
    #f
    (types)
    (variables
     (variable dummy (type bool) (expression false)))
    (functions)
     (compound
      (on (triggers (trigger #f done))
          (compound
           (guard (expression true)
                    (compound
                     (reply (expression (value Status Yes)))))
           (guard (expression true)
                  (compound (reply (expression (value Status No))))))))))
    (interface
        U
      (types (enum Status #f (fields Ok Nok)))
      (events (event what (signature (type Status)) in))
      (behaviour
       #f
       (types)
       (variables
        (variable dummy (type bool) (expression false)))
       (functions)
       (compound
        (on (triggers (trigger #f what))
            (compound
             (guard (expression true)
                    (compound (reply (expression (value Status Ok)))))
             (guard (expression true)
                    (compound
                     (reply (expression (value Status Nok))))))))))
    (component
     Reply
     (ports (port i I provides) (port u U requires))
     (behaviour
      #f
      (types)
      (variables
       (variable dummy (type bool) (expression false)))
      (functions)
      (compound
       (guard (expression true)
              (compound
               (on (triggers (trigger i done))
                   (compound
                    (variable s (type U (type Status)) (expression (value u what)))
                    (if (expression (== (var s) (literal U Status Ok)))
                        (compound
                         (reply (expression (literal I Status Yes))))
                        (compound
                         (reply (expression (literal I Status No))))))))))))))

(define var-ast
  '((interface
        ivar
      (types (enum E #f (fields v)))
      (events (event foo (signature (type E)) in)
              (event bar (signature (type void)) out))
      (behaviour
       #f
       (types)
       (variables)
       (functions)
       (compound
        (on (triggers (trigger #f foo))
            (reply (expression (literal #f E v)))))))
    (component
     var
     (ports (port i ivar provides) (port o ivar requires))
     (behaviour
      #f
      (types)
      (variables)
      (functions)
      (compound
       (on (triggers (trigger i foo))
           (compound)))))))

