(define ast-transform-semi
  '(semi (csp-if (context (s b c))
             (expression b)
             ()
             ())
         (assign (context (s b c)) (expression (context (s true c))))))

(pass-if "ast-transform-semi"
         (csp-pretty-noisy-equal?

          ;; from:
          (ast-transform*

           i-ast

           '(compound
             (if (expression b)
                 (compound))
             (assign b (expression true))))

          ;; via:
          ast-transform-semi))

(pass-if "csp-transform-semi"
         (diff-noisy-equal?

          ;; via/from:
          (csp-transform* i-ast ast-transform-semi)

          ;; to:
          "semi_(\\ P',((s,b,c),(stack')) @ ifthenelse_(b,
skip_,
skip_
)(P',((s,b,c),(stack'))),
assign_(\\ ((s,b,c),(stack')) @ ((s,true,c),(stack'))))"))

;; \\)

(define csp-transform-via
  '(csp-on (context (s b c)) (e)
    (semi (semi (csp-if (context (s b c))
                  (expression (or c b))
                  (semi (action (trigger #f f)) (action (trigger #f g)))
                  ())
                (semi (csp-if (context (s b c))
                        (expression b)
                        (semi (csp-if (context (s b c))
                                  (expression c)
                                  (action (trigger #f g))
                                  ())
                              (semi (assign
                                      (context (s b c))
                                      (expression (context (s b false))))
                                    (action (trigger #f f))))
                        (csp-if (context (s b c))
                          (expression c)
                          (semi (assign (context (s b c))
                                        (expression (context (s false c))))
                                (action (trigger #f h)))
                          (semi (assign (context (s b c))
                                        (expression (context (s true c))))
                                (action (trigger #f g)))))
                      (assign
                        (context (s b c))
                        (expression (context ((literal #f S S2) b c))))))
          (voidreply))))

(pass-if "ast-transform"
         (csp-pretty-noisy-equal?

          ;; from:
          (ast-transform*

           i-ast

           '(compound
             (on (e)
                 (compound

                  (if (expression (or c b))
                      (compound (action (trigger #f f))
                                (action (trigger #f g))))
                  (if (expression b)
                      (compound
                       (if (expression c)
                           (compound (action (trigger #f g))))
                       (assign c (expression false))
                       (action (trigger #f f)))
                      (compound
                       (if (expression c)
                           (compound
                            (assign b (expression false))
                            (action (trigger #f h)))
                           (compound
                            (assign b (expression true))
                            (action (trigger #f g))))))
                  (assign s (expression (literal #f S S2)))))))

          ;; via:
          csp-transform-via))

(pass-if "csp-transform"
         (diff-noisy-equal?

          ;; from/via:
          (csp-transform* i-ast csp-transform-via)

          ;; to:
          "i?x:{e} ->
semi_(semi_(\\ P',((s,b,c),(stack')) @ ifthenelse_((c or b),
                             semi_((\\ P',V' @ i!f -> P'(V')),
                                  (\\ P',V' @ i!g -> P'(V'))),
                             skip_
                             )(P',((s,b,c),(stack'))),
     semi_(\\ P',((s,b,c),(stack')) @ ifthenelse_(b,
                                  semi_(\\ P',((s,b,c),(stack')) @ ifthenelse_(c,
                                                               (\\ P',V' @ i!g -> P'(V')),
                                                               skip_
                                                               )(P',((s,b,c),(stack'))),
                                       semi_(assign_(\\ ((s,b,c),(stack')) @ ((s,b,false),(stack'))),
                                            (\\ P',V' @ i!f -> P'(V')))),
                                  \\ P',((s,b,c),(stack')) @ ifthenelse_(c,
                                                          semi_(assign_(\\ ((s,b,c),(stack')) @ ((s,false,c),(stack'))),
                                                               (\\ P',V' @ i!h -> P'(V'))),
                                                          semi_(assign_(\\ ((s,b,c),(stack')) @ ((s,true,c),(stack'))),
                                                               (\\ P',V' @ i!g -> P'(V')))
                                                          )(P',((s,b,c),(stack')))
                                  )(P',((s,b,c),(stack'))),
          assign_(\\ ((s,b,c),(stack')) @ ((S_S2,b,c),(stack'))))),
(\\ P',V' @ i_'.return -> P'(V')))(\\ V' @ i_B(V'),((s,b,c),(stack')))"))


(define c-ast (append
               i-ast
               '((component
                  c
                  (ports (provides i j)
                         (requires i k))
                  (behaviour
                   B
                   (types (enum S (S1 S2)))
                   (variables
                    (variable s (type S) (expression (literal #f S S1)))
                    (variable b (type bool) (expression false))
                    (variable c (type bool) (expression true)))
                   (compound
                    (on ((trigger j e))
                        (compound))))))))

