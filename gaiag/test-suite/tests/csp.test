;; -*-scheme-*-

(read-set! keywords 'prefix)

(define-module (test-suite tests csp)
  :use-module (test-suite lib)
  :use-module (test-suite misc)

  :use-module (ice-9 and-let-star)
  :use-module (ice-9 pretty-print)
  :use-module (ice-9 match)

  :use-module (gaiag csp)
  :use-module (gaiag misc)
  :use-module (gaiag resolve)
  :use-module (gaiag ast))

;; JUNKME
(define (ast->sugar ast)
  (match ast
    ;; (('provides type name) `(port ,name ,type provides))
    ;; (('requires type name injected ...) `(port ,name ,type requires ,injected))
    (('on ('triggers t ...) statement) ast)
    (('on triggers statement) (list 'on (cons 'triggers (map ast->trigger-sugar triggers)) statement))
    (_ ast)))

(define (ast->trigger-sugar ast)
  (match ast
    ((port event) (cons 'trigger ast))
    ((? symbol?) (cons 'trigger (list #f ast)))
    (_ ast)))

(define ast-transform- (@@ (gaiag csp) ast-transform-))
(define ast-transform-return (@@ (gaiag csp) ast-transform-return))
(define statement-on-p/r (@@ (gaiag csp) statement-on-p/r))
(define om:component (@@ (gaiag csp) om:component))
(define purge-data (@@ (gaiag csp) purge-data))
(define tail-call (@@ (gaiag csp) tail-call))
(define csp-expression->string (@@ (gaiag csp) csp-expression->string))

(define (csp-expression->string* ast expression locals)
  (csp-expression->string (csp->om ast) (csp->sugar expression) locals))

(define (ast-transform* ast src)
  (let ((root (csp->om ast)))
    ((om:register csp:norm) root #t)
    (ast-transform- root
                    (ast-transform-return root
                                          (purge-data root (csp->om src))))))

(define (purge-data* ast src)
  (let ((root (csp->om ast)))
    ((om:register csp:norm) root #t)
    (purge-data root (csp->om src))))

(define (ast-transform-return* ast src)
  (let ((root (csp->om ast)))
    ((om:register csp->om) root #t)
    (ast-transform-return root (csp->om src))))

(define (csp-transform* ast src)
  (let ((root (csp->om ast)))
    ((om:register csp->om) root #t)
    (->string (csp-transform root (csp->om src)))))

(define (csp->om ast)
  ((compose ast->om csp->sugar ast->sugar) ast))

(define (csp->sugar ast)
  ;;(stderr "csp->sugar: ~a\n" ast)
  (match ast
    (('expression expression)
     (make <expression> :value (csp->om expression)))
    (('csp-on context ('triggers triggers) statement)
     (make <csp-on>
       :context (csp->om context)
       :triggers (csp->om (caddr ast))
       :statement (csp->om statement)))
    (('csp-on context triggers statement)
     (make <csp-on>
       :context (csp->om context)
       :triggers (make <triggers>
                   :elements (csp->om (map ast->trigger-sugar triggers)))
       :statement (csp->om statement)))
    (('csp-if context expression then else)
     (make <csp-if>
       :context (csp->om context)
       :expression (csp->om expression)
       :then (csp->om then)
       :else (csp->om else)))
    (('csp-call context name)
     (make <csp-call>
       :context (csp->om context)
       :identifier name))
    (('csp-call context name arguments)
     (make <csp-call>
       :context (csp->om context)
       :identifier name
       :arguments (csp->om arguments)))
    (('csp-call context name arguments last?)
     (make <csp-call>
       :context (csp->om context)
       :identifier name
       :arguments (csp->om arguments)
       :last? last?))
    (('csp-reply context expression)
     (make <csp-reply>
       :context (csp->om context)
       :expression (csp->om expression)))
    (('csp-return context expression)
     (make <csp-return>
       :context (csp->om context)
       :expression (csp->om expression)))
    (('context) (make <context>))
    (('context members) (make <context> :members (csp->om members)))
    (('context members locals) (make <context> :members (csp->om members) :locals (csp->om locals)))
    (('literal scope type field) (make <literal> :scope scope :type type :field field))
    (('csp-variable context name type expression)
     (make <csp-variable>
       :context (csp->om context)
       :name name
       :type (csp->om type)
       :expression (csp->om expression)))
    (('csp-assign context identifier expression expressions)
     (make <csp-assign>
       :context (csp->om context)
       :identifier identifier
       :expression (csp->om expression)
       :expressions (csp->om expressions)))
    (('voidreply) (make <voidreply>))
    (('vector identifiers ...) (make <context-vector> :elements identifiers))
    (('skip) (make <skip>))
    ((h t ...) (map csp->sugar ast))
    (_ ast)))

(define (csp-noisy-equal? actual expected)
  (let ((actual* (om->list (csp->om actual)))
        (expected* (om->list (csp->om expected))))
   (or (equal? actual* expected*)
       (fail "~a\n!=\n~a\n" expected* actual*))))

(define (csp-pretty-noisy-equal? actual expected)
  (let ((actual* (om->list (csp->om actual)))
        (expected* (om->list (csp->om expected))))
  (or (equal? actual* expected*)
      (fail "~a!=\n~a" (pretty-string expected*) (pretty-string actual*)))))

(define i-ast '((interface i
                  (types (enum Status #f (fields Yes No))
                         (extern xint #f int&))
                  (events (event e (signature (type void)) in)
                          (event f (signature (type Status)) in)
                          (event g (signature (type void)) out)
                          (event h (signature (type void)) out)
                          (event ei (signature (type void)
                              (formals (formal in (type xint))))
                              in))
                  (behaviour
                   B
                   (types (enum S #f (fields S1 S2))
                          (int I02 #f (range 0 2)))
                   (variables
                    (variable s (type S) (action (trigger S S1)))
                    (variable b (type bool) (expression false))
                    (variable c (type I02) (expression 0)))
                   (functions
                    (function toggle (signature (type void)) #f (compound))
                    (function vtoggle (signature (type bool)) #f (compound))
                    (function f (signature (type IO2)) #f (compound))
                    (function g (signature (type void) (formals (formal b1 (type bool)) (formal b2 (type bool)))) #f (compound))
                    (function funx (signature (type S) (formals (formal xi (type xint)))) #f (compound)))
                   (compound)))))


