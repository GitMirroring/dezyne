  '(on ((trigger i e))
    (semi (semi (assign
                 (ctx ((b)))
                 (expression (ctx (((! b))))))
                (context-active
                  ((ctx ((b))) c (call g (arguments (expression b))))
                  (context-active
                    ((ctx ((b) c)) d (call g (arguments (expression c))))
                    (context-active
                      ((ctx ((b) c d)) cc (call g (arguments (expression c))))
                      (context-active
                        ((ctx ((b) c d cc)) dd (call g (arguments (expression d))))
                        (if (ctx ((b) c d cc dd))
                          (expression dd)
                          (action (trigger i f))
                          ()))))))
          (eventreturn))
    (the-end (b))))

