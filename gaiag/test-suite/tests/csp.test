(define callvalued-on-deep
  '(on ((trigger i e))
       (compound
        (assign b (expression (! b)))
        (variable (type bool) c (call g (arguments (expression b))))
        (variable (type bool) d (call g (arguments (expression c))))
        (compound
         (variable (type bool) cc (call g (arguments (expression c))))
         (variable (type bool) dd (call g (arguments (expression d))))
         (if (expression dd)
             (compound (action (trigger i f))))))))

