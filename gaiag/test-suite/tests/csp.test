(define alarm-ast
  '((component
     Alarm
     (ports (provides IConsole console)
            (requires ISensor sensor)
            (requires ISiren siren))
     (behaviour
      d
      (types (enum States
                   (Disarmed Armed Triggered Disarming)))
      (variables
       (variable state (type States) (expression (literal #f States Disarmed)))
       (variable sounding (type bool) (expression false)))
      (compound
       (on ((trigger sensor triggered))
           (compound
            (action (trigger console detected))
            (action (trigger siren turnon))
            (assign sounding (expression true))
            (assign state (expression (literal #f States Triggered))))))))))


(define csp-transform-alarm-snippet-via
  '(csp-on (context (state sounding)) ((trigger sensor triggered))
    (semi (semi (action (trigger console detected))
                (semi (action (trigger siren turnon))
                      (semi (csp-assign (context (unused)) sounding
                             (context (state sounding))
                             (context (state true)))
                            (csp-assign (context (unused)) state
                             (context (state sounding))
                             (context ((literal #f States Triggered) sounding))))))
          (voidreply))))

(pass-if "c-ast-transform-alarm-snippet"
         (csp-pretty-noisy-equal?
          (ast-transform*
           alarm-ast

           ;;from
           '(on ((trigger sensor triggered))
