(define member-i-ast
  '((interface i
      (types)
      (events (event e (signature (type void)) in))
      (behaviour
       B
       (types)
       (variables)
       (functions)
       (compound)))))

(define member-c-ast
  (append
   member-i-ast
   '((component c
               (ports)
               (behaviour
                B
                (types)
                (variables)
                (functions)
                (compound))))))

(pass-if "no-members"
         (diff-noisy-equal?
          (csp-transform* member-i-ast '(csp-on (context) (e) (voidreply)))
          "i?x:{e} -> (
i_'.return ->
i.the_end' ->
i_B()
)"))

(pass-if "unbehaved"
         (diff-noisy-equal?
          (behaviour->csp (om:component (ast->om member-c-ast)))
          "STOP"))

(define guard-i-ast
