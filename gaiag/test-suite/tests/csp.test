(\\ P',V' @ i_''!f -> P'(V')),
skip_
)))),
(\\ P',V' @ I_'.return -> P'(V')))(\\ V' @ transition_end -> arguments_(V'),((b),(stack')))"))

(define callvalued-on-2
  '(on ((trigger i e))
       (compound
        (assign b (expression (! (var b))))
        (variable c (type bool)
                  (call h (arguments (expression (var s)) (expression (var b)))))
        (assign b (call h (arguments (expression (var s)) (expression (var b)))))
        (if (expression (var c))
            (compound (action (trigger i f)))))))

(define csp-callvalued-on-2
  '(csp-on (context (b)) ((trigger i e))
           (semi (semi (csp-assign (context (unused)) b (context (b))
                                   (context ((! (var b)))))
                (csp-variable (context (b)) c (type bool)
                 (call h (arguments (expression (var s)) (expression (var b))))
                  (semi (csp-assign (context (b) (c))
                                    b
                                    (call h (arguments (expression (var s))
                                                       (expression (var b))))
                                    (context (r') (c)))
                        (csp-if (context (b) (c))
                          (expression (var c))
                          (action (trigger i f))
                          ()))))
          (voidreply))))

(pass-if "ast-transform-callvalued-2"
         (csp-pretty-noisy-equal?

          ;; from:
          (ast-transform* callvalued-c-ast callvalued-on-2)

          ;; via:
          csp-callvalued-on-2))


(pass-if "csp-transform-callvalued-2"
         (diff-noisy-equal?

          ;; from:
          (csp-transform* callvalued-c-ast csp-callvalued-on-2)
          ;; via:
         "i?x:{e} ->
semi_(semi_(assign_(\\ ((b),(stack')) @ (((not b)),(stack'))),
context_active_(call_args_(\\ P',V' @ h(P',V'),(\\ ((b),(stack')) @ (s,b))),
semi_(assign_active_(call_args_(\\ P',V' @ h(P',V'),(\\ ((b),((stack',c))) @ (s,b))),
\\ ((b),((stack',c))),r' @ ((r'),((stack',c)))),
ifthenelse_(\\ ((b),((stack',c))) @ (c),
(\\ P',V' @ i_''!f -> P'(V')),
skip_
)))),
(\\ P',V' @ I_'.return -> P'(V')))(\\ V' @ transition_end -> arguments_(V'),((b),(stack')))"))


(define doc
"
  on i.e:
    {
      b = ! b;
      bool c = g (b);
      bool d = g (c);

      {
        bool cc = g (c);
        bool dd = g (d);

        if(c)
        {
          f;
        }
      }
   }

")

;; '

(define callvalued-on-deep
  '(on ((trigger i e))
       (compound
        (assign b (expression (! (var b))))
        (variable c (type bool) (call g (arguments (expression (var b)))))
        (variable d (type bool) (call g (arguments (expression (var c)))))
        (compound
         (variable cc (type bool) (call g (arguments (expression (var c)))))
         (variable dd (type bool) (call g (arguments (expression (var d)))))
         (if (expression (var dd))
             (compound (action (trigger i f))))))))

(define csp-callvalued-on-deep
  '(csp-on
    (context (b))
    (triggers (trigger i e))
    (semi (semi (csp-assign (context (unused)) b
                   (context (b))
                   (context ((! (var b)))))
                  (csp-variable
                   (context (b))
                   c
                   (type bool #f)
                   (call g (arguments (expression (var b))))
                   (csp-variable
                    (context (b) (c))
                    d
                    (type bool #f)
                    (call g (arguments (expression (var c))))
                    (csp-variable
                     (context (b) (c d))
                     cc
                     (type bool #f)
                     (call g (arguments (expression (var c))))
                     (csp-variable
                      (context (b) (c d cc))
                      dd
                      (type bool #f)
                      (call g (arguments (expression (var d))))
                      (csp-if (context)
                       (expression (var dd))
                       (action (trigger i f))
                       ()))))))
           (voidreply))))

(pass-if "ast-transform-callvalued-deep"
         (csp-pretty-noisy-equal?

          ;; from:
          (ast-transform* callvalued-c-ast callvalued-on-deep)

          ;; via:
          csp-callvalued-on-deep))

