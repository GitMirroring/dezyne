;; -*-scheme-*-
;; This file is part of Gaiag, Guile in Asd In Asd in Guile.

(read-set! keywords 'prefix)

(define-module (test-handler)
  :use-module (test-suite lib)
  :use-module (test-suite misc)

  :use-module (gaiag reader)
  :use-module (gaiag annotate))

(define annotate-locations (@@ (gaiag annotate) annotate-locations))

(pass-if "annotate-first-dummy-test"
  #t)

(define ast (read-ast "examples/loc.dzn"))

(define locations
  '(locations
  (root ((location "examples/loc.dzn" 0 0 0 #f)
         interface
         ((location "examples/loc.dzn" 0 10 10 #f)
          name
          iloc)
         (types)
         (events
           (event e
                  (signature
                    ((location "examples/loc.dzn" 2 5 22 #f)
                     type
                     void))
                  in)
           (event a
                  (signature
                    ((location "examples/loc.dzn" 2 5 22 #f)
                     type
                     void))
                  out))
         (behaviour
           #f
           (types)
           (ports)
           (variables)
           (functions)
           ((location "examples/loc.dzn" 4 2 50 #f)
            compound
            ((location "examples/loc.dzn" 6 4 68 #f)
             on
             (triggers
               ((location "examples/loc.dzn" 6 7 71 #f)
                trigger
                #f
                e
                (arguments)))
             ((location "examples/loc.dzn" 6 10 74 #f)
              action
              (trigger #f a (arguments)))))))
        ((location "examples/loc.dzn" 10 0 84 #f)
         component
         ((location "examples/loc.dzn" 10 10 94 #f)
          name
          loc)
         (ports (port i
                      ((location "examples/loc.dzn" 12 11 111 #f)
                       name
                       iloc)
                      provides
                      #f
                      #f))
         (behaviour
           #f
           (types)
           (ports)
           (variables)
           (functions)
           ((location "examples/loc.dzn" 13 2 121 #f)
            compound
            ((location "examples/loc.dzn" 15 4 139 #f)
             on
             (triggers
               ((location "examples/loc.dzn" 15 7 142 #f)
                trigger
                i
                e
                (arguments)))
             ((location "examples/loc.dzn" 15 14 149 #f)
              action
              (trigger i a (arguments))))))))))

(pass-if "annotate-extract"
  (pretty-noisy-equal?
   (extract-locations (read-dzn "examples/loc.dzn"))
   locations))

(pass-if "annotate-apply"
  (pretty-noisy-equal?
   (extract-locations (annotate-locations (append ast (list locations))))
   locations))
