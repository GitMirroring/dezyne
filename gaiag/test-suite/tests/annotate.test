;; -*-scheme-*-
;; This file is part of Gaiag, Guile in Asd In Asd in Guile.

(read-set! keywords 'prefix)

(define-module (test-handler)
  :use-module (test-suite lib)
  :use-module (test-suite misc)

  :use-module (gaiag reader)
  :use-module (gaiag annotate))

(define annotate-locations (@@ (gaiag annotate) annotate-locations))

(pass-if "annotate-first-dummy-test"
  #t)

(define ast
  '(root (interface
        iloc
        (types)
        (events
          (in (signature (type void)) e)
          (out (signature (type void)) a))
        (behaviour
          #f
          (types)
          (variables)
          (functions)
          (compound
            (on (triggers (trigger #f e))
                (action (trigger #f a))))))
      (component
        loc
        (ports (provides iloc i #f))
        (behaviour
          #f
          (types)
          (variables)
          (functions)
          (compound
            (on (triggers (trigger i e))
                (action (trigger i a))))))))

(define locations
  '(locations
  (root ((location "examples/loc.dzn" 0 0 0 #f)
         interface
         iloc
         (types)
         (events
           (in (signature
                 ((location "examples/loc.dzn" 2 5 22 #f)
                  type
                  void))
               e)
           (out (signature
                  ((location "examples/loc.dzn" 2 5 22 #f)
                   type
                   void))
                a))
         (behaviour
           #f
           (types)
           (variables)
           (functions)
           (compound
             ((location "examples/loc.dzn" 6 4 64 #f)
              on
              (triggers
                ((location "examples/loc.dzn" 6 7 67 #f)
                 trigger
                 #f
                 e))
              ((location "examples/loc.dzn" 6 10 70 #f)
               action
               (trigger #f a))))))
        ((location "examples/loc.dzn" 10 0 80 #f)
         component
         loc
         (ports (provides iloc i #f))
         (behaviour
           #f
           (types)
           (variables)
           (functions)
           (compound
             ((location "examples/loc.dzn" 15 4 135 #f)
              on
              (triggers
                ((location "examples/loc.dzn" 15 7 138 #f)
                 trigger
                 i
                 e))
              ((location "examples/loc.dzn" 15 12 143 #f)
               action
               (trigger i a)))))))))

(pass-if "annotate-extract"
  (pretty-noisy-equal?
   (extract-locations (read-dezyne "examples/loc.dzn"))
   locations))

(pass-if "annotate-apply"
  (pretty-noisy-equal?
   (extract-locations (annotate-locations (append ast (list locations))))
   locations))
