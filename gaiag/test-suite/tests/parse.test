(read-set! keywords 'prefix)

(define-module (test-handler)
  :use-module (test-suite lib)
  :use-module (test-suite misc)

  :use-module (gaiag reader))

(pass-if "asd-first-dummy-test"
	 #t)

(pass-if "asd-parse-interface"
  (pretty-noisy-equal?
   (asd->ast
    #{ interface i { } #}
    )
   '((interface i (types) (events) (no-behaviour)))))

(pass-if "asd-parse-component"
  (pretty-noisy-equal?
   (asd->ast
    #{ component c { } #}
    )
   '((component c (ports) (no-behaviour)))))
