(pass-if "ast:resolve-reply-value-interface"
         (om-pretty-noisy-equal?
          (ast:resolve*
           (resolve-interface)
           '(on (triggers (trigger #f foo (arguments)))
                (compound
                 (reply (expression (dotted ivar mixed v))))))
          '(on (triggers (trigger #f foo (arguments)))
                (compound
                 (reply (expression (literal (scope.name (ivar) mixed) v)))))))

(pass-if "ast:resolve-guarded-reply-value-interface"
         (om-pretty-noisy-equal?
          (ast:resolve*
           (resolve-interface)
           '(guard (expression false)
                   (on (triggers (trigger #f foo (arguments)))
                       (compound
                        (guard
                         (expression true)
                         (compound
                          (reply (expression (dotted ivar mixed v)))))))))

          '(guard
            (expression false)
            (on (triggers (trigger #f foo (arguments)))
                 (compound
                  (guard
                   (expression true)
                   (compound
                    (reply (expression (literal (scope.name (ivar) mixed) v))))))))))

(pass-if "ast:resolve-reply-value-component"
         (om-pretty-noisy-equal?
          (ast:resolve*
           (resolve-component)
           '(on (triggers (trigger o foo (arguments)))
                (compound
                 (reply (expression (dotted ivar mixed v))))))

          '(on (triggers (trigger o foo (arguments)))
                (compound
                 (reply (expression (literal (scope.name (ivar) mixed) v)))))))

