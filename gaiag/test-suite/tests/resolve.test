(pass-if "ast:resolve-system"
         (gom-pretty-noisy-equal?
          (ast:resolve-model
           '(system
             AlarmSystem
             (ports (provides Console console))
             (compound
              (instance alarm Alarm)
              (instance sensor Sensor)
              (instance siren Siren)
              (bind (binding #f console) (binding alarm console))
              (bind (binding alarm sensor) (binding sensor sensor))
              (bind (binding alarm siren) (binding siren siren)))))
          '(system
            AlarmSystem
            (ports (provides Console console))
            (instances
             (instance alarm Alarm)
             (instance sensor Sensor)
             (instance siren Siren))
            (bindings
             (bind (binding #f console) (binding alarm console))
             (bind (binding alarm sensor) (binding sensor sensor))
             (bind (binding alarm siren) (binding siren siren))))))

