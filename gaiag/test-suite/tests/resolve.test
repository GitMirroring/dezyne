           namespace-om
           (resolve-namespace-component)
           '(variable state (type (dotted foo I Bool)) (expression (dotted foo I Bool t))))
          '(variable state (type (scope.name (foo I) Bool)) (expression (literal (scope.name (foo I) Bool) t)))))

(pass-if "ast:resolve-undefined-identifier"
  (om-pretty-noisy-equal?
   (ast:resolve*
    (resolve-interface)
    '(assign q true))
   (undefined-error '(assign q true) 'q)))

(pass-if "ast:resolve-undefined-action"
  (om-pretty-noisy-equal?
   (ast:resolve*
    (resolve-interface)
    '(action (trigger #f q (arguments))))
   (resolve-error '(action (trigger #f q (arguments))) 'q "undefined function or event: ~a")))

(pass-if "ast:resolve-undefined-call"
  (om-pretty-noisy-equal?
   (ast:resolve*
    (resolve-interface)
    '(call q (arguments) #f))
