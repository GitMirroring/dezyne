  (om-pretty-noisy-equal?
   (ast:resolve*
    (resolve-interface)
    '(root (variable b (type bool) (expression 0))))
   `(root ,(type-mismatch '(expression 0) 'bool 'int))))

(pass-if "ast:resolve-init-enum-mismatch"
  (om-pretty-noisy-equal?
   (ast:resolve*
    (resolve-interface)
    '(root (variable b (type bool) (dotted ivar state one))))
   `(root ,(type-mismatch '(dotted ivar state one) 'bool 'ivar.state))))

(pass-if "ast:resolve-init-enum-mismatch"
  (om-pretty-noisy-equal?
   (ast:resolve*
    (resolve-component)
    '(root (variable b (type bool) (dotted ivar e v))))
   `(root ,(type-mismatch '(dotted ivar e v) 'bool 'ivar.e))))

(pass-if "ast:resolve-extern-mismatch"
         (om-pretty-noisy-equal?
          (ast:resolve*
           (resolve-interface)
           '(root (variable e (type (dotted ivar xint)) (expression 0))))
          `(root ,(type-mismatch '(expression 0) 'ivar.xint 'int))))

(pass-if "ast:resolve-bool-unspecified-mismatch"
         (om-pretty-noisy-equal?
          (ast:resolve*
           (resolve-interface)
           '(root (variable e (type bool) (expression))))
          `(root ,(resolve-error '(variable e (type bool) (expression)) 'e "undefined variable value: ~a"))))

(pass-if "ast:resolve-argument-count-mismatch"
         (om-pretty-noisy-equal?
          (ast:resolve*
           (resolve-component)
           '(call rfun (arguments (expression true)) #f))
          (resolve-error '(call rfun (arguments (expression true)) #f)
                         'rfun
                         (format #f "function ~a expects ~a arguments, found: ~a" "~a" 0 1))))

(pass-if "ast:resolve-variable-range-error"
         (or #t ;; disable range checks
             (om-pretty-noisy-equal?
              (ast:resolve*
               '(interface
                 I
                 (types (int I02 #f (range 0 2)))
                 (events)
                 (behaviour
                  #f
                  (types)
                  (variables
                   (variable i (type (dotted I02)) (expression 3)))
                  (functions)
                  (compound))))
              `(interface
                I
                (types (int I02 #f (range 0 2)))
                (events)
                (behaviour
                 #f
                 (types)
                 (variables
                  ,(resolve-error '(variable i (type (dotted I02)) (expression 3))
                                  'i
                                  (format #f "variable ~a out of range, expected ~a..~a, found: ~a" "~a" 0 2 3)))
                 (functions)
                 (compound))))))

(read-hash-extend #\{ hash-read-string)
