(pass-if "ast:resolve-value-field-interface"
         (om-pretty-noisy-equal?
          (ast:resolve*
           (resolve-interface)
           '(guard (expression (dotted m one)) (illegal)))
          '(guard (expression (field m one)) (illegal))))

(pass-if "ast:resolve-shadow-event"
         (om-pretty-noisy-equal?
          (ast:resolve*
           (resolve-interface)
           '(compound
             (variable foo (type bool) (expression true))
             (assign b (expression (var foo)))))
          '(compound
            (variable foo (type bool) (expression true))
            (assign b (expression (var foo))))))

(define resolve-system
  '(component
    trap
    (ports (provides I (dotted i)) (requires U (dotted u)))
    (system
     #f
     (compound
      (instance trip u)
      (bind i (binding u i))
      (bind (binding u u) u)))))

(pass-if "ast:resolve-member"
         (om-pretty-noisy-equal?
          (ast:resolve*
           (resolve-component)
           '(assign m (expression (var m))))
          '(assign m (expression (var m)))))

(pass-if "ast:resolve-local"
         (om-pretty-noisy-equal?
          (ast:resolve*
           (resolve-component)
           '(compound
             (variable e (type (dotted ivar e)) (expression (dotted o foo)))
             (assign e (expression (var e)))))
          '(compound
             (variable e (type (scope.name (ivar) e)) (action (trigger o foo (arguments))))
             (assign e (expression (var e))))))

(pass-if "ast:resolve-local-if"
         (om-pretty-noisy-equal?
          (ast:resolve*
           (resolve-interface)
           '(compound
             (variable c (type bool) (expression true))
             (assign b (call g (arguments (expression (var c)) (expression (var c))) #f))
             (if (expression (var c))
                 (compound))))
          '(compound
             (variable c (type bool) (expression true))
             (assign b (call g (arguments (expression (var c)) (expression (var c))) #f))
             (if (expression (var c))
                 (compound)))))

