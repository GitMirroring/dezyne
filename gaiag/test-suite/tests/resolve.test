             (assign b (call g (arguments (expression (var c)) (expression (var c)))))
             (if (expression (var c))
                  (compound))))
          '(compound
             (variable c (type bool) (expression true))
             (assign b (call g (arguments (expression (var c)) (expression (var c)))))
             (if (expression (var c))
                  (compound)))))

