;; -*-scheme-*-

(read-set! keywords 'prefix)

(define-module (test-handler)
  :use-module (test-suite lib)
  :use-module (test-suite misc)

  :use-module (gaiag resolve)

  :use-module (oop goops)
  :use-module (gaiag gom))

(define resolve-model (@@ (gaiag resolve) resolve-model))
(define resolve-mixed (@@ (gaiag resolve) resolve-mixed))

(define-method (ast:resolve-model o)
  (let* ((gom (ast->gom o))
         (m (resolve-mixed gom)))
    (resolve-model m m)))

(define-method (ast:resolve-model (model <list>) o)
  (let ((model (resolve-mixed (ast->gom model))))
    (resolve-model model (ast->gom o))))

(define-method (ast:resolve-root-model (root <list>) (model <list>) o)
  (let* ((root (ast:resolve root))
         (model (resolve-mixed (ast->gom model))))
    (resolve-model model (ast->gom o))))

(pass-if "resolve-first-dummy-test"
         #t)

(define resolve-ast
  '((interface
        ivar
      (types (enum e (v)))
      (events (in (signature (type e)) foo)
              (enum mixed (v))
              (in (signature (type mixed)) bar))
      (behaviour
       #f
       (types
        (enum state (one two)))
       (variables
        (variable (type state) m (expression (value state one)))
        (variable (type bool) b (expression true)))
       (functions (function toggle (signature (type void)) (compound))
                  (function g
                            (signature (type bool)
                                       (parameters (parameter (type bool) ga)
                                                   (parameter (type bool) gb)))
                            (compound))
                  (function efun
                            (signature (type state)) (compound (return m))))
       (compound
        (on (triggers (trigger #f foo))
            (reply (expression (value e v)))))))
    (component
     var
     (ports (provides ivar i) (requires ivar o))
     (behaviour
      #f
      (types
       (enum state (one two)))
      (variables
       (variable (type state) m (expression (value state one)))
       (variable (type bool) b true))
       (functions
        (function fun (signature (type void) (parameters (parameter (type bool) a)))
                  (compound (assign a (expression true))))
        (function rfun (signature (type void) (parameters))
                  (compound (call rgun)))
        (function rgun (signature (type void) (parameters (parameter (type bool) a)))
                  (compound (call rgun)))
        (function fa (signature (type void) (parameters (parameter (type bool) a)))
                  (compound (call fb)))
        (function fb (signature (type void) (parameters (parameter (type bool) a)))
                  (compound (call fc)))
        (function fc (signature (type void) (parameters (parameter (type bool) a)))
                  (compound (assign b (expression true))))
        (function rfa (signature (type void) (parameters (parameter (type bool) a)))
                  (compound (call rfb)))
        (function rfb (signature (type void) (parameters (parameter (type bool) a)))
                  (compound (call rfc)))
        (function rfc (signature (type void) (parameters (parameter (type bool) a)))
                  (compound (call rfa)))
        (function rbfa (signature (type void) (parameters (parameter (type bool) a)))
                  (assign b (call rbfb)))
        (function rbfb (signature (type void) (parameters (parameter (type bool) a)))
                  (compound (assign b (call rbfc))))
        (function rbfc (signature (type void) (parameters (parameter (type bool) a)))
                  (compound (call f) (call g) (compound (call d) (assign b (call rbfa))))))
      (compound
       (on (triggers (trigger i foo))
           (compound
            (variable (type ivar (type e)) e (expression (value o foo)))
            (assign e (expression (value o foo)))))
       (reply e))))))

(pass-if "ast:resolve-function-call"
         (gom-pretty-noisy-equal?
          (ast:resolve-model
           (car resolve-ast)
           '(on (triggers ((trigger #f e)))
                (compound
                 (action toggle))))
          '(on (triggers ((trigger #f e)))
               (compound
                (call toggle)))))

(pass-if "ast:resolve-variable-valued-function-call"
         (gom-pretty-noisy-equal?
          (ast:resolve-model
           (car resolve-ast)
           '(variable (type ivar (type e))
                      e
                      (expression efun)))
          '(variable (type e ivar) e (call efun))))

(pass-if "ast:resolve-assign-valued-function-call"
         (gom-pretty-noisy-equal?
          (ast:resolve-model
           (car resolve-ast)
           '(assign m (expression efun)))
          '(assign m (call efun))))

(pass-if "ast:resolve-variable-valued-action"
         (gom-pretty-noisy-equal?
          (ast:resolve-root-model
           resolve-ast
           (cadr resolve-ast)
           '(on (triggers (trigger o foo))
                (compound
                 (variable (type ivar (type e))
                           e
                           (expression (value o foo))))))

          '(on (triggers (trigger o foo))
               (compound
                (variable (type ivar (type e))
                          e
                          (action (trigger o foo)))))))

(pass-if "ast:resolve-assign-valued-action"
         (gom-pretty-noisy-equal?
          (ast:resolve-model
           (cadr resolve-ast)
           '(on (triggers (trigger o foo))
                (compound
                 (assign e (expression (value o foo))))))

          '(on (triggers (trigger o foo))
               (compound
                (assign e (action (trigger o foo)))))))

(pass-if "ast:resolve-reply-value-interface"
         (gom-pretty-noisy-equal?
          (ast:resolve-model
           (car resolve-ast)
           '(on (triggers (trigger #f bar))
                (compound
                 (reply (expression (value mixed v))))))

          '(on (triggers (trigger #f bar))
                (compound
                 (reply (expression (literal #f mixed v)))))))

(pass-if "ast:resolve-guarded-reply-value-interface"
         (gom-pretty-noisy-equal?
          (ast:resolve-model
           (car resolve-ast)
           '(guard (expression false)
                   (on (triggers (trigger #f bar))
                       (compound
                        (guard
                         (expression true)
                         (compound
                          (reply (expression (value mixed v)))))))))

          '(guard
            (expression false)
            (on (triggers (trigger #f bar))
                 (compound
                  (guard
                   (expression true)
                   (compound
                    (reply (expression (literal #f mixed v))))))))))

(pass-if "ast:resolve-reply-value-component"
         (gom-pretty-noisy-equal?
          (ast:resolve-model
           (cadr resolve-ast)
           '(on (triggers (trigger o bar))
                (compound
                 (reply (expression (literal ivar mixed v))))))

          '(on (triggers (trigger o bar))
                (compound
                 (reply (expression (literal ivar mixed v)))))))

(pass-if "ast:resolve-value-enum-value"
         (gom-pretty-noisy-equal?
          (ast:resolve-model
           (cadr resolve-ast)
           '(variables
             (variable (type state) m (expression (value state one)))))
          '(variables
            (variable (type state) m (expression (literal #f state one))))))

(pass-if "ast:resolve-value-field-interface"
         (gom-pretty-noisy-equal?
          (ast:resolve-model
           (car resolve-ast)
           '(guard (expression (value m one)) (illegal)))
          '(guard (expression (field m one)) (illegal))))

(define resolve-system
  '(component
    trap
    (ports (provides I i) (requires U u))
    (system
     #f
     (compound
      (instance trip u)
      (bind i (value u i))
      (bind (value u u) u)))))

(pass-if "ast:resolve-system"
         (gom-pretty-noisy-equal?
          (ast:resolve-model
           resolve-system
           '(component c (ports) (system #f (compound))))
          '(system c (ports) (instances) (bindings))))

(pass-if "ast:resolve-binds"
         (gom-pretty-noisy-equal?
          (ast:resolve-model
           resolve-system
           '(bind i (value u i)))
          '(bind (binding #f i) (binding u i))))

(pass-if "ast:resolve-member"
         (gom-pretty-noisy-equal?
          (ast:resolve-model
           (cadr resolve-ast)
           '(assign m (expression m)))
          '(assign m (expression (var m)))))

(pass-if "ast:resolve-local"
         (gom-pretty-noisy-equal?
          (ast:resolve-model
           (cadr resolve-ast)
           '(compound
             (variable (type ivar (type E)) e (expression (value o foo)))
             (assign e (expression e))))
          '(compound
             (variable (type ivar (type E)) e (action (trigger o foo)))
             (assign e (expression (var e))))))

(pass-if "ast:resolve-local-if"
         (gom-pretty-noisy-equal?
          (ast:resolve-model
           (cadr resolve-ast)
           '(compound
             (variable (type bool) c (expression true))
             (assign b (call g (arguments (expression c) (expression c))))
             (if (expression c)
                  (compound))))
          '(compound
             (variable (type bool) c (expression true))
             (assign b (call g (arguments (expression (var c)) (expression (var c)))))
             (if (expression (var c))
                  (compound)))))

(pass-if "ast:resolve-missing-local"
         (gom-pretty-noisy-equal?
          (ast:resolve-model
           (cadr resolve-ast)
           '(assign e (expression e)))
          '(assign e (expression e))))

(pass-if "ast:resolve-true"
         (gom-pretty-noisy-equal?
          (ast:resolve-model
           (cadr resolve-ast)
           '(assign b (expression true)))
          '(assign b (expression true))))

(pass-if "ast:resolve-parameter"
         (gom-pretty-noisy-equal?
          (ast:resolve-model
           (cadr resolve-ast)
           '(function fun (signature (type void) (parameters (parameter (type bool) a)))
                            (compound (assign b (expression a)))))
          '(function fun (signature (type void) (parameters (parameter (type bool) a)))
                     #f
                     (compound (assign b (expression (var a)))))))

(pass-if "ast:resolve-recursive"
         (gom-pretty-noisy-equal?
          (ast:resolve-model
           (cadr resolve-ast)
           '(function rgun (signature (type void) (parameters))
                      (compound (call rgun))))
          '(function rgun (signature (type void) (parameters))
                     recursive
                      (compound (call rgun)))))

(pass-if "ast:resolve-recursive-indirect"
         (gom-pretty-noisy-equal?
          (ast:resolve-model
           (cadr resolve-ast)
           '(function rfun (signature (type void) (parameters))
                      (compound (call rgun))))
          '(function rfun (signature (type void) (parameters))
                     recursive
                     (compound (call rgun)))))

(pass-if "ast:resolve-non-recursive-deep"
         (gom-pretty-noisy-equal?
          (ast:resolve-model
           (cadr resolve-ast)
           '(function fa (signature (type void) (parameters))
                      (compound (call fb))))
          '(function fa (signature (type void) (parameters))
                     #f
                     (compound (call fb)))))

(pass-if "ast:resolve-recursive-3"
         (gom-pretty-noisy-equal?
          (ast:resolve-model
           (cadr resolve-ast)
           '(function rfa (signature (type void) (parameters))
                      (compound (call rfb))))
          '(function rfa (signature (type void) (parameters))
                     recursive
                     (compound (call rfb)))))

(pass-if "ast:resolve-recursive-3-assign"
         (gom-pretty-noisy-equal?
          (ast:resolve-model
           (cadr resolve-ast)
           '(function rbfa (signature (type void) (parameters))
                      (assign b (compound (call rbfb)))))
          '(function rbfa (signature (type void) (parameters))
                     recursive
                      (assign b (compound (call rbfb))))))

(pass-if "ast:resolve-system"
         (gom-pretty-noisy-equal?
          (ast:resolve-model
           '(system
             AlarmSystem
             (ports (provides Console console))
             (compound
              (instance alarm Alarm)
              (instance sensor Sensor)
              (instance siren Siren)
              (bind console (value alarm console))
              (bind (value alarm sensor) (value sensor sensor))
              (bind (value alarm siren) (value siren siren)))))
          '(system
            AlarmSystem
            (ports (provides Console console))
            (instances
             (instance alarm Alarm)
             (instance sensor Sensor)
             (instance siren Siren))
            (bindings
             (bind (binding #f console) (binding alarm console))
             (bind (binding alarm sensor) (binding sensor sensor))
             (bind (binding alarm siren) (binding siren siren))))))

(pass-if "ast:resolve-component-system"
         (gom-pretty-noisy-equal?
          (ast:resolve-model
           '(system
             AlarmComponentSystem
            (ports (provides Console console))
             (instances
              (instance alarm Alarm)
              (instance sensor Sensor)
              (instance siren Siren)
              (bind console (binding alarm console))
              (bind (binding alarm sensor)
                    (binding sensor sensor))
              (bind (binding alarm siren) (binding siren siren)))
             (bindings)))
          '(system
            AlarmComponentSystem
            (ports (provides Console console))
            (instances
             (instance alarm Alarm)
             (instance sensor Sensor)
             (instance siren Siren))
            (bindings
             (bind (binding #f console) (binding alarm console))
             (bind (binding alarm sensor) (binding sensor sensor))
             (bind (binding alarm siren) (binding siren siren))))))
