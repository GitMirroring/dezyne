;; -*-scheme-*-

(define-module (test-handler)
  #:use-module (test-suite lib)
  #:use-module (test-suite misc)

  #:use-module (srfi srfi-1)
  #:use-module (ice-9 optargs)
  #:use-module (ice-9 match)

  #:use-module ((oop goops) #:renamer (lambda (x) (if (eq? x '<port>) 'goops:<port> x)))
  #:use-module (gaiag goops)
  #:use-module (gaiag util)
  #:use-module (gaiag ast2om)
  #:use-module (gaiag om)

  #:use-module (gaiag misc)
  #:use-module (gaiag reader)
  #:use-module (gaiag resolve)
  )

(define namespace-om
  ((compose ast:resolve ast->om dzn->ast) 'test-suite/tests/namespace.dzn))

(define resolve-om
  ((compose ast:resolve ast->om dzn->ast) 'test-suite/tests/resolve.dzn))

(define (resolve-namespace-interface)
  (om:find (is? <interface>) namespace-om))

(define (resolve-namespace-component)
  (om:find (is? <component>) namespace-om))

(eval-when (compile eval load) (read-hash-extend #\{ #f))

(define resolve (@@ (gaiag resolve) resolve))

(define (resolve-error o identifier message)
  (let ((e ((@@ (gaiag resolve) resolve-error) (ast->om `(root ,o)) identifier message)))
    (make <error> #:ast (car (.elements (.ast e))) #:message (.message e))))

(define (undefined-error o identifier)
  ((@@ (gaiag resolve) undefined-error) (ast->om o) identifier))

(define (type-mismatch o expected actual)
  ((@@ (gaiag resolve) type-mismatch) (ast->om o) expected actual))

(define (ast:resolve-root-model root model o)
  (let ((root (ast:resolve root)))
    ((resolve model '()) (ast->om o))))

(define (resolve-interface)
  (om:find (is? <interface>) resolve-om))

(define (resolve-component)
  (om:find (is? <component>) resolve-om))

(define (ast:resolve* m o)
  ((resolve m '()) (ast->om o)))

(pass-if "resolve-first-dummy-test"
         #t)

(pass-if "ast:resolve-function-call"
         (om-pretty-noisy-equal?
          (ast:resolve*
           (resolve-interface)
           '(on (triggers (trigger #f e (arguments)))
                (compound
                 (action (trigger #f toggle (arguments))))))
          '(on (triggers (trigger #f e (arguments)))
               (compound
                (call toggle (arguments) #f)))))

(pass-if "ast:resolve-variable-valued-function-call"
         (om-pretty-noisy-equal?
          (ast:resolve*
           (resolve-interface)
           '(root (variable e (type (dotted ivar e)) (expression (var efun)))))
          '(root (variable e (type (scope.name (ivar) e)) (call efun (arguments) #f)))))

(pass-if "ast:resolve-assign-valued-function-call"
         (om-pretty-noisy-equal?
          (ast:resolve*
           (resolve-interface)
           '(assign m (expression (var efun))))
          '(assign m (call efun (arguments) #f))))

(pass-if "ast:resolve-variable-valued-action"
         (om-pretty-noisy-equal?
          (ast:resolve-root-model
           resolve-om
           (resolve-component)
           '(on (triggers (trigger o foo (arguments)))
                (compound
                 (variable e (type (dotted ivar e)) (expression (dotted o foo))))))
          '(on (triggers (trigger o foo (arguments)))
               (compound
                (variable e (type (scope.name (ivar) e)) (action (trigger o foo (arguments))))))))

