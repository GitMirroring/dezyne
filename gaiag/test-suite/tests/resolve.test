          (ast:resolve-model*
           (car resolve-ast)
           '(guard (expression false)
                   (on (triggers (trigger #f foo))
                       (compound
                        (guard
                         (expression true)
                         (compound
                          (reply (expression (value mixed v)))))))))

          '(guard
            (expression false)
