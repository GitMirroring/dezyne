          (ast:resolve-root-model
           resolve-om
           (resolve-component)
           '(root (variable v (type (dotted ivar e)) (expression (action (trigger eo o (arguments (data 0))))))))
          '(root (variable v (type (scope.name (ivar) e)) (action (trigger eo o (arguments (data 0))))))))

