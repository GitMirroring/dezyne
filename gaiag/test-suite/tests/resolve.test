;; -*-scheme-*-

(read-set! keywords 'prefix)

(define-module (test-handler)
  :use-module (test-suite lib)
  :use-module (test-suite misc)

  :use-module (ice-9 optargs)
  :use-module (ice-9 match)  

  :use-module (gaiag misc)
  :use-module (gaiag resolve)

  :use-module (gaiag ast))

(eval-when (compile eval load) (read-hash-extend #\{ #f))

(define resolve-model (@@ (gaiag resolve) resolve-model))

(define (resolve-error o identifier message)
  (let ((e ((@@ (gaiag resolve) resolve-error) (ast->om `(root ,o)) identifier message)))
    (make <error> :ast (car (.elements (.ast e))) :message (.message e))))

(define (undefined-error o identifier)
  ((@@ (gaiag resolve) undefined-error) (ast->om o) identifier))

(define (type-mismatch o expected actual)
  ((@@ (gaiag resolve) type-mismatch) (ast->om o) expected actual))

(define* (ast:resolve-model* m :optional (o #f))
  (match o
    (#f
     (let* ((m (ast->om m)))
       ((resolve-model m '()) m)))
    (_
      (let ((m (ast->om m)))
        ((resolve-model m '()) (ast->om o))))))

(define (ast:resolve-root-model root model o)
  (let* ((root ((compose ast:resolve ast->om) root))
         (m (ast->om model)))
    ((resolve-model m '()) (ast->om o))))

(define resolve-ast
  '((interface
     ivar
      (types (enum e #f (fields v))
             (extern xint #f int&)
             (enum mixed #f (fields v)))
      (events (event foo (signature (type e)) in)
              (event bar (signature (type mixed)) out)
              (event ei (signature
                   (type void)
                   (formals (formal i (type xint) out)))
                  in)
              (event eo (signature
                   (type e)
                   (formals (formal i (type xint) in)))
                  out))
      (behaviour
       #f
       (types
        (enum state #f (fields one two))
        (int mode #f (range 0 3)))
       (variables
        (variable m (type state) (expression (value state one)))
        (variable b (type bool) (expression true))
        (variable x (type mixed) (expression (value mixed v))))
       (functions (function toggle (signature (type void)) #f (compound))
                  (function g
                            (signature (type bool)
                                       (formals (formal ga (type bool))
                                                   (formal gb (type bool))))
                            #f
                            (compound))
                  (function efun
                            (signature (type state)) #f (compound (return (var m)))))
       (compound
        (on (triggers (trigger #f foo))
            (reply (expression (value e v)))))))
    (component
     var
     (ports (port i ivar provides) (port o ivar requires))
     (behaviour
      #f
      (types
       (enum state #f (fields one two))
       (int mode #f (range 0 3)))
      (variables
       (variable m (type state) (expression (value state one)))
       (variable e (type e ivar) (expression (literal ivar e v)))
       (variable b (type bool) true))
       (functions
        (function fun (signature (type void) (formals (formal a (type bool)))) #f
                  (compound (assign a (expression true))))
        (function rfun (signature (type void) (formals)) #f
                  (compound (call rgun (arguments (expression #t)))))
        (function rgun (signature (type void) (formals (formal a (type bool)))) #f
                  (compound (call rgun (arguments (expression #t)))))
        (function fa (signature (type void) (formals (formal a (type bool)))) #f
                  (compound (call fb (arguments (expression #t)))))
        (function fb (signature (type void) (formals (formal a (type bool)))) #f
                  (compound (call fc (arguments (expression #t)))))
        (function fc (signature (type void) (formals (formal a (type bool)))) #f
                  (compound (assign b (expression true))))
        (function rfa (signature (type void) (formals (formal a (type bool)))) #f
                  (compound (call rfb (arguments (expression #t)))))
        (function rfb (signature (type void) (formals (formal a (type bool)))) #f
                  (compound (call rfc (arguments (expression #t)))))
        (function rfc (signature (type void) (formals (formal a (type bool)))) #f
                  (compound (call rfa (arguments (expression #t)))))
        (function rbfa (signature (type void) (formals (formal a (type bool)))) #f
                  (assign b (call rbfb (arguments (expression #t)))))
        (function rbfb (signature (type void) (formals (formal a (type bool)))) #f
                  (compound (assign b (call rbfc (arguments (expression #t))))))
        (function rbfc (signature (type void) (formals (formal a (type bool)))) #f
                  (compound (call fa (arguments (expression #t))) (call fb (arguments (expression #t))) (compound (call fc (arguments (expression #t))) (assign b (call rbfa (arguments (expression #t)))))))
        (function efun
                  (signature (type state)) #f (compound (return (var m)))))
       (compound
       (on (triggers (trigger i foo))
           (compound
            (variable e (type e ivar) (expression (value o foo)))
            (assign e (expression (value o foo)))
            (reply (expression (var e)))))
       (on (triggers
            (trigger i ei (arguments (expression (var i)))))
           (compound
            (assign i (expression (data 0))))))))))

(pass-if "resolve-first-dummy-test"
         #t)

(pass-if "ast:resolve-function-call"
         (om-pretty-noisy-equal?
          (ast:resolve-model*
           (car resolve-ast)
           '(on (triggers (trigger #f e))
                (compound
                 (action (trigger #f toggle)))))
          '(on (triggers (trigger #f e))
               (compound
                (call toggle)))))

(pass-if "ast:resolve-variable-valued-function-call"
         (om-pretty-noisy-equal?
          (ast:resolve-model*
           (car resolve-ast)
          '(root (variable e (type e) (expression (var efun)))))
          '(root (variable e (type e) (call efun)))))

