;; -*-scheme-*-

(read-set! keywords 'prefix)

(define-module (test-handler)
  :use-module (test-suite lib)
  :use-module (test-suite misc)

  :use-module (gaiag resolve)

  :use-module (oop goops)
  :use-module (gaiag gom))

;;(eval-when (expand) (read-hash-extend #\{ #f))
(eval-when (compile eval load) (read-hash-extend #\{ #f))

(define resolve-model (@@ (gaiag resolve) resolve-model))
(define resolve-mixed (@@ (gaiag resolve) resolve-mixed))

(define-method (undefined-error (o <list>) (identifier <symbol>))
  ((@@ (gaiag resolve) undefined-error) (ast->gom o) identifier))

(define-method (undefined-error (o <list>) (identifier <symbol>) (message <string>))
  ((@@ (gaiag resolve) undefined-error) (ast->gom o) identifier message))

(define-method (type-mismatch (o <list>) (expected <symbol>) (actual <symbol>))
  ((@@ (gaiag resolve) type-mismatch) (ast->gom o) expected actual))

(define-method (ast:resolve-model o)
  (let* ((gom (ast->gom o))
         (m (resolve-mixed gom)))
    (resolve-model m m)))

(define-method (ast:resolve-model (model <list>) o)
  (let ((model (resolve-mixed (ast->gom model))))
    (resolve-model model (ast->gom o))))

(define-method (ast:resolve-root-model (root <list>) (model <list>) o)
  (let* ((root (ast:resolve root))
         (model (resolve-mixed (ast->gom model))))
    (resolve-model model (ast->gom o))))

(define resolve-ast
  '((interface
     ivar
      (types (enum e (v))
             (extern xint int&))
      (events (in (signature (type e)) foo)
              (enum mixed (v))
              (out (signature (type mixed)) bar)
              (in (signature
                   (type void)
                   (parameters (parameter i (type xint) out)))
                  ei))
      (behaviour
       #f
       (types
        (enum state (one two))
        (int mode (range 0 3)))
       (variables
        (variable m (type state) (expression (value state one)))
        (variable b (type bool) (expression true))
        (variable x (type mixed) (expression (value mixed v))))
       (functions (function toggle (signature (type void)) (compound))
                  (function g
                            (signature (type bool)
                                       (parameters (parameter ga (type bool))
                                                   (parameter gb (type bool))))
                            (compound))
                  (function efun
                            (signature (type state)) (compound (return (var m)))))
       (compound
        (on (triggers (trigger #f foo))
            (reply (expression (value e v)))))))
    (component
     var
     (ports (provides ivar i) (requires ivar o))
     (behaviour
      #f
      (types
       (enum state (one two))
       (int mode (range 0 3)))
      (variables
       (variable m (type state) (expression (value state one)))
       (variable b (type bool) true))
       (functions
        (function fun (signature (type void) (parameters (parameter a (type bool))))
                  (compound (assign a (expression true))))
        (function rfun (signature (type void) (parameters))
                  (compound (call rgun)))
        (function rgun (signature (type void) (parameters (parameter a (type bool))))
                  (compound (call rgun)))
        (function fa (signature (type void) (parameters (parameter a (type bool))))
                  (compound (call fb)))
        (function fb (signature (type void) (parameters (parameter a (type bool))))
                  (compound (call fc)))
        (function fc (signature (type void) (parameters (parameter a (type bool))))
                  (compound (assign b (expression true))))
        (function rfa (signature (type void) (parameters (parameter a (type bool))))
                  (compound (call rfb)))
        (function rfb (signature (type void) (parameters (parameter a (type bool))))
                  (compound (call rfc)))
        (function rfc (signature (type void) (parameters (parameter a (type bool))))
                  (compound (call rfa)))
        (function rbfa (signature (type void) (parameters (parameter a (type bool))))
                  (assign b (call rbfb)))
        (function rbfb (signature (type void) (parameters (parameter a (type bool))))
                  (compound (assign b (call rbfc))))
        (function rbfc (signature (type void) (parameters (parameter a (type bool))))
                  (compound (call fa) (call fb) (compound (call fc) (assign b (call rbfa))))))
      (compound
       (on (triggers (trigger i foo))
           (compound
            (variable e (type e ivar) (expression (value o foo)))
            (assign e (expression (value o foo)))
            (reply (expression (var e)))))
       (on (triggers
            (trigger i ei (arguments (expression (var i)))))
           (compound
            (assign i (expression (data 0)))))
       (function efun
                 (signature (type state)) (compound (return (var m)))))))))

(pass-if "resolve-first-dummy-test"
         #t)

(pass-if "ast:resolve-function-call"
         (gom-pretty-noisy-equal?
          (ast:resolve-model
           (car resolve-ast)
           '(on (triggers (trigger #f e))
                (compound
                 (action (trigger #f toggle)))))
          '(on (triggers (trigger #f e))
               (compound
                (call toggle)))))

(pass-if "ast:resolve-variable-valued-function-call"
         (gom-pretty-noisy-equal?
          (ast:resolve-model
           (car resolve-ast)
           '(variable e (type e) (expression (var efun))))
          '(variable e (type e) (call efun))))

