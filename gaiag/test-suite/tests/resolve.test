(pass-if "ast:resolve-argument-count-mismatch"
         (om-pretty-noisy-equal?
          (ast:resolve-model*
           (cadr resolve-ast)
           '(call rfun (arguments (expression true))))
          (resolve-error '(call rfun (arguments (expression true)))
