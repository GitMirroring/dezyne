(pass-if "ast:resolve-variable-range-error"
         (or #t ;; disable range checks
             (om-pretty-noisy-equal?
              (ast:resolve-model*
               '(interface
                 I
                 (types (int I02 #f (range 0 2)))
                 (events)
                 (behaviour
                  #f
                  (types)
                  (variables
                   (variable i (type (name I02)) (expression 3)))
                  (functions)
                  (compound))))
              `(interface
                I
                (types (int I02 #f (range 0 2)))
                (events)
                (behaviour
                 #f
                 (types)
                 (variables
                  ,(resolve-error '(variable i (type (name I02)) (expression 3))
                                  'i
                                  (format #f "variable ~a out of range, expected ~a..~a, found: ~a" "~a" 0 2 3)))
                 (functions)
                 (compound))))))

(read-hash-extend #\{ hash-read-string)
