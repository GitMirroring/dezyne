;; -*-scheme-*-

(read-set! keywords 'prefix)

(define-module (test-handler)
  :use-module (test-suite lib)
  :use-module (test-suite misc)

  :use-module (srfi srfi-1)
  :use-module (ice-9 optargs)
  :use-module (ice-9 match)

  :use-module (gaiag om)

  :use-module (gaiag misc)
  :use-module (gaiag reader)
  :use-module (gaiag resolve)
  )

(define namespace-ast
  (dzn->ast
#{
interface foo.I {
  enum Bool {f,t};
  in Bool e();
  behaviour {
    on e: {
    reply(Bool.t);
    }
  }
}

component bar.c {
  provides foo.I i;
  behaviour {
    foo.I.Bool state = foo.I.Bool.t;
    on i.e(): {
      reply(foo.I.Bool.t);
    }
  }
}
#}))

(define resolve-ast
  (dzn->ast #{
interface ivar {
  enum e {v};
  extern xint $int&$;
  enum mixed {v};
  in e foo();
  in mixed bar();
  in void ei(out xint i);
  in e eo(xint i);

  behaviour {
    enum state {one, two};
    subint mode {0..3};
    state m = state.one;
    e r = e.v;
    bool b = true;
    mixed x = mixed.v;

    void toggle() {}

    bool g(bool ga, bool gb) {return true;}

    state efun() {
      return m;
    }

    on foo:
    reply(e.v);
  }
}

component var {
  provides ivar i;
  requires ivar o;

  behaviour {
    enum state {one, two};
    subint mode {0..3};
    state m = state.one;
    ivar.e r = ivar.e.v;
    ivar.e e = ivar.e.v;
    bool b = true;
    ivar.xint x = $0$;

    void fun(bool a) {
      a = true;
    }

    void rfun() {
      rgun(true);
    }

    void rgun(bool a) {
      rgun(true);
    }

    void fa(bool a) {
      fb(true);
    }

    void fb(bool a) {
      fc(true);
    }

    void fc(bool a) {
      b = true;
    }

    void rfa(bool a) {
      rfb(true);
    }

    void rfb(bool a) {
      rfc(true);
    }

    void rfc(bool a) {
      rfa(true);
    }

    void rbfa(bool a) {rbfb(true);}

    void rbfb(bool a) {
      rbfc(true);
    }

    void rbfc(bool a) {
      fa(true);
      fb(true);
      {
        fc(true);
        rbfa(true);
      }
    }

    state efun() {
      return m;
    }

    on i.foo():
    {
      ivar.e e = o.foo();
      e = o.foo();
      reply(e);
    }

    on i.ei(i):
    {
      i = $0$;
    }
  }
}
#}
  ))

(define (resolve-namespace-interface)
  (find (is? <interface>) namespace-ast))
(define (resolve-namespace-component)
  (find (is? <component>) namespace-ast))

(eval-when (compile eval load) (read-hash-extend #\{ #f))

(define resolve (@@ (gaiag resolve) resolve))

(define (resolve-error o identifier message)
  (let ((e ((@@ (gaiag resolve) resolve-error) (ast->om `(root ,o)) identifier message)))
    (make <error> :ast (car (.elements (.ast e))) :message (.message e))))

(define (undefined-error o identifier)
  ((@@ (gaiag resolve) undefined-error) (ast->om o) identifier))

(define (type-mismatch o expected actual)
  ((@@ (gaiag resolve) type-mismatch) (ast->om o) expected actual))

(define* (ast:resolve* m :optional (o #f))
  (match o
    (#f
     (let* ((m (ast->om m)))
       ((resolve m '()) m)))
    (_
      (let ((m (ast->om m)))
        ((resolve m '()) (ast->om o))))))

(define (ast:resolve-root-model root model o)
  (let* ((root ((compose ast:resolve ast->om) root))
         (m (ast->om model)))
    ((resolve m '()) (ast->om o))))

(define (resolve-interface)
  (find (is? <interface>) resolve-ast))

(define (resolve-component)
  (find (is? <component>) resolve-ast))

(pass-if "resolve-first-dummy-test"
         #t)

(pass-if "ast:resolve-function-call"
         (om-pretty-noisy-equal?
          (ast:resolve*
           (resolve-interface)
           '(on (triggers (trigger #f e (arguments)))
                (compound
                 (action (trigger #f toggle (arguments))))))
          '(on (triggers (trigger #f e (arguments)))
               (compound
                (call toggle (arguments) #f)))))

(pass-if "ast:resolve-variable-valued-function-call"
         (om-pretty-noisy-equal?
          (ast:resolve*
           (resolve-interface)
          '(root (variable e (type (name ivar e)) (expression (var efun)))))
          '(root (variable e (type (name ivar e)) (call efun (arguments) #f)))))

