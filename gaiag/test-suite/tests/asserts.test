;; -*-scheme-*-

(read-set! keywords 'prefix)

(define-module (test-handler)
  :use-module (test-suite lib)
  :use-module (test-suite misc)

  :use-module (gaiag reader)
  :use-module (gaiag asserts)
  :use-module (gaiag gom))

(pass-if "asserts-first-dummy-test"
	 #t)

(pass-if "assert"
  (pretty-noisy-equal?
   (assert-list
    (gom:parse-dezyne
     #{ interface I { }
                  component C {
                               provides I i ;
                                        requires I j ;
                                        behaviour { }
                                        } #}))
   '((interface I completeness)
     (interface I deadlock)
     (interface I livelock)
     (component C deterministic)
     (component C completeness)
     (component C illegal)
     (component C deadlock)
     (component C compliance I)
     (component C livelock))))

(pass-if "assert"
  (pretty-noisy-equal?
   (assert-list
    (gom:parse-dezyne
     #{ component C {} #}))
   '()))

(pass-if "assert-interface"
  (pretty-noisy-equal?
   (assert-list
    (gom:parse-dezyne
     #{ interface I {behaviour { }}
                  component C {
                               provides I i ;
                                        requires I j ;
                                        } #}))
   '((interface I completeness)
     (interface I deadlock)
     (interface I livelock))))
