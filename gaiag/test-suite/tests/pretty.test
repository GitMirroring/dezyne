(read-set! keywords 'prefix)

(define-module (test-handler)
  :use-module (test-suite lib)
  :use-module (test-suite misc)

  :use-module (gaiag reader)
  :use-module (gaiag pretty))

(pass-if "pretty-first-dummy-test"
	 #t)

(pass-if "pretty-interface"
  (let ((asd #{
interface i
{
}
#}))
    (diff-noisy-equal?
     (ast->pretty
      (asd->ast asd))
     asd)))

(pass-if "pretty-component"
  (let ((asd #{
component c
{
}
#}))
(diff-noisy-equal?
 (ast->pretty
  (asd->ast asd))
 asd)))

(pass-if "pretty-in"
  (let ((asd #{
interface i
{
  in void identifier;
}
#}))
(diff-noisy-equal?
 (ast->pretty
  (asd->ast asd))
 asd)))

(pass-if "pretty-provides"
  (let ((asd #{
component c
{
  provides Interface identifier;
}
#}))
(diff-noisy-equal?
 (ast->pretty
  (asd->ast asd))
 asd)))

(pass-if "pretty-expression"  ;; FIXME: 878d54f Add normstate.scm broke pretty.
  (let ((asd #{
interface i
{
  behaviour
  {
   [true || false]
   {
   }
  }
}
#}))
(diff-noisy-equal?
 (ast->pretty
  (asd->ast asd))
 asd)))
