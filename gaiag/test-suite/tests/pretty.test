(read-set! keywords 'prefix)

(define-module (test-handler)
  :use-module (test-suite lib)
  :use-module (test-suite misc)

  :use-module (gaiag reader)
  :use-module (gaiag pretty))

(define (ast->pretty* ast) ((compose ast->pretty ast->om) ast))
(pass-if "pretty-first-dummy-test"
	 #t)

(pass-if "pretty-interface"
  (let ((dezyne #{
interface i
{
  behaviour
  {
  }
}
#}))
    (diff-noisy-equal?
     (ast->pretty*
      (dezyne->ast dezyne))
     dezyne)))

(pass-if "pretty-component"
  (let ((dezyne #{
component c
{
}
#}))
(diff-noisy-equal?
 (ast->pretty*
  (dezyne->ast dezyne))
 dezyne)))

(pass-if "pretty-in"
  (let ((dezyne #{
interface i
{
  in void identifier();
  behaviour
  {
  }
}
#}))
(diff-noisy-equal?
 (ast->pretty*
   (dezyne->ast dezyne))
 dezyne)))

(pass-if "pretty-provides"
  (let ((dezyne #{
interface Interface
{
  behaviour
  {
  }
}
component c
{
  provides Interface identifier;
  behaviour
  {
    on i.a():
       illegal;
  }
}
#}))
(diff-noisy-equal?
 (ast->pretty*
   (dezyne->ast dezyne))
 dezyne)))

(pass-if "pretty-expression"  ;; FIXME: 878d54f Add norm.scm broke pretty.
  (let ((dezyne #{
interface i
{
  behaviour
  {
   [true || false]
   {
   }
  }
}
#}))
(diff-noisy-equal?
 (ast->pretty*
   (dezyne->ast dezyne))
 dezyne)))
