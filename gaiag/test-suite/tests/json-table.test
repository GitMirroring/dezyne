;; -*-mode:scheme-*-
;; This file is part of Gaiag, Guile in Asd In Asd in Guile.

(read-set! keywords 'prefix)

(define-module (test-handler)
  :use-module (test-suite lib)
  :use-module (test-suite misc)

  :use-module (gaiag om)

  :use-module (gaiag json-table)
  :use-module (gaiag misc)
  :use-module (gaiag reader)
  :use-module (gaiag resolve))

(define json-callback (@@ (gaiag json-table) json-callback))
(define json-next (@@ (gaiag json-table) json-next))

(pass-if "json-table-first-dummy-test"
         #t)

(define i-ast
 (om:interface
  (ast:resolve
   (ast->om
   (dzn->ast
#{
interface I
{
  in void e;
  out void a;

  behaviour
  {
    void f ()
    {
      e;
    }
    void g ()
    {
      e;
      g ();
    }
    on e: {}
  }
}
#})))))

(pass-if "json-table-json-callback"
         (pretty-noisy-equal?
          (json-callback
           i-ast
           (make <action> :trigger (make <trigger> :event 'e)))
          '("e;\n")))

(pass-if "json-table-json-callback-if"
         (pretty-noisy-equal?
          (json-callback
           i-ast
           (make <if>
             :then (make <action> :trigger (make <trigger> :event 'e))
             :else (make <action> :trigger (make <trigger> :event 'f))))
          '("e;\n" "f;\n")))

(pass-if "json-table-json-callback-if-same"
         (pretty-noisy-equal?
          (json-callback
           i-ast
           (make <if>
             :then (make <action> :trigger (make <trigger> :event 'e))
             :else (make <action> :trigger (make <trigger> :event 'e))))
          '("e;\n" "e;\n")))

(pass-if "json-table-json-callback-function"
         (pretty-noisy-equal?
          (json-callback
           i-ast
           (make <call> :identifier 'f))
          '("e;\n")))

(pass-if "json-table-json-callback-recursive-function"
         (pretty-noisy-equal?
          (json-callback
           i-ast
           (make <call> :identifier 'g))
          '()))

(define if-ast
 (om:interface
  (ast:resolve
  (ast->om
   (dzn->ast
#{
interface I {
  in void e;
  in void f;
  in void g;
  behaviour
    {
      enum S {one, two, three};
      S s = S.one;
      bool b = false;
      void fun () {
        fun ();
      }
      on e: if (b) {} else s = S.three;
      on f: if (b) s = S.two; else s = S.three;
      on g: if (b) fun(); else s = S.three;
    }
}
#})))))

(pass-if "json-table-if-one"
         (pretty-noisy-equal?
          (json-next
           if-ast
           's
           (make <field> :identifier 's :field 'one)
           (ast->om
            '(if (expression (var b))
                 (compound)
                 (assign s (expression (literal (name S) three))))))
          '(s.one s.three)))

(pass-if "json-table-if-two"
         (pretty-noisy-equal?
          (json-next
           if-ast
           's
           (make <field> :identifier 's :field 'one)
           (ast->om
            '(if (expression (var b))
                 (assign s (expression (literal (name S) two)))
                 (assign s (expression (literal (name S) three))))))
          '(s.two s.three)))

(pass-if "json-table-if-recursive"
         (pretty-noisy-equal?
          (json-next
           if-ast
           's
           (make <field> :identifier 's :field 'one)
           (ast->om
            '(if (expression (var b)) (call fun (arguments) #f) (assign s (expression (literal (name S) three))))))
          '(s.one s.three)))
