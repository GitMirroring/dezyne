(read-set! keywords 'prefix)

(define-module (test-handler)
  :use-module (test-suite lib)
  :use-module (test-suite misc)

  :use-module (gaiag ast:)
  :use-module (gaiag reader)
  :use-module (gaiag normstate)

  :use-module (oop goops)
  :use-module (gaiag gom))

(pass-if "normstate-first-dummy-test"
	 #t)

(pass-if "normstate-101"
  (gom-pretty-noisy-equal?
   (normstate
    (ast:interface (asd->ast
      #{
        interface i { behaviour { on a: [true] { } } } #})))
   '(interface i (types) (events)
               (behaviour #f (types) (variables) (functions)
                          (compound
                           (guard (expression true) (on (triggers (trigger #f a)) (skip))))))))

(pass-if "normstate-102"
  (gom-pretty-noisy-equal?
   (normstate
    (ast:interface (asd->ast
      #{
        interface i { behaviour { on a: [true] b;
                                     } } #})))
   '(interface i (types) (events)
               (behaviour #f (types) (variables) (functions)
                          (compound
                           (guard (expression true)
                                  (on (triggers (trigger #f a))
                                      (action (trigger #f b)))))))))

(pass-if "normstate-aggregate-guard-passive"
  (gom-pretty-noisy-equal?
   (normstate
    (ast:interface (asd->ast
      #{
        interface i { behaviour { on a,b,c: [true] d;
                                     } } #})))
   '(interface i (types) (events)
               (behaviour #f (types) (variables) (functions)
                          (compound
                           (guard (expression true)
                                  (on (triggers (trigger #f a) (trigger #f b) (trigger #f c))
                                      (action (trigger #f d)))))))))

(pass-if "normstate-aggregate-guard-active"
  (gom-pretty-noisy-equal?
   (normstate
    (ast:interface (asd->ast
      #{
        interface i { behaviour { on a: [true] d;
                                     on b: [true] e;
                                     on c: [true] f;
                                     } } #})))
   '(interface i (types) (events)
               (behaviour #f (types) (variables) (functions)
                          (compound
                           (guard (expression true)
                                  (compound
                                   (on (triggers (trigger #f a)) (action (trigger #f d)))
                                   (on (triggers (trigger #f b)) (action (trigger #f e)))
                                   (on (triggers (trigger #f c)) (action (trigger #f f))))))))))

(pass-if "normstate-function-call"
  (gom-pretty-noisy-equal?
   (normstate
    (ast:interface (asd->ast
      #{
        interface i { behaviour { void foo(){ if(true){}} on a,b,c: [true] d ;
                                                 } } #})))
   '(interface i (types) (events)
               (behaviour #f
                          (types)
                          (variables)
                          (functions
                           (function foo (signature (type void)) #f
                                     (compound (if (expression true) (skip)))))
                          (compound
                           (guard (expression true)
                                  (on (triggers (trigger #f a) (trigger #f b) (trigger #f c))
                                      (action (trigger #f d)))))))))

(pass-if "normstate-split-on-passive"
  (gom-pretty-noisy-equal?
   (normstate
    (ast:interface (asd->ast
      #{
        interface i { behaviour { on a,b,c: [true] d;
                                     } } #})))
   '(interface i (types) (events)
               (behaviour #f (types) (variables) (functions)
                          (compound
                           (guard (expression true)
                                  (on (triggers (trigger #f a) (trigger #f b) (trigger #f c))
                                      (action (trigger #f d)))))))))

(pass-if "normstate-split-on-active"
  (gom-pretty-noisy-equal?
   (normstate
    (ast:component (asd->ast
      #{
        component c { behaviour { on i.a,i.b,j.a: [true] d;
                                     on j.b: [true] e;
                                     } } #})))
   '(component c (ports)
               (behaviour #f (types) (variables) (functions)
                          (compound
                           (guard (expression true)
                                  (compound
                                   (on (triggers (trigger i a) (trigger i b))
                                       (action (trigger #f d)))
                                   (on (triggers (trigger j a))
                                       (action (trigger #f d)))
                                   (on (triggers (trigger j b))
                                       (action (trigger #f e))))))))))

