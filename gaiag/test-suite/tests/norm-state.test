(read-set! keywords 'prefix)

(define-module (test-handler)
  :use-module (test-suite lib)
  :use-module (test-suite misc)

  :use-module (gaiag reader)
  :use-module (gaiag norm-state)

  :use-module (gaiag ast))

(define (csp-norm-state* ast)
  ((compose csp-norm-state ast->om) ast))

(pass-if "csp-norm-state-first-dummy-test"
         #t)

(pass-if "csp-norm-state-101"
         (om-pretty-noisy-equal?
          (csp-norm-state*
           (cadr (dzn->ast
                           #{
                             interface i { in void a; out void b;
                                          behaviour { on a: [true] { } } } #})))
          '(interface (name i) (types) (events (event a (signature (type void)) in) (event b (signature (type void)) out))
                      (behaviour #f (types) (variables) (functions)
                                 (compound
                                  (guard (expression true) (on (triggers (trigger #f a)) (compound))))))))

(pass-if "csp-norm-state-102"
         (om-pretty-noisy-equal?
          (csp-norm-state*
           (cadr (dzn->ast
                           #{
                             interface i { in void a; out void b;
                                              behaviour { on a: [true] b;
                                                             } } #})))
          '(interface (name i) (types) (events (event a (signature (type void)) in) (event b (signature (type void)) out))
                      (behaviour #f (types) (variables) (functions)
                                 (compound
                                  (guard (expression true)
                                         (on (triggers (trigger #f a))
                                             (action (trigger #f b)))))))))

(pass-if "csp-norm-state-aggregate-guard-passive"
         (om-pretty-noisy-equal?
          (csp-norm-state*
           (cadr (dzn->ast
                           #{
                             interface i { in void a; in void b; in void c;
                                              out void d;
                                              behaviour { on a,b,c: [true] d;
                                                          } } #})))
          '(interface (name i) (types) (events (event a (signature (type void)) in) (event b (signature (type void)) in) (event c (signature (type void)) in)
                                        (event d (signature (type void)) out))
                      (behaviour #f (types) (variables) (functions)
                                 (compound
                                  (guard (expression true)
                                         (on (triggers (trigger #f a) (trigger #f b) (trigger #f c))
                                             (action (trigger #f d)))))))))

(pass-if "csp-norm-state-aggregate-guard-active"
         (om-pretty-noisy-equal?
          (csp-norm-state*
           (cadr (dzn->ast
                           #{
                             interface i { in void a; in void b; in void c;
                                              out void d; out void e; out void f;
                                          behaviour { on a: [true] d;
                                                          on b: [true] e;
                                                          on c: [true] f;
                                                          } } #})))
          '(interface (name i) (types) (events (event a (signature (type void)) in) (event b (signature (type void)) in) (event c (signature (type void)) in)
                                        (event d (signature (type void)) out) (event e (signature (type void)) out) (event f (signature (type void)) out))
                      (behaviour #f (types) (variables) (functions)
                                 (compound
                                  (guard (expression true)
                                         (compound
                                          (on (triggers (trigger #f a)) (action (trigger #f d)))
                                          (on (triggers (trigger #f b)) (action (trigger #f e)))
                                          (on (triggers (trigger #f c)) (action (trigger #f f))))))))))

(pass-if "csp-norm-state-aggregate-guard-recurse"
         (om-pretty-noisy-equal?
          (csp-norm-state*
           '(compound
             (guard
              (expression (field state Disarming))
              (compound
               (on (triggers
                    (trigger console arm)
                    (trigger console disarm))
                   (illegal))
               (on (triggers (trigger sensor triggered))
                   (compound))
               (on (triggers (trigger sensor disabled))
                   (compound
                    (guard
                     (expression (var sounding))
                     (compound
                      (action (trigger console deactivated))
                      (action (trigger siren turnoff))
                      (assign
                       state
                       (expression (literal (name States) Disarmed)))
                      (assign sounding (expression false))))
                    (guard
                     (otherwise)
                     (compound
                      (action (trigger console deactivated))
                      (assign
                       state
                       (expression
                        (literal (name States) Disarmed)))))))))))
          '(compound
            (guard
             (expression (field state Disarming))
             (compound
              (on (triggers
                   (trigger console arm)
                   (trigger console disarm))
                  (illegal))
              (on (triggers (trigger sensor triggered))
                  (compound))))
            (guard
             (expression
              (and (field state Disarming) (var sounding)))
             (on (triggers (trigger sensor disabled))
                 (compound
                  (action (trigger console deactivated))
                  (action (trigger siren turnoff))
                  (assign
                   state
                   (expression (literal (name States) Disarmed)))
                  (assign sounding (expression false)))))
            (guard
             (expression
              (and (field state Disarming)
                   (! (var sounding))))
             (on (triggers (trigger sensor disabled))
                 (compound
                  (action (trigger console deactivated))
                  (assign
                   state
                   (expression (literal (name States) Disarmed)))))))))

(pass-if "csp-norm-state-function-call"
         (om-pretty-noisy-equal?
          (csp-norm-state*
           (cadr (dzn->ast
                           #{
                             interface i { in void a; out void d;
                                              behaviour
                                              { void foo(){ if(true){}} on a,b,c: [true] d ;
                                                     } } #})))
          '(interface (name i) (types) (events (event a (signature (type void)) in) (event d (signature (type void)) out))
                      (behaviour #f
                                 (types)
                                 (variables)
                                 (functions
                                  (function foo (signature (type void)) #f
                                            (compound (if (expression true) (compound)))))
                                 (compound
                                  (guard (expression true)
                                         (on (triggers (trigger #f a) (trigger #f b) (trigger #f c))
                                             (action (trigger #f d)))))))))

(pass-if "csp-norm-state-split-on-passive"
         (om-pretty-noisy-equal?
          (csp-norm-state*
           (cadr (dzn->ast
                           #{
                             interface i { in void a; in void b; in void c;
                                              out void d;
                                              behaviour
                                              { on a,b,c: [true] d ;
                                                   } } #})))
          '(interface (name i) (types) (events (event a (signature (type void)) in) (event b (signature (type void)) in) (event c (signature (type void)) in)
                                        (event d (signature (type void)) out))
                      (behaviour #f (types) (variables) (functions)
                                 (compound
                                  (guard (expression true)
                                         (on (triggers (trigger #f a) (trigger #f b) (trigger #f c))
                                             (action (trigger #f d)))))))))

(pass-if "csp-norm-state-split-on-active-single-on"
         (om-pretty-noisy-equal?
          (csp-norm-state*
           (cadr (dzn->ast
                           #{
                             component c { behaviour { [true] on i.a: illegal;
                                                       [false] on i.b,i.c,j.a: illegal;
                                                          } } #})))
          '(component (name c)
            (ports)
            (behaviour
             #f
             (types)
             (variables)
             (functions)
             (compound
              (guard
               (expression true)
               (on (triggers (trigger i a)) (illegal)))
              (guard
               (expression false)
               (compound
                (on (triggers (trigger i b) (trigger i c))
                     (illegal))
                (on (triggers (trigger j a)) (illegal)))))))))

(pass-if "csp-norm-state-aggregate-on-interface-passive"
         (om-pretty-noisy-equal?
          (csp-norm-state*
           (cadr (dzn->ast
                           #{
                             interface i {  in void a; in void b; in void c;
                                              out void d;
                                              behaviour { on a,b,c: [true] d;
                                                          } } #})))
          '(interface (name i) (types) (events (event a (signature (type void)) in) (event b (signature (type void)) in) (event c (signature (type void)) in)
                                        (event d (signature (type void)) out))
                      (behaviour #f (types) (variables) (functions)
                                 (compound
                                  (guard (expression true)
                                         (on (triggers (trigger #f a) (trigger #f b) (trigger #f c)) (action (trigger #f d)))))))))

(pass-if "csp-norm-state-aggregate-on-interface-active"
         (om-pretty-noisy-equal?
          (csp-norm-state*
           (cadr (dzn->ast
                           #{
                             interface i {  in void a; in void b; in void c;
                                              out void d;
                                              behaviour { on a: [true] d;
                                                          on b: [true] d;
                                                          on c: [true] d;
                                                          } } #})))
          '(interface (name i) (types) (events (event a (signature (type void)) in) (event b (signature (type void)) in) (event c (signature (type void)) in)
                                        (event d (signature (type void)) out))
                      (behaviour #f (types) (variables) (functions)
                                 (compound
                                  (guard (expression true)
                                         (compound
                                          (on (triggers (trigger #f a) (trigger #f b) (trigger #f c)) (action (trigger #f d))))))))))

;; not modifying the input where it is already fine,
;; helps retaining more location information in AST.
(pass-if "csp-norm-state-aggregate-on-component-passive"
         (om-pretty-noisy-equal?
          (csp-norm-state*
           (cadr (dzn->ast
                           #{
                             component c { behaviour { on i.a,i.b: [true] j.d;
                                                          on j.a:     [true] j.d;
                                                          on j.b:     [true] j.e;
                                                          } } #})))
          '(component (name c) (ports)
                      (behaviour #f (types) (variables) (functions)
                                 (compound
                                  (guard (expression true)
                                         (compound
                                          (on (triggers (trigger i a) (trigger i b))
                                              (action (trigger j d)))
                                          (on (triggers (trigger j a))
                                              (action (trigger j d)))
                                          (on (triggers (trigger j b))
                                              (action (trigger j e))))))))))

(pass-if "csp-norm-state-aggregate-on-component-active"
         (om-pretty-noisy-equal?
          (csp-norm-state*
           (cadr (dzn->ast
                           #{
                             component c { behaviour { on i.a: [true] j.d;
                                                          on i.b: [true] j.d;
                                                          on j.a: [true] j.d;
                                                          on j.b: [true] j.e;
                                                          } } #})))
          '(component (name c) (ports)
                      (behaviour #f (types) (variables) (functions)
                                 (compound
                                  (guard (expression true)
                                         (compound
                                          (on (triggers (trigger i a) (trigger i b))
                                              (action (trigger j d)))
                                          (on (triggers (trigger j a))
                                              (action (trigger j d)))
                                          (on (triggers (trigger j b))
                                              (action (trigger j e))))))))))

(pass-if "csp-norm-state-aggregate-on-component-active"
         (om-pretty-noisy-equal?
          (csp-norm-state*
           '(compound
             (compound
              (guard (expression (value state Disarmed))
                     (on (triggers (trigger console arm))
                         (compound
                          (action (trigger sensor enable))
                          (assign state (expression (value States Armed))))))
              (guard (expression (value state Disarmed))
                     (on (triggers
                          (trigger console disarm)
                          (trigger sensor triggered)
                          (trigger sensor disabled))
                         (illegal))))
             (compound
              (guard (expression (value state Armed))
                     (on (triggers (trigger console arm)) (illegal))))))
          '(compound
            (guard
             (expression (value state Disarmed))
             (compound
              (on (triggers (trigger console arm))
                  (compound
                   (action (trigger sensor enable))
                   (assign
                    state
                    (expression (value States Armed)))))
              (on (triggers (trigger console disarm))
                  (illegal))
              (on (triggers
                   (trigger sensor triggered)
                   (trigger sensor disabled))
                  (illegal))))
            (guard
             (expression (value state Armed))
             (on (triggers (trigger console arm))
                 (illegal))))))

(pass-if "csp-norm-state-nested-guards"
         (om-pretty-noisy-equal?
          (csp-norm-state*
           (cadr (ast:resolve (ast->om (dzn->ast
                           #{
interface norm_nested_guards
{
  enum Reply {Ok, Nok};
  in Reply e;

  behaviour
  {
    enum State {Foo};
    State state = State.Foo;
    bool bar = true;
    [state.Foo]
    {
      [bar] on e: [true] { reply(Reply.Ok);
      }
      [bar] on e: [true] { reply(Reply.Nok);
      }
    }
  }
}
#})))))
'(interface
  (name norm_nested_guards)
  (types (enum (name norm_nested_guards Reply) (fields Ok Nok)))
  (events (event e (signature (type (name norm_nested_guards Reply))) in))
  (behaviour
    #f
    (types (enum (name norm_nested_guards State) (fields Foo)))
    (variables
      (variable
        state
        (type (name norm_nested_guards State))
        (expression (literal (name norm_nested_guards State) Foo)))
      (variable
        bar
        (type bool)
        (expression true)))
    (functions)
    (compound
      (guard
        (expression
          (and (and (field state Foo) (var bar)) true))
        (compound
          (on (triggers (trigger #f e (arguments)))
              (reply (expression (literal (name norm_nested_guards Reply) Ok))))
          (on (triggers (trigger #f e (arguments)))
              (reply (expression (literal (name norm_nested_guards Reply) Nok)))))))))))
