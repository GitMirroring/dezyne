(define-module (test-handler)
  #:use-module (test-suite lib)
  #:use-module (test-suite misc)

  #:use-module ((oop goops) #:renamer (lambda (x) (if (eq? x '<port>) 'goops:<port> x)))
  #:use-module (gaiag goops)
  #:use-module (gaiag ast2om)
  #:use-module (gaiag om)

  #:use-module (gaiag reader)
  #:use-module (gaiag norm-state)
  #:use-module (gaiag resolve))

(define (csp-norm-state* ast)
  ((compose csp-norm-state ast->om) ast))

(pass-if "csp-norm-state-first-dummy-test"
         #t)

(pass-if "csp-norm-state-101"
         (om-pretty-noisy-equal?
          (csp-norm-state*
           (cadr (dzn->ast
                           #{
                             interface i { in void a; out void b;
                                          behaviour { on a: [true] { } } } #})))
          '(interface (scope.name () i) (types) (events (event a (signature (type void)) in) (event b (signature (type void)) out))
                      (behaviour #f (types) (variables) (functions)
                                 (compound
                                  (guard (expression true) (on (triggers (trigger #f a (arguments))) (compound))))))))

(pass-if "csp-norm-state-102"
         (om-pretty-noisy-equal?
          (csp-norm-state*
           (cadr (dzn->ast
                           #{
                             interface i { in void a; out void b;
                                              behaviour { on a: [true] b;
                                                             } } #})))
          '(interface (scope.name () i) (types) (events (event a (signature (type void)) in) (event b (signature (type void)) out))
                      (behaviour #f (types) (variables) (functions)
                                 (compound
                                  (guard (expression true)
                                         (on (triggers (trigger #f a (arguments)))
                                             (action (trigger #f b (arguments))))))))))

(pass-if "csp-norm-state-aggregate-guard-passive"
         (om-pretty-noisy-equal?
          (csp-norm-state*
           (cadr (dzn->ast
                           #{
                             interface i { in void a; in void b; in void c;
                                              out void d;
                                              behaviour { on a,b,c: [true] d;
                                                          } } #})))
          '(interface (scope.name () i) (types) (events (event a (signature (type void)) in) (event b (signature (type void)) in) (event c (signature (type void)) in)
                                        (event d (signature (type void)) out))
                      (behaviour #f (types) (variables) (functions)
                                 (compound
                                  (guard (expression true)
                                         (on (triggers (trigger #f a (arguments)) (trigger #f b (arguments)) (trigger #f c (arguments)))
                                             (action (trigger #f d (arguments))))))))))

(pass-if "csp-norm-state-aggregate-guard-active"
         (om-pretty-noisy-equal?
          (csp-norm-state*
           (cadr (dzn->ast
                           #{
                             interface i { in void a; in void b; in void c;
                                              out void d; out void e; out void f;
                                          behaviour { on a: [true] d;
                                                          on b: [true] e;
                                                          on c: [true] f;
                                                          } } #})))
          '(interface (scope.name () i) (types) (events (event a (signature (type void)) in) (event b (signature (type void)) in) (event c (signature (type void)) in)
                                        (event d (signature (type void)) out) (event e (signature (type void)) out) (event f (signature (type void)) out))
                      (behaviour #f (types) (variables) (functions)
                                 (compound
                                  (guard (expression true)
                                         (compound
                                          (on (triggers (trigger #f a (arguments))) (action (trigger #f d (arguments))))
                                          (on (triggers (trigger #f b (arguments))) (action (trigger #f e (arguments))))
                                          (on (triggers (trigger #f c (arguments))) (action (trigger #f f (arguments)))))))))))

(pass-if "csp-norm-state-aggregate-guard-recurse"
         (om-pretty-noisy-equal?
          (csp-norm-state*
           '(compound
             (guard
              (expression (field state Disarming))
              (compound
               (on (triggers
                    (trigger console arm (arguments))
                    (trigger console disarm (arguments)))
                   (illegal))
               (on (triggers (trigger sensor triggered (arguments)))
                   (compound))
               (on (triggers (trigger sensor disabled (arguments)))
                   (compound
                    (guard
                     (expression (var sounding))
                     (compound
                      (action (trigger console deactivated (arguments)))
                      (action (trigger siren turnoff (arguments)))
                      (assign
                       state
                       (expression (literal (scope.name () States) Disarmed)))
                      (assign sounding (expression false))))
                    (guard
                     (otherwise)
                     (compound
                      (action (trigger console deactivated (arguments)))
                      (assign
                       state
                       (expression
                        (literal (scope.name () States) Disarmed)))))))))))
          '(compound
            (guard
             (expression (field state Disarming))
             (compound
              (on (triggers
                   (trigger console arm (arguments))
                   (trigger console disarm (arguments)))
                  (illegal))
              (on (triggers (trigger sensor triggered (arguments)))
                  (compound))))
            (guard
             (expression
              (and (field state Disarming) (var sounding)))
             (on (triggers (trigger sensor disabled (arguments)))
                 (compound
                  (action (trigger console deactivated (arguments)))
                  (action (trigger siren turnoff (arguments)))
                  (assign
                   state
                   (expression (literal (scope.name () States) Disarmed)))
                  (assign sounding (expression false)))))
            (guard
             (expression
              (and (field state Disarming)
                   (! (var sounding))))
             (on (triggers (trigger sensor disabled (arguments)))
                 (compound
                  (action (trigger console deactivated (arguments)))
                  (assign
                   state
                   (expression (literal (scope.name () States) Disarmed)))))))))

(pass-if "csp-norm-state-function-call"
         (om-pretty-noisy-equal?
          (csp-norm-state*
           (cadr (dzn->ast
                           #{
                             interface i { in void a; out void d;
                                              behaviour
                                              { void foo(){ if(true){}} on a,b,c: [true] d ;
                                                     } } #})))
          '(interface (scope.name () i) (types) (events (event a (signature (type void)) in) (event d (signature (type void)) out))
                      (behaviour #f
                                 (types)
                                 (variables)
                                 (functions
                                  (function foo (signature (type void)) #f
                                            (compound (if (expression true) (compound)))))
                                 (compound
                                  (guard (expression true)
                                         (on (triggers (trigger #f a (arguments)) (trigger #f b (arguments)) (trigger #f c (arguments)))
                                             (action (trigger #f d (arguments))))))))))

(pass-if "csp-norm-state-split-on-passive"
         (om-pretty-noisy-equal?
          (csp-norm-state*
           (cadr (dzn->ast
                           #{
                             interface i { in void a; in void b; in void c;
                                              out void d;
                                              behaviour
                                              { on a,b,c: [true] d ;
                                                   } } #})))
          '(interface (scope.name () i) (types) (events (event a (signature (type void)) in) (event b (signature (type void)) in) (event c (signature (type void)) in)
                                        (event d (signature (type void)) out))
                      (behaviour #f (types) (variables) (functions)
                                 (compound
                                  (guard (expression true)
                                         (on (triggers (trigger #f a (arguments)) (trigger #f b (arguments)) (trigger #f c (arguments)))
                                             (action (trigger #f d (arguments))))))))))

(pass-if "csp-norm-state-split-on-active-single-on"
         (or #t
         (om-pretty-noisy-equal?
          (csp-norm-state*
           (cadr (dzn->ast
                           #{
                             component c { behaviour { [true] on i.a: illegal;
                                                       [false] on i.b,i.c,j.a: illegal;
                                                          } } #})))
          '(component (scope.name () c)
            (ports)
            (behaviour
             #f
             (types)
             (variables)
             (functions)
             (compound
              (guard
               (expression true)
               (on (triggers (trigger i a (arguments))) (illegal)))
              (guard
               (expression false)
               (compound
                (on (triggers (trigger i b (arguments)) (trigger i c (arguments)))
                     (illegal))
                (on (triggers (trigger j a (arguments))) (illegal))))))))))

(pass-if "csp-norm-state-aggregate-on-interface-passive"
         (om-pretty-noisy-equal?
          (csp-norm-state*
           (cadr (dzn->ast
                           #{
                             interface i {  in void a; in void b; in void c;
                                              out void d;
                                              behaviour { on a,b,c: [true] d;
                                                          } } #})))
          '(interface (scope.name () i) (types) (events (event a (signature (type void)) in) (event b (signature (type void)) in) (event c (signature (type void)) in)
                                        (event d (signature (type void)) out))
                      (behaviour #f (types) (variables) (functions)
                                 (compound
                                  (guard (expression true)
                                         (on (triggers (trigger #f a (arguments)) (trigger #f b (arguments)) (trigger #f c (arguments))) (action (trigger #f d (arguments))))))))))

(pass-if "csp-norm-state-aggregate-on-interface-active"
         (om-pretty-noisy-equal?
          (csp-norm-state*
           (cadr (dzn->ast
                           #{
                             interface i {  in void a; in void b; in void c;
                                              out void d;
                                              behaviour { on a: [true] d;
                                                          on b: [true] d;
                                                          on c: [true] d;
                                                          } } #})))
          '(interface (scope.name () i) (types) (events (event a (signature (type void)) in) (event b (signature (type void)) in) (event c (signature (type void)) in)
                                        (event d (signature (type void)) out))
                      (behaviour #f (types) (variables) (functions)
                                 (compound
                                  (guard (expression true)
                                         (on (triggers (trigger #f a (arguments)) (trigger #f b (arguments)) (trigger #f c (arguments))) (action (trigger #f d (arguments))))))))))

;; not modifying the input where it is already fine,
;; helps retaining more location information in AST.
(pass-if "csp-norm-state-aggregate-on-component-passive"
        (or #t
         (om-pretty-noisy-equal?
          (csp-norm-state*
           (cadr (dzn->ast
                           #{
                             component c { behaviour { on i.a,i.b: [true] j.d;
                                                          on j.a:     [true] j.d;
                                                          on j.b:     [true] j.e;
                                                          } } #})))
          '(component (scope.name () c) (ports)
                      (behaviour #f (types) (variables) (functions)
                                 (compound
                                  (guard (expression true)
                                         (compound
                                          (on (triggers (trigger i a (arguments)) (trigger i b (arguments)))
                                              (action (trigger j d (arguments))))
                                          (on (triggers (trigger j a (arguments)))
                                              (action (trigger j d (arguments))))
                                          (on (triggers (trigger j b (arguments)))
                                              (action (trigger j e (arguments))))))))))))

(pass-if "csp-norm-state-aggregate-on-component-active"
         (or #t
         (om-pretty-noisy-equal?
          (csp-norm-state*
           (cadr (dzn->ast
                           #{
                             component c { behaviour { on i.a: [true] j.d;
                                                          on i.b: [true] j.d;
                                                          on j.a: [true] j.d;
                                                          on j.b: [true] j.e;
                                                          } } #})))
          '(component (scope.name () c) (ports)
                      (behaviour #f (types) (variables) (functions)
                                 (compound
                                  (guard (expression true)
                                         (compound
                                          (on (triggers (trigger i a (arguments)) (trigger i b (arguments)))
                                              (action (trigger j d (arguments))))
                                          (on (triggers (trigger j a (arguments)))
                                              (action (trigger j d (arguments))))
                                          (on (triggers (trigger j b (arguments)))
                                              (action (trigger j e (arguments))))))))))))

(pass-if "csp-norm-state-aggregate-on-component-active"
         (om-pretty-noisy-equal?
          (csp-norm-state*
           '(compound
             (compound
              (guard (expression (dotted state Disarmed))
                     (on (triggers (trigger console arm (arguments)))
                         (compound
                          (action (trigger sensor enable (arguments)))
                          (assign state (expression (dotted States Armed))))))
              (guard (expression (dotted state Disarmed))
                     (on (triggers
                          (trigger console disarm (arguments))
                          (trigger sensor triggered (arguments))
                          (trigger sensor disabled (arguments)))
                         (illegal))))
             (compound
              (guard (expression (dotted state Armed))
                     (on (triggers (trigger console arm (arguments))) (illegal))))))
          '(compound
            (guard
             (expression (dotted state Disarmed))
             (compound
              (on (triggers (trigger console arm (arguments)))
                  (compound
                   (action (trigger sensor enable (arguments)))
                   (assign
                    state
                    (expression (dotted States Armed)))))
              (on (triggers (trigger console disarm (arguments)))
                  (illegal))
              (on (triggers
                   (trigger sensor triggered (arguments))
                   (trigger sensor disabled (arguments)))
                  (illegal))))
            (guard
             (expression (dotted state Armed))
             (on (triggers (trigger console arm (arguments)))
                 (illegal))))))

(pass-if "csp-norm-state-nested-guards"
         (om-pretty-noisy-equal?
          (csp-norm-state*
           (car (.elements (ast:resolve (ast->om (dzn->ast
                           #{
interface norm_nested_guards
{
  enum Reply {Ok, Nok};
  in Reply e;

  behaviour
  {
    enum State {Foo};
    State state = State.Foo;
    bool bar = true;
    [state.Foo]
    {
      [bar] on e: [true] { reply(Reply.Ok);
      }
      [bar] on e: [true] { reply(Reply.Nok);
      }
    }
  }
}
#}))))))
'(interface
  (scope.name () norm_nested_guards)
  (types (enum (scope.name (norm_nested_guards) Reply) (fields Ok Nok)))
  (events (event e (signature (type (scope.name (norm_nested_guards) Reply))) in))
  (behaviour
    #f
    (types (enum (scope.name (norm_nested_guards) State) (fields Foo)))
    (variables
      (variable
        state
        (type (scope.name (norm_nested_guards) State))
        (expression (literal (scope.name (norm_nested_guards) State) Foo)))
      (variable
        bar
        (type bool)
        (expression true)))
    (functions)
    (compound
      (guard
        (expression
          (and (and (field state Foo) (var bar)) true))
        (compound
          (on (triggers (trigger #f e (arguments)))
              (reply (expression (literal (scope.name (norm_nested_guards) Reply) Ok))))
          (on (triggers (trigger #f e (arguments)))
              (reply (expression (literal (scope.name (norm_nested_guards) Reply) Nok)))))))))))
