(read-set! keywords 'prefix)

(define-module (test-handler)
  :use-module (test-suite lib)
  :use-module (test-suite misc)

  :use-module (gaiag reader)
  :use-module (gaiag norm-state)

  :use-module (oop goops)
  :use-module (gaiag gom))

(pass-if "norm-state-first-dummy-test"
         #t)

(pass-if "norm-state-101"
         (gom-pretty-noisy-equal?
          (norm-state
           (cadr (dezyne->ast
                           #{
                             interface i { in void a; out void b;
                                          behaviour { on a: [true] { } } } #})))
          '(interface i (types) (events (event a (signature (type void #f)) in) (event b (signature (type void #f)) out))
                      (behaviour #f (types) (variables) (functions)
                                 (compound
                                  (guard (expression true) (on (triggers (trigger #f a)) (compound))))))))

(pass-if "norm-state-102"
         (gom-pretty-noisy-equal?
          (norm-state
           (cadr (dezyne->ast
                           #{
                             interface i { in void a; out void b;
                                              behaviour { on a: [true] b;
                                                             } } #})))
          '(interface i (types) (events (event a (signature (type void #f)) in) (event b (signature (type void #f)) out))
                      (behaviour #f (types) (variables) (functions)
                                 (compound
                                  (guard (expression true)
                                         (on (triggers (trigger #f a))
                                             (action (trigger #f b)))))))))

(pass-if "norm-state-aggregate-guard-passive"
         (gom-pretty-noisy-equal?
          (norm-state
           (cadr (dezyne->ast
                           #{
                             interface i { in void a; in void b; in void c;
                                              out void d;
                                              behaviour { on a,b,c: [true] d;
                                                          } } #})))
          '(interface i (types) (events (event a (signature (type void #f)) in) (event b (signature (type void #f)) in) (event c (signature (type void #f)) in)
                                        (event d (signature (type void #f)) out))
                      (behaviour #f (types) (variables) (functions)
                                 (compound
                                  (guard (expression true)
                                         (on (triggers (trigger #f a) (trigger #f b) (trigger #f c))
                                             (action (trigger #f d)))))))))

(pass-if "norm-state-aggregate-guard-active"
         (gom-pretty-noisy-equal?
          (norm-state
           (cadr (dezyne->ast
                           #{
                             interface i { in void a; in void b; in void c;
                                              out void d; out void e; out void f;
                                          behaviour { on a: [true] d;
                                                          on b: [true] e;
                                                          on c: [true] f;
                                                          } } #})))
          '(interface i (types) (events (event a (signature (type void #f)) in) (event b (signature (type void #f)) in) (event c (signature (type void #f)) in)
                                        (event d (signature (type void #f)) out) (event e (signature (type void #f)) out) (event f (signature (type void #f)) out))
                      (behaviour #f (types) (variables) (functions)
                                 (compound
                                  (guard (expression true)
                                         (compound
                                          (on (triggers (trigger #f a)) (action (trigger #f d)))
                                          (on (triggers (trigger #f b)) (action (trigger #f e)))
                                          (on (triggers (trigger #f c)) (action (trigger #f f))))))))))

(pass-if "norm-state-aggregate-guard-recurse"
         (gom-pretty-noisy-equal?
          (norm-state
           '(compound
             (guard
              (expression (field state Disarming))
              (compound
               (on (triggers
                    (trigger console arm)
                    (trigger console disarm))
                   (illegal))
               (on (triggers (trigger sensor triggered))
                   (compound))
               (on (triggers (trigger sensor disabled))
                   (compound
                    (guard
                     (expression (var sounding))
                     (compound
                      (action (trigger console deactivated))
                      (action (trigger siren turnoff))
                      (assign
                       state
                       (expression (literal #f States Disarmed)))
                      (assign sounding (expression false))))
                    (guard
                     (otherwise)
                     (compound
                      (action (trigger console deactivated))
                      (assign
                       state
                       (expression
                        (literal #f States Disarmed)))))))))))
          '(compound
            (guard
             (expression (field state Disarming))
             (compound
              (on (triggers
                   (trigger console arm)
                   (trigger console disarm))
                  (illegal))
              (on (triggers (trigger sensor triggered))
                  (compound))))
            (guard
             (expression
              (and (field state Disarming) (var sounding)))
             (on (triggers (trigger sensor disabled))
                 (compound
                  (action (trigger console deactivated))
                  (action (trigger siren turnoff))
                  (assign
                   state
                   (expression (literal #f States Disarmed)))
                  (assign sounding (expression false)))))
            (guard
             (expression
              (and (field state Disarming)
                   (! (var sounding))))
             (on (triggers (trigger sensor disabled))
                 (compound
                  (action (trigger console deactivated))
                  (assign
                   state
                   (expression (literal #f States Disarmed)))))))))

(pass-if "norm-state-function-call"
         (gom-pretty-noisy-equal?
          (norm-state
           (cadr (dezyne->ast
                           #{
                             interface i { in void a; out void d;
                                              behaviour
                                              { void foo(){ if(true){}} on a,b,c: [true] d ;
                                                     } } #})))
          '(interface i (types) (events (event a (signature (type void #f)) in) (event d (signature (type void #f)) out))
                      (behaviour #f
                                 (types)
                                 (variables)
                                 (functions
                                  (function foo (signature (type void)) #f
                                            (compound (if (expression true) (compound)))))
                                 (compound
                                  (guard (expression true)
                                         (on (triggers (trigger #f a) (trigger #f b) (trigger #f c))
                                             (action (trigger #f d)))))))))

(pass-if "norm-state-split-on-passive"
         (gom-pretty-noisy-equal?
          (norm-state
           (cadr (dezyne->ast
                           #{
                             interface i { in void a; in void b; in void c;
                                              out void d;
                                              behaviour
                                              { on a,b,c: [true] d ;
                                                   } } #})))
          '(interface i (types) (events (event a (signature (type void #f)) in) (event b (signature (type void #f)) in) (event c (signature (type void #f)) in)
                                        (event d (signature (type void #f)) out))
                      (behaviour #f (types) (variables) (functions)
                                 (compound
                                  (guard (expression true)
                                         (on (triggers (trigger #f a) (trigger #f b) (trigger #f c))
                                             (action (trigger #f d)))))))))

(pass-if "norm-state-split-on-active-single-on"
         (gom-pretty-noisy-equal?
          (norm-state
           (cadr (dezyne->ast
                           #{
                             component c { behaviour { [true] on i.a: illegal;
                                                       [false] on i.b,i.c,j.a: illegal;
                                                          } } #})))
          '(component
            c
            (ports)
            (behaviour
             #f
             (types)
             (variables)
             (functions)
             (compound
              (guard
               (expression true)
               (on (triggers (trigger i a)) (illegal)))
              (guard
               (expression false)
               (compound
                (on (triggers (trigger i b) (trigger i c))
                     (illegal))
                (on (triggers (trigger j a)) (illegal)))))))))

(pass-if "norm-state-aggregate-on-interface-passive"
         (gom-pretty-noisy-equal?
          (norm-state
           (cadr (dezyne->ast
                           #{
                             interface i {  in void a; in void b; in void c;
                                              out void d;
                                              behaviour { on a,b,c: [true] d;
                                                          } } #})))
          '(interface i (types) (events (event a (signature (type void #f)) in) (event b (signature (type void #f)) in) (event c (signature (type void #f)) in)
                                        (event d (signature (type void #f)) out))
                      (behaviour #f (types) (variables) (functions)
                                 (compound
                                  (guard (expression true)
                                         (on (triggers (trigger #f a) (trigger #f b) (trigger #f c)) (action (trigger #f d)))))))))

(pass-if "norm-state-aggregate-on-interface-active"
         (gom-pretty-noisy-equal?
          (norm-state
           (cadr (dezyne->ast
                           #{
                             interface i {  in void a; in void b; in void c;
                                              out void d;
                                              behaviour { on a: [true] d;
                                                          on b: [true] d;
                                                          on c: [true] d;
                                                          } } #})))
          '(interface i (types) (events (event a (signature (type void #f)) in) (event b (signature (type void #f)) in) (event c (signature (type void #f)) in)
                                        (event d (signature (type void #f)) out))
                      (behaviour #f (types) (variables) (functions)
                                 (compound
                                  (guard (expression true)
                                         (compound
                                          (on (triggers (trigger #f a) (trigger #f b) (trigger #f c)) (action (trigger #f d))))))))))

;; not modifying the input where it is already fine,
;; helps retaining more location information in AST.
(pass-if "norm-state-aggregate-on-component-passive"
         (gom-pretty-noisy-equal?
          (norm-state
           (cadr (dezyne->ast
                           #{
                             component c { behaviour { on i.a,i.b: [true] j.d;
                                                          on j.a:     [true] j.d;
                                                          on j.b:     [true] j.e;
                                                          } } #})))
          '(component c (ports)
                      (behaviour #f (types) (variables) (functions)
                                 (compound
                                  (guard (expression true)
                                         (compound
                                          (on (triggers (trigger i a) (trigger i b))
                                              (action (trigger j d)))
                                          (on (triggers (trigger j a))
                                              (action (trigger j d)))
                                          (on (triggers (trigger j b))
                                              (action (trigger j e))))))))))

(pass-if "norm-state-aggregate-on-component-active"
         (gom-pretty-noisy-equal?
          (norm-state
           (cadr (dezyne->ast
                           #{
                             component c { behaviour { on i.a: [true] j.d;
                                                          on i.b: [true] j.d;
                                                          on j.a: [true] j.d;
                                                          on j.b: [true] j.e;
                                                          } } #})))
          '(component c (ports)
                      (behaviour #f (types) (variables) (functions)
                                 (compound
                                  (guard (expression true)
                                         (compound
                                          (on (triggers (trigger i a) (trigger i b))
                                              (action (trigger j d)))
                                          (on (triggers (trigger j a))
                                              (action (trigger j d)))
                                          (on (triggers (trigger j b))
                                              (action (trigger j e))))))))))

(pass-if "norm-state-aggregate-on-component-active"
         (gom-pretty-noisy-equal?
          (norm-state
           '(compound
             (compound
              (guard (expression (value state Disarmed))
                     (on (triggers (trigger console arm))
                         (compound
                          (action (trigger sensor enable))
                          (assign state (expression (value States Armed))))))
              (guard (expression (value state Disarmed))
                     (on (triggers
                          (trigger console disarm)
                          (trigger sensor triggered)
                          (trigger sensor disabled))
                         (illegal))))
             (compound
              (guard (expression (value state Armed))
                     (on (triggers (trigger console arm)) (illegal))))))
          '(compound
            (guard
             (expression (value state Disarmed))
             (compound
              (on (triggers (trigger console arm))
                  (compound
                   (action (trigger sensor enable))
                   (assign
                    state
                    (expression (value States Armed)))))
              (on (triggers (trigger console disarm))
                  (illegal))
              (on (triggers
                   (trigger sensor triggered)
                   (trigger sensor disabled))
                  (illegal))))
            (guard
             (expression (value state Armed))
             (on (triggers (trigger console arm))
                 (illegal))))))

(pass-if "norm-state-nested-guards"
         (gom-pretty-noisy-equal?
          (norm-state
           (cadr (dezyne->ast
                           #{
interface norm_nested_guards
{
  enum Reply {Ok, Nok};
  in Reply e;

  behaviour
  {
    enum State {Foo};
    State state = State.Foo;
    bool bar = true;
    [state.Foo]
    {
      [bar] on e: [true] { reply(Reply.Ok);
      }
      [bar] on e: [true] { reply(Reply.Nok);
      }
    }
  }
}
#})))
'(interface
  norm_nested_guards
  (types (enum Reply #f (fields Ok Nok)))
  (events (event e (signature (type Reply #f)) in))
  (behaviour
    #f
    (types (enum State #f (fields Foo)))
    (variables
      (variable
        state
        (type State #f)
        (expression (literal #f State Foo)))
      (variable
        bar
        (type bool #f)
        (expression true)))
    (functions)
    (compound
      (guard
        (expression
          (and (and (field state Foo) (var bar)) true))
        (compound
          (on (triggers (trigger #f e (arguments)))
               (compound
                 (reply (expression (literal #f Reply Ok)))))
          (on (triggers (trigger #f e (arguments)))
               (compound
                 (reply (expression (literal #f Reply Nok))))))))))))
