(pass-if "table-state-non-det"
  (or ;; (stderr "disabled: ~a\n" "table-state-non-det")
   (diff-noisy-equal?
   (pretty-table-state
    (ast:resolve*
     (dezyne->ast
#{interface IDevice {
 
 enum Res { OK, NOK };
 
 in Res turnon();
 in void turnoff();

 behaviour {
  
  enum State { Off, On };
  State s = State.Off;
  
  on turnon: {
   [s.Off] {
    reply(Res.OK);
    s = State.On;
   }
   [s.Off] reply(Res.NOK);
   [s.On] illegal;
  }
  on turnoff: {
   [s.Off] illegal;
   [s.On] s = State.Off;    
  }
 }
}
#}
)))
"
{
  [s.Off]
  {
    on turnon:
    {
      [true]
      {
        reply(Res.OK);
        s = State.On;
      }
      [true]
      reply(Res.NOK);
    } 
    on turnoff:
    illegal;
  }
  [s.On]
  {
    on turnon:
    illegal;
    on turnoff:
    s = State.Off;
  }
}
")))

(pass-if "table-state-locations"
  (or ;;(stderr "disabled: ~a\n" "table-state-locations")
   (pretty-noisy-equal?
   (extract-locations
    (test-table-state
     (ast:resolve*
      (dezyne->ast
#{interface table
{
  in void e();
  out void a();

  behaviour 
  {
    enum S { init, idle };
    S s = S.init;
    [s.init]
    on e:
    {
      s = S.idle;
      a;
    }
    [s.idle]
    on e:
    a;
  }
}
#}))))
'(compound
  (guard (expression (field s init))
         (on (triggers
               ((location #f 10 7 132 #f)
                trigger
                #f
                e
                (arguments)))
             (compound
               ((location #f 12 6 147 #f)
                assign
                s
                (expression
                  ((location #f 12 11 152 #f) literal #f S idle)))
               ((location #f 13 6 165 #f)
                action
                (trigger #f a (arguments))))))
  (guard (expression (field s idle))
         (on (triggers
               ((location #f 10 7 132 #f)
                trigger
                #f
                e
                (arguments)))
             ((location #f 17 4 201 #f)
              action
              (trigger #f a (arguments)))))))))

