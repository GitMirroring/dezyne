;; -*-mode:scheme-*-
;; This file is part of Gaiag, Guile in Asd In Asd in Guile.

(read-set! keywords 'prefix)

(define-module (test-handler)

  :use-module (test-suite lib)
  :use-module (test-suite misc)

  :use-module (gaiag ast)
  :use-module (gaiag annotate)  
  :use-module (gaiag pretty)
  :use-module (gaiag reader)
  :use-module (gaiag resolve)
  :use-module (gaiag table-state))

(define (ast:resolve* ast)
  ((compose ast:resolve ast->om) ast))

(define simplify-literal (@@ (gaiag table-state) simplify-literal))

(module-define! (resolve-module '(gaiag table-state))
                'command-line
                        (lambda () '("test-suite/run-tests" "foo" "bar")))

(define (model o)
  (car (filter (is? <model>) o)))

(define (test-table-state o)
  ((compose .statement .behaviour) ((table table-state) (model o))))

(define (pretty-table-state o)
 (ast->dezyne (test-table-state o)))

(pass-if "table-state-dummy-test"
         #t)

(define idle-init-busy-ast
  (model
   (ast:resolve*
    (dezyne->ast
#{
interface i
{
  in void e;
  out void a;
  behaviour
  {
     enum S { init, idle, busy };
     S s = S.init;

        [s.init] on e: { a; s = S.idle;
                         }
        [s.idle] on e: { a; s = S.busy;
                         }
        [s.busy] on e: { a; s = S.init;
                         }
        }
}
#}))))

(define idle-init-busy-statement
  ((compose .statement .behaviour om:interface) idle-init-busy-ast))

(pass-if "table-state-expression-state-field"
  (let ((state (make <literal> :type 'S :field 'idle)))
   (om-pretty-noisy-equal?
    (simplify-literal
     (om:interface idle-init-busy-ast)
     state
     (make <field> :identifier 's :field 'idle))
    #t)))

(pass-if "table-state-expression-state-var"
  (let ((state (make <literal> :type 'S :field 'idle)))
   (om-pretty-noisy-equal?
    (simplify-literal
     (om:interface idle-init-busy-ast)
     state
     (make <var> :name 's))
    state)))

(pass-if "table-state-expression-state-b-not-b"
  (let ((state (make <literal> :type 'S :field 'idle)))
   (om-pretty-noisy-equal?
    (simplify-literal
     (om:interface idle-init-busy-ast)
     state
     (list
      'or
      (make <var> :name 'b)
      (list '! (make <var> :name 'b))))
    #t)))

(pass-if "table-state-static"
  (om-pretty-noisy-equal?
   (test-table-state
    (ast:resolve*
     (dezyne->ast
#{
interface i
{
  in void e;
  out void a;
  behaviour
  {
     enum S { init, idle, busy };
     S s = S.init;

     [s.init] on e:
     {
      a; s = S.idle;                     
      }
     [s.idle] on e:
     {
      a; s = S.busy;
      }
     [s.busy] on e:
     {
      a; s = S.init;
      }
   }
}
#})))
   idle-init-busy-statement))

(pass-if "table-state-first-enum-variable"
  (om-pretty-noisy-equal?
   (test-table-state
    (ast:resolve*
     (dezyne->ast
#{
interface i
{
  in void e;
  out void a;
  behaviour
  {
     enum Foo { bar };
     enum S { init, idle, busy };
     S s = S.init;

        [s.init] on e: { a; s = S.idle;
                         }
        [s.idle] on e: { a; s = S.busy;
                         }
        [s.busy] on e: { a; s = S.init;
                         }
        }
}
#})))
'(compound
(guard
 (expression (field s init))
 (on (triggers (trigger #f e (arguments)))
     (compound
      (action (trigger #f a (arguments)))
      (assign s (expression (literal #f S idle))))))
(guard
 (expression (field s idle))
 (on (triggers (trigger #f e (arguments)))
     (compound
      (action (trigger #f a (arguments)))
      (assign s (expression (literal #f S busy))))))
(guard
 (expression (field s busy))
 (on (triggers (trigger #f e (arguments)))
     (compound
      (action (trigger #f a (arguments)))
      (assign s (expression (literal #f S init))))))
)))

(pass-if "table-state-state-var-equals"
  (om-pretty-noisy-equal?
   (test-table-state
    (ast:resolve*
     (dezyne->ast
#{
interface i
{
  in void e;
  out void a;
  behaviour
  {
     enum S { init, idle, busy };
     S s = S.init;

        [s == S.idle] on e: { a; s = S.busy;
                         }
        [s == S.busy] on e: { a; s = S.init;
                         }
        [s == S.init] on e: { a; s = S.idle;
                         }
        }
}
#})))
   idle-init-busy-statement))

(pass-if "table-state-state-on"
  (om-pretty-noisy-equal?
   (test-table-state
    (ast:resolve*
     (dezyne->ast
#{
interface i
{
  in void e;
  out void a;
  behaviour
  {
     enum S { init, idle, busy };
     S s = S.init;
     bool b = true;

        [s == S.idle] on e: [true] { a; s = S.busy;
                                 }
        [s == S.busy] on e: [false] { a; s = S.init;
                                 }
        [s == S.init] on e: [b] { a; s = S.idle;
                                 }
        }
}
#})))
'(compound
  (guard
    (expression (field s init))
    (on (triggers (trigger #f e (arguments)))
         (guard
           (expression (var b))
           (compound
             (action (trigger #f a (arguments)))
             (assign s (expression (literal #f S idle)))))))
  (guard
    (expression (field s idle))
    (on (triggers (trigger #f e (arguments)))
         (compound
           (action (trigger #f a (arguments)))
           (assign s (expression (literal #f S busy)))))))))

(pass-if "table-state-expressions"
  (om-pretty-noisy-equal?
   (test-table-state
    (ast:resolve*
     (dezyne->ast
#{
interface i
{
  in void e;
  out void a;
  behaviour
  {
     enum S { init, idle, busy };
     S s = S.init;
     bool b = true;

        [s.idle && b] on e: { a; s = S.busy;
                         }
        [s.busy && !b] on e: { a; s = S.init;
                         }
        [s.init && (b || !b)] on e: { a ; s = S.idle;
                         }
        }
}
#})))
'(compound
(guard
 (expression (field s init))
 (on (triggers (trigger #f e (arguments)))
     (compound
      (action (trigger #f a (arguments)))
      (assign s (expression (literal #f S idle))))))
(guard
 (expression (field s idle))
 (on (triggers (trigger #f e (arguments)))
     (guard
      (expression (var b))
      (compound
       (action (trigger #f a (arguments)))
       (assign s (expression (literal #f S busy)))))))
(guard
 (expression (field s busy))
 (on (triggers (trigger #f e (arguments)))
     (guard
      (expression (! (var b)))
      (compound
       (action (trigger #f a (arguments)))
       (assign s (expression (literal #f S init))))))))))

(pass-if "table-state-expressions-pretty"
  (diff-noisy-equal?
   (pretty-table-state
    (ast:resolve*
     (dezyne->ast
#{
interface i
{
  in void e;
  out void a;
  behaviour
  {
     enum S { init, idle, busy };
     S s = S.init;
     bool b = true;

     [s.idle && b]
        on e:
        {
          a;
          s = S.busy;
        }
      [s.busy && !b]
        on e:
        {
          a;
          s = S.init;
        }
      [s.init && (b || !b)]
        on e:
        {
          a;
          s = S.idle;
        }
     }
}
#})))
"
{
  [s.init]
    on e:
    {
      a;
      s = S.idle;
    }
  [s.idle]
    on e:
    [b]
    {
      a;
      s = S.busy;
    }
  [s.busy]
    on e:
    [!b]
    {
      a;
      s = S.init;
    }
}
"))

(pass-if "table-state-guards"
  (or ;;(stderr "disabled: ~a\n" "table-state-guards")
  (diff-noisy-equal?
   (pretty-table-state
    (ast:resolve*
     (dezyne->ast
#{
interface i
{
  in void e;
  out void a;
  behaviour
    {
      enum S { init, idle, busy };
      S s = S.init;
      bool b = true;
      bool bb = true;

      [s.idle]
        [bb]
        {
          [b]
            on e:
            {
              a;
              s = S.busy;
            }
          [!b]
            on e:
            {
            }
        }
      [s.busy]
        [true]
        on e:
        [!b]
        {
          a;
          s = S.init;
        }
      [s.init && (b || !b)]
        {
          [!bb]
            {
              on e:
                [true]
                [b]
              {
                a;
                s = S.idle;
              }
            }
          [bb]
            {
              on e:
                [true]
                [b]
              {
                a;
                s = S.idle;
              }
            }
        }
    }
}
#})))
"
{
  [s.init]
  on e:
  {
    [!bb && b]
    {
      a;
      s = S.idle;
    }
    [bb && b]
    {
      a;
      s = S.idle;
    }
  }
  [s.idle]
  on e:
  {
    [bb && b]
    {
      a;
      s = S.busy;
    }
    [bb && !b]
    {
    }
  }
  [s.busy]
  on e:
  [!b]
  {
    a;
    s = S.init;
  }
}
")))

(pass-if "table-state-choice"
  (diff-noisy-equal?
   (pretty-table-state
    (ast:resolve*
     (dezyne->ast
#{
interface i
{
  in void e;
  out void a;
  behaviour
    {
     enum S { init };
     S s = S.init;

     [s.init]
     on e:
     {
      [true]
      {
       a;
      }
      [true]
      {
      }
     }
  }
}
#})))
"
{
  [s.init]
    on e:
    {
      [true]
      a;
      [true]
      {
      }
  }
}
"))


(pass-if "table-state-sort-triggers"
  (or (stderr "disabled: ~a\n" "table-state-sort-triggers")
   (diff-noisy-equal?
   (pretty-table-state
    (ast:resolve*
     (dezyne->ast
#{
interface ISiren
{
  in void start();
  in void stop();

  behaviour
  {
    bool running = false;
    [running]
    {
      on start: running = !running;
      on stop: illegal;
    }
    [otherwise]
    {
      on start: illegal;
      on stop: running = !running;
    }
  }
}
#})))
"
{
    [true]
    {
      on start:
      {
        [running]
        running = !running;
        [otherwise]
        illegal;
      }
      on stop:
      {
        [running]
        illegal;
        [otherwise]
        running = !running;
      }
   }
}
")))


(pass-if "table-state-resolve-deep-otherwise"
  (diff-noisy-equal?
   (pretty-table-state
    (ast:resolve*
     (dezyne->ast
#{
interface i
{
  in void e;
  out void a;
  behaviour
  {
     enum S { init, idle, busy };
     S s = S.init;

    [s.init || s.idle]
    {
      on e:
      {
        [s.init]
        {
          a;
          s = S.busy;
        }
        [otherwise] {}
      }
    }
    [s.busy] on e: s = S.init;
  }
}
#})))
"
{
  [s.init]
  on e:
  {
    a;
    s = S.busy;
  }
  [s.idle]
  on e:
  {
  }
  [s.busy]
  on e:
  s = S.init;
}
"))

