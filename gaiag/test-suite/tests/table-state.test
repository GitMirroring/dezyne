}

"))

(pass-if "table-state-nested-compound"
  (diff-noisy-equal?
   (pretty-table-state
    (ast:resolve*
     (dezyne->ast
#{
interface I
{
  in void e;
  behaviour
  {
    bool b = true;
    [b] { {on e: {}} }
  }
}
#})))
"
{
  [true]
  on e:
  [b]
  {
  }
}
"))

(pass-if "table-state-other-enum"
  (diff-noisy-equal?
   (pretty-table-state
    (ast:resolve*
     (dezyne->ast
#{
interface I {
 in void e;
 
 behaviour {
  enum S { init };
  
  S s = S.init;
  S o = S.init;
  
  bool b = false;
  
  [o.init] {
   on e: {
    [b] { }
    [otherwise] illegal;
   }
  }
 }
}
#}
)))
"
{
  [s.init]
    on e:
      [o.init]
      {
        [b]
        {
        }
        [otherwise]
        illegal;
      }
}
"))

(pass-if "table-state-collapse-inevitable"
  (diff-noisy-equal?
   (pretty-table-state
    (ast:resolve*
     (dezyne->ast
#{
interface I {
  in void i;
  in void o;
  out void a;
  
  behaviour
  {
    enum S {init, setup, idle};
    
    S s = S.init;
    
    on o: s = S.init;
    on i: {
      [s.init] s = S.setup;
      [otherwise] illegal;
    }    
    
    on inevitable: {
      [s.setup]
      {
        a;
        s = S.idle;
      }
    }
  }
}
#}
)))
"
{
  [s.init]
  {
    on o:
    s = S.init;
    on i:
    s = S.setup;
  }
  [s.setup]
  {
    on o:
    s = S.init;
    on i:
    illegal;
    on inevitable:
    {
      a;
      s = S.idle;
    }
  }
  [s.idle]
  {
    on o:
    s = S.init;
    on i:
    illegal;
  }
}
"))

