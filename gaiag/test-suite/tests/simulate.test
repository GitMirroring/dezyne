(read-set! keywords 'prefix)

(define-module (test-handler)
  :use-module (test-suite lib)
  :use-module (test-suite misc)

  :use-module (gaiag reader)
  :use-module (gaiag pretty-print)
  :use-module (gaiag evaluate)
  :use-module (gaiag simulate)


  :use-module (gaiag ast))

(pass-if "simulator-first-dummy-test"
	 #t)

(define if-ast
  '((interface
     i
     (types)
     (events
      (event a (signature (type void #f)) in)
      (event b (signature (type void #f)) out)
      (event c (signature (type void #f)) out))
     (behaviour
      #f
      (types)
      (variables
       (variable t (type bool) (expression false)))
      (functions)
      (compound
       (on (triggers (trigger #f a))
           (compound
            (if (expression (var t))
                (compound (action (trigger #f b)))
                (compound (action (trigger #f c))))
            (assign t (expression (! (var t)))))))))
    (component C (ports (provides i I)) (behaviour))))

(pass-if "simulator-state-vector"
  (pretty-noisy-equal?
   ((@@ (gaiag simulate) state-vector) (simulate:om (car if-ast)))
   '((t . #f))))

(pass-if "simulator-var!"
  (pretty-noisy-equal?
   ((@@ (gaiag simulate) var!) '((t . #f)) 't #t)
   '((t . #t))))

(pass-if "simulator-simple-trail"
  (om-pretty-noisy-equal?
   (walk-trail
    (om:interface
     (simulate:om
      (dezyne->ast
       #{
         interface i { in void a; out void b;
                          behaviour { on a: b;
                                         } } #})))
    '(a a a))
   (map
    (lambda (x) (cons x (cons '() '((on (triggers (trigger #f a)) (action (trigger #f b))) (action (trigger #f b))))))
    '(a a a))))

(pass-if "simulator-guard-trail"
   (om-pretty-noisy-equal?
    (walk-trail
     (simulate:om
      (cadr
       (dezyne->ast
        #{ interface i
                     {
                      in void a; out void b;
                      behaviour
                      {
                       bool t = true    ;
                       on a:
                       {
                        [t] t = !t      ;
                        [!t] b          ;
                        }
                       }
                      } #})))
     '(a a a))
    '((a
       ((t . #t))
       (on (triggers (trigger #f a))
           (compound
            (guard (expression (var t)) (assign t (expression (! (var t)))))
            (guard (expression (! (var t))) (action (trigger #f b)))))
       (guard (expression (var t)) (assign t (expression (! (var t)))))
       (assign t (expression (! (var t)))))
      (a
       ((t . #f))
       (on (triggers (trigger #f a))
           (compound
            (guard (expression (var t)) (assign t (expression (! (var t)))))
            (guard (expression (! (var t))) (action (trigger #f b)))))
       (guard (expression (! (var t))) (action (trigger #f b)))
       (action (trigger #f b)))
      (a
       ((t . #f))
       (on (triggers (trigger #f a))
           (compound
            (guard (expression (var t)) (assign t (expression (! (var t)))))
            (guard (expression (! (var t))) (action (trigger #f b)))))
       (guard (expression (! (var t))) (action (trigger #f b)))
       (action (trigger #f b))))))

(pass-if "walk-trail-arguments"
(or #t (let* ((arguments-ast (read-ast 'examples/arguments.dzn))
          (om ((om:register simulate:om) arguments-ast #t))
          (model (om:component om))
          (trail '(i.e i.e i.e))
          (foobar (set-program-arguments '("gaiag" "--json" "foobar")))
          (arguments-trace (with-output-to-string (lambda () (pretty-print (mangle-trace model (walk-trail model trail))))))
          (baseline-trace 'baseline-trace))
     #t)))

(pass-if "walk-trail-pauls"
(or #t  (let* ((pauls-ast (read-ast 'examples/regression/Comp.dzn))
          (om ((om:register simulate:om) pauls-ast #t))
          (model (om:component om))
          (trail '(client.initialize result_t.OK result_t.OK client.perform_actions result_t.OK result_t.OK client.perform_actions result_t.NOK client.recover result_t.OK client.perform_actions))
          (pauls-trace (walk-trail model trail))
          (baseline-trace 'baseline-trace))
     #t)))

