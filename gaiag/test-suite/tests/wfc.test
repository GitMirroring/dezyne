(read-set! keywords 'prefix)

(define-module (test-handler)
  :use-module (test-suite lib)
  :use-module (test-suite misc)

  :use-module (gaiag reader)
  :use-module (gaiag wfc)
  :use-module (gaiag gom)
  :use-module (oop goops))

(define (asd->gom o)
  ((compose gom:resolve ast->gom asd->ast) o))

(pass-if "wfc-first-dummy-test"
	 #t)

(pass-if "wfc-second-on"
  (gom-pretty-noisy-equal?
   (second-on
    (asd->gom
     #{
       interface i { behaviour { [true] on a: [false] on a: b;
                                 } } #}))
   '(("second on"
      (on (triggers (trigger #f a))
          (action (trigger #f b)))))))

(pass-if "wfc-mixing-declarative-imperative"
  (gom-pretty-noisy-equal?
   (mixing-declarative-imperative
    (asd->gom
     #{
       interface i { behaviour { bool b = false;
                                      [true] on a: b;
                                      b = true;
                                      } } #}))
   '(("mixing imperative"
      (assign* b (expression* true))))))
