(define-module (test-handler)
  #:use-module (test-suite lib)
  #:use-module (test-suite misc)

  #:use-module ((oop goops) #:renamer (lambda (x) (if (eq? x '<port>) 'goops:<port> x)))
  #:use-module (gaiag goops)
  #:use-module (gaiag ast2om)
  #:use-module (gaiag om)
  #:use-module (gaiag resolve)

  #:use-module (gaiag reader)
;;  #:use-module (gaiag wfc)
)

(define (dezyne->om o)
  ((compose ast:resolve ast->om dzn->ast) o))

(define (wfc-error o message)
  ((@@ (gaiag wfc) wfc-error) (ast->om o) message))

(define second-on (@@ (gaiag wfc) second-on))
(define mixing-declarative-imperative (@@ (gaiag wfc) mixing-declarative-imperative))
(define component (@@ (gaiag wfc) component))
(define interface (@@ (gaiag wfc) interface))

(pass-if "wfc-first-dummy-test"
	 #t)

(pass-if "wfc-second-on"
  (om-pretty-noisy-equal?
   (car ((second-on)
     (dezyne->om
      #{
        interface i { in void a         ; out void b;
                         behaviour
                         { [true] on a: [false] on a: b ;
                           } } #})))
   (wfc-error '(on (triggers (trigger #f a@))
                   (action b@))
              "second on")))

(pass-if "wfc-mixing-declarative-imperative"
  (om-pretty-noisy-equal?
   (car
    (mixing-declarative-imperative
     (dezyne->om
      #{
        interface i { in void a         ; out void c;
                         behaviour
                         { bool b = false     ;
                                [true] on a: c ;
                                b = true       ;
                                } } #})))
   (wfc-error '(assign b@ (expression true)) "mixing imperative")))

(pass-if "wfc-interface"
  (om-pretty-noisy-equal?
   (car
    (interface
     (dezyne->om
      #{ interface i { } #} )))
   (wfc-error '(interface (scope.name () i)) "interface must have a behaviour")))

(pass-if "wfc-component"
  (om-pretty-noisy-equal?
   (car
    (component
     (dezyne->om
      #{ component c { behaviour { } } #})))
   (wfc-error '(component (scope.name () c) (ports) (behaviour #f)) "component with behaviour must have one provides port")))
