(read-set! keywords 'prefix)

(define-module (test-handler)
  :use-module (test-suite lib)
  :use-module (test-suite misc)

  :use-module (gaiag reader)
  :use-module (gaiag wfc)
  :use-module (gaiag gom)
  :use-module (oop goops))

(define (asd->gom o)
  ((compose gom:resolve ast->gom asd->ast) o))

(define-method (wfc-error (o <list>) (message <string>))
  ((@@ (gaiag wfc) wfc-error) (ast->gom o) message))

(define second-on (@@ (gaiag wfc) second-on))
(define mixing-declarative-imperative (@@ (gaiag wfc) mixing-declarative-imperative))
(define component (@@ (gaiag wfc) component))
(define interface (@@ (gaiag wfc) interface))

(pass-if "wfc-first-dummy-test"
	 #t)

(pass-if "wfc-second-on"
  (gom-pretty-noisy-equal?
   (second-on
    (asd->gom
     #{
       interface i { in void a; out void b;
                        behaviour
                        { [true] on a: [false] on a: b ;
                          } } #}))
   (list (wfc-error '(on (triggers (trigger #f a))
                         (action (trigger #f b)))
                    "second on"))))

(pass-if "wfc-mixing-declarative-imperative"
  (gom-pretty-noisy-equal?
   (mixing-declarative-imperative
    (asd->gom
     #{
       interface i { in void a; out void c;
                        behaviour
                        { bool b = false             ;
                               [true] on a: c        ;
                               b = true              ;
                               } } #}))
   (list (wfc-error '(assign b (expression true)) "mixing imperative"))))

(pass-if "wfc-interface"
  (gom-pretty-noisy-equal?
   (interface
    (asd->gom
     #{ interface i { } #} ))
   (list
    (wfc-error '(interface i) "interface must have a behaviour"))))

(pass-if "wfc-component"
  (gom-pretty-noisy-equal?
   (component
    (asd->gom
     #{ component c { behaviour { } } #}))
   (list
    (wfc-error '(component c (ports) (behaviour #f)) "component with behaviour must have one provides port")
    (wfc-error '(component c (ports) (behaviour #f)) "component with behaviour must accept an event"))))
