        pending_reply = true;
        synchronous = false;
        WaitInit_datasource_Init();
        number__ = nr__STORE;
      }
      blocking on outParam.e_inout(number__ <- nr__STORE):
      {
         /*- Reply at end of transaction -*/
        nr = number__;
        pending_reply = true;
        synchronous = true;
        WaitInit_datasource_Init();
        number__ = nr__STORE;
      }
      blocking on outParam.e_inout_async(number__):
      {
         /*- Reply at end of transaction -*/
        pending_reply = true;
        synchronous = false;
        WaitInit_datasource_Init();
      }
      on outParam.e_outdated(number__):
      {
         /*- Early Reply ensures output parameter not modified after this point. -*/
        number__ = nr;
        pending_reply = false;
        synchronous = true;
        // WARNING: in ASD: following a reply, Data Parameters are modified in the next (synchronous return) state
        WaitInit_datasource_Init();
      }
      on datasource.ReceiveData:
      {
        illegal;
      }
    }

    [state_.WaitReceive]
    {
      on datasource.ReceiveData(number__):
      {
        nr = number__;
        datasource.Term();
        outParam.reply();
        pending_reply = false;
        state_ = States.Available;
      }
      on outParam.e_out,
          outParam.e_out_async,
          outParam.e_inout,
          outParam.e_inout_async,
          outParam.e_outdated:
      {
        illegal;
      }
    }

     /*- Reply at end of transaction -*/
    void WaitInit_datasource_Init()
    {
      IMultiStepOutParam.IMultiStepOutParam_Values value_ = datasource.Init();

      if (value_.Ok)
      {
        if (synchronous)
