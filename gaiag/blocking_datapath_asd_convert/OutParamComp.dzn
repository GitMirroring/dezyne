import IOutParam.dzn;
import IMultiStepOutParam.dzn;

component OutParamComp
{
  provides IOutParam outParam;
  requires IMultiStepOutParam datasource;

  behaviour
  {
    enum States {Available, WaitReceive /*- pending_reply == true -*/ };

    States state_ = States.Available;
    bool pending_reply = false;
    bool synchronous = false;

    xint nr;

    [state_.Available]
    {
      blocking on outParam.e_out(number__ <- nr):
      {
         /*- Reply at end of transaction -*/ 
        pending_reply = true;
        synchronous = true;
        WaitInit_datasource_Init();
      }
      blocking on outParam.e_out_async(number__ <- nr):
      {
         /*- Reply at end of transaction -*/ 
        pending_reply = true;
        synchronous = false;
        WaitInit_datasource_Init();
      }
      blocking on outParam.e_inout(number__ <- nr):
      {
         /*- Reply at end of transaction -*/ 
        nr = number__;
        pending_reply = true;
        synchronous = true;
        WaitInit_datasource_Init();
      }
      blocking on outParam.e_inout_async(number__ <- nr):
      {
         /*- Reply at end of transaction -*/ 
        nr = number__;
        pending_reply = true;
        synchronous = false;
        WaitInit_datasource_Init();
      }
      blocking on outParam.e_outdated(number__ <- nr):
      {
         /*- Early Reply ensures output parameter not modified after this point. -*/ 
        outParam.reply();
        pending_reply = false;
        synchronous = true;
        // WARNING: in ASD: following a reply, Data Parameters are modified in the next (synchronous return) state
        WaitInit_datasource_Init();
      }
      on datasource.ReceiveData:
      {
        illegal;
      }
    }

    [state_.WaitReceive]
    {
      on datasource.ReceiveData(number__):
      {
        nr = number__;
        datasource.Term();
        outParam.reply();
        pending_reply = false;
        state_ = States.Available;
      }
      on outParam.e_out, 
          outParam.e_out_async, 
          outParam.e_inout, 
          outParam.e_inout_async, 
          outParam.e_outdated:
      {
        illegal;
      }
    }

     /*- Reply at end of transaction -*/ 
    void WaitInit_datasource_Init()
    {
      IMultiStepOutParam.IMultiStepOutParam_Values value_ = datasource.Init();

      if (value_.Ok)
      {
        if (synchronous)
        {
          WaitGet_datasource_GetData(nr);
        }
        else
        {
          datasource.RequestData();
          state_ = States.WaitReceive;
        }
      }
      else
      {
        illegal;
      }
    }

    void WaitGet_datasource_GetData(out xint nr)
    {
      IMultiStepOutParam.IMultiStepOutParam_Values value_ = datasource.GetData(nr);

      if (value_.Ok)
      {
        if (pending_reply)
        {
          datasource.Term();
          outParam.reply();
          pending_reply = false;
          state_ = States.Available;
        }
        else
        {
          datasource.Term();
          pending_reply = false;
          state_ = States.Available;
        }
      }
      else
      {
        illegal;
      }
    }

  }
}
