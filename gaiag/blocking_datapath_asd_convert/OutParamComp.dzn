import IOutParam.dzn;
import IMultiStepOutParam.dzn;

component OutParamComp
{
  provides IOutParam outParam;
  requires IMultiStepOutParam datasource;

  behaviour
  {
    enum States {Available, WaitReceive /*- pending_reply == true -*/ };

    States state_ = States.Available;
    bool pending_reply = false;
    bool synchronous = false;

    xint nr;
    xint nr__STORE;// Capture data at Reply (ASD semantics)

    [state_.Available]
    {
      blocking on outParam.e_out(number__ <- nr__STORE):
      {
         /*- Reply at end of transaction -*/
        pending_reply = true;
        synchronous = true;
        WaitInit_datasource_Init();
        number__ = nr__STORE;
