          datasource.Term();
          outParam.reply();
          nr__STORE = nr;
          pending_reply = false;
          state_ = States.Available;
        }
        else
        {
          datasource.Term();
          pending_reply = false;
          state_ = States.Available;
        }
      }
      else
      {
        illegal;
      }
    }

  }
