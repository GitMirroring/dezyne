(define-module (gaiag config)
  #:export (%asd
            %bindir
            %sbindir
            %datadir
            %datarootdir
            %dzn
            %dezyne-prefix
            %localstatedir
            %guilemoduledir
            %guileobjectdir
            %guile-piped-process?
            %lps2lts-stdout?
            %ltscompare-stdin?
            %prefix
            %root-dir
            %service-bindir
            %service-dir
            %service-version
            %service-versions-dir
            %sysconfdir
            %command-dir
            %template-dir
            %version
            %version-major
            %version-minor
            %version-patch))

;;; Commentary:
;;;
;;; Compile-time configuration of gdzn.  When adding a substitution variable
;;; here, make sure to have configure substitute it.
;;;
;;; Code:

(define %prefix
  (or (and (getenv "DZN_UNINSTALLED") (getenv "PREFIX"))
      "@prefix@"))

(define %exec-prefix
  (or (and (getenv "DZN_UNINSTALLED") (getenv "PREFIX"))
      "@exec_prefix@"))

(define %dezyne-prefix
  (or (getenv "DEZYNE_PREFIX") %prefix))

(define %datadir
  (or (and (getenv "DZN_UNINSTALLED") %prefix)
      "@datadir@"))

(define %datarootdir
  (or (and (getenv "DZN_UNINSTALLED") %prefix)
      "@datarootdir@"))

(define %pkgdatadir
  (or (and (getenv "DZN_UNINSTALLED") %prefix)
      (string-append %datadir "/dzn")))

(define %bindir
  (or (and (getenv "DZN_UNINSTALLED") (string-append %prefix "/bin"))
      "@bindir@"))

(define %root-dir
  (or (and (getenv "DZN_UNINSTALLED") %prefix)
      %pkgdatadir))

(define %service-bindir
  (string-append %datadir "/bin"))

(define %sbindir
  "@sbindir")

(define %template-dir
  (string-append %datadir "/templates"))

(define %guilemoduledir
  "@guilemoduledir@")

(define %guileobjectdir
  "@guileobjectdir@")

(define %command-dir
  (or (and (getenv "DZN_UNINSTALLED") (string-append %prefix "/gaiag/commands"))
      (string-append %guileobjectdir "/gaiag/commands")))

(define %service-dir
  (string-append %datadir "/services"))

(define %service-version
  "@PACKAGE_VERSION@")

(define %version
  "@PACKAGE_VERSION@")

(define %version-major
  @VERSION_MAJOR@)

(define %version-minor
  @VERSION_MINOR@)

(define %version-patch
  @VERSION_PATCH@)

(define %service-versions-dir
  (string-append %dezyne-prefix "/services"))

(define %localstatedir
  "@localstatedir@")

(define %sysconfdir
  "@sysconfdir@")

(define %asd
  "@ASD@")

(define %dzn
  (string-append %bindir "/dzn"))

(define %lps2lts-stdout?
  (equal? "@have_lps2lts_stdout@" "yes"))

(define %ltscompare-stdin?
  (equal? "@have_ltscompare_stdin@" "yes"))

(define %guile-piped-process?
  (equal? "@have_guile_piped_process@" "yes"))
