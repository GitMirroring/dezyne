;;; Commentary:
;;;
;;; Code:

(define-module (gaiag config)
  #:export (%bindir
            %sbindir
            %datadir
            %dezyne-prefix
            %localstatedir
            %prefix
            %root-dir
            %service-bindir
            %service-dir
            %service-version
            %service-versions-dir
            %sysconfdir
            %command-dir
            %template-dir))

;;; Commentary:
;;;
;;; Compile-time configuration of gdzn.  When adding a substitution variable
;;; here, make sure to have configure substitute it.
;;;
;;; Code:

(define %prefix
  (or (and (getenv "DZN_UNINSTALLED") (getenv "PREFIX"))
      "@prefix@"))

(define %dezyne-prefix
  (or (getenv "DEZYNE_PREFIX") %prefix))

(define %datadir
  (or (and (getenv "DZN_UNINSTALLED") %prefix)
      "@datadir@"))

(define %bindir
  (or (and (getenv "DZN_UNINSTALLED") (string-append %prefix "/bin"))
      "@bindir@"))

(define %root-dir
  (or (and (getenv "DZN_UNINSTALLED") (string-append %prefix "/services/root"))
      (string-append %datadir "/root")))

(define %service-bindir
  (string-append %datadir "/bin"))

(define %sbindir
  (or (and (getenv "DZN_UNINSTALLED") (string-append %prefix "/sbin"))
      "@sbindir@"))

(define %template-dir
  (string-append %datadir "/gaiag/templates"))

(define %command-dir
  (string-append %datadir "/gaiag/gaiag/commands"))

(define %service-dir
  (string-append %datadir "/services"))

(define %service-version
  "@SERVICE_VERSION@")

(define %service-versions-dir
  (string-append %dezyne-prefix "/services"))

(define %localstatedir
  "@localstatedir@")

(define %sysconfdir
  "@sysconfdir@")
