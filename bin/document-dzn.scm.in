(use-modules (ice-9 regex)
             (ice-9 documentation)
             (srfi srfi-1)
             (sxml simple)
             (texinfo reflection)
             (texinfo html)
             (texinfo serialize)
             (texinfo plain-text)
             (texinfo reflection))

(define scrub-//
  (let ((dirt (make-regexp "^//+")))
    (lambda (line)
      (let ((m (regexp-exec dirt line)))
        (if m (match:suffix m) line)))))

(define (dzn-commentary file-name)
  (file-commentary file-name "^// Commentary:" "^// Code:" scrub-//))

(define string->stexi (@@ (texinfo reflection) string->stexi))

(define (dzn-stexi-documentation file-name)
  "Return documentation for FILE-NAME.  The documentation is taken from
the FILE-NAMEs commentary, and is returned in the @code{stexi}
format (@pxref{texinfo,texinfo})."
  (let ((commentary (dzn-commentary file-name)))
    `(texinfo (% (title ,(basename file-name)))
              (node (% (name ,(basename file-name))))
              ,@(if commentary
                    (cdr
                     (string->stexi
                      (string-trim-both commentary #\newline)))
                    '()))))

(define (main args)
  (let* ((output-format 'texinfo)
         (file-name (cadr args))
         (dzn-docs (dzn-stexi-documentation file-name))
         ;;(dzn-docs (snippet-stexi-documentation file-name))
         )
    (format (current-error-port) "dzn-docs: ~s\n" dzn-docs)
    (case output-format
      ((text)
       (display (stexi->plain-text dzn-docs)))
      ((html)
       (sxml->xml (stexi->shtml dzn-docs)))
      ((texinfo)
       (display (stexi->texi dzn-docs))))))
