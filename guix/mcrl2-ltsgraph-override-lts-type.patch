From: Johri van Eerd <johri.van.eerd@verum.com>
Date: Thu, 31 May 2018 17:27:26 +0200
Subject: [PATCH] ltsgraph-override-lts-type

---
 tools/release/ltsgraph/graph.cpp      |  7 ++++++-
 tools/release/ltsgraph/graph.h        | 10 ++++++++++
 tools/release/ltsgraph/main.cpp       | 37 ++++++++++++++++++++++++++++++++++-
 tools/release/ltsgraph/mainwindow.cpp | 13 ++++++++++--
 tools/release/ltsgraph/mainwindow.h   |  7 +++++++
 5 files changed, 70 insertions(+), 4 deletions(-)

diff --git a/tools/release/ltsgraph/graph.cpp b/tools/release/ltsgraph/graph.cpp
index 85cb51072..03899d705 100644
--- a/tools/release/ltsgraph/graph.cpp
+++ b/tools/release/ltsgraph/graph.cpp
@@ -703,10 +703,15 @@ void Graph::clear()
 void Graph::load(const QString& filename, const QVector3D& min,
                  const QVector3D& max)
 {
+  this->load(filename, min, max, mcrl2::lts::detail::guess_format(filename.toUtf8().constData()));
+}
+
+void Graph::load(const QString& filename, const QVector3D& min,
+		 const QVector3D& max, mcrl2::lts::lts_type m_type)
+{
   lockForWrite(m_lock, GRAPH_LOCK_TRACE);

   clear();
-  m_type = mcrl2::lts::detail::guess_format(filename.toUtf8().constData());
   try
   {
     switch (m_type)
diff --git a/tools/release/ltsgraph/graph.h b/tools/release/ltsgraph/graph.h
index 67742a838..6fbe66655 100644
--- a/tools/release/ltsgraph/graph.h
+++ b/tools/release/ltsgraph/graph.h
@@ -20,6 +20,7 @@
 #define GRAPH_H

 #include "mcrl2/lts/lts.h"
+#include "mcrl2/lts/lts_type.h"
 #include "mcrl2/lts/state_label_empty.h"

 #include <cmath>
@@ -437,6 +438,15 @@ class Graph
     void load(const QString& filename, const QVector3D& min, const QVector3D& max);

     /**
+     * @brief Loads a graph with random positioning for the nodes.
+     * @param filename The file which contains the graph.
+     * @param min The minimum coordinates for any node.
+     * @param max The maximum coordinates for any node.
+     * @param m_type The type of the graph provided in filename.
+     */
+    void load(const QString& filename, const QVector3D& min, const QVector3D& max, mcrl2::lts::lts_type m_type);
+
+    /**
      * @brief Loads a graph with from a XML file exported using @fn saveXML.
      * @param filename The file which contains the graph.
      */
diff --git a/tools/release/ltsgraph/main.cpp b/tools/release/ltsgraph/main.cpp
index ec94d55a6..fe332ff09 100644
--- a/tools/release/ltsgraph/main.cpp
+++ b/tools/release/ltsgraph/main.cpp
@@ -7,6 +7,8 @@
 // http://www.boost.org/LICENSE_1_0.txt)
 //

+#include "mcrl2/lts/lts_type.h"
+#include "mcrl2/lts/lts_io.h"
 #include "mcrl2/utilities/input_tool.h"
 #include "mainwindow.h"
 #include "mcrl2/gui/qt_tool.h"
@@ -17,6 +18,34 @@ using namespace mcrl2::utilities;
 typedef gui::qt::qt_tool<tools::input_tool> ltsgraph_base;
 class ltsgraph_tool : public ltsgraph_base
 {
+private:
+  mcrl2::lts::lts_type m_type;
+protected:
+  void add_options(interface_description& desc)
+  {
+    ltsgraph_base::add_options(desc);
+    desc.add_option("in", make_mandatory_argument("FORMAT"),
+		    "use FORMAT as the input format.", 'i');
+  }
+  void parse_options(const command_line_parser& parser)
+  {
+    ltsgraph_base::parse_options(parser);
+    if (parser.options.count("in"))
+    {
+      if (1 < parser.options.count("in"))
+      {
+	mCRL2log(warning) << "multiple input formats specified; can only use one\n";
+      }
+
+      m_type = mcrl2::lts::detail::parse_format(parser.option_argument("in"));
+
+      if (m_type == mcrl2::lts::lts_none)
+      {
+	mCRL2log(warning) << "format '" << parser.option_argument("in") <<
+	  "' is not recognised; option ignored" << std::endl;
+      }
+    } else m_type = mcrl2::lts::lts_none;
+  }
   public:
     ltsgraph_tool():
       ltsgraph_base("LTSGraph",
@@ -31,10 +60,16 @@ class ltsgraph_tool : public ltsgraph_base
     {
       MainWindow* window = new MainWindow();

-      if (!m_input_filename.empty())
+      //--in option not or wrongly specified, so m_type is lts_none -> execute as normal
+      if (m_type == mcrl2::lts::lts_none && !m_input_filename.empty())
       {
         window->delayedOpenFile(QString::fromStdString(m_input_filename));
       }
+      //filename is of a certain lts type, propagate m_type to parse input lts with
+      else if(!m_input_filename.empty())
+      {
+	window->delayedOpenFile(QString::fromStdString(m_input_filename), m_type);
+      }

       return show_main_window(window);
     }
diff --git a/tools/release/ltsgraph/mainwindow.cpp b/tools/release/ltsgraph/mainwindow.cpp
index 6cf97113a..5e112bbe9 100644
--- a/tools/release/ltsgraph/mainwindow.cpp
+++ b/tools/release/ltsgraph/mainwindow.cpp
@@ -24,7 +24,8 @@

 MainWindow::MainWindow(QWidget* parent) :
   QMainWindow(parent),
-  m_fileDialog("", this)
+  m_fileDialog("", this),
+  m_type(mcrl2::lts::lts_none)
 {

   m_ui.setupUi(this);
@@ -177,6 +178,12 @@ void MainWindow::delayedOpenFile(QString fileName)
   m_delayedOpen = std::move(fileName);
 }

+void MainWindow::delayedOpenFile(QString fileName, mcrl2::lts::lts_type type)
+{
+  m_delayedOpen = std::move(fileName);
+  m_type = std::move(type);
+}
+
 void MainWindow::openFile(const QString& fileName)
 {
   if (!fileName.isNull())
@@ -189,7 +196,9 @@ void MainWindow::openFile(const QString& fileName)
       m_glwidget->resetViewpoint(0);
       const double scaling = 0.5;
       QVector3D limit = m_glwidget->size3() / 2.0 * scaling;
-      m_graph.load(fileName, -limit, limit);
+      m_type == mcrl2::lts::lts_none ?
+	m_graph.load(fileName, -limit, limit)
+	: m_graph.load(fileName, -limit, limit, m_type);

       if (m_graph.nodeCount() > MAX_NODE_COUNT && !hadSelection)
       {
diff --git a/tools/release/ltsgraph/mainwindow.h b/tools/release/ltsgraph/mainwindow.h
index cb7198dd3..c5c01a2e2 100644
--- a/tools/release/ltsgraph/mainwindow.h
+++ b/tools/release/ltsgraph/mainwindow.h
@@ -22,6 +22,7 @@
 #include <QMainWindow>
 #include "ui_mainwindow.h"

+#include "mcrl2/lts/lts_type.h"
 #include "mcrl2/gui/persistentfiledialog.h"

 #include "glwidget.h"
@@ -54,6 +55,11 @@ class MainWindow : public QMainWindow
      */
     void delayedOpenFile(QString fileName);

+    /**
+     * @brief Opens the given file and sets lts_type to type.
+     */
+    void delayedOpenFile(QString fileName, mcrl2::lts::lts_type type);
+
   private slots:

     /**
@@ -122,6 +128,7 @@ class MainWindow : public QMainWindow
     Graph::SpringLayout* m_layout;      ///< The SpringLayout algorithm which is applied to the graph.
     Graph::Information* m_information;  ///< The Information display which calculates the statistics of the graph.
     QString m_delayedOpen;              ///< The file that should be opened when the program is ready
+    mcrl2::lts::lts_type m_type;        ///< The type of LTS that is being provided, if any

     mcrl2::gui::qt::PersistentFileDialog m_fileDialog;

