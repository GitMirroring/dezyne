interface ihello
{
  in void hello ();
  out void cruel ();
  out void world ();

  behavior
  {
    bool idle = true;
    [idle] on hello: idle = false;
    [!idle] on inevitable: {idle = true; cruel; world;}
    [!idle] on inevitable: {cruel; idle = true; world;}
  }
}

interface iworld
{
  in void cruel ();
  in void world ();

  behavior
  {
    on cruel, world: {}
  }
}

component det
{
  provides ihello h;
  requires iworld w;

  behavior
  {
    on h.hello (): defer {
      h.cruel ();
      if (h.idle)
        w.cruel ();
      else
        w.world ();
      h.world ();
    }
  }
}
