% hello makreel
% mcrl22lps -b hello.makreel | lps2lts /dev/stdin my.aut

sort
ihello'actions = struct
ihello'in'hello
|ihello'out'cruel
|ihello'out'world
;

ihello'modeling = struct ihello'optional | ihello'inevitable;


ihello'replies = struct ihello'void;

ihello'events = struct
    ihello'action (value: ihello'actions)
    | ihello'reply (value: ihello'replies)
    ;



map

QueueLength : Nat;
illegal_guard: Bool;

eqn

QueueLength = 3;

act
ihello'in: ihello'events;
ihello'out: ihello'events;
ihello'reply: ihello'replies;
ihello'internal: ihello'modeling;
ihello'end;
h'in: ihello'events;
h'in': ihello'events;
h'out: ihello'events;
h'out': ihello'events;
h'reply: ihello'replies;
h'reply': ihello'replies;
h'internal: ihello'modeling;
h'internal': ihello'modeling;
h'end;
h'end';
h'reply'out: ihello'replies;
h'blocking;
h'blocking';

hello_function_local_nest'end;
hello_function_local_nest'end';
declarative_illegal;
illegal;
queue_full;
queue_empty;
queue_empty';
range_error;
recurse;
return;

proc
Illegal' = illegal . Illegal';
Declarative_Illegal' = declarative_illegal . Declarative_Illegal';

%%%%%%%%%%%%%%%%% INTERFACE %%%%%%%%%%%%%%%%%

ihello'interface = ihello' ;

ihello'  = non_optional_ihello' ;

non_optional_ihello'  = ihello'0 ;


% {
%   [true] on hello: {
%     cruel();
%     reply(void);
%   }
%   [true] on hello: {
%     world();
%     reply(void);
%   }
%   [(!(true) && (!(true) && true))] on hello: declaritive-illegal;
% }
ihello'0 = ihello'1
  + ihello'6
  + ihello'11 ;


% [true] on hello: {
%   cruel();
%   reply(void);
% }
ihello'1 = (true) -> ihello'2 ;


% on hello: {
%   cruel();
%   reply(void);
% }
ihello'2 = ihello'in (ihello'action (ihello'in'hello)) . ihello'3 ;


% {
%   cruel();
%   reply(void);
% }
ihello'3 = ihello'4 ;


% cruel();
ihello'4 = ihello'out (ihello'action (ihello'out'cruel)) . ihello'5 ;

% reply(void);
ihello'5 = ihello'reply (ihello'void) . ihello' ;


% [true] on hello: {
%   world();
%   reply(void);
% }
ihello'6 = (true) -> ihello'7 ;


% on hello: {
%   world();
%   reply(void);
% }
ihello'7 = ihello'in (ihello'action (ihello'in'hello)) . ihello'8 ;


% {
%   world();
%   reply(void);
% }
ihello'8 = ihello'9 ;


% world();
ihello'9 = ihello'out (ihello'action (ihello'out'world)) . ihello'10 ;

% reply(void);
ihello'10 = ihello'reply (ihello'void) . ihello' ;


% [(!(true) && (!(true) && true))] on hello: declaritive-illegal;
ihello'11 = ((!(true) && (!(true) && true))) -> ihello'12 ;


% on hello: declaritive-illegal;
ihello'12 = ihello'in (ihello'action (ihello'in'hello)) . ihello'13 ;


% declaritive-illegal;
ihello'13 = Declarative_Illegal' . delta;





%%%%%%%%%%%%%%%%%%%%%%%%% FUNCTIONS %%%%%%%%%%%%%%%%%%%%%%%%%





%%%%%%%%%%%%%%%%%%% COMPONENT %%%%%%%%%%%%%%%%%%%

hello_function_local_nest' (b': Bool) = hello_function_local_nest'0 ();


% {
%   [true] on h'.hello(): {
%     g'(b');
%     b' = true;
%     if (false) {
%       ha'();
%     } reply(void);
%   }
%   [(!(true) && true)] on h'.hello(): declaritive-illegal;
% }
hello_function_local_nest'0(b': Bool) = hello_function_local_nest'1 ()
  + hello_function_local_nest'9 ();


% [true] on h'.hello(): {
%   g'(b');
%   b' = true;
%   if (false) {
%     ha'();
%   } reply(void);
% }
hello_function_local_nest'1(b': Bool) = (true) -> hello_function_local_nest'2 ();


% on h'.hello(): {
%   g'(b');
%   b' = true;
%   if (false) {
%     ha'();
%   } reply(void);
% }
hello_function_local_nest'2(b': Bool) = h'in (ihello'action (ihello'in'hello)) . hello_function_local_nest'3 ();


% {
%   g'(b');
%   b' = true;
%   if (false) {
%     ha'();
%   } reply(void);
% }
hello_function_local_nest'3(b': Bool) = hello_function_local_nest'4 ();


% g'(b');
hello_function_local_nest'4(b': Bool) = hello_function_local_nest'g' (bp'1 = b',s = Frame'hello_function_local_nest'5(hello_function_local_nest'5'return, stack_empty'hello_function_local_nest'));


% b' = true;
hello_function_local_nest'5(b': Bool) = hello_function_local_nest'6(b' = true);


% if (false) {
%   ha'();
% }
hello_function_local_nest'6(b': Bool) = (false) -> hello_function_local_nest'7 ()<> hello_function_local_nest'8 ();


% ha'();
hello_function_local_nest'7(b': Bool) = hello_function_local_nest'ha' (s = Frame'hello_function_local_nest'8(hello_function_local_nest'8'return, stack_empty'hello_function_local_nest'));


% reply(void);
hello_function_local_nest'8(b': Bool) = h'reply (ihello'void) . hello_function_local_nest' ();


% [(!(true) && true)] on h'.hello(): declaritive-illegal;
hello_function_local_nest'9(b': Bool) = ((!(true) && true)) -> hello_function_local_nest'10 ();


% on h'.hello(): declaritive-illegal;
hello_function_local_nest'10(b': Bool) = h'in (ihello'action (ihello'in'hello)) . hello_function_local_nest'11 ();


% declaritive-illegal;
hello_function_local_nest'11(b': Bool) = Declarative_Illegal' . delta;


% {
%   h'.cruel();
%   ha'();
%   return ;
% }
hello_function_local_nest'g'12(b': Bool, bp'1: Bool, s: Stack'hello_function_local_nest') = hello_function_local_nest'g'13 ();


% h'.cruel();
hello_function_local_nest'g'13(b': Bool, bp'1: Bool, s: Stack'hello_function_local_nest') = h'out (ihello'action (ihello'out'cruel)) . hello_function_local_nest'g'14 ();

% ha'();
hello_function_local_nest'g'14(b': Bool, bp'1: Bool, s: Stack'hello_function_local_nest') = return . hello_function_local_nest'ha' (s=Frame'hello_function_local_nest'g'15(hello_function_local_nest'g'15'return,bp'1,s));  %% FIXME call stack


% return ;
hello_function_local_nest'g'15(b': Bool, bp'1: Bool, s: Stack'hello_function_local_nest') = hello_function_local_nest'g'return ();

% {
%   h'.world();
%   return ;
% }
hello_function_local_nest'ha'16(b': Bool, s: Stack'hello_function_local_nest') = hello_function_local_nest'ha'17 ();


% h'.world();
hello_function_local_nest'ha'17(b': Bool, s: Stack'hello_function_local_nest') = h'out (ihello'action (ihello'out'world)) . hello_function_local_nest'ha'18 ();

% return ;

hello_function_local_nest'ha'18(b': Bool, s: Stack'hello_function_local_nest') = return . hello_function_local_nest'ha'return ();

component_behaviour = hello_function_local_nest'(false);

%%%%%%%%%%%%%%%%%%%%%%%%% FUNCTIONS %%%%%%%%%%%%%%%%%%%%%%%%%
hello_function_local_nest'g'(b': Bool, bp'1: Bool, s: Stack'hello_function_local_nest') = hello_function_local_nest'g'12 ();

hello_function_local_nest'g'return (b': Bool, bp'1: Bool, s: Stack'hello_function_local_nest') = is'hello_function_local_nest'5'return (return(s)) -> hello_function_local_nest'5 ()
;
hello_function_local_nest'ha'(b': Bool, s: Stack'hello_function_local_nest') = hello_function_local_nest'ha'16 ();

hello_function_local_nest'ha'return (b': Bool, s: Stack'hello_function_local_nest') = is'hello_function_local_nest'8'return (return(s)) -> hello_function_local_nest'8 ()
 + is'hello_function_local_nest'g'15'return (return(s)) -> hello_function_local_nest'g'15 (bp'1=local'bp'1(s),s=stack(s))
;


sort
Stack'hello_function_local_nest' = struct stack_empty'hello_function_local_nest'

  | Frame'hello_function_local_nest'5(return: hello_function_local_nest'returns, stack: Stack'hello_function_local_nest')
  | Frame'hello_function_local_nest'8(return: hello_function_local_nest'returns, stack: Stack'hello_function_local_nest')
  | Frame'hello_function_local_nest'g'15(return: hello_function_local_nest'returns, local'bp'1: Bool, stack: Stack'hello_function_local_nest')
  ;

hello_function_local_nest'returns = struct hello_function_local_nest'5'return?is'hello_function_local_nest'5'return
  | hello_function_local_nest'8'return?is'hello_function_local_nest'8'return
    | hello_function_local_nest'g'15'return?is'hello_function_local_nest'g'15'return;
proc



%%%%%%%%%%%%%% PORT PROCESSES %%%%%%%%%%%%%%%

h'_port_rename = rename ({
  ihello'in -> h'in
  , ihello'out -> h'out
  , ihello'reply -> h'reply
  , ihello'internal -> h'internal
  , ihello'end -> h'end
  }, ihello'interface);

h'_port = hide ({recurse,return}, h'_port_rename);


%%%%%%%%%%%%%%%%%%%% Q %%%%%%%%%%%%%%%%%%%%%%


req_and_queue = delta;


%%%%%%%%%%%%%%%%%%%%% COMPONENT REORDER %%%%%%%%%%%%%%%%%%%%%%%%%%%

component_reorder
  = sum a: ihello'actions. h'in (ihello'action (a))
  . (sum r: ihello'replies. h'reply (r) . h'reply'out (r) . component_reorder
)
  ;

component_reorder_parallel = component_behaviour || component_reorder;

component_reorder_comm = comm({
  h'reply | h'reply -> h'reply'
, h'in | h'in -> h'in'
, h'blocking | h'blocking -> h'blocking'
  }, component_reorder_parallel);

component_reorder_allow = allow({
  declarative_illegal
  , illegal
  , queue_empty
  , range_error
  , recurse
  , return

  , h'in'
  , h'blocking'
  , h'out
  , h'reply'
  , h'reply'out

  , hello_function_local_nest'end
  }, component_reorder_comm);

component_reorder_rename = rename({
  h'in' -> h'in
  , h'blocking' -> h'blocking
  , h'reply'out -> h'reply
  }, component_reorder_allow);

component_reorder_hide = hide({
  h'reply'
  }, component_reorder_rename);

%%%%%%%%%%%%%%%%%%%%%%%%% SEMANTICS %%%%%%%%%%%%%%%%%%%%%%%%%%%

semantics(h'blocking'bool: Bool)
  = (!h'blocking'bool) -> sum e : ihello'actions. h'in (ihello'action(e)) . semantics_empty()


;

semantics_empty(h'blocking'bool: Bool)
  = sum r : ihello'replies. h'reply (r) . semantics(h'blocking'bool=false)
  + h'blocking . semantics(h'blocking'bool=true)


;

semantics_flush(h'blocking'bool: Bool)
  =
  queue_empty .  (semantics() + semantics_empty())
  ;

component_semantics = component_reorder_hide || semantics(h'blocking'bool=false);

component_semantics_comm = comm({
  h'in | h'in -> h'in'
  , h'blocking | h'blocking -> h'blocking'
  , h'reply | h'reply -> h'reply'


  , hello_function_local_nest'end | hello_function_local_nest'end -> hello_function_local_nest'end'
  }, component_semantics);

component_semantics_allow = allow({
  declarative_illegal
  , illegal
  , queue_empty
  , range_error
  , recurse
  , return
  , hello_function_local_nest'end'

  , h'in'
  , h'blocking'
  , h'out
  , h'reply'

  }, component_semantics_comm);

component_semantics_rename = rename({
  hello_function_local_nest'end' -> hello_function_local_nest'end

  , h'in' -> h'in
  , h'blocking' -> h'blocking
  , h'reply' -> h'reply

  }, component_semantics_allow);

component_semantics_hide = hide({
  hello_function_local_nest'end
  }, component_semantics_rename);

%%%%%%%%%%%%%%%%%%%%% COMPONENT ASSEMBLY %%%%%%%%%%%%%%%%%%%%%%

component_parallel = component_semantics_hide || req_and_queue;

component_comm = comm({
  queue_empty | queue_empty -> queue_empty'

  }, component_parallel);

component_allow = allow({
  declarative_illegal
  , illegal
  , queue_empty'
  , queue_full
  , range_error
  , recurse
  , return

  , h'in
  , h'blocking
  , h'out
  , h'reply

  , hello_function_local_nest'end
  }, component_comm);

% Note that out' is renamed to qin and qin' is renamed to out;
% This is done to preserve the information that events are
% queued which might lead to queue_full.
component_rename = rename({
  queue_empty' -> queue_empty

  }, component_allow);

component = hide({
  queue_empty
  , range_error
  , recurse
  , return

  , h'blocking


  }, component_rename);

%%component = component_rename;

%%%%%%%%%%%%%%%%%%%%%%% PROVIDES %%%%%%%%%%%%%%%%%%%%%%%%%%

provides_r2c = sum x: ihello'actions . h'in (ihello'action (x)) . provides_out
  + sum m: ihello'modeling. h'internal (m) . provides_out;

provides_out = sum x: ihello'replies . h'reply (x) . provides_r2c
  + h'end . provides_r2c
  + sum x: ihello'actions . h'out (ihello'action (x)) . provides_out

;

provides_parallel = h'_port|| provides_r2c;

provides_comm = comm ({
  h'in | h'in -> h'in'
  , h'out | h'out -> h'out'
  , h'reply | h'reply -> h'reply'
  , h'internal | h'internal -> h'internal'
  , h'end | h'end -> h'end'
  }, provides_parallel);

provides_allow = allow ({
  h'in'
  , h'out'
  , h'reply'
  , h'internal'
  , h'end'
  , declarative_illegal
  , illegal
  }, provides_comm);

provides_rename = rename ({
  h'in' -> h'in
  , h'out' -> h'out
  , h'reply' -> h'reply
  , h'internal' -> h'internal
  , h'end' -> h'end
  }, provides_allow);

provides = hide ({
  h'internal
  , h'end
  }, provides_rename);

%init component;
%init provides;

init component_behaviour;
