second_reply;

proc
Illegal' = illegal . Illegal';
Declarative_Illegal' = declarative_illegal . Declarative_Illegal';

%%%%%%%%%%%%%%%%% INTERFACE %%%%%%%%%%%%%%%%%

ihello'reorder
 = sum i : ihello'events. ihello'in(i) . (sum r : ihello'replies. ihello'reply(r) . ihello'reorder_replied(r)
                                                                       +sum i : ihello'events. ihello'in(i) . missing_reply . delta)
 ;

ihello'reorder_replied(r : ihello'replies)
 = ihello'reply'reordered (r) . ihello'reorder
 + sum r : ihello'replies. ihello'reply(r) . second_reply .delta
 ;

ihello'reordered_parallel = ihello'(true)|| ihello'reorder;

ihello'reordered_comm = comm({
  ihello'in | ihello'in -> ihello'in'
  , ihello'reply | ihello'reply -> ihello'reply'}, ihello'reordered_parallel);

ihello'reordered_allow = allow({
    ihello'end
  , ihello'flush
  , ihello'in'
  , ihello'internal
  , ihello'out
  , ihello'reply'
  , ihello'reply'reordered
  , declarative_illegal
  , incomplete
  , missing_reply
  , range_error
  , recurse
  , return
  , second_reply
}, ihello'reordered_comm);

ihello'reordered_rename = rename({
    ihello'in' -> ihello'in
  , ihello'reply'reordered -> ihello'reply}, ihello'reordered_allow);

ihello'reordered = hide({
    ihello'reply'
}, ihello'reordered_rename);


ihello'semantics
 = sum i : ihello'events. ihello'in(i) . ihello'semantics_sync
 + sum m : ihello'modeling. ihello'internal(m) . (ihello'end . ihello'semantics + ihello'semantics_flush)
 ;

ihello'semantics_sync
 = sum r : ihello'replies. ihello'reply(r) . ihello'semantics
 + sum i : ihello'events. ihello'out(i) . ihello'semantics_sync
 ;

ihello'semantics_flush
 = sum i : ihello'events. ihello'out(i) . (ihello'end . ihello'flush . ihello'semantics + ihello'semantics_flush)
 ;

ihello'parallel = ihello'semantics || (ihello'reordered );

ihello'comm = comm({
  ihello'in | ihello'in -> ihello'in'
  , ihello'out | ihello'out -> ihello'out'
  , ihello'reply | ihello'reply -> ihello'reply'
  , ihello'internal | ihello'internal -> ihello'internal'
  , ihello'end | ihello'end -> ihello'end'
  }, ihello'parallel);

ihello'allow = allow({
  ihello'in'
  , ihello'reply'
  , ihello'internal'
  , ihello'end'
  , ihello'out'
  , ihello'flush
  , declarative_illegal
  , incomplete
  , range_error
  , recurse
  , return
  }, ihello'comm);

ihello'rename = rename({
  ihello'in' -> ihello'in
  , ihello'out' -> ihello'out
  , ihello'reply' -> ihello'reply
  , ihello'internal' -> ihello'internal
  , ihello'end' -> ihello'end
  }, ihello'allow);

%ihello'hide = hide({#x:makreel:model-name end}, ihello'rename);
ihello'hide = ihello'rename;

ihello'interface = ihello'hide;

ihello' (idle': Bool) = non_optional_ihello' ();

non_optional_ihello' (idle': Bool) = ihello'0 ();


