%   [(idle' && true)] on hello: {
%     idle' = !(idle');
%     reply(void);
%   }
%   [(!(idle') && true)] on hello: declarative-illegal;
%   [(!((!(idle') && true)) && (!((idle' && true)) && true))] on hello: incomplete;
%   [(!(idle') && true)] on inevitable: {
%     idle' = !(idle');
%     world();
%     <end of process>
%   }
% }
ihello'0(idle': Bool) = ihello'1 ()
 + ihello'6 ()
 + ihello'9 ()
 + ihello'12 ();


