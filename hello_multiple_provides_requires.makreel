% incomplete;
ihello'11(idle': Bool) = incomplete . delta;


% [(!(idle') && true)] on inevitable: {
%   idle' = !(idle');
%   world();
%   <end of process>
% }
ihello'12(idle': Bool) = ((!(idle') && true)) -> ihello'13 ();


% on inevitable: {
%   idle' = !(idle');
%   world();
%   <end of process>
% }
ihello'13(idle': Bool) = ihello'internal(ihello'inevitable) . ihello'14 ();


% {
%   idle' = !(idle');
%   world();
%   <end of process>
% }
ihello'14(idle': Bool) = ihello'15 ();


% idle' = !(idle');
ihello'15(idle': Bool) =  ihello'16(idle' = !(idle')
);


% world();
ihello'16(idle': Bool) = ihello'out (ihello'action (ihello'out'world)) . ihello'17 ();

% <end of process>
ihello'17(idle': Bool) = ihello'end . ihello' ();





