      (statement
       (sequence*
        `(,@(if (not action?)
                (makreel:type->out-of-range-processes type expression)
                `(,(ast->action action?)
                  ,@(if (not (makreel:switch-context? action?))
                        `(,(assign->sum model action? o))
                        `(,(%switch-context-action port)))))
          ,(if (and action? (makreel:switch-context? action?))
               (goto (name (statement->process-name next))
                     (arguments (makreel:process-parens next)))
               (goto (name (statement->process-name next))
                     (arguments
                      (let* ((variable (.name o))
                             (variables (makreel:variables-in-scope next))
                             (variables (map
                                         (match-lambda
                                           ((and ($ <variable>) variable)
                                            (.name variable))
                                           ((and ($ <formal>) variable)
                                            (.name variable))
                                           ((and ($ <shared-variable>) variable)
                                            (makreel:full-name variable))
                                           ((and ($ <stack>) stack)
                                            "s"))
                                         variables))
                             (assign? (member variable variables))
                             (shared (ast:shared* model)))
                        (cond ((and (or (not assign?)
                                        (and action?
                                             (ast:out? action?)))
                                    (null? shared))
                               (makreel:process-parens next))
                              (else
                               `(,@(if (not action?) '()
                                       (makreel:shared-process-arguments action?))
                                 ,@(if (not assign?) '()
                                       (list
                                        (is*
                                         variable
                                         (if action? "i"
                                             expression)))))))))))))))))

(define-method (ast->process (model <interface>) (o <the-end>) (next <ast>))
  (let* ((members (ast:member* model))
         (members (map .name members))
         (on (ast:parent o <on>))
         (trigger (car (ast:trigger* on))))
    (process
      (name (statement->process-name o))
      (formals (makreel:process-formals o))
      (statement
       (sequence*
        `(,(if (ast:modeling? trigger) (%end-action model)
               (%reorder-end-action model))
          ,(goto (name (statement->process-name next))
                 (arguments (makreel:process-parens next)))))))))

(define-method (ast->process (model <component>) (o <the-end>) (next <ast>))
  (process
    (name (statement->process-name o))
    (formals (makreel:process-formals o))
    (statement
     (sequence*
      `(,@(if (not (makreel:defer-skip? model)) '()
              (list (%defer-skip-action model)))
        ,(%end-action model)
        ,(goto (name (statement->process-name next))
               (arguments (makreel:process-parens next))))))))

(define-method (ast->process (model <model>) (o <if>) (next <ast>))
  (process
    (name (statement->process-name o))
    (formals (makreel:process-formals o))
    (statement
     (if* (ast->expression (.expression o))
          (goto (name (statement->process-name next))
                (arguments (makreel:process-parens next)))))))

(define-method (ast->process (model <model>) (o <if>) (next <list>))
  (process
    (name (statement->process-name o))
    (formals (makreel:process-formals o))
    (statement
     (match next
       ((then else)
        (if* (ast->expression (.expression o))
             (goto (name (statement->process-name then))
                   (arguments (makreel:process-parens then)))
             (goto (name (statement->process-name else))
                   (arguments (makreel:process-parens else)))))))))

(define-method (ast->process (model <model>) (o <defer>) (next <ast>))
  (let* ((statement (.statement o))
         (id (makreel:process-identifier statement))
         (members (filter (negate (is? <shared-variable>)) (ast:member* model)))
         (names (map ast->expression members))
         (locals (makreel:locals statement))
         (local-names (map ast->expression locals)))
    (process
      (name (statement->process-name o))
      (formals (makreel:process-formals o))
      (statement
       (sequence*
        (invoke %defer-qin-action
                (list
                 (entity (name "state_vector")
                         (formals (and (pair? names) names)))
                 (set* (map (cute variable-prefix "select" <>)
                            (ast:defer-variable* o)))
                 (entity (name (simple-format #f "locals~a" id))
                         (formals (and (pair? local-names) local-names))))
                #:keep-constructor? #t)
        (goto (name (statement->process-name next))
              (arguments (makreel:process-parens next))))))))

(define-method (ast->process (model <model>) (o <defer-end>) (next <ast>))
  (process
    (name (statement->process-name o))
    (formals (makreel:process-formals o))
    (statement
     (sequence*
      `(,%defer-end-action
        ,@(if (not (makreel:defer-skip? model)) '()
              (list (%defer-skip-action model)))
        ,(%end-action model)
        ,(goto (name (statement->process-name next))
               (arguments (makreel:process-parens next))))))))


;;;
;;; Processes.
;;;
(define (illegal-processes)
  (list
   (process (name "Illegal")
            (statement
             (sequence* %illegal-action
                        (goto (name name)))))
   (process (name "Constrained_Illegal")
            (statement
             (sequence* %constrained-illegal-action
                        (goto (name name)))))
   (process (name "Declarative_Illegal")
            (statement
             (sequence* %declarative-illegal-action
                        (goto (name name)))))))

(define-method (statement->processes (model <model>) (statement <ast>))
  (define (step statement)
    (let ((next (ast:continuation* statement)))
      (match next
        ((next)
         (ast->process model statement next))
        ((next ...)
         (ast->process model statement next)))))
  (let loop ((statements (list statement)))
    (if (null? statements) '()
        (let* ((statement (car statements))
               (statements (cdr statements))
               (processes (cons (step statement)
                                (loop (ast:statement* statement)))))
          (append processes (loop statements))))))

(define-method (behavior->processes (model <model>))
  (let ((behavior (.behavior model)))
    (statement->processes model behavior)))

(define-method (defer->processes (o <defer>))
  (let* ((model (ast:parent o <model>))
         (statement (.statement o)))
    (statement->processes model statement)))

(define-method (function->processes (o <function>))
  (let ((model (ast:parent o <model>))
        (statement (.statement o)))
    (statement->processes model statement)))

(define-method (return-processes (o <model>))
  (define (variable->local v)
    (let ((name (.name v)))
      (simple-format #f "~a=~a (s)" name (variable-prefix "local" v))))
  (let ((returns calls (makreel:call-continuation* o)))
    (if (null? returns) '()
        (list
         (process
           (name (model-prefix "return" o))
           (formals (append
                     (makreel:process-formals o)
                     (list (formal (type (model-prefix "stack" o))
                                   (name "s"))
                           (formal (type (model-prefix "return_type" o))
                                   (name "return_value")))))
           (statement
            (union*
             (map
              (lambda (c r)
                (let* ((type (ast:type c))
                       (locals (makreel:locals r))
                       (f (and (not (is-a? r <defer>))
                               (not (ast:parent r <defer>))
                               (or (is-a? r <function>)
                                   (ast:parent r <function>))))
                       (arguments
                        `(,@(map variable->local locals)
                          ,@(if (not f) '()
                                '("s=stack (s)"))
                          ,@(match type
                              (($ <void>)
                               '())
                              (($ <bool>)
                               '("return_value=bool_value (return_value)"))
                              ((or ($ <int>) ($ <subint>))
                               '("return_value=int_value (return_value)"))
                              (($ <enum>)
                               (list
                                (simple-format
                                 #f
                                 "return_value=~a_value (return_value)"
                                 (makreel:type->string type))))))))
                  (if* (invoke (%return-predicate r)
                               "return (s)")
                       (goto (name (statement->process-name r))
                             (arguments arguments)))))
              calls returns))))))))


;;;
;;; Interface.
;;;
(define-method (interface-reorder-processes (o <interface>))
  (let* ((interface-reorder
          (process
            (name (model-prefix "reorder"))
            (statement
             (union*
              (sequence*
               (sum (type (%events o))
                    (statement
                     (sequence*
                      (invoke (%in-action o))
                      (union*
                       (sum (var "i")
                            (type (%state o))
                            (statement
                             (sequence*
                              (invoke (%state-action o) var)
                              (goto
                               (name (model-prefix "reorder_reply"))))))
                       (sum (var "i")
                            (type (%replies o))
                            (statement
                             (sequence* (invoke (%reply-action o) var)
                                        (goto (name
                                               (model-prefix "reorder_replied"))
                                              (arguments (list var))))))
                       (sequence* (%reorder-end-action o)
                                  %missing-reply-action
                                  %delta))))))
              (sum (var "i")
                   (type (%modeling o))
                   (statement
                    (sequence* (invoke (%internal-action o) var)
                               (goto (name (model-prefix "reorder_internal"))))))
              (sum (var "i")
                   (type (%state o))
                   (statement
                    (sequence* (invoke (%state-action o) var)
                               (goto (name name)))))))))
         (interface-reorder-internal
          (process
            (name (model-prefix "reorder_internal"))
            (statement
             (union*
              (sequence*
               (%end-action o)
               (goto (name (model-prefix "reorder"))))
              (sum (var "i")
                   (type (%state o))
                   (statement
                    (sequence*
                     (invoke (%state-action o) var)
                     (goto (name name)))))))))
         (interface-reorder-reply
          (process
            (name (model-prefix "reorder_reply"))
            (statement
             (union*
              (sum (var "i")
                   (type (%replies o))
                   (statement
                    (sequence* (invoke (%reply-action o) var)
                               (goto (name
                                      (model-prefix "reorder_replied"))
                                     (arguments (list var))))))
              (sum (var "i")
                   (type (%state o))
                   (statement
                    (sequence*
                     (invoke (%state-action o) var)
                     (goto (name name)))))))))
         (interface-reorder-replied
          (let ((reply "r"))
            (process
              (name (model-prefix "reorder_replied"))
              (formals (list (formal (type (%replies o)) (name reply))))
              (statement
               (union*
                (sequence* (%reorder-end-action o)
                           (invoke (%reply-reordered-action o) reply)
                           (goto (name (model-prefix "reorder"))))
                (sum (var "i")
                     (type (%replies o))
                     (statement
                      (sequence* (invoke (%reply-action o) var)
                                 %second-reply-action
                                 %delta)))
                (sum (var "i")
                     (type (%state o))
                     (statement
                      (sequence* (invoke (%state-action o) var)
                                 (goto (name name)
                                       (arguments '()))))))))))
         (members (ast:variable* o))
         (member-values (map (compose ast->expression .expression) members))
         (member-types (map .type members))
         (interface-reordered-parallel
          (process
            (name (model-prefix "reordered_parallel"))
            (statement (parallel*
                        (sequence*
                         `(,@(append-map makreel:type->out-of-range-processes
                                         member-types member-values)
                           ,(goto (name (model-prefix "behavior"))
                                  (arguments member-values))))
                        (model-prefix "reorder")))))
         (interface-reordered-comm
          (process
            (name (model-prefix "reordered_comm"))
            (statement
             (comm
              (process interface-reordered-parallel)
              (events
               (list
                (comm-event (from (multi-event (events
                                                (list (%in-action o))))))
                (comm-event (from
                             (multi-event (events
                                           (list (%reply-action o))))))
                (comm-event (from (multi-event (events
                                                (list (%internal-action o))))))
                (comm-event (from
                             (multi-event (events
                                           (list (%end-action o))))))
                (comm-event (from (multi-event
                                   (events
                                    (list (%reorder-end-action o))))))
                (comm-event (from (multi-event
                                   (events
                                    (list (%state-action o))))))))))))
         (interface-reordered-allow
          (process
            (name (model-prefix "reordered_allow"))
            (statement
             (allow
              (process interface-reordered-comm)
              (events (list %declarative-illegal-action
                            %missing-reply-action
                            %range-error-action
                            %recurse-action
                            %return-action
                            %second-reply-action
                            %tag-action
                            %tau-void-action
                            (%flush-action o)
                            (%out-action o)
                            (%reply-reordered-action o)
                            (%tau-reply-action o)))))))
         (interface-reordered
          (process
            (name (model-prefix "reordered"))
            (statement
             (rename
              (process interface-reordered-allow)
              (events (cons*
                       (rename-event (from (transpose-tick (%reply-action o)))
                                     (to (%tau-reply-action o)))
                       (rename-event (from (%reply-reordered-action o))
                                     (to (%reply-action o)))
                       (rename-event (from (transpose-tick
                                            (%reorder-end-action o)))
                                     (to %tau-void-action))
                       (comm-events (process-statement
                                     interface-reordered-comm))))))))
         (interface-semantics
          (process
            (name (model-prefix "semantics"))
            (statement
             (union*
              (sum (type (%state o))
                   (statement
                    (sequence*
                     (invoke (%state-action o))
                     (goto (name name)))))
              (sum (type (%events o))
                   (statement
                    (sequence*
                     (invoke (%in-action o))
                     (goto (name (model-prefix "semantics_sync"))))))
              (sum (var "i")
                   (type (%modeling o))
                   (statement
                    (sequence*
                     (invoke (%internal-action o) var)
                     (union*
                      (goto (name (model-prefix "semantics_flush")))
                      (sequence*
                       (%end-action o)
                       (%end-reordered-action o)
                       (goto (name (model-prefix "semantics"))))))))))))
         (interface-semantics-sync
          (process
            (name (model-prefix "semantics_sync"))
            (statement
             (union*
              (sequence*
               (sum (var "i")
                    (type (%replies o))
                    (statement
                     (sequence* (invoke (%reply-action o) var)
                                (goto (name (model-prefix "semantics")))))))
              (sum (type (%events o))
                   (statement
                    (sequence*
                     (invoke (%out-action o))
                     (goto (name name)))))
              (sum (type (%state o))
                   (statement
                    (sequence*
                     (invoke (%state-action o))
                     (goto (name name)))))))))
         (interface-semantics-flush
          (process
            (name (model-prefix "semantics_flush"))
            (statement
             (sum (type (%events o))
                  (statement
                   (union*
                    (sequence*
                     (invoke (%out-action o))
                     (goto (name name)))
                    (sequence*
                     (%end-action o)
                     (%flush-action o)
                     (%end-reordered-action o)
                     (goto (name (model-prefix "semantics"))))
                    (sum (var "i")
                         (type (%state o))
                         (statement
                          (sequence*
                           (invoke (%state-action o) var)
                           (goto (name name)))))))))))
         (interface-parallel
          (process
            (name (model-prefix "parallel"))
            (statement
             (parallel* (model-prefix "semantics")
                        (model-prefix "reordered")))))
         (interface-comm
          (process
            (name (model-prefix "comm"))
            (statement
             (comm
              (process interface-parallel)
              (events
               (list
                (comm-event (from (multi-event (events
                                                (list (%in-action o))))))
                (comm-event (from (multi-event (events
                                                (list (%out-action o))))))
                (comm-event (from (multi-event (events
                                                (list (%internal-action o))))))
                (comm-event (from
                             (multi-event (events
                                           (list (%reply-action o))))))
                (comm-event (from
                             (multi-event (events
                                           (list (%end-action o))))))
                (comm-event (from
                             (multi-event (events
                                           (list (%state-action o))))))))))))
         (interface-allow
          (process
            (name (model-prefix "allow"))
            (statement
             (allow
              (process interface-comm)
              (events (list %declarative-illegal-action
                            %missing-reply-action
                            %range-error-action
                            %recurse-action
                            %return-action
                            %second-reply-action
                            %tag-action
                            %tau-void-action
                            (%end-reordered-action o)
                            (%flush-action o)
                            (%tau-reply-action o)))))))
         (interface-internal
          (process
            (name (model-prefix "interface_internal"))
            (statement
             (rename
              (process interface-allow)
              (events (cons*
                       (rename-event (from %recurse-action)
                                     (to %tau-void-action))
                       (rename-event (from %return-action)
                                     (to %tau-void-action))
                       (rename-event (from (transpose-tick (%end-action o)))
                                     (to %tau-void-action))
                       (rename-event (from (%end-reordered-action o))
                                     (to (%end-action o)))
                       (comm-events (process-statement interface-comm))))))))
         (interface
          (process
            (name (model-prefix "interface"))
            (statement
             (hide
              (process interface-internal)
              (events (list %tau-void-action
                            (%end-action o)
                            (%flush-action o)
                            (%tau-reply-action o))))))))
    (list interface-reorder
          interface-reorder-reply
          interface-reorder-replied
          interface-reorder-internal
          interface-reordered-parallel
          interface-reordered-comm
          interface-reordered-allow
          interface-reordered
          interface-semantics
          interface-semantics-sync
          interface-semantics-flush
          interface-parallel
          interface-comm
          interface-allow
          interface-internal
          interface)))

(define-method (interface->scmackerel-unmemoized (o <interface>))
  (let* ((model-name (ast:dotted-name o))
         (behavior (.behavior o))
         (enums (filter (is? <enum>) (append (ast:type* o)
                                             (ast:type* behavior))))
         (enums (map enum->scmackerel enums))
         (behavior-processes (behavior->processes o))
         (functions (makreel:called-function* behavior))
         (function-processes (append-map function->processes functions))
         (return-processes (return-processes o))
         (reorder-processes (interface-reorder-processes o))
         (processes `(,@behavior-processes
                      ,(makreel:caption "FUNCTIONS")
                      ,@function-processes
                      ,@return-processes
                      ,@reorder-processes))
         (return-type (%return-type o))
         (returns-type (%returns-type o))
         (types `(,%void
                  ,(%actions o)
                  ,(%modeling o)
                  ,(%replies o)
                  ,(%events o)
                  ,@enums
                  ,(%state o)
                  ,@(if (not return-type) '()
                        (list return-type))
                  ,(%stack-type o)
                  ,@(if (not returns-type) '()
                        (list returns-type)))))
    (scmackerel (types types) (processes processes))))

(define interface->scmackerel
  (ast:perfect-funcq interface->scmackerel-unmemoized))

(define-method (model->scmackerel (o <interface>))
  (makreel:proc-list (.behavior o))
  (parameterize ((%model-name (makreel:full-name o)))
    (interface->scmackerel o)))


