(define-method (port-processes (o <port>))
  (parameterize ((%model-name (makreel:full-name (.type o)))
                 (%port-name (.name o)))
    (let* ((interface (.type o))
           (rename
            (process
              (name (port-prefix "_port"))
              (statement
               (rename
                (process (model-prefix "interface_internal"))
                (events (list
                         (rename-event (from (%in-action interface))
                                       (to (%in-action o)))
                         (rename-event (from (%out-action interface))
                                       (to (%out-action o)))
                         (rename-event (from (%reply-action interface))
                                       (to (%reply-action o)))
                         (rename-event (from (%internal-action interface))
                                       (to (%internal-action o)))
                         (rename-event (from (%end-action interface))
                                       (to (%end-action o)))
                         (rename-event (from (%state-action interface))
                                       (to (%state-action o)))
                         (rename-event (from (%flush-action interface))
                                       (to (%flush-action o))))))))))
      (list rename))))

(define-method (provides-processes (o <component>))
  (let* ((ports (ast:port* o))
         (provides (ast:provides-port* o))
;;; XXX TODO: when/how to print a type's entities in a formal?
         (provides-ports-set
          (type (name "Set")
                (entities (list (entity (name "provides_ports")
                                        (formals '("provides_ports")))))))
         (provides-ports-set
          (type (name "Set (provides_ports)")
                (entities (list (entity (name "provides_ports")
                                        (formals '("provides_ports")))))))
         (blocking? (find ast:blocking? provides))
         (provides-r2c
          (if (not blocking?)
              (process
                (name "provides_r2c")
                (formals (list (formal (name "ports")
                                       (type provides-ports-set))))
                (statement
                 (union*
                  (append-map
                   (lambda (p)
                     (let ((interface (.type p)))
                       (list
                        (sum (type (%actions interface))
                             (statement
                              (sequence* (invoke (%in-action p)
                                                 #:keep-constructor? #t)
                                         (goto (name "provides_out")
                                               (arguments '())))))
                        (sum (type (%modeling interface))
                             (statement
                              (sequence* (invoke (%internal-action p))
                                         (goto (name "provides_out")
                                               (arguments '()))))))))
                   provides))))
              (process
                (name "provides_r2c")
                (formals (list (formal (name "ports")
                                       (type provides-ports-set))))
                (statement
                 (union*
                  (append-map
                   (lambda (p)
                     (let ((interface (.type p)))
                       (list
                        (sum (type (%actions interface))
                             (statement
                              (sequence*
                               (invoke (%in-action p)
                                       #:keep-constructor? #t)
                               (union*
                                (sequence* "tau" (%blocking-action p))
                                "tau")
                               (goto (name name)
                                     (arguments
                                      (list
                                       (plus*
                                        "ports"
                                        (set* (port-prefix "port" p)))))))))
                        (if* (in* (port-prefix "port" p) "ports")
                             (sequence*
                              "tau"
                              (union*
                               (sum (type (%replies interface))
                                    (statement
                                     (sequence*
                                      (invoke (%reply-action p))
                                      (goto (name name)
                                            (arguments
                                             (list
                                              (minus*
                                               "ports"
                                               (set* (port-prefix "port" p)))))))))
                               (sum (type (%actions interface))
                                    (statement
                                     (sequence*
                                      (invoke (%out-action p)
                                              (construct
                                               (%out-action interface)))
                                      (goto (name name)
                                            (arguments '()))))))))
                        (sum (type (%modeling interface))
                             (statement
                              (sequence* (invoke (%internal-action p))
                                         (goto (name "provides_out")
                                               (arguments '())))))
                        (sequence* (%end-action p)
                                   (goto (name name)
                                         (arguments '()))))))
                   provides))))))
         (provides-out
          (process
            (name "provides_out")
            (formals (list (formal (name "ports") (type provides-ports-set))))
            (statement
             (union*
              (append-map
               (lambda (p)
                 (let ((interface (.type p)))
                   (list
                    (sum (type (%replies interface))
                         (statement
                          (sequence* (invoke (%reply-action p))
                                     (goto (name "provides_r2c")
                                           (arguments '())))))
                    (sequence* (%end-action p)
                               (goto (name "provides_r2c")
                                     (arguments '())))
                    (sum (type (%actions interface))
                         (statement
                          (sequence* (invoke (%out-action p)
                                             #:keep-constructor? #t)
                                     (goto (name name)
                                           (arguments '()))))))))
               provides)))))
         (provides-parallel
          (process
            (name "provides_parallel")
            (statement (parallel
                        (processes
                         `(,@(map (cute port-prefix "_port" <>) provides)
                           ,(goto (name "provides_r2c")
                                  (arguments (list (set*))))))))))
         (provides-comm
          (process
            (name "provides_comm")
            (statement
             (comm
              (process provides-parallel)
              (events
               (append-map
                (lambda (p)
                  (list
                   (comm-event (from (multi-event
                                      (events
                                       (list (%in-action p))))))
                   (comm-event (from (multi-event
                                      (events
                                       (list (%out-action p))))))
                   (comm-event (from (multi-event
                                      (events
                                       (list (%internal-action p))))))
                   (comm-event (from
                                (multi-event (events
                                              (list (%reply-action p))))))
                   (comm-event (from
                                (multi-event (events
                                              (list (%end-action p))))))))
                provides))))))
         (provides-interfaces (delete-duplicates (map .type provides) ast:eq?))
         (provides-allow
          (process
            (name "provides_allow")
            (statement
             (allow
              (process provides-comm)
              (events (cons* %declarative-illegal-action
                             %illegal-action
                             %missing-reply-action
                             %range-error-action
                             %second-reply-action
                             %tag-action
                             %tau-void-action
                             (append
                              (map %tau-reply-action provides-interfaces)
                              (append-map
                               (lambda (p)
                                 (list
                                  (%blocking-action p)
                                  (%flush-action p)
                                  (%state-action p)))
                               provides))))))))
         (provides-rename
          (process
            (name "provides_rename")
            (statement
             (rename
              (process provides-allow)
              (events (append
                       (map (lambda (p)
                              (rename-event (from (transpose-tick (%end-action p)))
                                            (to %tau-void-action)))
                            provides)
                       (comm-events (process-statement provides-comm))))))))
         (interfaces (delete-duplicates (map .type ports) ast:eq?))
         (provides
          (process
            (name "provides")
            (statement
             (hide
              (process provides-rename)
              (events (cons %tau-void-action
                            (append-map (lambda (i)
                                          (list (%tau-event-action i)
                                                (%tau-modeling-action i)
                                                (%tau-reply-action i)))
                                        interfaces))))))))
    (list provides-r2c
          provides-out
          provides-parallel
          provides-comm
          provides-allow
          provides-rename
          provides)))

(define-method (requires-processes (o <component>))
  (let* ((ports (ast:requires-port* o)))
    '()))

(define-method (component-defer-processes (o <component>))
  (let* ((ports (ast:port* o))
         (provides (ast:provides-port* o))
         (requires (ast:requires-port* o))
         (members (ast:variable* o))
         (member-types (map .type members))
         (member-values (and
                         (pair? members)
                         (map (compose ast->expression .expression) members)))
         (component-defer-parallel
          (process (name "component_defer_parallel")
                   (statement
                    (parallel*
                     (sequence*
                      `(,@(if (not member-values) '()
                              (append-map makreel:type->out-of-range-processes
                                          member-types member-values))
                        ,(goto (name (model-prefix "behavior"))
                               (arguments member-values))))
                     (goto (name "defer_queue")
                           (arguments '("[]")))))))
         (component-defer-comm
          (process
            (name "component_defer_comm")
            (statement
             (comm
              (process component-defer-parallel)
              (events
               (list
                (comm-event (from (multi-event (events
                                                (list %defer-qin-action)))))
                (comm-event (from (multi-event (events
                                                (list (%defer-qout-action o))))))
                (comm-event (from (multi-event (events
                                                (list (%defer-skip-action o))))))))))))
         (interfaces (delete-duplicates (map .type ports) ast:eq?))
         (component-defer-allow
          (process
            (name "component_defer_allow")
            (statement
             (allow
              (process component-defer-comm)
              (events (cons* %constrained-legal-action
                             %constrained-illegal-action
                             %declarative-illegal-action
                             %defer-end-action
                             %illegal-action
                             %queue-full-action
                             %range-error-action
                             %recurse-action
                             %return-action
                             %tag-action
                             ;; XXX wip-shared-state does not have this
                             ;; %tau-void-action
                             (%end-action o)
                             (append
                              (append-map
                               (lambda (p)
                                 (list
                                  (%blocking-action p)
                                  (%flush-action p)
                                  (%in-action p)
                                  (%out-action p)
                                  (%reply-action p)
                                  (%state-action p)))
                               provides)
                              (append-map
                               (lambda (p)
                                 (list
                                  (%in-action p)
                                  (%out-action p)
                                  (%reply-action p)
                                  (%state-action p)
                                  (%switch-context-action p)))
                               requires))))))))
         (component-defer-rename
          (process
            (name "component_defer_rename")
            (statement
             (rename
              (process component-defer-allow)
              (events
               (append
                (comm-events (process-statement component-defer-comm))
                (map (lambda (p)
                       ;; FIXME: comm-event is weird, from and to are reversed
                       (comm-event (from (%qout-action p)) (to (%out-action p))))
                     (ast:requires-port* o))))))))
         (component-defer
          (process
            (name "component_defer")
            (statement
             (hide
              (process component-defer-rename)
              (events (list %defer-qin-action))))))
         (component-behavior
          (process (name "component_behavior")
                   (statement (goto (name "component_defer"))))))
    (list component-defer-parallel
          component-defer-comm
          component-defer-allow
          component-defer-rename
          component-defer
          component-behavior)))

(define-method (component-no-q-processes (o <component>))
  (list
   (process (name "component_queue")
            (statement (sequence*
                        %queue-empty-action
                        (goto (name name)))))
   (process (name "req_and_queue")
            (statement  (goto (name "component_queue"))))))

(define-method (port->external-processes (o <port>))
  (let* ((interface (.type o))
         (port-name (.name o))
         (external-q
          (process
            (name (port-prefix "external_queue" o))
            (formals (list (formal (type "List (requires_events)")
                                   (name "l"))))
            (statement
             (union*
              (if* "#l < ExternalQueueLength"
                   (sum (type (%events interface))
                        (statement
                         (sequence*
                          (invoke (%qin-action o))
                          (goto (name name)
                                (arguments
                                 (list
                                  (simple-format #f "l=l <| ~a (i)"
                                                 (port-prefix "events" o)))))))))
              (if* (simple-format #f "l != [] && ~a (head (l))"
                                  (port-prefix "is" o))
                   (sequence*
                    (invoke (%internal-action o)
                            (model-prefix "inevitable" interface))
                    (invoke (%qout-action o)
                            ;; XXX WTF "projection?"
                            (port-prefix "projection (head (l))" o))
                    (%end-action o)
                    (goto (name name)
                          (arguments '("l=tail (l)")))))
              (if* "#l == ExternalQueueLength"
                   (sum (type (%events interface))
                        (statement
                         (sequence*
                          (invoke (%qin-action o))
                          (%port-queue-full-action o)
                          (goto (name "Illegal"))))))))))
         (port-internal
          (process
            (name (port-prefix "port_internal" o))
            (statement
             (rename
              (process (port-prefix "_port" o))
              (events (list
                       (rename-event (from (%internal-action o))
                                     (to (%tau-modeling-action interface)))
                       (rename-event (from (%end-action o))
                                     (to %tau-void-action))
                       (rename-event (from (%flush-action o))
                                     (to %tau-void-action))))))))
         (external-parallel
          (process
            (name (port-prefix "external_parallel" o))
            (statement (parallel
                        (processes
                         (list
                          (goto (name (process-name external-q))
                                (arguments '("[]")))
                          (goto (name (port-prefix "port_internal" o)))))))))
         (external-comm
          (process
            (name (port-prefix "external_comm" o))
            (statement
             (comm
              (process external-parallel)
              (events
               (list
                (comm-event (from (multi-event
                                   (events (list (%out-action o)
                                                 (%qin-action o)))))
                            (to (transpose-tick (%qin-action o))))))))))
         (external-allow
          (process
            (name (port-prefix "external_allow" o))
            (statement
             (allow
              (process external-comm)
              (events (list %declarative-illegal-action
                            %illegal-action
                            %tag-action
                            %tau-void-action
                            (%tau-modeling-action interface)
                            (%tau-reply-action interface)
                            (%in-action o)
                            (%qout-action o)
                            (%reply-action o)
                            (%internal-action o)
                            (%end-action o)
                            (%flush-action o)
                            (%port-queue-full-action o)))))))
         (external
          (process
            (name (port-prefix "external" o))
            (statement
             (rename
              (process external-allow)
              (events (list
                       (rename-event (from (transpose-tick (%qin-action o)))
                                     (to (%tau-event-action interface)))
                       (rename-event (from (%qout-action o))
                                     (to (%out-action o))))))))))
    (list
     external-q
     port-internal
     external-parallel
     external-comm
     external-allow
     external)))

(define-method (component-q-processes (o <component>))
  (let* ((ports (ast:port* o))
         (interfaces (ast:interface* o))
         (requires (ast:requires-port* o))
         (requires-interfaces (map .type requires))
         (component-queue
          (process
            (name "component_queue")
            (formals (list (formal (name "l") (type "List (requires_events)"))))
            (statement
             (union*
              (cons*
               (if* "#l == 0"
                    (sequence*
                     %queue-empty-action
                     (goto (name name)
                           (arguments '()))))
               (if* "l != []"
                    (sequence*
                     %queue-not-empty-action
                     (goto (name name)
                           (arguments '()))))
               (append-map
                (lambda (p)
                  (let* ((interface (.type p)))
                    (list
                     (if* "#l < QueueLength"
                          (sequence*
                           (sum (type (%events interface))
                                (statement (invoke (%qin-action p))))
                           (goto (name name)
                                 (arguments
                                  (list
                                   (string-append "l=l <| "
                                                  (port-prefix "events" p)
                                                  " (i)"))))))
                     (if* "#l == QueueLength"
                          (sequence*
                           (sum (type (%events interface))
                                (statement (invoke (%qin-action p))))
                           %queue-full-action
                           (goto (name "Illegal"))))
                     (if* (string-append "l != [] && "
                                         (port-prefix "is (head (l))" p))
                          (sequence*
                           (invoke (%qout-action p)
                                   (port-prefix "projection (head (l))" p))
                           (goto (name name)
                                 (arguments
                                  '("l=tail (l)"))))))))
                requires))))))
         (external (filter ast:external? requires))
         (non-external (filter (negate ast:external?) requires))
         (port-external-processes
          (append-map port->external-processes external))
         (req-and-queue-parallel
          (process
            (name "req_and_queue_parallel")
            (statement
             (parallel
              (processes
               (cons*
                (goto (name "component_queue")
                      (arguments (list "[]")))
                (append
                 (map (lambda (p)
                        (goto (name (port-prefix "_port" p))))
                      non-external)
                 (map (lambda (p)
                        (goto (name (port-prefix "external" p))))
                      external))))))))
         (req-and-queue-comm
          (process
            (name "req_and_queue_comm")
            (statement
             (comm
              (process req-and-queue-parallel)
              (events
               (map
                (lambda (p)
                  (comm-event
                   (from
                    (multi-event
                     (events
                      (list (%qin-action p)
                            (%out-action p)))))))
                requires))))))
         (req-and-queue-allow
          (process
            (name "req_and_queue_allow")
            (statement
             (allow
              (process req-and-queue-comm)
              (events
               (cons* %declarative-illegal-action
                      %illegal-action
                      %queue-empty-action
                      %queue-full-action
                      %queue-not-empty-action
                      %tau-void-action
                      %tag-action
                      (append
                       (append-map
                        (lambda (i)
                          (list
                           (%tau-event-action i)
                           (%tau-modeling-action i)
                           (%tau-reply-action i)))
                        interfaces)
                       (append-map
                        (lambda (p)
                          (list
                           (%in-action p)
                           (%reply-action p)
                           (%internal-action p)
                           (%qout-action p)
                           (%end-action p)
                           (%flush-action p)
                           (%state-action p)
                           (%port-queue-full-action p)))
                        requires))))))))
         (req-and-queue
          (process
            (name "req_and_queue")
            (statement
             (rename
              (process req-and-queue-allow)
              (events
               (cons*
                (rename-event (from %declarative-illegal-action)
                              (to %illegal-action))
                (map
                 (lambda (p)
                   (rename-event (from (transpose-tick (%qin-action p)))
                                 (to (%qin-action p))))
                 requires))))))))
    `(,component-queue
      ,@port-external-processes
      ,req-and-queue-parallel
      ,req-and-queue-comm
      ,req-and-queue-allow
      ,req-and-queue)))


;;;
;;; Semantics.
;;;
(define %blocking-formals '("blocking: Set (provides_ports)"
                            "released: List (provides_ports)"
                            "reply: reply_values"))

(define %blocked-formals `("rtc: provides_ports"
                           ,@%blocking-formals))

(define-method (out-actions (p <port>) name)
  (let ((interface (.type p)))
    (sum (type (%actions interface))
         (statement
          (sequence*
           (invoke (%out-action p) #:keep-constructor? #t)
           (goto (name name)
                 (arguments '())))))))

(define-method (qout-actions (p <port>) name)
  (let ((interface (.type p)))
    (sum (type (%actions interface))
         (statement
          (sequence*
           (invoke (%qout-action p) #:keep-constructor? #t)
           (goto (name name)
                 (arguments '())))))))

(define-method (switch-context-actions (p <port>) name)
  (sequence*
   (%switch-context-action p)
   (goto (name name)
         (arguments '()))))

(define-method (modeling+switch-context (p <port>) name continuation)
  (let ((interface (.type p)))
    (list
     (if* (not-equal* (port-prefix "port" p)
                      "switch")
          (sum (type (%modeling interface))
               (statement
                (sequence*
                 (invoke (%internal-action p))
                 (%end-action p)
                 (goto (name name)
                       (arguments '()))))))
     (if* (equal* (port-prefix "port" p)
                  "switch")
          (sequence*
           (%switch-context-action p)
           (goto (name continuation)
                 (arguments '())))))))

(define-method (defer-qout-actions (o <component>) name)
  (sum (type (%locals o))
       (statement
        (sequence*
         (invoke (%defer-qout-action o))
         (goto (name name)
               (arguments '()))))))

(define-method (defer-qout-actions-async (o <component>) name)
  (sum (type (%locals o))
       (statement
        (sequence*
         (invoke (%defer-qout-action o))
         (goto (name "semantics_async")
               (arguments '("port=no_port")))))))

(define-method (semantics-main (o <component>))
  (let* ((provides (ast:provides-port* o))
         (provides-interfaces (map .type provides))
         (requires (ast:requires-port* o))
         (shared (ast:shared* o))
         (state (lset-intersection
                 ast:eq?
                 requires
                 (map .port shared))))
    (define (semantics-provides p name)
      (let ((interface (.type p)))
        (sum (type (%actions interface))
             (statement
              (sequence*
               (invoke (%in-action p) #:keep-constructor? #t)
               (goto (name "semantics_unblocked")
                     (arguments
                      (list
                       (is*
                        "reply"
                        (entity
                         (name "replies")
                         (formals
                          (map
                           (cute model-prefix "nil" <>)
                           provides-interfaces))))))))))))
    (define (semantics-requires p name)
      (let ((interface (.type p)))
        (sum (type (%modeling interface))
             (statement
              (sequence*
               `(,(invoke (%internal-action p))
                 ,(%end-action p)
                 ,(union*
                   (list
                    (sequence*
                     `(,%queue-empty-action
                       ,@(map (lambda (port)
                                (sum (type (%state (.type port)))
                                     (var (port-prefix "s" port))
                                     (statement
                                      (invoke (%state-action port) var))))
                              (ast:provides-port* (ast:parent p <component>)))
                       ,(goto (name name))))
                    (goto (name "semantics_async")
                          (arguments
                           (list
                            "blocking={}"
                            "released=[]"
                            (is*
                             "reply"
                             (entity
                              (name "replies")
                              (formals
                               (map
                                (cute model-prefix "nil" <>)
                                provides-interfaces))))
                            "port=no_port")))))))))))
    ;; invariant QMT => allow provides in, or requires modeling
    (process
      (name "semantics_main")
      (statement
       (union*
        `(,@(map (cute semantics-provides <> name) provides)
          ,@(map (cute semantics-requires <> name) requires)))))))

(define-method (semantics-unblocked (o  <component>))
  (let* ((provides (ast:provides-port* o))
         (provides-interfaces (map .type provides))
         (provides-interface (.type (ast:provides-port o)))
         (requires (ast:requires-port* o)))
    (define (handle-provides-reply p name)
      (let ((interface (.type p)))
        (list
         (sequence* (%blocking-action p)
                    (goto (name "semantics_blocking")
                          (arguments
                           `(,(is*
                               "blocking"
                               (set*
                                (port-prefix "port" p)))
                             "released=[]"))))
         (sum (type (%replies interface))
              (statement
               (sequence*
                (invoke (%reply-action p))
                (if* (invoke
                      (%nil-predicate interface)
                      (construct (%port-predicate p) "reply"))
                     (goto (name name)
                           (arguments
                            ;; XXX loop var i
                            (list
                             (is*
                              "reply"
                              (entity
                               (name "replies")
                               (formals
                                (map
                                 (lambda (i)
                                   (if (ast:eq? i p) "i"
                                       (port-prefix "port (reply)"
                                                    i)))
                                 provides)))))))
                     (sequence*
                      %second-reply-action
                      %delta))))))))
    (define (handle-missing-reply name)
      (if* (expression
            (operator "&&")
            (operands
             (map
              (lambda (p)
                (let ((interface (.type p)))
                  (invoke (%nil-predicate interface)
                          (construct (%port-predicate p)
                                     "reply"))))
              provides)))
           (sequence* %missing-reply-action %delta)))
    (define (handle-defer-qout+goto-main p name)
      (let ((interface (.type p)))
        (if* (not*
              (invoke (%nil-predicate interface)
                      (construct (%port-predicate p)
                                 "reply")))
             (sequence*
              (invoke (%reply-reordered-action p)
                      ;; FIXME constructor?
                      (port-prefix "port (reply)" p))
              (let ((port p))
                (sum (type (%state (.type port)))
                     (var (port-prefix "s" port))
                     (statement
                      (invoke (%state-action port) var))))
              (union*
               (goto (name "semantics_main"))
               (sum (type (%locals o))
                    (statement
                     (sequence*
                      (invoke (%defer-qout-action o))
                      (goto
                       (name "semantics_async")
                       (arguments
                        `("blocking={}"
                          "released=[]"
                          ,(is*
                            "reply"
                            (entity
                             (name "replies")
                             (formals
                              (map
                               (cute model-prefix
                                     "nil" <>)
                               provides-interfaces))))
                          "port=no_port")))))))))))
    (define (handle-qout name)
      (if (null? requires) '()
          (list
           (sequence*
            `(,%queue-not-empty-action
              ,(union*
                (map (cute qout-actions <> name) requires)))))))
    ;; switch-context-actions but goto
    ;; semantics_unblocked_switch_context with switch=h'port
    (define (switch-context-actions+switch=p p name)
      (sequence*
       (%switch-context-action p)
       (goto (name "semantics_unblocked_switch_context")
             (arguments (list (string-append "switch="
                                             (port-prefix "port" p)))))))
    ;; handle (provides) replies (missing, second, reorder) and
    ;; synchronous (provides) out events, or continue as blocked
    ;; => emit blocking event
    (process
      (name "semantics_unblocked")
      (formals (list (formal (name "reply") (type (%reply-values o)))))
      (statement
       (union*
        `(,@(append-map (cute handle-provides-reply <> name) provides)
          ,@(map (cute out-actions <> name) provides)
          ,(sequence*
            (%end-action o)
            (union*
             `(,(sequence*
                 %queue-empty-action
                 (union*
                  `(,(handle-missing-reply name)
                    ,@(map
                       (cute handle-defer-qout+goto-main <> name)
                       provides))))
               ,@(handle-qout name))))
          ,@(map (cute switch-context-actions+switch=p <> name) requires)))))))

(define-method (semantics-modeling+switch-context (o <component>))
  ;; handle switch_context: collateral blocking => allow
  ;; requires modeling for other ports
  (let ((requires (ast:requires-port* o)))
    (process
      (name "semantics_unblocked_switch_context")
      (formals '("reply: reply_values" "switch: requires_ports"))
      (statement
       (union*
        `(,%delta
          ,@(append-map
             (cute modeling+switch-context <> name "semantics_unblocked")
             requires)))))))

(define-method (semantics-blocking (o <component>))
  (let ((provides (ast:provides-port* o))
        (requires (ast:requires-port* o)))
    (define (reordered p name)
      (let ((interface (.type p)))
        (sequence*
         (if* (not*
               (invoke (%nil-predicate interface)
                       (construct (%port-predicate p)
                                  "reply")))
              (invoke (%reply-reordered-action p)
                      ;; FIXME constructor?
                      (port-prefix "port (reply)" p)))
         (let ((port p))
           (sum (type (%state (.type port)))
                (var (port-prefix "s" port))
                (statement
                 (invoke (%state-action port) var))))
         (union*
          (goto (name "semantics_main"))
          (defer-qout-actions-async o name)))))
    (define (provides-reply p name)
      (let ((interface (.type p)))
        (sum (type (%replies interface))
             (statement
              (sequence*
               (invoke (%reply-action p))
               (goto (name name)
                     (arguments
                      (list
                       (is*
                        "released"
                        (string-append
                         "released <| "
                         ;; XXX FIXME: port-constructor?
                         (port-prefix "port" p)))
                       (is*
                        "reply"
                        (entity
                         (name "replies")
                         (formals
                          (map
                           (lambda (i)
                             (if (ast:eq? i p) "i"
                                 (port-prefix "port (reply)" i)))
                           provides))))))))))))
    ;; at the end of the component behavior =>
    ;;   when not all blocked ports are released =>
    ;;     goto blocked rtc or skip blocked (qout
    ;;   when all blocked ports are released =>
    ;;     if QMT perform reordered reply => allow defer or goto main
    ;;     else (!QMT) goto skip blocked
    ;; or handle provides synchronous out and reply
    ;; or collateral block => switch context
    (process
      (name "semantics_blocking")
      (formals %blocking-formals)
      (statement
       (union*
        `(,(if* "blocking - list2set (released) != {}"
                (sequence*
                 (%end-action o)
                 (union*
                  (sequence*
                   %queue-empty-action
                   (goto (name "semantics_blocked_rtc") (arguments '())))
                  (sequence*
                   %queue-not-empty-action
                   (goto (name "semantics_skip_blocked") (arguments '()))))))
          ,(if* "blocking - list2set (released) == {}"
                (sequence*
                 (%end-action o)
                 (union*
                  (sequence* %queue-empty-action
                             (union*
                              `(,(goto (name "semantics_skip_blocked")
                                       (arguments '()))
                                ,@(map (cute reordered <> name) provides))))
                  (sequence* %queue-not-empty-action
                             (goto (name "semantics_skip_blocked")
                                   (arguments '()))))))
          ,@(append-map (seq (cute provides-reply <> name)
                             (cute out-actions <> name))
                        provides)
          ,@(map (cute switch-context-actions <> name) requires)))))))

(define-method (semantics-skip-blocking (o <component>))
  (let ((provides (ast:provides-port* o))
        (requires (ast:requires-port* o)))
    (define (handle-provides-replies p name)
      (let ((interface (.type p)))
        (list
         (sum (type (%replies interface))
              (statement
               (sequence*
                (invoke (%reply-action p))
                (goto (name name)
                      (arguments
                       (list
                        (is*
                         "released"
                         (string-append
                          "released <| "
                          ;; XXX FIXME: port-constructor?
                          (port-prefix "port" p)))
                        (is*
                         "reply"
                         (entity
                          (name "replies")
                          (formals
                           (map
                            (lambda (i)
                              (if (ast:eq? i p) "i"
                                  (port-prefix "port (reply)" i)))
                            provides))))))))))
         (if* (simple-format
               #f
               "released != [] && ~a == head (released)"
               ;; XXX FIXME: port-constructor?
               (port-prefix "port" p))
              (sequence*
               (%end-action o)
               (union*
                `(,(sequence*
                    %queue-empty-action
                    (invoke (%reply-reordered-action p)
                            (construct (%port-predicate p)
                                       "reply"))
                    (let ((port p))
                      (sum (type (%state (.type port)))
                           (var (port-prefix "s" port))
                           (statement
                            (invoke (%state-action port) var))))
                    (union*
                     (goto (name "semantics_main"))
                     (sum (type (%locals o))
                          (statement
                           (sequence*
                            (invoke (%defer-qout-action o))
                            (goto (name "semantics_async")
                                  (arguments '("blocking={}"
                                               "port=no_port"))))))))
                  ,@(append-map (seq (cute switch-context-actions <> name)
                                     (cute qout-actions <> name))
                                requires))))))))
    (define (handle-no-provides-reply name)
      (if* (not*
            (list ;;; XXX TODO group*?
             ;; XXX TODO or*?
             (string-join
              (map
               (lambda (p)
                 (simple-format
                  #f
                  "released != [] && ~a == head (released)"
                  (port-prefix "port" p)))
               provides)
              " || ")))
           (sequence* (%end-action o)
                      (union*
                       `(,(goto (name "semantics_blocked_rtc")
                                (arguments '()))
                         ,@(append-map
                            (seq (cute switch-context-actions <> name)
                                 (cute qout-actions <> name))
                            requires))))))
    ;; when at the end of the component behavior
    ;;   if reply seen and QMT => reordered (switch context or goto main or defer qout)
    ;;                            or handle requires qout
    ;;   if not reply seen => switch context or goto blocked_rtc
    ;;                        or handle requires qout
    ;; or handle requires qout and reply
    (process
      (name "semantics_skip_blocked")
      (formals %blocking-formals)
      (statement
       (union*
        `(,@(append-map (cute handle-provides-replies <> name) provides)
          ,@(map (cute out-actions <> name) provides)
          ,(handle-no-provides-reply name)
          ,@(append-map (seq (cute switch-context-actions <> name)
                             (cute qout-actions <> name))
                        requires)
          ,(defer-qout-actions o name)
          ,(sequence* %defer-end-action
                      (goto (name name) (arguments '())))))))))

(define-method (semantics-blocked (o <component>))
  (let ((provides (ast:provides-port* o))
        (requires (ast:requires-port* o)))
    (define (handle-queue-empty name)
      (sequence*
       %queue-empty-action
       (if* "released != []"
            (goto (name "semantics_reply")
                  (arguments '()))
            (goto (name "semantics_blocked_rtc")
                  (arguments '())))))
    (define (handle-blocked-port-reply p name)
      (let ((interface (.type p)))
        (if* (invoke (%nil-predicate interface)
                     (construct (%port-predicate p) "reply"))
             (sum (type (%replies interface))
                  (statement
                   (sequence*
                    (invoke (%reply-action p))
                    (goto (name name)
                          (arguments
                           (list
                            (is*
                             "released"
                             (string-append
                              "released <| "
                              ;; XXX FIXME: port-constructor?
                              (port-prefix "port" p)))
                            (is*
                             "reply"
                             (entity (name "replies")
                                     (formals
                                      (map
                                       (lambda (i)
                                         (if (ast:eq? i p) "i"
                                             (port-prefix "port (reply)" i)))
                                       provides))))))))))
             (sum (type (%replies interface))
                  (statement
                   (sequence*
                    (invoke (%reply-action p))
                    %second-reply-action
                    %delta))))))
    (define (handle-port-blocking p name)
      (sequence*
       (%blocking-action p)
       (goto (name name)
             (arguments
              (list
               "rtc=no_port"
               (is* "blocking"
                    (plus* "blocking"
                           ;; XXX FIXME: port-constructor?
                           (set* (port-prefix "port" p)))))))))
    ;; nothing blocked => goto main or defer qout
    ;; when at end of behavior and queue_empty
    ;;    if nothing released => goto blocked_rtc
    ;;    else                => goto reply
    ;;    or handle requires qout
    ;;    or handle switch context
    (process
      (name "semantics_blocked")
      (formals %blocked-formals)
      (statement
       (union*
        `(,(if* "blocking == {} && released == []"
                (sequence*
                 `(,@(map (lambda (port)
                            (sum (type (%state (.type port)))
                                 (var (port-prefix "s" port))
                                 (statement
                                  (invoke (%state-action port) var))))
                          provides)
                   ,(union*
                     (goto (name "semantics_main"))
                     (defer-qout-actions-async o name)))))
          ,(sequence*
            (%end-action o)
            (union*
             `(,(handle-queue-empty name)
               ,@(append-map (seq (cute qout-actions <> name)
                                  (cute switch-context-actions <> name))
                             requires))))
          ,@(append-map (seq (cute out-actions <> name)
                             (cute handle-blocked-port-reply <> name)
                             (cute handle-port-blocking <> name))
                        provides)
          ,@(append-map (seq (cute qout-actions <> name)
                             (cute switch-context-actions <> name))
                        requires)
          ,(sequence* %defer-end-action
                      (goto (name name) (arguments '())))))))))

(define-method (semantics-reply (o <component>))
  (let ((provides (ast:provides-port* o)))
    (define (semantics-reply p name)
      (let ((interface (.type p)))
        (if* (or*
              (and*
               (equal* "rtc" (port-prefix "port" p))
               (not*
                (invoke (%nil-predicate interface)
                        (construct (%port-predicate p)
                                   "reply"))))
              (and*
               ;; FIXME: no_port predicate?
               (equal* "rtc" "no_port")
               (not-equal* "released" "[]")
               (equal*
                ;; FIXME: constructor?
                (port-prefix "port" p)
                "head (released)")))
             (sequence*
              (invoke (%reply-reordered-action p)
                      (construct (%port-predicate p)
                                 "reply"))
              (sum (type (%state (.type p)))
                   (var (port-prefix "s" p))
                   (statement
                    (sequence*
                     (invoke (%state-action p) var))))
              (let ((arguments
                     (list
                      (is*
                       "blocking"
                       (minus*
                        "blocking"
                        (set* (port-prefix "port" p))))
                      (simple-format
                       #f
                       "released=remove_port (~a, released)"
                       (port-prefix "port" p))
                      (is* "reply"
                           (entity
                            (name "replies")
                            (formals
                             (map
                              (lambda (i)
                                (if (ast:eq? i p) (model-prefix
                                                   "nil" interface)
                                    (port-prefix "port (reply)" i)))
                              provides)))))))
                (union*
                 (goto (name name)
                       (arguments (cons
                                   "rtc=no_port"
                                   arguments)))
                 (goto (name "semantics_blocked_rtc")
                       (arguments arguments))))))))
    (process
      (name "semantics_reply")
      (formals %blocked-formals)
      (statement
       (union*
        `(,(if* "blocking == {} && released == []"
                (goto (name "semantics_blocked")
                      (arguments '())))
          ,(if* "blocking - list2set (released) != {} && rtc == no_port"
                (goto (name "semantics_blocked_rtc")
                      (arguments '())))
          ,@(map (cute semantics-reply <> name) provides)))))))

;;TODO refactor: extract commonality in main and blocked-main
(define-method (semantics-blocked-main (o <component>))
  (let* ((provides (ast:provides-port* o))
         (requires (ast:requires-port* o))
         (shared (ast:shared* o))
         (state (lset-intersection
                 ast:eq?
                 (ast:requires-port* o)
                 (map .port shared))))
    (define (blocked-main-provides p name)
      (let ((interface (.type p)))
        (if* (not* (in* (port-prefix "port" p) "blocking"))
             (sequence*
              (sum (type (%actions interface))
                   (statement
                    (sequence*
                     (invoke (%in-action p)
                             #:keep-constructor? #t)
                     (goto
                      (name "semantics_blocked")
                      (arguments
                       (list
                        (is*
                         "rtc"
                         (port-prefix "port" p))))))))))))
    (define (blocked-main-requires p name)
      (let ((interface (.type p)))
        (if* "released == []"
             (sum (type (%modeling interface))
                  (statement
                   (sequence*
                    `(,(invoke (%internal-action p))
                      ,(%end-action p)
                      ,(goto
                        (name "semantics_blocked")
                        (arguments '("rtc=no_port"))))))))))
    (process
      (name "semantics_blocked_rtc")
      (formals %blocking-formals)
      (statement
       (union*
        (if* "blocking == {}"
             (sequence*
              `(,@(map (lambda (port)
                         (sum (type (%state (.type port)))
                              (var (port-prefix "s" port))
                              (statement
                               (invoke (%state-action port) var))))
                       provides)
                ,(union* (goto (name "semantics_main"))
                         (defer-qout-actions-async o name)))))
        (if* "blocking != {}"
             (union*
              `(,@(map (cute blocked-main-provides <> name) provides)
                ,@(map (cute blocked-main-requires <> name) requires)
                ,(sum (type (%locals o))
                      (statement
                       (sequence*
                        (invoke (%defer-qout-action o))
                        (goto (name "semantics_blocked")
                              (arguments '("rtc=no_port"))))))))))))))

(define-method (semantics-async-modeling+switch-context (o <component>))
  (let ((requires (ast:requires-port* o)))
    (process
      (name "semantics_async_switch_context")
      (formals `(,@%blocking-formals
                 "port: provides_ports"
                 "switch: requires_ports"))
      (statement
       (union*
        `(,%delta
          ,@(append-map
             (cute modeling+switch-context <> name "semantics_async")
             requires)))))))

(define-method (semantics-async (o <component>))
  (let ((provides (ast:provides-port* o))
        (requires (ast:requires-port* o)))
    (define (requires-flush p name)
      (let ((interface (.type p)))
        (if* (invoke (%port-predicate p) "port")
             (sequence*
              (%flush-action p)
              (union*
               (goto (name "semantics_main"))
               (defer-qout-actions-async o name))))))
    ;; XXX out-actions, but with port=h'port
    (define (out-actions+port=p p name)
      (let ((interface (.type p)))
        (sum (type (%actions interface))
             (statement
              (sequence*
               (invoke (%out-action p) #:keep-constructor? #t)
               (goto (name name)
                     (arguments
                      (list
                       (is* "port" (port-prefix "port" p))))))))))
    ;; XXX switch-context-actions but goto
    ;; semantics_async_switch_context with switch=h'port
    (define (switch-context-actions+switch=p p name)
      (sequence*
       (%switch-context-action p)
       (goto (name "semantics_async_switch_context")
             (arguments
              (list (is* "switch" (port-prefix "port" p)))))))
    (process
      (name "semantics_async")
      (formals `(,@%blocking-formals
                 "port: provides_ports"))
      (statement
       (union*
        `(,(sequence*
            (%end-action o)

            (union*
             (sequence*
              `(,%queue-empty-action
                ,@(map (lambda (port)
                         (sum (type (%state (.type port)))
                              (var (port-prefix "s" port))
                              (statement
                               (invoke (%state-action port) var))))
                       provides)
                ,(union*
                  `(,(if* (invoke %no-port-predicate "port")
                          (union* (goto (name "semantics_main"))
                                  (sequence*
                                   (defer-qout-actions o name))))
                    ,@(map (cute requires-flush <> name) provides)))))
             (sequence* %queue-not-empty-action
                        (goto (name name) (arguments '())))))
          ,(sequence* %defer-end-action
                      (goto (name name) (arguments '())))
          ,@(map (cute out-actions+port=p <> name) provides)
          ,@(append-map (seq (cute switch-context-actions+switch=p <> name)
                             (cute qout-actions <> name))
                        requires)))))))

(define-method (component-semantics-processes (o <component>))
  (let* ((provides (ast:provides-port* o))
         (requires (ast:requires-port* o))
         (shared (ast:shared* o))
         (component-semantics-parallel
          (process (name "component_semantics_parallel")
                   (statement
                    (parallel* (goto (name "component_behavior"))
                               (goto (name "semantics_main"))))))
         (component-semantics-comm
          (process
            (name "component_semantics_comm")
            (statement
             (comm
              (process component-semantics-parallel)
              (events
               (append
                (list
                 (comm-event (from (multi-event
                                    (events
                                     (list %defer-end-action)))))
                 (comm-event (from (multi-event
                                    (events
                                     (list (%defer-qout-action o))))))
                 (comm-event (from (multi-event
                                    (events
                                     (list (%end-action o)))))))
                (append-map
                 (lambda (p)
                   (list
                    (comm-event (from (multi-event
                                       (events
                                        (list (%in-action p))))))
                    (comm-event (from (multi-event
                                       (events
                                        (list (%out-action p))))))
                    (comm-event (from (multi-event
                                       (events
                                        (list (%blocking-action p))))))
                    (comm-event (from (multi-event
                                       (events
                                        (list (%reply-action p))))))
                    (comm-event (from (multi-event
                                       (events
                                        (list (%state-action p))))))))
                 provides)
                (append-map
                 (lambda (p)
                   (list
                    (comm-event (from (multi-event
                                       (events
                                        (list (%qout-action p))))))
                    (comm-event (from (multi-event
                                       (events
                                        (list (%switch-context-action p))))))))
                 requires)
                (append-map
                 (lambda (p)
                   (list
                    (comm-event (from (multi-event
                                       (events
                                        (list (%state-action p))))))))
                 ;;TODO simplify + filter non external?
                 (lset-intersection ast:eq? requires (map .port shared)))))))))
         (interfaces (ast:interface* o))
         (component-semantics-allow
          (process
            (name "component_semantics_allow")
            (statement
             (allow
              (process component-semantics-comm)
              (events (cons* %constrained-legal-action
                             %constrained-illegal-action
                             %declarative-illegal-action
                             (%defer-skip-action o)
                             %illegal-action
                             %missing-reply-action
                             %queue-empty-action
                             %queue-full-action
                             %queue-not-empty-action
                             %range-error-action
                             %recurse-action
                             %return-action
                             %second-reply-action
                             %tag-action
                             %tau-void-action
                             (append
                              (append-map
                               (lambda (i)
                                 (list
                                  (%tau-event-action i)
                                  (%tau-modeling-action i)
                                  (%tau-reply-action i)))
                               interfaces)
                              (append-map
                               (lambda (p)
                                 (list
                                  (%reply-reordered-action p)
                                  (%flush-action p)))
                               provides)
                              (append-map
                               (lambda (p)
                                 (list
                                  (%in-action p)
                                  (%internal-action p)
                                  (%end-action p)
                                  (%reply-action p)
                                  (%state-action p)))
                               requires))))))))
         (component-semantics
          (process
            (name "component_semantics")
            (statement
             (rename
              (process component-semantics-allow)
              (events
               (append
                (append-map
                 (lambda (p)
                   (let ((interface (.type p)))
                     (list
                      (rename-event (from (transpose-tick (%reply-action p)))
                                    (to (%tau-reply-action interface)))
                      (rename-event (from (%reply-reordered-action p))
                                    (to (%reply-action p))))))
                 provides)
                (comm-events (process-statement
                              component-semantics-comm)))))))))

    ;; when QMT, i.e. RTC => allow defer qout
    (list (semantics-main o)
          (comment* "% semantics main\n")

          (semantics-unblocked o)
          (comment* "% semantics_unblocked\n")

          (semantics-modeling+switch-context o)
          (comment* "% semantics_unblocked switch-context\n")

          (semantics-blocking o)
          (comment* "% semantics_blocking\n")

          (semantics-skip-blocking o)
          (comment* "% semantics_skip blocked\n")

          (semantics-blocked o)
          (comment* "% semantics_blocked\n")

          (semantics-reply o)
          (comment* "% semantics reply\n")

          (semantics-blocked-main o)
          (comment* "% semantics blocked rtc\n")

          (semantics-async o)
          (comment* "% semantics async\n")

          (semantics-async-modeling+switch-context o)
          (comment* "% semantics async switch-context\n")

          component-semantics-parallel
          component-semantics-comm
          component-semantics-allow
          component-semantics)))

(define-method (component-processes (o <component>))
  (let* ((provides (ast:provides-port* o))
         (requires (ast:requires-port* o))
         (component-parallel
          (process (name "component_parallel")
                   (statement
                    (parallel* (goto (name "component_constrained"))
                               (goto (name "req_and_queue"))))))
         (component-comm
          (process
            (name "component_comm")
            (statement
             (comm
              (process component-parallel)
              (events
               (cons*
                (comm-event (from (multi-event
                                   (events
                                    (list %queue-empty-action)))))
                (comm-event (from (multi-event
                                   (events
                                    (list %queue-not-empty-action)))))
                (append
                 (append-map
                  (lambda (p)
                    (list
                     (comm-event (from (multi-event
                                        (events
                                         (list (%in-action p))))))
                     (comm-event (from (multi-event
                                        (events
                                         (list (%reply-action p))))))
                     (comm-event (from (multi-event
                                        (events
                                         (list (%internal-action p))))))
                     (comm-event (from (multi-event
                                        (events
                                         (list (%qout-action p))))))
                     (comm-event (from (multi-event
                                        (events
                                         (list (%end-action p))))))))
                  requires)
                 (map
                  (lambda (p)
                    (comm-event (from (multi-event
                                       (events
                                        (list (%state-action p)))))))
                  (filter (negate ast:external?) requires)))))))))
         (interfaces (ast:interface* o))
         (component-allow
          (process
            (name "component_allow")
            (statement
             (allow
              (process component-comm)
              (events (cons* %constrained-legal-action
                             %declarative-illegal-action
                             %defer-end-action
                             (%defer-qout-action o)
                             (%defer-skip-action o)
                             %illegal-action
                             %missing-reply-action
                             %queue-full-action
                             %range-error-action
                             %recurse-action
                             %return-action
                             %second-reply-action
                             %tag-action
                             %tau-void-action
                             (%end-action o)
                             (append
                              (append-map
                               (lambda (i)
                                 (list
                                  (%tau-event-action i)
                                  (%tau-modeling-action i)
                                  (%tau-reply-action i)))
                               interfaces)
                              (append-map
                               (lambda (p)
                                 (list
                                  (%in-action p)
                                  (%blocking-action p)
                                  (%out-action p)
                                  (%reply-action p)
                                  (%flush-action p)
                                  (%state-action p)))
                               provides)
                              (append-map
                               (lambda (p)
                                 (list
                                  (%qin-action p)
                                  (%flush-action p)
                                  (%port-queue-full-action p)
                                  (%switch-context-action p)))
                               requires)
                              (map
                               (lambda (p)
                                 (%state-action p))
                               (filter ast:external? requires)))))))))
         (component-rename
          (process
            (name "component_rename")
            (statement
             (rename
              (process component-allow)
              (events
               (comm-events (process-statement component-comm)))))))
         (component
          (process
            (name "component")
            (statement
             (hide
              (process component-rename)
              (events (cons* %constrained-legal-action
                             %defer-end-action
                             (%defer-skip-action o)
                             %queue-empty-action
                             %queue-not-empty-action
                             %recurse-action
                             %return-action
                             %tau-void-action
                             (%end-action o)
                             (append
                              (append-map
                               (lambda (i)
                                 (list
                                  (%tau-event-action i)
                                  (%tau-modeling-action i)
                                  (%tau-reply-action i)))
                               interfaces)
                              (map
                               (lambda (p)
                                 (%state-action p))
                               provides)
                              (append-map
                               (lambda (p)
                                 (list
                                  (%end-action p)
                                  (%switch-context-action p)))
                               requires)))))))))
    (list component-parallel
          component-comm
          component-allow
          component-rename
          component)))

(define-method (interface-constraint-processes (o <interface>))
  (let ((constraint (makreel:constraint o)))
    (list
     (comment* (makreel:caption (model-prefix "constraint" o)))
     (process
       (name (model-prefix "constraint_any" o))
       (statement
        (union*
         (sum (type (%actions o))
              (statement
               (sequence*
                (invoke (%in-action o) #:keep-constructor? #t)
                %constrained-legal-action
                (goto (name name)))))
         (sum (type (%actions o))
              (statement
               (sequence*
                (invoke (%out-action o) #:keep-constructor? #t)
                (goto (name name)))))
         (sum (type (%replies o))
              (statement
               (sequence*
                (invoke (%reply-action o))
                (goto (name name)))))
         (sum (type (%state o))
              (statement
               (sequence*
                (invoke (%state-action o))
                (goto (name name))))))))
     (comment* constraint))))

(define-method (provides-constraint-processes (o <port>))
  (let* ((interface (.type o))
         (provides-constraint
          (process
            (name (port-prefix "provides_constraint" o))
            (statement
             (rename
              (process (model-prefix "constraint_start" interface))
              (events
               (list
                (rename-event (from (%in-action interface))
                              (to (%in-action o)))
                (rename-event (from (%out-action interface))
                              (to (%out-action o)))
                (rename-event (from (%reply-action interface))
                              (to (%reply-action o)))
                (rename-event (from (%state-action interface))
                              (to (%state-action o))))))))))
    (list provides-constraint)))

(define-method (constraint-processes (o <component>))
  (let* ((provides (ast:provides-port* o))
         (provides-port (ast:provides-port o))
         (requires (ast:requires-port* o))
         (provides-constraint-parallel
          (process
            (name "provides_constraint_parallel")
            (statement
             (parallel
              (processes
               (map
                (lambda (p)
                  (goto (name (port-prefix "provides_constraint" p))))
                provides))))))
         (provides-constraint
          (if (= (length provides) 1)
              (process
                (name "provides_constraint")
                (statement
                 (goto (name "provides_constraint_parallel"))))
              (process
                (name "provides_constraint")
                (statement
                 (allow
                  (process provides-constraint-parallel)
                  (events (cons* %constrained-legal-action
                                 %constrained-illegal-action
                                 (append-map
                                  (lambda (p)
                                    (list
                                     (%in-action p)
                                     (%out-action p)
                                     (%reply-action p)
                                     (%state-action p)))
                                  provides))))))))
         (component-constrained-parallel
          (process (name "component_constrained_parallel")
                   (statement
                    (parallel* (goto (name "component_semantics"))
                               (goto (name "provides_constraint"))))))
         (component-constrained-comm
          (process
            (name "component_constrained_comm")
            (statement
             (comm
              (process component-constrained-parallel)
              (events
               (cons*
                (comm-event (from (multi-event
                                   (events
                                    (list %constrained-legal-action)))))
                (comm-event (from (multi-event
                                   (events
                                    (list %constrained-illegal-action)))))
                (append-map
                 (lambda (p)
                   (list
                    (comm-event (from (multi-event
                                       (events
                                        (list (%in-action p))))))
                    (comm-event (from (multi-event
                                       (events
                                        (list (%out-action p))))))
                    (comm-event (from (multi-event
                                       (events
                                        (list (%reply-action p))))))
                    (comm-event (from (multi-event
                                       (events
                                        (list (%state-action p))))))))
                 provides)))))))
         (provides-interfaces (map .type provides))
         (provides-interfaces (delete-duplicates provides-interfaces ast:eq?))
         (interfaces (ast:interface* o))
         (component-constrained-allow
          (process
            (name "component_constrained_allow")
            (statement
             (allow
              (process component-constrained-comm)
              (events (cons* %declarative-illegal-action
                             %defer-end-action
                             (%defer-qout-action o)
                             (%defer-skip-action o)
                             %illegal-action
                             %missing-reply-action
                             %queue-empty-action
                             %queue-full-action
                             %queue-not-empty-action
                             %range-error-action
                             %recurse-action
                             %return-action
                             %second-reply-action
                             %tag-action
                             %tau-void-action
                             (%end-action o)
                             (append
                              (append-map
                               (lambda (i)
                                 (list
                                  (%tau-event-action i)
                                  (%tau-modeling-action i)
                                  (%tau-reply-action i)))
                               interfaces)
                              (append-map
                               (lambda (p)
                                 (list
                                  (%blocking-action p)
                                  (%flush-action p)))
                               provides)
                              (append-map
                               (lambda (p)
                                 (list
                                  (%in-action p)
                                  (%reply-action p)
                                  (%internal-action p)
                                  (%end-action p)
                                  (%qout-action p)
                                  (%state-action p)
                                  (%switch-context-action p)))
                               requires))))))))
         (component-constrained
          (process
            (name "component_constrained")
            (statement
             (rename
              (process component-constrained-allow)
              (events
               (cons*
                (rename-event
                 (from (transpose-tick %constrained-illegal-action))
                 (to %declarative-illegal-action))
                (comm-events (process-statement
                              component-constrained-comm)))))))))
    (list provides-constraint-parallel
          provides-constraint
          component-constrained-parallel
          component-constrained-comm
          component-constrained-allow
          component-constrained)))

(define-method (unconstrained-processes (o <component>))
  (list
   (comment* "% actually unconstrained")
   (process
     (name "component_constrained")
     (statement
      (block
       (process "component_semantics")
       (events (list %constrained-illegal-action)))))))

(define-method (model->scmackerel (o <component>))
  (makreel:proc-list (.behavior o))
  (parameterize ((%model-name (makreel:full-name o)))
    (let* ((ports (ast:port* o))
           (requires (ast:requires-port* o))
           (port-processes (append-map port-processes ports))
           (provides (ast:provides-port* o))
           (provides-interfaces (map .type provides))
           (provides-interfaces (delete-duplicates provides-interfaces ast:eq?))
           (provides-processes (provides-processes o))
           (requires-processes (requires-processes o))
           (behavior (.behavior o))
           (enums (filter (is? <enum>) (ast:type* behavior)))
           (enums (map enum->scmackerel enums))
           (members (filter (negate (is? <shared-variable>)) (ast:variable* o)))
           (behavior-processes (behavior->processes o))
           (functions (makreel:called-function* behavior))
           (function-processes (append-map function->processes functions))
           (return-processes (return-processes o))
           (defer-processes (append-map defer->processes (makreel:defer* o)))
           (component-defer-processes (component-defer-processes o))
           (q-processes
            (if (null? requires) (component-no-q-processes o)
                (component-q-processes o)))
           (semantics-processes (component-semantics-processes o))
           (interface-constraint-processes
            (if (%no-constraint?) '()
                (append-map interface-constraint-processes provides-interfaces)))
           (provides-constraint-processes
            (if (%no-constraint?) '()
                (append-map provides-constraint-processes provides)))
           (constraint-processes
            (if (%no-constraint?) (unconstrained-processes o)
                (constraint-processes o)))
           (static-defer-processes
            (file-comments "defer.mcrl2"))
           (component-processes (component-processes o))
           (return-type (%return-type o))
           (returns-type (%returns-type o))
           (processes `(,(makreel:caption "PORT PROCESSES")
                        ,@port-processes
                        ,(makreel:caption "PROVIDES")
                        ,@provides-processes
                        ,(makreel:caption "REQUIRES")
                        ,@requires-processes
                        ,(makreel:caption "COMPONENT")
                        ,@static-defer-processes
                        ,@behavior-processes
                        ,(makreel:caption "FUNCTIONS")
                        ,@(if (not return-type) '()
                              (list return-type))
                        ,(%stack-type o)
                        ,@(if (not returns-type) '()
                              (list returns-type))
                        ,@function-processes
                        ,@return-processes
                        ,(makreel:caption "DEFER")
                        ,@defer-processes
                        ,@component-defer-processes
                        ,(makreel:caption "Q")
                        ,@q-processes
                        ,(makreel:caption "SEMANTICS")
                        ,@semantics-processes
                        ,@interface-constraint-processes
                        ,(makreel:caption "PROVIDES CONSTRAINT")
                        ,@provides-constraint-processes
                        ,(makreel:caption "COMPONENT CONSTRAINED")
                        ,@constraint-processes
                        ,(makreel:caption "COMPONENT ASSEMBLY")
                        ,@component-processes))
           (provides-ports-type
            (type (name "provides_ports")
                  (entities (cons* %no-port-predicate
                                   (map (lambda (p)
                                          (%port-predicate p))
                                        provides)))))
           (requires-ports (ast:requires-port* o))
           (requires-ports-type
            (type (name "requires_ports")
                  (entities (cons* "no_requires"
                                   (map (cute port-prefix "port" <>)
                                        requires)))))
           (requires-events-type
            (type
             (name "requires_events")
             (entities
              (cons*
               "no_type"
               (map
                (lambda (p)
                  (let ((interface (.type p)))
                    ;; FIXME: predicate name + type?
                    (predicate
                     (name (port-prefix "is" p))
                     (type (entity
                            (name (port-prefix "events" p))
                            (formals
                             (list (formal
                                    (type (model-prefix "events" interface))
                                    (name (port-prefix "projection" p))))))))))
                requires)))))
           (state-type (%state o))
           (selection-type (type (name "Selection")
                                 (entities
                                  (cons* "selection_empty"
                                         (map
                                          (cute variable-prefix "select" <>)
                                          members)))))
           (queue-size-equation (equation (left "QueueLength")
                                          (right (%queue-size))))
           (queue-size-defer-equation (equation (left "DeferQueueLength")
                                                (right (%queue-size-defer))))
           (queue-size-external-equation (equation (left "ExternalQueueLength")
                                                   (right (%queue-size-external))))
           (state-current-equation
            (equation (left "state_current (current, context)")
                      (right (if (or (null? defer-processes)
                                     (null? members)) "(true)"
                                     (and*
                                      (map variable->current? members)))))))
      (scmackerel (types `(,provides-ports-type
                           ,(%reply-values o)
                           ,requires-ports-type
                           ,requires-events-type
                           ,@enums
                           ,state-type
                           ,selection-type
                           ,%defer-context-type
                           ,(%locals o)))
                  (equations (list
                              state-current-equation
                              queue-size-equation
                              queue-size-defer-equation
                              queue-size-external-equation))
                  (processes processes)))))


;;;
;;; Entry point.
;;;
(define (root->scmackerel root)
  (let* ((models (ast:model* root))
         (interfaces (filter (is? <interface>) models))
         (component (find (is? <component>) models))
         (interface-scm (map model->scmackerel interfaces))
         (scm (fold merge-scmackerels
                    (car interface-scm)
                    (cdr interface-scm)))
         (component-scm (and=> component model->scmackerel))
         (scm (if (not component-scm) scm
                  (merge-scmackerels component-scm scm)))
         (scm (if (not component-scm) scm
                  (scmackerel
                   (inherit scm)
                   (processes
                    (cons (makreel:caption "INTERFACE")
                          (scmackerel-processes scm))))))
         (enums (filter (is? <enum>) (ast:type* root)))
         (enums (map enum->scmackerel enums))
         (illegal-processes (illegal-processes))
         (static-equations
          `(,(makreel:generated-comment root)
            ,@(if (not component) '()
                  (file-comments "component.mcrl2"))))
         (scm (scmackerel
               (inherit scm)
               (equations
                (append static-equations
                        (scmackerel-equations scm)
                        enums))
               (types
                (append (scmackerel-types scm)
                        enums))
               (processes
                (append illegal-processes
                        (scmackerel-processes scm)
                        (list (makreel:version-comment)))))))
    (display scm)))
