;;; Commentary:
;;;
;;; Compile-time configuration of dzn.  When adding a substitution
;;; variable here, make sure to have configure substitute it.
;;;
;;; Code:

(define-module (dzn config)
  #:export (%bindir
            %datadir
            %datarootdir
            %dzn
            %guilemoduledir
            %guileobjectdir
            %default-languages
            %package
            %prefix
            %root-dir
            %template-dir
            %version
            %version-major
            %version-minor
            %version-patch))

(define %package
  (or (and (getenv "DZN_UNINSTALLED") "dezyne")
      "@PACKAGE@"))

(define %prefix
  (or (and (getenv "DZN_UNINSTALLED") (getenv "DZN_PREFIX"))
      "@prefix@"))

(define %datadir
  (or (and (getenv "DZN_UNINSTALLED") %prefix)
      "@datadir@"))

(define %datarootdir
  (or (and (getenv "DZN_UNINSTALLED") %prefix)
      "@datarootdir@"))

(define %pkgdatadir
  (or (and (getenv "DZN_UNINSTALLED") %prefix)
      (getenv "DZN_DATADIR")
      (string-append %datadir "/" %package)))

(define %bindir
  (or (and (getenv "DZN_UNINSTALLED") (string-append %prefix "/bin"))
      "@bindir@"))

(define %root-dir
  (or (and (getenv "DZN_UNINSTALLED") %prefix)
      %pkgdatadir))

(define %template-dir
  (string-append %datadir "/templates"))

(define %guilemoduledir
  "@guilemoduledir@")

(define %guileobjectdir
  "@guileobjectdir@")

(define %version
  "@PACKAGE_VERSION@")

(define %version-major
  @VERSION_MAJOR@)

(define %version-minor
  @VERSION_MINOR@)

(define %version-patch
  @VERSION_PATCH@)

(define %dzn
  (string-append %bindir "/dzn"))

(define %default-languages
  (string-split (string-trim-both "@languages@") #\space))
