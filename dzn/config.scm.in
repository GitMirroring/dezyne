;;; Commentary:
;;;
;;; Compile-time configuration of dzn.  When adding a substitution
;;; variable here, make sure to have configure substitute it.
;;;
;;; Code:

(define-module (dzn config)
  #:use-module (dzn shell-util)
  #:export (%bindir
            %copyright-info
            %datadir
            %datarootdir
            %dzn
            %guilemoduledir
            %guileobjectdir
            %default-languages
            %license-info
            %package
            %package-name
            %package-version
            %prefix
            %template-dir
            %test-dir
            %version-major
            %version-minor
            %version-patch))

(define %package
  (or (and (getenv "DZN_UNINSTALLED") "dezyne")
      "@PACKAGE@"))

(define %prefix
  (or (and (getenv "DZN_UNINSTALLED") (getenv "DZN_PREFIX"))
      "@prefix@"))

(define %datadir
  (or (and (getenv "DZN_UNINSTALLED") %prefix)
      "@datadir@"))

(define %datarootdir
  (or (and (getenv "DZN_UNINSTALLED") %prefix)
      "@datarootdir@"))

(define %pkgdatadir
  (or (and (getenv "DZN_UNINSTALLED") %prefix)
      (getenv "DZN_DATADIR")
      (string-append %datadir "/" %package)))

(define %bindir
  (or (and (getenv "DZN_UNINSTALLED") (string-append %prefix "/bin"))
      "@bindir@"))

(define %template-dir
  (string-append %pkgdatadir "/dzn/templates"))

(define %test-dir
  (string-append %pkgdatadir "/test"))

(define %guilemoduledir
  "@guilemoduledir@")

(define %guileobjectdir
  "@guileobjectdir@")

(define %package-name
  "@PACKAGE_NAME@")

(define %package-version
  "@PACKAGE_VERSION@")

(define %version-major
  @VERSION_MAJOR@)

(define %version-minor
  @VERSION_MINOR@)

(define %version-patch
  @VERSION_PATCH@)

(define %dzn
  (if (mingw?) "dzn.cmd"
      (string-append %bindir "/dzn")))

(define %default-languages
  (string-split (string-trim-both "@languages@") #\space))

(define %copyright-info
  "Copyright (C) 2014-2022 the Dezyne authors
")

(define %license-info
  "License AGPLv3+: GNU AGPL version 3 or later <https://gnu.org/licenses/agpl.html>
This is free software: you are free to change and redistribute it.
There is NO WARRANTY, to the extent permitted by law.
")
